    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;">
      <button onclick="openModal(this)" data-source="real_estate_hero" class="btn-primary">Book Free Real Estate AI Audit</button>
      <a href="#what-we-build" class="btn-outline">See What We Build ↓</a>
    </div>
    <div class="stat-grid">
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">$41B</p>
        <p style="color:#42474e; font-size:0.8125rem; margin-top:4px;">PropTech investment globally in 2023 (KPMG)</p>
      </div>
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">63%</p>
        <p style="color:#42474e; font-size:0.8125rem; margin-top:4px;">of real estate firms piloting or using AI (Deloitte 2024)</p>
      </div>
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">±3%</p>
