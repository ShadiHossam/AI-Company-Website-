---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "How accurate are AI property valuations compared to human appraisers?", answer: "In high-transaction markets with rich data, AVMs are now highly competitive — Zillow's model carries a 2.4% median error for listed homes, vs. the roughly 5–8% variance in human appraisals. However, AVMs struggle with unique properties, low-transaction-volume markets, and sudden market shifts. The most reliable approach combines AI for initial pricing with human review for final decisions." },
  { question: "Will AI replace real estate agents?", answer: "Unlikely in the near term, but it will significantly change what agents spend their time on. AI handles the high-volume, low-complexity work: initial inquiry response, listing management, document processing, lead qualification. This frees agents to focus on advisory, negotiation, and relationship work. The agencies growing fastest are those using AI to make agents more productive, not replace them." },
  { question: "How does AI lead scoring work in practice?", answer: "A lead scoring model is trained on historical data — which leads eventually transacted, and what their behavioral patterns looked like before they did. It learns signals like: how many listings were viewed, time spent on each, viewing requests, response speed to follow-up. The model assigns a probability score to each new lead. Agents are shown a ranked list — highest-probability leads at the top — and notified in real time when a lead's score jumps." },
  { question: "Can AI handle property inquiries in Arabic?", answer: "Yes — modern LLMs handle Arabic fluently, including switching between Arabic and English mid-conversation. For UAE real estate, this is critical: a significant portion of high-value buyers prefer communicating in Arabic. The key is testing the Arabic output quality specifically, since some models produce correct but stilted formal Arabic rather than natural conversational language." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'real_estate')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI for Real Estate Dubai",
    "url": "https://aegisai.ae/industries/real-estate",
    "description": "Custom AI systems for Dubai real estate agencies: WhatsApp lead chatbots, CRM automation, document processing, and bilingual property assistants.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
    "areaServed": "Dubai",
    "serviceType": "AI Development for Real Estate"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aegisai.ae/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://aegisai.ae/industries" },
      { "@type": "ListItem", "position": 3, "name": "Real Estate AI", "item": "https://aegisai.ae/industries/real-estate" }
    ]
  }
];
---

<BaseLayout
  title="AI for Real Estate Dubai — Lead AI, WhatsApp Chatbots & CRM Automation | Aegis AI"
  description="Aegis AI builds custom AI systems for Dubai real estate agencies: WhatsApp lead chatbots, CRM automation, document processing, and bilingual property assistants."
