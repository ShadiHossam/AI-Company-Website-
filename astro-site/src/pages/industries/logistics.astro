---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "Does the route optimization account for Salik, Dubai traffic, and UAE road patterns?", answer: "Yes. The system uses real-time traffic data including UAE-specific road patterns, Salik gate costs, and historical congestion data by time of day. It also accounts for delivery time windows, prayer times, and weekend vs. weekday patterns that are unique to the UAE market. Route optimization built for the US or Europe doesn't always translate here. Ours is built for the UAE." },
  { question: "Can it integrate with our existing TMS or ERP? We don't want to replace our core systems.", answer: "That's how we always work. We integrate with your TMS, ERP, GPS tracking, and customer portals rather than replacing them. We've built integrations with most major ERP and logistics platforms. If you're on a custom-built system, we'll ask for API access and work from there. In the rare case something has no API, we'll tell you upfront and not discover it mid-project." },
  { question: "What about cross-border logistics? We operate between UAE, Saudi Arabia, and Oman.", answer: "Cross-border routing is more complex. Customs clearance times, border crossing queues, and transit documentation all affect delivery planning. We build that complexity into the model rather than pretending it doesn't exist. The system can factor in average clearance times, flag documentation issues before departure, and adjust delivery windows for international routes. This is something we'd scope specifically for your cross-border volume in the first call." },
  { question: "How does it handle same-day delivery requirements?", answer: "Same-day delivery requires real-time insertion into live routes, not rebuilding routes from scratch every time an order comes in. The system handles dynamic insertion, optimizing which driver picks up a new order based on proximity, current load, and remaining time window. It also sends customers an accurate ETA the moment the order is dispatched, which cuts inbound \"when is it arriving?\" calls significantly." },
  { question: "Can it help with driver performance management without being invasive?", answer: "Driver data is one of the more sensitive areas in logistics AI. We build dashboards that track performance metrics (delivery completion rate, idle time, fuel consumption, route adherence) and show trends, not just snapshots. Managers see aggregated data by team first, then individual breakdowns when investigating a specific issue. Drivers see their own data on a separate mobile view. We can advise on how to introduce this to your team in a way that feels fair, not surveillance." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'logistics')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const logisticsLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'AI for Logistics & Supply Chain',
    url: 'https://aegisai.ae/industries/logistics',
    description: 'AI systems for UAE logistics companies: route optimization, fleet management, demand forecasting, warehouse automation, and customer communication AI.',
    provider: { '@type': 'Organization', name: 'Aegis AI', url: 'https://aegisai.ae' },
    areaServed: 'UAE',
    serviceType: 'AI Consulting',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aegisai.ae/' },
      { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://aegisai.ae/industries/' },
      { '@type': 'ListItem', position: 3, name: 'Logistics AI', item: 'https://aegisai.ae/industries/logistics' },
    ],
  },
  faqLdJson,
];

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
