---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "Does AI concierge feel impersonal to guests?", answer: "Modern AI-based concierge systems can be tuned to match the hotel's brand voice closely, whether warm and personable or formal and precise, depending on the property. Guest research (Oracle, 2024) shows that 65% of guests prefer messaging-based communication over phone calls for routine requests, regardless of whether it's AI or human. What guests care about is that responses are fast, accurate, and in their language." },
  { question: "How does AI revenue management work differently from traditional RMS?", answer: "Traditional revenue management systems use rules and historical demand curves to suggest prices. AI systems use machine learning to find patterns across far more variables: not just historical bookings, but competitor rate movements, local event data, search trend signals, and macro factors. They also adjust in real time (sometimes hourly) rather than in nightly batch updates. The result is more frequent, more precise rate changes that capture demand exactly when it peaks." },
  { question: "What guest data does AI personalization actually use?", answer: "The foundation is PMS data: room type preferences, prior stay history, special requests, F&B charges. This is supplemented with explicit preferences captured during booking or pre-arrival communication, and inferred preferences from in-stay behavior. Importantly, guest data must be handled in compliance with GDPR, UAE data protection laws, and the hotel's own privacy policy. Transparency about data use is increasingly a guest expectation, not just a legal requirement." },
  { question: "How quickly can AI guest communication be deployed?", answer: "The timeline depends on PMS integration complexity, content creation (hotel-specific knowledge base, F&B menus, local recommendations), and testing in the target languages. The AI itself is fast to configure. The bottleneck is ensuring the knowledge base is accurate and the brand voice is correctly calibrated before going live with guests. We'll give you a precise timeline after the initial audit call." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'hospitality')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "AI for Hospitality & Hotels in the UAE",
    "url": "https://aegisai.ae/industries/hospitality",
    "description": "Custom AI systems for UAE hotels and hospitality groups: bilingual AI concierge, dynamic pricing tools, revenue management, and guest communication automation.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
    "areaServed": "United Arab Emirates",
    "serviceType": "AI Development for Hospitality"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aegisai.ae/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "https://aegisai.ae/industries" },
      { "@type": "ListItem", "position": 3, "name": "Hospitality AI", "item": "https://aegisai.ae/industries/hospitality" }
    ]
  }
];
---

<BaseLayout
  title="AI for Hotels & Hospitality in the UAE: AI Concierge & Guest Automation | Aegis AI"
  description="Aegis AI builds custom AI systems for UAE hotels: bilingual AI concierge, dynamic pricing, revenue management, and guest communication automation."
  canonicalPath="/industries/hospitality"
  arPath="/ar/industries/hospitality"
  ogImage="/assets/og-hospitality.jpg"
  ldJson={ldJson}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/industries" style="color:inherit;text-decoration:none;opacity:0.65;">Industries</a><span style="opacity:0.4;padding:0 4px;"> / </span>Hospitality</div>
    <h1>AI for Dubai Hotels<br>&amp; <span class="gradient-text">Hospitality Groups</span></h1>
    <p style="color:#42474e; font-size:1.0625rem; max-width:640px; margin:1.5rem auto 2rem; line-height:1.8;">Aegis AI builds custom AI systems for Dubai hotels and hospitality groups: bilingual AI concierge, dynamic pricing engines, guest personalization, and revenue intelligence. PMS-integrated, multilingual (Arabic &amp; English), and backed by our 100% refund guarantee.</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:2rem;">
      <button onclick="openModal(this)" data-source="hospitality_hero" class="btn-primary">Book Free Hospitality AI Audit</button>
      <a href="#what-we-build" class="btn-outline">See What We Build ↓</a>
    </div>
    <div class="stat-grid">
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">$12.8B</p>
        <p style="color:#42474e; font-size:0.8125rem; margin-top:4px;">AI in hospitality market by 2030 (Grand View Research)</p>
      </div>
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">+18%</p>
        <p style="color:#42474e; font-size:0.8125rem; margin-top:4px;">RevPAR improvement from AI revenue management (IDeaS)</p>
      </div>
      <div style="text-align:center;">
        <p class="stat-number" style="font-size:2rem;">74%</p>
        <p style="color:#42474e; font-size:0.8125rem; margin-top:4px;">of guest inquiries automatable with AI (Oracle Hospitality)</p>
      </div>
    </div>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:240px;">
  <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1400&q=80&auto=format&fit=crop" alt="Luxury hotel lobby representing AI-powered hospitality" loading="eager" fetchpriority="high" width="1400" height="240" style="width:100%; height:100%; object-fit:cover; object-position:center 30%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.15),rgba(0,37,59,0.25));"></div>
</div>

<!-- WHAT AEGIS BUILDS -->
<section id="what-we-build" class="section" aria-labelledby="build-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="build-heading">AI Systems Built for Dubai Hotels & Hospitality Groups</h2>
      <p>Six specific systems we deploy for hotels and hospitality groups across the UAE, each integrated with your PMS and guest communication channels.</p>
    </div>
    <div class="apps-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">support_agent</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Bilingual AI Concierge</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">Handles guest requests via messaging apps, your hotel app, or web chat, before arrival, during the stay, and after checkout. Dining reservations, room service, local recommendations, and complaints handled in Arabic, English, Russian, Chinese, and more.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">74% of routine guest inquiries handled automatically, freeing staff for high-touch service (Oracle)</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">price_change</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Dynamic Pricing Engine</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">Real-time rate optimization that processes competitor pricing, booking pace, local event calendars, and OTA channel data to adjust room rates automatically. Connects to your PMS and channel manager with no manual rate updates needed.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Average 10–18% RevPAR uplift over manual rate-setting</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">person_pin</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Guest Personalization System</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">Builds persistent guest profiles from PMS data, preferences, and stay history. Room preferences, dietary requirements, and special occasion flags are applied automatically at check-in and throughout the stay, without staff needing to remember or look anything up.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Personalized guests spend 23% more on F&B and ancillaries (Hyatt)</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">monitoring</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Revenue Intelligence Dashboard</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">Aggregates your PMS data, OTA performance, competitor rate movements, and demand signals into a live dashboard your revenue team and management can act on daily. Demand forecasts, booking pace alerts, and channel mix recommendations in one view.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Built on your actual property data, not generic benchmarks</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">reviews</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Review Analytics Tool</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">NLP model processes your reviews across major platforms to surface recurring themes, sentiment trends, and specific operational issues. GMs receive a structured weekly briefing: actionable findings, not raw data.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">1-point TripAdvisor improvement correlates with 11% ADR increase</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">restaurant</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">F&B Demand Forecasting</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">Forecasts restaurant covers, room service volume, and event catering demand using your occupancy data, reservation patterns, and seasonal trends. Reduces F&B waste, prevents overstaffing, and improves food cost percentage. Updated automatically each week.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">AI reduces hotel F&B waste by 20–35% (Winnow Solutions)</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;padding:2rem;background:#e7eeff;border-radius:20px;">
      <p style="color:#00253b;font-weight:700;font-size:1.0625rem;margin-bottom:0.5rem;">Covered by our 100% refund guarantee</p>
      <p style="color:#42474e;font-size:0.9375rem;margin-bottom:1.25rem;">Every system is built for your property, integrated with your PMS, and trained in your brand voice.</p>
      <button onclick="openModal(this)" data-source="hospitality_mid" class="btn-primary">Book Free Hospitality AI Audit</button>
    </div>
  </div>
</section>

<!-- INDUSTRY CONTEXT -->
<section class="section" style="background:#e7eeff;" aria-labelledby="shift-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="shift-heading">Why hospitality and AI are a natural fit</h2>
    </div>
    <div class="ind-context-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:22px;">person</span></div>
        <h3 style="font-weight:700; font-size:1rem; color:#00253b; margin-bottom:0.5rem;">Guest expectations are hyper-personal</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Modern travelers expect hotels to remember their preferences from prior stays, communicate in their language, and anticipate needs before they're voiced. Delivering this at scale, across thousands of guests, multiple languages, and dozens of touchpoints, is only possible with AI-assisted operations.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:22px;">layers</span></div>
        <h3 style="font-weight:700; font-size:1rem; color:#00253b; margin-bottom:0.5rem;">Revenue optimization is mathematically complex</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Hotel pricing involves dozens of variables: booking lead time, competitor rates, local events, room type mix, cancellation patterns, OTA fees. Human revenue managers can monitor a few signals; AI systems track all of them simultaneously and adjust rates in real time, consistently outperforming manual decisions.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:22px;">shield</span></div>
        <h3 style="font-weight:700; font-size:1rem; color:#00253b; margin-bottom:0.5rem;">Staff-to-guest ratios are under pressure</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Post-pandemic hospitality faces a structural staffing challenge: higher guest expectations combined with tighter labor markets. AI absorbs high-volume, routine communication work so staff can focus on genuine guest interaction that creates loyalty.</p>
      </div>
    </div>
  </div>
</section>

<!-- KEY AI APPLICATIONS (RENAMED) -->
<section id="applications" class="section" style="background:#e7eeff;" aria-labelledby="apps-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="apps-heading">Where AI is having the biggest impact in hospitality</h2>
    </div>
    <div class="apps-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">support_agent</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">AI Guest Concierge</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">AI-powered concierge agents communicate with guests via messaging apps, hotel apps, and web chat, before arrival, during the stay, and after checkout. They handle dining reservations, room service, local recommendations, complaints, and requests in the guest's preferred language. Oracle Hospitality research shows 74% of routine inquiries can be handled automatically.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Marriott and Hilton both deploy AI concierge at scale</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">price_change</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Dynamic Pricing &amp; Revenue Management</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">AI revenue management systems process competitor rates, booking pace, local event calendars, and historical patterns to set optimal room prices in real time. Hotels using AI revenue management report 10–25% RevPAR improvement over manual rate-setting, plus optimized OTA vs. direct booking channel mix.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">IDeaS clients average 18% RevPAR uplift in year one</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">favorite</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Guest Personalization</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">AI systems build persistent guest profiles from stay history, preferences, complaints, and in-stay behavior. Room temperature preferences, pillow type, dietary restrictions, and amenity requests are remembered and applied automatically. Hyatt reports guests receiving personalized service spend 23% more on F&amp;B and ancillaries.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Personalization drives 20–30% increase in ancillary revenue</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">build</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Predictive Maintenance</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">IoT sensors on HVAC systems, elevators, plumbing, and kitchen equipment feed data into AI models that predict failures before they happen. A broken AC in a Dubai hotel room in August is a serious guest experience failure. Predictive maintenance reduces emergency repair costs by 25% and equipment downtime by up to 50%.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">Predictive maintenance cuts equipment downtime by up to 50%</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">reviews</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Review Analytics</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">NLP models process thousands of guest reviews across TripAdvisor, Booking.com, Google, and direct surveys to identify recurring themes, sentiment trends, and specific operational issues. Instead of reading reviews manually, GMs receive structured weekly reports: specific, actionable, fast.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">1-point TripAdvisor improvement correlates with 11% ADR increase</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">restaurant</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">F&amp;B Demand Forecasting</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin-bottom:0.75rem;">AI forecasts restaurant covers, room service volume, and event catering demand using occupancy data, reservation patterns, and historical consumption. Hotels using AI food forecasting cut F&amp;B waste by 20–35%, reduce labor costs from overstaffing, and improve food cost percentage.</p>
        <p style="font-size:0.8125rem; font-weight:600; color:#006875;">AI reduces hotel F&amp;B waste by 20–35% (Winnow Solutions)</p>
      </div>
    </div>
  </div>
</section>

<!-- EVALUATION CRITERIA -->
<section class="section" aria-labelledby="eval-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="eval-heading">What makes hospitality AI work in practice</h2>
    </div>
    <div class="eval-grid">
      <div class="card" style="text-align:center;">
        <div class="num-circle">1</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">PMS integration is non-negotiable</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Any AI system in a hotel needs to connect to the Property Management System. Without PMS access, the AI can't check room availability, retrieve reservation details, or update guest preferences. An AI concierge that can't answer "what time is my check-in?" is a liability, not an asset.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">2</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">Language coverage for your guest mix</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">In Dubai, hotel guests arrive from over 190 nationalities. Arabic, English, Russian, Chinese, Hindi, and French are all common. An AI concierge that handles only English serves a fraction of guests. Coverage should match the actual top languages in your guest demographics.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">3</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">Brand voice consistency</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">A five-star resort and a business airport hotel have fundamentally different communication styles. AI systems need to match the property's brand voice, whether formal or warm, concise or detailed. Generic AI responses that don't match brand positioning erode the guest experience.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">4</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">Graceful human handoff</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">AI guest communication must know when to escalate: a genuine distress complaint, an unusual request requiring judgment, a VIP situation requiring personal attention. The handoff needs to be seamless, with full context transferred, so guests never have to repeat themselves.</p>
      </div>
    </div>
  </div>
</section>

<!-- INDUSTRY RESEARCH -->
<section class="section" style="background:#e7eeff;" aria-labelledby="research-heading">
  <div class="container" style="max-width:860px;">
    <div class="section-header">
      <h2 id="research-heading">What the data shows about AI in hospitality</h2>
    </div>
    <div class="ind-stats-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-bottom:2rem;">
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">+18%</p>
        <p style="color:#42474e; font-size:0.875rem;">RevPAR improvement at IDeaS clients using AI revenue management</p>
      </div>
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">74%</p>
        <p style="color:#42474e; font-size:0.875rem;">of routine guest inquiries handled automatically, freeing staff for meaningful service moments (Oracle)</p>
      </div>
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">23%</p>
        <p style="color:#42474e; font-size:0.875rem;">increase in ancillary spend by guests receiving personalized service (Hyatt)</p>
      </div>
    </div>
    <div class="research-panel">
      <div class="ind-text-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; font-size:0.875rem;">
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Revenue Management</p>
          <p style="color:#42474e; line-height:1.7;">A 2024 Skift Research study found hotels using AI revenue management outperform competitive sets by 10–18% on RevPAR consistently. The advantage compounds over time as the model learns the property's specific demand patterns. AI RMS tools now manage pricing for over 30,000 hotels globally.</p>
        </div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Guest Satisfaction</p>
          <p style="color:#42474e; line-height:1.7;">J.D. Power's Hotel Guest Satisfaction Study (2024) found that guests who received personalized service (room preferences remembered, special occasion acknowledgment, proactive communication) gave satisfaction scores 18% higher than those who didn't. AI makes this personalization scalable beyond VIP tiers.</p>
        </div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Operational Efficiency</p>
          <p style="color:#42474e; line-height:1.7;">McKinsey estimates AI could reduce hotel operational costs by 15–20% through labor optimization, energy management (AI-controlled HVAC and lighting), and F&amp;B waste reduction. For a 300-room full-service hotel, this represents millions of dirhams in annual savings.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">Questions about AI in hospitality</h2>
    </div>
    <div>
      {faqItems.map((item) => (
        <div class="faq-item">
          <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
            {item.question}
            <span class="faq-icon">+</span>
          </button>
