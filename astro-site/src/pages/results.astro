---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

// Hardcoded fallback case studies
const fallbackCaseStudies = [
  {
    industry: "Real Estate",
    industry_icon: "home",
    title: "How a Dubai Property Agency Reduced Lead Response Time from 4 Hours to 4 Minutes",
    delivery_time: "",
    results: [
      { value: "4 min", label: "Lead response time (was 4 hours)" },
      { value: "+40%", label: "Viewing bookings in 90 days" },
      { value: "3h/day", label: "Admin time saved per agent" },
    ],
    challenge: "Agency receiving 200+ WhatsApp leads per day. Agents manually qualifying each one, average response time was 4 hours. High-intent leads were going cold and to competitors who responded faster.",
    solution: "AI WhatsApp assistant that qualifies leads, answers property questions in Arabic and English, books viewing appointments, and auto-updates the CRM, 24/7 without human intervention on standard queries.",
    timeline: [
      "Step 1: Discovery, data mapping, CRM audit",
      "Step 2: AI training on property listings, FAQ database",
      "Step 3: Integration, testing, team training",
      "Step 4: Go-live and full adoption.",
    ],
    media_sections: [],
  },
  {
    industry: "Retail",
    industry_icon: "shopping_bag",
    title: "How a Dubai Retail Chain Cut Overstock by 28% With AI Demand Forecasting",
    delivery_time: "",
    results: [
      { value: "−28%", label: "Overstock reduction" },
      { value: "−44%", label: "Stockout incidents" },
      { value: "+12%", label: "Gross margin improvement" },
    ],
    challenge: "Multi-branch retailer with chronic overstock on slow-moving lines and stockouts on top sellers. Buying decisions relied on gut feel and spreadsheets. Each stockout meant lost revenue; each overstock tied up cash.",
    solution: "Demand forecasting AI trained on 3 years of sales data, seasonal patterns, and UAE-specific external signals: Ramadan, UAE National Day, Dubai Shopping Festival, plus weather and competitor promotions.",
    timeline: [
      "Step 1: Data extraction, cleaning, and model design",
      "Step 2: Model training and validation on historical data",
      "Step 3: Dashboard integration, buyer team training",
      "Results visible within first buying cycle.",
    ],
    media_sections: [],
  },
  {
    industry: "Hospitality",
    industry_icon: "hotel",
    title: "How a Dubai Hotel Group Automated 74% of Guest Inquiries With AI",
    delivery_time: "",
    results: [
      { value: "74%", label: "Standard inquiries handled automatically" },
      { value: "+0.4", label: "Guest satisfaction score improvement" },
      { value: "6h/day", label: "Staff time freed for high-value service" },
    ],
    challenge: "Guest services team spending 6+ hours per day answering the same questions via WhatsApp and email: check-in times, pool access, restaurant hours, late checkout. Staff couldn't focus on high-touch guest experience.",
    solution: "AI concierge handling all standard queries 24/7 in Arabic and English. Personalised to the hotel's brand voice. Complex requests and complaints escalated instantly to the duty manager with full conversation context.",
    timeline: [
      "Step 1: FAQ audit, integration setup, brand voice mapping",
      "Step 2: AI training, escalation logic, staff briefing",
      "Step 3: Go-live. Satisfaction score up within 60 days.",
      "Team reassigned to proactive guest experience roles.",
    ],
    media_sections: [],
  },
  {
    industry: "Logistics",
    industry_icon: "local_shipping",
    title: "How a UAE Logistics Firm Cut Delivery Costs 22% with AI Route Optimisation",
    delivery_time: "",
    results: [
      { value: "−22%", label: "Delivery cost reduction" },
      { value: "+18%", label: "On-time delivery rate" },
      { value: "4h/day", label: "Dispatch time saved" },
    ],
    challenge: "A UAE courier and distribution company was planning every delivery run manually in Excel. Drivers frequently overlapped territories, fuel was wasted on inefficient routes, and dispatch managers spent 4+ hours daily building the next day's schedule. Late deliveries were damaging key client contracts.",
    solution: "AI route-optimisation dashboard that ingests delivery addresses, vehicle capacity, driver availability, and traffic patterns each morning and generates optimised routes for the full fleet in under 3 minutes. Integrated with the company's existing TMS and driver communications.",
    timeline: [
      "Step 1: Data mapping, TMS integration audit, route pattern analysis",
      "Step 2: Model training on 18 months of historical route data",
      "Step 3: Dashboard build, driver app integration, dispatcher training",
      "Step 4: Go-live. Cost and time savings visible immediately.",
    ],
    media_sections: [],
  },
];

let caseStudies = fallbackCaseStudies;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('case_studies')
    .select('industry, title, delivery_time, challenge, solution, results, timeline_items, media_sections')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    caseStudies = data.map((cs) => ({
      industry: cs.industry,
      industry_icon: cs.industry?.toLowerCase() === 'real estate' ? 'home'
        : cs.industry?.toLowerCase() === 'retail' ? 'shopping_bag'
        : cs.industry?.toLowerCase() === 'hospitality' ? 'hotel'
        : cs.industry?.toLowerCase() === 'logistics' ? 'local_shipping'
        : 'business',
      title: cs.title,
      delivery_time: cs.delivery_time,
      results: Array.isArray(cs.results) ? cs.results : [],
      challenge: cs.challenge,
      solution: cs.solution,
      timeline: Array.isArray(cs.timeline_items)
        ? cs.timeline_items.map((t: { step: string; description: string }) => `${t.step}${t.description ? ': ' + t.description : ''}`)
        : [],
      media_sections: Array.isArray(cs.media_sections) ? cs.media_sections : [],
    }));
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const resultsSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Aegis AI Case Studies',
    description: 'Real AI results from Dubai businesses across real estate, retail, and hospitality.',
    url: 'https://aegisai.ae/results',
    itemListElement: caseStudies.map((cs, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Article',
        headline: cs.title,
        description: cs.challenge,
        author: { '@type': 'Organization', name: 'Aegis AI' },
        publisher: { '@type': 'Organization', name: 'Aegis AI', url: 'https://aegisai.ae' },
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aegisai.ae/' },
      { '@type': 'ListItem', position: 2, name: 'Results', item: 'https://aegisai.ae/results' },
    ],
  },
];
---

<BaseLayout
  title="AI Case Studies Dubai — Real ROI for SMEs | Aegis AI"
  description="Real AI results from Dubai businesses: 4× ROI, 3h saved/day, 74% of inquiries automated. Case studies across real estate, retail, and hospitality."
  canonicalPath="/results"
  arPath="/ar/results"
  ogImage="/assets/og-results.jpg"
  ldJson={resultsSchema}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><strong>Results</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">bar_chart</span>
      Case Studies
    </div>
    <h1 style="max-width:720px; margin-left:auto; margin-right:auto;">
      Real Results.<br><span class="gradient-text">Real Businesses. Real AI.</span>
    </h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      Every project we deliver is measured by one thing: the impact on your business. Here's what that looks like in practice.
    </p>
  </div>
</header>

<!-- AGGREGATE METRICS -->
<section style="padding:4rem 0;">
  <div class="container" style="max-width:800px;">
    <div class="agg-bar">
      <div class="agg-grid" style="display:grid; grid-template-columns:1fr 1px 1fr 1px 1fr 1px 1fr; gap:0; align-items:center;">
        <div class="agg-stat">
          <p style="font-size:2.25rem; font-weight:800; color:#00e3fd; margin:0;">3.2h</p>
          <p style="color:rgba(255,255,255,0.70); font-size:0.8125rem; margin:4px 0 0; line-height:1.5;">Avg. admin time saved per day</p>
        </div>
        <div class="agg-divider" style="height:60px;"></div>
        <div class="agg-stat">
          <p style="font-size:2.25rem; font-weight:800; color:#00e3fd; margin:0;">4.1×</p>
          <p style="color:rgba(255,255,255,0.70); font-size:0.8125rem; margin:4px 0 0; line-height:1.5;">Average ROI within 12 months</p>
        </div>
        <div class="agg-divider" style="height:60px;"></div>
        <div class="agg-stat">
          <p style="font-size:2.25rem; font-weight:800; color:#00e3fd; margin:0;">100%</p>
          <p style="color:rgba(255,255,255,0.70); font-size:0.8125rem; margin:4px 0 0; line-height:1.5;">Satisfaction guarantee on every project</p>
        </div>
        <div class="agg-divider" style="height:60px;"></div>
        <div class="agg-stat">
          <p style="font-size:2.25rem; font-weight:800; color:#00e3fd; margin:0;">100%</p>
          <p style="color:rgba(255,255,255,0.70); font-size:0.8125rem; margin:4px 0 0; line-height:1.5;">Clients who would recommend us</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CASE STUDIES -->
<section class="section" style="background:#e7eeff; padding-top:3rem;" aria-labelledby="cases-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <div class="section-eyebrow">Case Studies</div>
      <h2 id="cases-heading">Projects That Delivered</h2>
    </div>

    {caseStudies.map((cs, index) => (
      <div class="case-card" style={index === caseStudies.length - 1 ? "margin-bottom:0;" : ""}>
        <div class="case-header">
          <div style="display:flex; flex-wrap:wrap; align-items:flex-start; gap:1rem; justify-content:space-between;">
            <div>
              <div class="industry-tag" style="margin-bottom:0.875rem;">
                <span class="material-symbols-outlined" style="font-size:14px;">{cs.industry_icon}</span> {cs.industry}
              </div>
              <h3 style="font-weight:700; font-size:1.25rem; color:#fff; max-width:540px; line-height:1.4; margin:0;">{cs.title}</h3>
            </div>
            {cs.delivery_time && (
              <div style="text-align:right; flex-shrink:0;">
                <p style="color:rgba(255,255,255,0.60); font-size:0.75rem; margin:0;">Project scope</p>
                <p style="font-weight:700; font-size:1.125rem; color:#00e3fd; margin:0;">{cs.delivery_time}</p>
              </div>
            )}
          </div>
        </div>
        <div class="case-body">
          {Array.isArray(cs.results) && cs.results.length > 0 && (
            <div class="results-pills-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:1.75rem;">
              {cs.results.map((r: { value: string; label: string }) => (
                <div class="result-pill"><div class="result-val">{r.value}</div><p class="result-label">{r.label}</p></div>
              ))}
            </div>
          )}
          <div class="case-col-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; font-size:0.9rem;">
            <div><p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The Challenge</p><p style="color:#42474e; line-height:1.7; margin:0;">{cs.challenge}</p></div>
            <div><p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The Solution</p><p style="color:#42474e; line-height:1.7; margin:0;">{cs.solution}</p></div>
            {Array.isArray(cs.timeline) && cs.timeline.length > 0 && (
              <div>
                <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The Timeline</p>
                {cs.timeline.map((step: string) => (
                  <div class="timeline-line"><div class="timeline-dot-sm"></div><p style="color:#42474e;">{step}</p></div>
                ))}
              </div>
            )}
          </div>

          {Array.isArray(cs.media_sections) && cs.media_sections.length > 0 && (
            <div class="media-sections" style="margin-top:2rem; display:flex; flex-direction:column; gap:1.75rem;">
              {cs.media_sections.map((m: { type: string; url: string; caption: string; description: string }) => (
                <div class="media-block">
                  {m.type === 'image' && m.url && (
                    <figure style="margin:0;">
                      <img
                        src={m.url}
                        alt={m.caption || m.description || ''}
                        loading="lazy"
                        style="width:100%; border-radius:12px; display:block; object-fit:cover; max-height:480px;"
                      />
                      {m.caption && <figcaption style="color:#42474e; font-size:0.8125rem; margin-top:0.5rem; text-align:center;">{m.caption}</figcaption>}
                    </figure>
                  )}
                  {m.type === 'video' && m.url && (
                    <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px;">
                      <iframe
                        src={m.url}
                        title={m.caption || 'Video'}
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                        style="position:absolute; top:0; left:0; width:100%; height:100%; border:0; border-radius:12px;"
                      ></iframe>
                    </div>
                  )}
                  {m.description && (
                    <p style="color:#42474e; line-height:1.75; margin:0.75rem 0 0; font-size:0.9375rem;">{m.description}</p>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- INDUSTRIES COVERED -->
<section class="section" aria-labelledby="industries-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">Expertise</div>
      <h2 id="industries-heading">Industries We've Delivered Results In</h2>
    </div>
    <div class="results-industries-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px; max-width:840px; margin:0 auto;">
      <a href="/industries/real-estate" class="industry-link-card">
        <div class="industry-link-icon"><span class="material-symbols-outlined">home</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1rem; margin-bottom:4px;">Real Estate</h3>
        <p style="color:#42474e; font-size:0.8125rem; margin-bottom:0.75rem; line-height:1.5;">Lead scoring, WhatsApp AI, CRM automation</p>
        <p style="color:#006875; font-size:0.8125rem; font-weight:600; margin:0;">See solutions →</p>
      </a>
      <a href="/industries/retail" class="industry-link-card">
        <div class="industry-link-icon"><span class="material-symbols-outlined">shopping_bag</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1rem; margin-bottom:4px;">Retail &amp; E-commerce</h3>
        <p style="color:#42474e; font-size:0.8125rem; margin-bottom:0.75rem; line-height:1.5;">Demand forecasting, pricing, personalization</p>
        <p style="color:#006875; font-size:0.8125rem; font-weight:600; margin:0;">See solutions →</p>
      </a>
      <a href="/industries/hospitality" class="industry-link-card">
        <div class="industry-link-icon"><span class="material-symbols-outlined">hotel</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1rem; margin-bottom:4px;">Hospitality</h3>
        <p style="color:#42474e; font-size:0.8125rem; margin-bottom:0.75rem; line-height:1.5;">AI concierge, revenue management, scheduling</p>
        <p style="color:#006875; font-size:0.8125rem; font-weight:600; margin:0;">See solutions →</p>
      </a>
      <a href="/industries/logistics" class="industry-link-card">
        <div class="industry-link-icon"><span class="material-symbols-outlined">local_shipping</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1rem; margin-bottom:4px;">Logistics</h3>
        <p style="color:#42474e; font-size:0.8125rem; margin-bottom:0.75rem; line-height:1.5;">Route optimization, fleet AI, demand forecasting</p>
        <p style="color:#006875; font-size:0.8125rem; font-weight:600; margin:0;">See solutions →</p>
      </a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div class="cta-band" style="text-align:center; max-width:680px; margin:0 auto;">
      <h2 style="color:#fff; font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; margin-bottom:1.25rem;">Your Business Could Be Next.</h2>
      <p style="color:rgba(255,255,255,0.65); font-size:1.0625rem; margin-bottom:2.5rem;">Book a free consultation. We'll identify the top 3 AI opportunities in your business — in 30 minutes.</p>
      <button onclick="openModal(this)" data-source="results_cta" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Book Free Consultation</button>
      <p style="color:rgba(255,255,255,0.40); font-size:0.8125rem; margin-top:1rem;">Free · No commitment · 100% Satisfaction Guarantee</p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.case-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:24px; overflow:hidden; box-shadow:0 20px 40px rgba(0,59,92,0.04); margin-bottom:2rem; }
    .case-header { background:linear-gradient(135deg,#00253b,#006875); padding:2rem; }
    .case-body { padding:2rem; }
    .result-pill { background:rgba(0,104,117,0.06); border:1px solid rgba(0,104,117,0.12); border-radius:16px; padding:1rem 1.25rem; text-align:center; }
    .result-val { font-size:1.75rem; font-weight:800; color:#006875; }
    .result-label { color:#42474e; font-size:0.75rem; margin:4px 0 0; }
    .industry-tag { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; background:rgba(255,255,255,0.15); color:#fff; border-radius:100px; font-size:0.75rem; font-weight:600; }
    .timeline-line { display:grid; grid-template-columns:8px 1fr; gap:0.75rem; align-items:flex-start; margin-bottom:0.5rem; }
    .timeline-dot-sm { width:8px; height:8px; border-radius:50%; background:#00e3fd; margin-top:6px; flex-shrink:0; }
    .agg-bar { background:linear-gradient(135deg,#00253b 0%,#006875 100%); border-radius:24px; padding:3rem 2.5rem; }
    .agg-stat { text-align:center; }
    .agg-divider { width:1px; background:rgba(255,255,255,0.20); }
    .industry-link-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:1.75rem; text-align:center; box-shadow:0 20px 40px rgba(0,59,92,0.04); text-decoration:none; display:block; transition:transform .25s, box-shadow .25s; }
    .industry-link-card:hover { transform:translateY(-4px); box-shadow:0 24px 56px rgba(0,59,92,0.10); }
    .industry-link-icon { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); display:flex; align-items:center; justify-content:center; margin:0 auto 0.875rem; color:#006875; }
    @media(max-width:700px) { .agg-grid { grid-template-columns:1fr 1fr !important; } .case-col-grid { grid-template-columns:1fr !important; } .results-industries-grid { grid-template-columns:1fr 1fr !important; } .results-pills-grid { grid-template-columns:1fr !important; } }
</style>