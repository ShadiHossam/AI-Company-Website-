---
// This page is shown to visitors when maintenance mode is enabled in site_config.
// Admin IPs bypass this redirect (set in system.maintenance_allowed_ips).
export const prerender = false;

import { getSupabaseAdmin } from '../lib/supabase';

let message = 'We\'ll be back shortly. Check back in a few minutes.';
try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('site_config')
    .select('value')
    .eq('key', 'system.maintenance_message')
    .single();
  if (data?.value) message = data.value;
} catch { /* fallback to default */ }
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Maintenance | Aegis AI</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
      background: #0a0f1a;
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      text-align: center;
    }
    .wrap { max-width: 520px; }
    .logo { font-size: 1.5rem; font-weight: 800; color: #00e3fd; margin-bottom: 2.5rem; }
    .icon {
      width: 72px; height: 72px;
      border-radius: 20px;
      background: rgba(0,227,253,0.10);
      border: 1px solid rgba(0,227,253,0.25);
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 1.5rem;
    }
    h1 { font-size: 1.75rem; font-weight: 800; margin-bottom: 1rem; }
    p { color: #94a3b8; font-size: 1.0625rem; line-height: 1.7; margin-bottom: 2rem; }
    .contact {
      display: inline-flex; align-items: center; gap: 8px;
      color: #00e3fd; text-decoration: none; font-weight: 600;
      border: 1px solid rgba(0,227,253,0.25); border-radius: 8px;
      padding: 10px 20px; font-size: 0.9375rem;
      transition: background 0.15s;
    }
    .contact:hover { background: rgba(0,227,253,0.08); }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">Aegis AI</div>
    <div class="icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="#00e3fd" stroke-width="1.5" style="width:36px;height:36px;">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
      </svg>
    </div>
    <h1>Under Maintenance</h1>
    <p>{message}</p>
    <a href="https://wa.me/971501234567" class="contact">
      <svg viewBox="0 0 24 24" fill="currentColor" style="width:18px;height:18px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.852L0 24l6.335-1.652A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.001-1.369l-.359-.213-3.76.98 1.006-3.659-.234-.375A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      Contact us on WhatsApp
    </a>
  </div>
</body>
</html>
