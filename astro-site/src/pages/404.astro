---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Aegis AI"
  description="The page you're looking for doesn't exist or has been moved."
  canonicalPath="/404"
  noindex={true}
>
  <section class="error-section">
    <div class="container">
      <div class="error-inner">
        <div class="error-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="#00e3fd" stroke-width="1.5" style="width:34px;height:34px;">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35M11 8v6M8 11h6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="error-code">404</div>
        <h1>Page not found</h1>
        <p>The page you're looking for doesn't exist or may have been moved.<br />Let's get you back on track.</p>
        <div class="error-actions">
          <a href="/" class="btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke-linecap="round" stroke-linejoin="round"/>
              <polyline points="9 22 9 12 15 12 15 22" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Go Home
          </a>
          <a href="/contact" class="btn-outline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-section {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 0 5rem;
    position: relative;
    background: #f9f9ff;
  }
  .error-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,227,253,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .error-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,37,59,0.05) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .error-inner {
    text-align: center;
    max-width: 520px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .error-icon {
    width: 72px;
    height: 72px;
    border-radius: 20px;
    background: rgba(0,227,253,0.10);
    border: 1px solid rgba(0,227,253,0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }
  .error-code {
    font-size: clamp(5rem, 18vw, 8rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #00253b 0%, #006875 50%, #00e3fd 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #111c2d;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  p {
    color: #64748b;
    font-size: 1.0625rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }
  .error-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
