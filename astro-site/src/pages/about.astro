---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";
import { loadPageContent, getVal } from "../lib/page-content";

// Hardcoded fallback team members
const fallbackTeam = [
  {
    name: "Faris Al-Hashemi",
    title: "Founder & CEO",
    bio: "Faris spent 12 years watching AI projects fail across multiple industries and markets — usually because the system didn't fit the business, or the team wasn't trained to use it. He started Aegis AI to fix that.",
    image_url: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80&auto=format&fit=crop&crop=face",
  },
  {
    name: "Dr. Elena Rostova",
    title: "Head of Engineering",
    bio: "Elena has a PhD in Machine Learning and leads our engineering team. She's the reason our AI systems work in production, not just in demos — rigorous about testing before anything goes live.",
    image_url: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80&auto=format&fit=crop&crop=face",
  },
  {
    name: "Tareq Al-Mansoori",
    title: "Head of Training",
    bio: "Tareq has trained over 1,500 professionals across multiple markets and industries. He knows that most training fails not because of content, but because it doesn't connect to the job people actually do.",
    image_url: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=200&q=80&auto=format&fit=crop&crop=face",
  },
];

let teamMembers = fallbackTeam;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('team_members')
    .select('name, title, bio, image_url, sort_order')
    .eq('active', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    teamMembers = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
const pc = await loadPageContent('about');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Aegis AI',
  url: 'https://aegisai.ae/about',
  description: 'Aegis AI helps businesses of every size build and adopt AI — with custom development and hands-on team training.',
  mainEntity: {
    '@type': 'Organization',
    name: 'Aegis AI',
    url: 'https://aegisai.ae',
    employee: teamMembers.map(m => ({
      '@type': 'Person',
      name: m.name,
      jobTitle: m.title,
      description: m.bio,
      ...(m.image_url ? { image: m.image_url } : {}),
      worksFor: { '@type': 'Organization', name: 'Aegis AI' },
    })),
  },
};
---

<BaseLayout
  title="About Aegis AI — AI That Works for Real Businesses"
  description="Aegis AI builds custom AI solutions and trains teams to use them. We work with businesses of every size — from SMEs to growing enterprises — across industries and markets."
  canonicalPath="/about"
  arPath="/ar/about"
  ogImage="/assets/og-about.jpg"
  ldJson={aboutSchema}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><strong>About</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">group</span>
      {g('hero_eyebrow', 'About Us')}
    </div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      {g('hero_h1', 'Most AI projects fail. We built a company to fix that.')}
    </h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      {g('hero_subtext', 'Not a generic platform. Not an enterprise vendor. A real partner that builds AI around how your business actually works — and trains your team to use it from day one.')}
    </p>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:280px;">
  <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1400&q=80&auto=format&fit=crop" alt="Global city skyline — Aegis AI works with businesses across markets worldwide" loading="eager" fetchpriority="high" width="1400" height="280" style="width:100%;height:100%;object-fit:cover;object-position:center 60%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0.05) 100%);"></div>
</div>

<!-- MISSION STATS -->
<section class="section" style="padding:5rem 0; background:#e7eeff;">
  <div class="container">
    <div class="about-stats-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; max-width:760px; margin:0 auto; text-align:center;">
      <div>
        <p class="stat-number">70%</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">of AI implementations globally fail to reach production — not because of bad technology, but because teams weren't ready</p>
      </div>
      <div>
        <p class="stat-number">$4.4T</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">estimated annual value AI could add to the global economy — most of it still unclaimed by small and mid-size businesses</p>
      </div>
      <div>
        <p class="stat-number">3–5×</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">the performance gap between businesses that have adopted AI and those still waiting, measured in speed, cost, and response time</p>
      </div>
    </div>
  </div>
</section>

<!-- MISSION & VISION -->
<section class="section" aria-labelledby="mission-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <div class="section-eyebrow">Why we exist</div>
      <h2 id="mission-heading">We built this company for a reason.</h2>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;" class="about-mv-grid">
      <div style="background:#00253b; border-radius:20px; padding:2.25rem; position:relative; overflow:hidden;">
        <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(0,227,253,0.06);"></div>
        <p style="color:#00e3fd; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:1rem;">Mission</p>
        <p style="color:#fff; font-size:1.125rem; font-weight:700; line-height:1.6; margin-bottom:1rem;">Make AI practical and profitable for businesses of every size.</p>
        <p style="color:rgba(255,255,255,0.60); font-size:0.9375rem; line-height:1.7; margin:0;">Not just the ones with enterprise budgets and internal data science teams. Every business deserves access to AI that actually works — built around their workflows, their people, and their goals.</p>
      </div>
      <div style="background:#f0f3ff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:2.25rem; position:relative; overflow:hidden;">
        <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(0,227,253,0.08);"></div>
        <p style="color:#006875; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:1rem;">Vision</p>
        <p style="color:#00253b; font-size:1.125rem; font-weight:700; line-height:1.6; margin-bottom:1rem;">A world where any business owner can compete with the biggest players — using AI.</p>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">Anywhere in the world. Any industry. Without needing a technical co-founder or an in-house engineering team to make it happen.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR STORY -->
<section class="section" aria-labelledby="story-heading">
  <div class="container" style="max-width:960px;">
    <div class="about-story-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
      <div>
        <div class="section-eyebrow" style="text-align:left; margin-bottom:1rem;">Our Story</div>
        <h2 id="story-heading" style="text-align:left; font-size:2rem; margin-bottom:1.25rem;">Built After Watching AI Projects Fail</h2>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We founded Aegis AI after watching dozens of promising AI projects fail — not because the technology was wrong, but because the people using it weren't ready, and the systems were built for someone else's business.</p>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We saw enterprise AI vendors charging millions to large organisations while small and mid-size businesses across industries were left out entirely — still running on spreadsheets and gut feel in 2025.</p>
        <p style="color:#42474e; line-height:1.8;">We decided to do it differently. We build AI that's custom to your workflows, and we train your team to actually use it. That's our promise — backed by a full refund if we don't deliver.</p>
      </div>
      <div>
        <div style="background:#f0f3ff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:2rem;">
          <p style="color:#72787e; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.10em; font-weight:700; margin-bottom:1.5rem;">Why We're Different</p>
          <div class="timeline-item">
            <div class="timeline-dot">01</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">Build + Train in One Partnership</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">You shouldn't have to choose between building AI and training your team. We do both.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">02</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">Built for Real Businesses</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">No bloated enterprise contracts. Every project is scoped and priced specifically for your business, your size, and your goals.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">03</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">Multilingual from Day One</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">We deliver in the language your team works in. Training materials, support, and documentation — adapted to your workforce from the start.</p>
            </div>
          </div>
          <div class="timeline-item" style="margin-bottom:0;">
            <div class="timeline-dot">04</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">A Full Refund Guarantee — No Fine Print</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">If you're not satisfied with what we build, we refund 100% of your investment. Period.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BUSINESS OWNER MESSAGE -->
<section class="section" style="background:#00253b; padding:5rem 0;" aria-labelledby="owner-heading">
  <div class="container" style="max-width:820px;">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <p style="color:#00e3fd; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:0.75rem;">For Business Owners</p>
      <h2 id="owner-heading" style="color:#fff; font-size:clamp(1.375rem,2.5vw,1.75rem); font-weight:800; margin-bottom:0;">If you're running a business right now, you already feel it.</h2>
    </div>
    <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.15); border-radius:20px; padding:2rem 2.5rem;">
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1rem;">Decisions that used to take a day now need to happen in an hour. Your customers expect faster replies, faster delivery, faster everything. Your margins are tighter than they were three years ago. And somewhere in your industry, a competitor just started using AI — and they're getting faster without hiring more people.</p>
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1rem;">That's not a technology problem. That's a business problem. And it's solvable.</p>
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1.5rem;">We work with business owners who want to grow their company — not get a PhD in machine learning. We handle the technical side. You stay focused on the business. The result is AI that actually moves the needle: more leads handled, less time wasted, better decisions made with the data you already have.</p>
      <p style="color:#00e3fd; font-size:0.9375rem; font-weight:700; margin:0;">That's what we build. That's who we build it for.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:2rem;" class="owner-outcomes-grid">
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">trending_up</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">More Revenue</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">AI-powered follow-up and lead handling that runs while you sleep</p>
      </div>
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">schedule</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">Less Wasted Time</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">Automate the repetitive tasks draining your team every single day</p>
      </div>
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">insights</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">Better Decisions</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">Use the data you already have to see what's working and what's not</p>
      </div>
    </div>
  </div>
</section>

<!-- OFFICE IMAGE -->
<div style="position:relative; overflow:hidden; height:260px;">
  <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1400&q=80&auto=format&fit=crop" alt="Modern office workspace where our team works" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;" />
  <div style="position:absolute;inset:0;background:rgba(0,104,117,0.08);"></div>
</div>

<!-- VALUES -->
<section class="section" style="background:#e7eeff;" aria-labelledby="values-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">How we operate</div>
      <h2 id="values-heading">Four things we won't compromise on.</h2>
    </div>
    <div class="about-values-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:24px;">
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">trending_up</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Results Before Revenue</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">We won't sell you AI you don't need. If it doesn't make business sense for you, we'll tell you — even if it costs us a sale.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">home</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Built for Your Market</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">We adapt to your local context — language, regulations, workforce, and business norms. Our solutions are shaped around how your market actually works.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">group</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">A tool nobody uses is worthless.</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">We design for the person who'll actually click it every day — not just for the demo. Adoption starts at the design stage, not after launch.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">visibility</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">No surprises, ever.</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">Clear timelines. Clear scope. Clear pricing. You'll never get a vague proposal or find out about a problem after the invoice arrives.</p>
      </div>
    </div>
  </div>
</section>

<!-- COST OF WAITING -->
<section class="section" aria-labelledby="waiting-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <div class="section-eyebrow">The Cost of Inaction</div>
      <h2 id="waiting-heading">Your competitors aren't waiting.</h2>
    </div>
    <div class="about-why-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">bolt</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Your competitor is using AI to process leads while your team sleeps.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">AI doesn't clock out. Businesses that automate lead follow-up and customer responses are replying in minutes — not the next morning.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">bar_chart</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The gap between adopters and non-adopters grows every quarter.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Companies that adopted AI early have had years of compounding efficiency gains and cost advantages. That gap doesn't close — it widens.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">group_remove</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">You don't need more staff. You need smarter systems.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Most of the tasks draining your team's time — data entry, reports, follow-ups, scheduling — can be handled by AI built around the workflows you already use.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">timer</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Waiting for AI to "mature" is the mistake.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">The businesses that win are the ones that adopt now, learn what works, and build internal competency before their competitors do. The second-best time to start is today.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div class="cta-band" style="text-align:center; max-width:680px; margin:0 auto;">
      <h2 style="color:#fff; font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; margin-bottom:1.25rem;">Talk to us. No pitch deck required.</h2>
      <p style="color:rgba(255,255,255,0.65); font-size:1.0625rem; margin-bottom:2.5rem;">Tell us about your business. We'll tell you honestly whether AI can help — and exactly what that would look like.</p>
      <button onclick="openModal(this)" data-source="about_cta" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Book a Free Consultation</button>
      <p style="color:rgba(255,255,255,0.40); font-size:0.8125rem; margin-top:1rem;">Free · No commitment · Multilingual support available</p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.value-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:1.75rem; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .value-card:hover { transform:translateY(-4px); box-shadow:0 24px 56px rgba(0,59,92,0.10); }
    .value-icon { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem; color:#006875; }
    .stat-pill { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:1.5rem; text-align:center; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .stat-pill:hover { transform:translateY(-3px); box-shadow:0 24px 48px rgba(0,59,92,0.10); }
.timeline-item { display:grid; grid-template-columns:48px 1fr; gap:1.25rem; align-items:flex-start; margin-bottom:1.5rem; }
    .timeline-dot { width:48px; height:48px; border-radius:50%; background:#00e3fd; display:flex; align-items:center; justify-content:center; color:#00253b; font-weight:800; font-size:0.9rem; flex-shrink:0; }
    @media(max-width:900px) {
      .about-values-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .about-story-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
      .about-mv-grid { grid-template-columns: 1fr !important; }
      .owner-outcomes-grid { grid-template-columns: 1fr !important; }
    }
    @media(max-width:640px) {
      .about-stats-grid { grid-template-columns: 1fr !important; }
