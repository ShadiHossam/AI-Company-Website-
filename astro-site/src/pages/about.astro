---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";
import { loadPageContent, getVal } from "../lib/page-content";

// Hardcoded fallback team members
const fallbackTeam = [
  {
    name: "Faris Al-Hashemi",
    title: "Founder & CEO",
    bio: "Faris spent 12 years watching AI projects fail across the GCC — usually because the system didn't fit the business, or the team wasn't trained to use it. He started Aegis AI to fix that.",
    image_url: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&q=80&auto=format&fit=crop&crop=face",
  },
  {
    name: "Dr. Elena Rostova",
    title: "Head of Engineering",
    bio: "Elena has a PhD in Machine Learning and leads our engineering team. She's the reason our AI systems work in production, not just in demos — rigorous about testing before anything goes live.",
    image_url: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&q=80&auto=format&fit=crop&crop=face",
  },
  {
    name: "Tareq Al-Mansoori",
    title: "Head of Training",
    bio: "Tareq has trained over 1,500 professionals across the UAE in Arabic and English. He knows that most training fails not because of content, but because it doesn't connect to the job people actually do.",
    image_url: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=200&q=80&auto=format&fit=crop&crop=face",
  },
];

let teamMembers = fallbackTeam;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('team_members')
    .select('name, title, bio, image_url, sort_order')
    .eq('active', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    teamMembers = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
const pc = await loadPageContent('about');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Aegis AI',
  url: 'https://aegisai.ae/about',
  description: 'Aegis AI is a Dubai-based AI company helping SMEs build and adopt AI — in Arabic and English.',
  mainEntity: {
    '@type': 'Organization',
    name: 'Aegis AI',
    url: 'https://aegisai.ae',
    areaServed: { '@type': 'City', name: 'Dubai' },
    employee: teamMembers.map(m => ({
      '@type': 'Person',
      name: m.name,
      jobTitle: m.title,
      description: m.bio,
      ...(m.image_url ? { image: m.image_url } : {}),
      worksFor: { '@type': 'Organization', name: 'Aegis AI' },
    })),
  },
};
---

<BaseLayout
  title="AI Company Dubai for SMEs — Our Story | Aegis AI"
  description="Aegis AI is a Dubai-based AI company helping SMEs build and adopt AI. We combine custom AI development with employee training — in Arabic and English."
  canonicalPath="/about"
  ogImage="/assets/og-about.jpg"
  ldJson={aboutSchema}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><strong>About</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">group</span>
      {g('hero_eyebrow', 'About Us')}
    </div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      {g('hero_h1', 'We Believe Every Business Deserves AI That Actually Works.')}
    </h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      {g('hero_subtext', 'Not just enterprise giants. Not just tech companies. Every business in Dubai should be able to use AI to grow faster, waste less, and work smarter.')}
    </p>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:280px;">
  <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1400&q=80&auto=format&fit=crop" alt="Dubai skyline representing our home market" loading="eager" fetchpriority="high" width="1400" height="280" style="width:100%;height:100%;object-fit:cover;object-position:center 60%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0.05) 100%);"></div>
</div>

<!-- MISSION STATS -->
<section class="section" style="padding:5rem 0; background:#e7eeff;">
  <div class="container">
    <div class="about-stats-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px; max-width:760px; margin:0 auto; text-align:center;">
      <div>
        <p class="stat-number">94%</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">of UAE businesses are SMEs — most AI companies ignore them</p>
      </div>
      <div>
        <p class="stat-number">84%</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">of UAE AI projects fail due to skill gaps, not technology</p>
      </div>
      <div>
        <p class="stat-number">2031</p>
        <p style="color:#42474e; font-size:0.875rem; margin:0; line-height:1.6;">UAE National AI Strategy target — AI is a national priority</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR STORY -->
<section class="section" aria-labelledby="story-heading">
  <div class="container" style="max-width:960px;">
    <div class="about-story-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
      <div>
        <div class="section-eyebrow" style="text-align:left; margin-bottom:1rem;">Our Story</div>
        <h2 id="story-heading" style="text-align:left; font-size:2rem; margin-bottom:1.25rem;">Built After Watching AI Projects Fail</h2>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We founded Aegis AI in Dubai after watching dozens of promising AI projects fail — not because the technology was wrong, but because the people using it weren't ready, and the systems were built for someone else's business.</p>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We saw enterprise AI providers charging millions to government entities while Dubai's real estate agencies, retailers, hotel groups, and logistics companies were left behind — running on spreadsheets and gut feel in 2025.</p>
        <p style="color:#42474e; line-height:1.8;">We decided to do it differently. We build AI that's custom to your workflows, and we train your team to actually use it. That's our promise — backed by a full refund if we don't deliver.</p>
      </div>
      <div>
        <div style="background:#f0f3ff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:2rem;">
          <p style="color:#72787e; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.10em; font-weight:700; margin-bottom:1.5rem;">Why We're Different</p>
          <div class="timeline-item">
            <div class="timeline-dot">01</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">Build + Train in One Partnership</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">You shouldn't have to choose between building AI and training your team. We do both.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">02</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">SME-First Approach</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">No bloated enterprise contracts. Every project is scoped and priced specifically for your business, size, and goals.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">03</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">Arabic + English — Always</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Full bilingual service delivery, training materials, and customer support from day one.</p>
            </div>
          </div>
          <div class="timeline-item" style="margin-bottom:0;">
            <div class="timeline-dot">04</div>
            <div>
              <p style="font-weight:700; color:#00253b; margin-bottom:0.375rem;">The UAE's Only Full Refund Guarantee</p>
              <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">If you're not satisfied with what we build, we refund 100% of your investment. Period.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- OFFICE IMAGE -->
<div style="position:relative; overflow:hidden; height:260px;">
  <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1400&q=80&auto=format&fit=crop" alt="Modern office workspace where our Dubai AI team works" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;" />
  <div style="position:absolute;inset:0;background:rgba(0,104,117,0.08);"></div>
</div>

<!-- VALUES -->
<section class="section" style="background:#e7eeff;" aria-labelledby="values-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">What We Stand For</div>
      <h2 id="values-heading">Our Values</h2>
    </div>
    <div class="about-values-grid" style="display:grid; grid-template-columns:repeat(4,1fr); gap:24px;">
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">trending_up</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Results Before Revenue</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">We won't sell you AI you don't need. If it doesn't make business sense for you, we'll tell you — even if it costs us a sale.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">home</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Built for the UAE</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">Arabic-first. UAE-compliant. UAE-native. We understand your regulatory environment, your workforce, and your market.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">group</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Your Team Matters</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">A system your team can't use is worthless. We design for adoption — not just deployment — from day one.</p>
      </div>
      <div class="value-card">
        <div class="value-icon"><span class="material-symbols-outlined">visibility</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem;">Radical Transparency</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">Clear timelines. Clear expectations. No vague SOWs, hidden fees, or scope surprises mid-project.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHY DUBAI, WHY NOW -->
<section class="section" aria-labelledby="why-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <div class="section-eyebrow">Context</div>
      <h2 id="why-heading">Why Dubai. Why Now.</h2>
    </div>
    <div class="about-why-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">shield</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">UAE National AI Strategy 2031</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">The UAE government has committed to making AI a national priority. Businesses that adopt AI now will have a structural advantage over those that wait.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">bar_chart</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">SMEs Are 94% of UAE Business</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Yet almost every AI company in the UAE targets large enterprises or government — leaving the vast majority of businesses with no AI partner suited to their size and budget.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">person</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The Skills Gap Is Massive</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">84% of UAE AI implementations get stuck because teams aren't trained to use the systems built for them. Technology without training is just expensive software gathering dust.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">chat</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Arabic-First Is Non-Negotiable</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">The majority of UAE's SME workforce communicates primarily in Arabic. An AI system or training program that ignores that reality will fail in adoption.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div class="cta-band" style="text-align:center; max-width:680px; margin:0 auto;">
      <h2 style="color:#fff; font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; margin-bottom:1.25rem;">Let's Build Something Together.</h2>
      <p style="color:rgba(255,255,255,0.65); font-size:1.0625rem; margin-bottom:2.5rem;">Book a free strategy call. Tell us about your business. We'll tell you honestly if and how AI can help.</p>
      <button onclick="openModal(this)" data-source="about_cta" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Book a Free Consultation</button>
      <p style="color:rgba(255,255,255,0.40); font-size:0.8125rem; margin-top:1rem;">Free · No commitment · Available in Arabic &amp; English</p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.value-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:1.75rem; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .value-card:hover { transform:translateY(-4px); box-shadow:0 24px 56px rgba(0,59,92,0.10); }
    .value-icon { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem; color:#006875; }
    .stat-pill { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:1.5rem; text-align:center; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .stat-pill:hover { transform:translateY(-3px); box-shadow:0 24px 48px rgba(0,59,92,0.10); }
.timeline-item { display:grid; grid-template-columns:48px 1fr; gap:1.25rem; align-items:flex-start; margin-bottom:1.5rem; }
    .timeline-dot { width:48px; height:48px; border-radius:50%; background:#00e3fd; display:flex; align-items:center; justify-content:center; color:#00253b; font-weight:800; font-size:0.9rem; flex-shrink:0; }
    @media(max-width:900px) {
      .about-values-grid { grid-template-columns: repeat(2, 1fr) !important; }
      .about-story-grid { grid-template-columns: 1fr !important; gap: 2rem !important; }
    }
    @media(max-width:640px) {
      .about-stats-grid { grid-template-columns: 1fr !important; }
      .about-why-grid { grid-template-columns: 1fr !important; }
    }
    @media(max-width:480px) {
      .about-values-grid { grid-template-columns: 1fr !important; }
    }
</style>