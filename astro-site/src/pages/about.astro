---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPageContent, getVal } from "../lib/page-content";
import FaqAccordion from "../components/FaqAccordion.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
const pc = await loadPageContent('about');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const aboutFaqs = [
  { question: "Do you build the AI, or do you train our team?", answer: "Both, in one engagement. We build the system around your actual workflows, then train the people who will use it every day. Most AI projects fail at the handover point, so we don't hand over and leave. Your team is using the system confidently before we call the project done." },
  { question: "Do you only work with Dubai companies?", answer: "We're based in Dubai and most of our clients are in the UAE, but we work with businesses in other markets too. Discovery calls, builds, and training all work remotely. If you're in Dubai, we're happy to meet in person." },
  { question: "How big does our company need to be?", answer: "There's no minimum. We work with businesses from a handful of employees up to several hundred. Every project is scoped and priced for your size and your goals, so a 10-person company gets a 10-person-company project, not a stripped-down enterprise contract." },
  { question: "What happens on the first call?", answer: "You talk, we listen. In 30 minutes we'll understand your business, point out the two or three places where AI would actually pay off, and tell you honestly if it wouldn't. The call is free and there's no follow-up pressure either way." },
  { question: "How does the refund guarantee work?", answer: "If you're not satisfied with the AI system we build, we refund 100% of your investment. No conditions, no partial refunds, no fine print. We can offer this because we scope carefully and only take on projects we're confident will deliver." },
];

const aboutSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: aboutFaqs.map((f) => ({
      '@type': 'Question',
      name: f.question,
      acceptedAnswer: { '@type': 'Answer', text: f.answer },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Lenoo AI',
    url: 'https://lenooai.com/about',
    description: 'Lenoo AI helps businesses of every size build and adopt AI, with custom development and hands-on team training.',
    mainEntity: {
      '@type': 'Organization',
      name: 'Lenoo AI',
      url: 'https://lenooai.com',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lenooai.com/' },
      { '@type': 'ListItem', position: 2, name: 'About', item: 'https://lenooai.com/about' },
    ],
  },
];
---

<BaseLayout
  title="About Lenoo AI: The AI Team Behind UAE Businesses"
  description="Lenoo AI is an AI agency in Dubai. We build custom AI solutions and train teams to use them, working with UAE businesses of every size across every industry."
  canonicalPath="/about"
  arPath="/ar/about"
  ogImage="/assets/og-about.jpg"
  ldJson={aboutSchema}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>About</div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      {g('hero_h1', 'Most AI projects fail. We built a company to fix that.')}
    </h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      {g('hero_subtext', 'Not a generic platform. Not an enterprise vendor. A real partner that builds AI around how your business actually works, and trains your team to use it from day one.')}
    </p>
  </div>
</header>

<!-- WHY WE EXIST -->
<section class="section" style="padding-bottom:0;" aria-label="Why Lenoo AI exists">
  <div class="container">
    <div class="bento-grid bento-grid-3">
      <div class="value-card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:0.75rem;">70%</p>
        <p style="color:#42474e; font-size:0.9375rem; margin:0; line-height:1.65;">of AI implementations globally fail to reach production, not because of bad technology, but because teams weren't ready</p>
      </div>
      <div class="value-card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:0.75rem;">$4.4T</p>
        <p style="color:#42474e; font-size:0.9375rem; margin:0; line-height:1.65;">estimated annual value AI could add to the global economy, most of it still unclaimed by small and mid-size businesses</p>
      </div>
      <div class="value-card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:0.75rem;">3–5×</p>
        <p style="color:#42474e; font-size:0.9375rem; margin:0; line-height:1.65;">the performance gap between businesses that have adopted AI and those still waiting, measured in speed, cost, and response time</p>
      </div>
    </div>
  </div>
</section>

<!-- MISSION & VISION -->
<section class="section" aria-labelledby="mission-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <h2 id="mission-heading">We built this company for a reason.</h2>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;" class="about-mv-grid">
      <div style="background:#00253b; border-radius:20px; padding:2.25rem; position:relative; overflow:hidden;">
        <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(0,227,253,0.06);"></div>
        <p style="color:#00e3fd; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:1rem;">Mission</p>
        <p style="color:#fff; font-size:1.125rem; font-weight:700; line-height:1.6; margin-bottom:1rem;">Help every business adopt AI and get real results from it.</p>
        <p style="color:rgba(255,255,255,0.60); font-size:0.9375rem; line-height:1.7; margin:0;">Not just the ones with enterprise budgets and data science teams. Every business deserves to use AI in a way that makes their team more capable and their results better. We help you get there, without replacing your people.</p>
      </div>
      <div style="background:#f0f3ff; border:1px solid rgba(0,37,59,0.08); border-radius:20px; padding:2.25rem; position:relative; overflow:hidden;">
        <div style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:rgba(0,227,253,0.08);"></div>
        <p style="color:#006875; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:1rem;">Vision</p>
        <p style="color:#00253b; font-size:1.125rem; font-weight:700; line-height:1.6; margin-bottom:1rem;">A world where any business owner can use AI to get better results from their team.</p>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">Any industry. Any market. AI that makes good teams great, without replacing the people who built the business in the first place.</p>
      </div>
    </div>
  </div>
</section>

<!-- OUR STORY -->
<section class="section" aria-labelledby="story-heading">
  <div class="container" style="max-width:1080px;">
    <div class="split-grid">
      <div>
        <h2 id="story-heading" style="text-align:left; font-size:2rem; margin-bottom:1.25rem;">Built After Watching AI Projects Fail</h2>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We founded Lenoo AI after watching dozens of promising AI projects fail, not because the technology was wrong, but because the people using it weren't ready, and the systems were built for someone else's business.</p>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1rem;">We saw enterprise AI vendors charging millions to large organisations while small and mid-size businesses across industries were left out entirely, still running on spreadsheets and gut feel in 2025.</p>
        <p style="color:#42474e; line-height:1.8;">We decided to do it differently. As an AI agency based in Dubai, we build AI that's custom to your workflows, and we train your team to actually use it. That's our promise, backed by a full refund if we don't deliver.</p>
      </div>
      <div class="split-media">
        <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=900&q=80&auto=format&fit=crop" alt="Global city skyline representing Lenoo AI work with businesses across markets worldwide" loading="lazy" width="900" height="620" />
      </div>
    </div>
  </div>
</section>

<!-- WHY WE'RE DIFFERENT -->
<section class="section" style="padding-top:0;" aria-labelledby="different-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="different-heading">Why We're Different</h2>
    </div>
    <div style="border-radius:20px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 20px 48px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?w=1200&q=80&auto=format&fit=crop" alt="Lenoo AI team presenting a project plan to a Dubai business during a build and training session" loading="lazy" width="1200" height="320" style="width:100%; height:clamp(180px, 26vw, 320px); object-fit:cover; display:block;" />
    </div>
    <div class="bento-grid bento-grid-4">
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">construction</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Build + Train in One Partnership</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">You shouldn't have to choose between building AI and training your team. We do both.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">storefront</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Built for Real Businesses</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">No bloated enterprise contracts. Every project is scoped and priced specifically for your business, your size, and your goals.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">translate</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Multilingual from Day One</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">We deliver in the language your team works in. Training materials, support, and documentation, adapted to your workforce from the start.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">verified</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">A Full Refund Guarantee: No Fine Print</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">If you're not satisfied with what we build, we refund 100% of your investment. Period.</p>
      </div>
    </div>
  </div>
</section>

<!-- BUSINESS OWNER MESSAGE -->
<section class="section" style="background:#00253b; padding:5rem 0;" aria-labelledby="owner-heading">
  <div class="container" style="max-width:820px;">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <p style="color:#00e3fd; font-size:0.75rem; text-transform:uppercase; letter-spacing:0.12em; font-weight:700; margin-bottom:0.75rem;">For Business Owners</p>
      <h2 id="owner-heading" style="color:#fff; font-size:clamp(1.375rem,2.5vw,1.75rem); font-weight:800; margin-bottom:0;">If you're running a business right now, you already feel it.</h2>
    </div>
    <div style="border-radius:20px; overflow:hidden; margin-bottom:2rem; box-shadow:0 20px 48px rgba(0,0,0,0.25);">
      <img src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?w=1200&q=80&auto=format&fit=crop" alt="Business owner discussing AI adoption with a Lenoo AI consultant" loading="lazy" width="1200" height="320" style="width:100%; height:clamp(180px, 26vw, 320px); object-fit:cover; display:block;" />
    </div>
    <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.15); border-radius:20px; padding:2rem 2.5rem;">
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1rem;">Decisions that used to take a day now need to happen in an hour. Your customers expect faster replies, faster delivery, faster everything. Your margins are tighter than they were three years ago. And somewhere in your industry, a competitor just started using AI, and their team is getting more done without burning out.</p>
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1rem;">That's not a technology problem. That's a business problem. And it's solvable.</p>
      <p style="color:rgba(255,255,255,0.80); font-size:0.9375rem; line-height:1.8; margin-bottom:1.5rem;">We work with business owners who want to use AI to grow their business, not replace their people. We help you figure out where AI fits, build it around how your team actually works, and make sure your people know how to use it well. The goal is always the same: better results with the team you already have.</p>
      <p style="color:#00e3fd; font-size:0.9375rem; font-weight:700; margin:0;">AI adoption, done right. That's what we're here for.</p>
    </div>
    <div class="bento-grid bento-grid-3" style="margin-top:2rem;">
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">trending_up</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">More Revenue</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">AI-powered follow-up and lead handling that runs while you sleep</p>
      </div>
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">schedule</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">Less Wasted Time</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">Automate the repetitive tasks draining your team every single day</p>
      </div>
      <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(0,227,253,0.12); border-radius:14px; padding:1.25rem; text-align:center;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:28px; margin-bottom:0.75rem; display:block;">insights</span>
        <p style="color:#fff; font-weight:700; font-size:0.9375rem; margin-bottom:0.25rem;">Better Decisions</p>
        <p style="color:rgba(255,255,255,0.50); font-size:0.8125rem; margin:0; line-height:1.5;">Use the data you already have to see what's working and what's not</p>
      </div>
    </div>
  </div>
</section>


<!-- VALUES -->
<section class="section" style="background:#e7eeff;" aria-labelledby="values-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="values-heading">Four things we won't compromise on.</h2>
    </div>
    <div style="border-radius:20px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 20px 48px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1600880292089-90a7e086ee0c?w=1200&q=80&auto=format&fit=crop" alt="Team members stacking hands to represent Lenoo AI's partnership with client teams" loading="lazy" width="1200" height="320" style="width:100%; height:clamp(180px, 26vw, 320px); object-fit:cover; display:block;" />
    </div>
    <div class="bento-grid bento-grid-4">
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">trending_up</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1.0625rem; margin-bottom:0.5rem;">Results Before Revenue</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">We won't sell you AI you don't need. If it doesn't make business sense for you, we'll tell you, even if it costs us a sale.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">home</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1.0625rem; margin-bottom:0.5rem;">Built for Your Market</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">We adapt to your local context: language, regulations, workforce, and business norms. Our solutions are shaped around how your market actually works.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">group</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1.0625rem; margin-bottom:0.5rem;">AI works with your team. Not instead of them.</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Our purpose is to help your people do their jobs better using AI. We're not here to reduce headcount. We're here to make your team more capable and get better results from the people you already have.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">visibility</span></div>
        <h3 style="font-weight:700; color:#00253b; font-size:1.0625rem; margin-bottom:0.5rem;">No surprises, ever.</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Clear timelines. Clear scope. Clear pricing. You'll never get a vague proposal or find out about a problem after the invoice arrives.</p>
      </div>
    </div>
  </div>
</section>

<!-- COST OF WAITING -->
<section class="section" aria-labelledby="waiting-heading">
  <div class="container" style="max-width:900px;">
    <div class="section-header">
      <h2 id="waiting-heading">Your competitors aren't waiting.</h2>
    </div>
    <div class="about-why-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">bolt</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Your competitor is using AI to process leads while your team sleeps.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">AI doesn't clock out. Businesses that automate lead follow-up and customer responses are replying in minutes, not the next morning.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">bar_chart</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">The gap between adopters and non-adopters grows every quarter.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Companies that adopted AI early have had years of compounding efficiency gains and cost advantages. That gap doesn't close. It widens.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">group_add</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Your team can do more. AI gives them the time to do it.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">AI takes over the repetitive, time-consuming tasks so your people can focus on the work that actually needs human thinking, judgment, and relationships.</p>
      </div>
      <div class="stat-pill">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">timer</span></div>
        <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">Waiting for AI to "mature" is the mistake.</p>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">The businesses that win are the ones that adopt now, learn what works, and build internal competency before their competitors do. The second-best time to start is today.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ: WORKING WITH US -->
<section class="section" style="background:#f0f3ff;" aria-labelledby="about-faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="about-faq-heading">Questions People Ask Before Working With Us</h2>
      <p>Short, honest answers. If yours isn't here, ask us on the call.</p>
    </div>
    <div>
      {aboutFaqs.map((item) => (
        <div class="faq-item">
          <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
            {item.question}
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-body">{item.answer}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div class="cta-band" style="text-align:center; max-width:680px; margin:0 auto;">
      <div style="position:relative; z-index:1; text-align:center;">
        <p class="cta-eyebrow">Free Discovery Call</p>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; margin-bottom:1.25rem;">Talk to us. No pitch deck required.</h2>
        <p style="font-size:1.0625rem; max-width:36rem; margin:0 auto 2rem; line-height:1.7;">Tell us about your business. We'll tell you honestly whether AI can help, and exactly what that would look like.</p>
        <div class="cta-trust-badges">
          <span class="cta-trust-badge">✓ 100% free</span>
          <span class="cta-trust-badge">✓ No commitment</span>
          <span class="cta-trust-badge">✓ Refund guarantee</span>
        </div>
        <button onclick="openModal(this)" data-source="about_cta" class="btn-primary" style="font-size:1.125rem; padding:1.125rem 2.75rem;">Book a Free Consultation</button>
        <p style="font-size:.875rem; margin-top:1rem; color:#94a3b8;">30-min call · No sales pressure</p>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

