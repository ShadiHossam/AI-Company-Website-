---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const id = Astro.params.id!;

const [
  { data: lead, error },
  { data: activity },
  { count: unreadNotifs },
  { data: authData },
] = await Promise.all([
  supabase.from('leads').select('*').eq('id', id).single(),
  supabase.from('activity_log').select('*').eq('entity_id', id).order('created_at', { ascending: false }).limit(50),
  supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false),
  supabase.auth.admin.listUsers(),
]);

if (error || !lead) return Astro.redirect('/admin/leads');

const adminUsers = (authData?.users ?? []).map(u => ({
  id: u.id,
  label: (u.user_metadata?.name as string | undefined) ?? u.email ?? u.id,
}));

const statusLabels: Record<string, string> = {
  new: 'New', contacted: 'Contacted', qualified: 'Qualified',
  proposal_sent: 'Proposal Sent', closed_won: 'Closed Won', closed_lost: 'Closed Lost',
};
const statusBadge: Record<string, string> = {
  new: 'badge-new', contacted: 'badge-contacted', qualified: 'badge-qualified',
  proposal_sent: 'badge-proposal', closed_won: 'badge-won', closed_lost: 'badge-lost',
};

function timeAgo(date: string) {
  const diff = Date.now() - new Date(date).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}
---

<AdminLayout title={`${lead.full_name} — Lead`} user={user} unreadCount={unreadNotifs ?? 0}>

  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-muted mb-4">
    <a href="/admin/leads" style="color:var(--text-muted); text-decoration:none;">Leads</a>
    <span>/</span>
    <span style="color:var(--text-primary);">{lead.full_name}</span>
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div style="display:flex; align-items:center; gap:1rem;">
      <div style="width:48px; height:48px; border-radius:50%; background:linear-gradient(135deg,#006875,#00e3fd); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.125rem; color:#0a0f1a;">
        {lead.full_name.slice(0, 2).toUpperCase()}
      </div>
      <div>
        <h1 style="font-size:1.25rem; font-weight:800;">{lead.full_name}</h1>
        <div class="text-muted text-sm">{lead.company_name} · {lead.job_title ?? 'No title'}</div>
      </div>
    </div>
    <div class="flex gap-2 items-center">
      {lead.duplicate_email && (
        <span class="badge badge-lost" title="Same email submitted before">⚠ Duplicate Email</span>
      )}
      <span class={`badge ${statusBadge[lead.status] ?? 'badge-new'}`}>{statusLabels[lead.status] ?? lead.status}</span>
      <span class="text-xs text-muted">Source: {String(lead.page_source ?? 'unknown').replace(/_/g,' ')}</span>
      {lead.utm_campaign && <span class="text-xs text-muted">UTM: {lead.utm_campaign}</span>}
    </div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 380px; gap:1.5rem; align-items:start;">

    <!-- Left: submitted data -->
    <div style="display:flex; flex-direction:column; gap:1.5rem;">

      <!-- Quick actions -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Quick Actions</div>
        <div class="flex gap-2" style="flex-wrap:wrap;">
          <a href={`https://wa.me/${String(lead.whatsapp ?? '').replace(/\D/g,'')}`} target="_blank" rel="noopener" class="btn btn-sm" style="background:rgba(37,211,102,0.12);color:#25d366;border-color:rgba(37,211,102,0.25);">
            Open in WhatsApp
          </a>
          <a href={`mailto:${lead.work_email}`} class="btn btn-secondary btn-sm">
            Send Email
          </a>
          <button onclick={`navigator.clipboard.writeText('${lead.whatsapp}')`} class="btn btn-ghost btn-sm">Copy WhatsApp</button>
          <button onclick={`navigator.clipboard.writeText('${lead.work_email}')`} class="btn btn-ghost btn-sm">Copy Email</button>
        </div>
      </div>

      <!-- Step 1 data -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Contact Details</div>
        <div class="grid-2">
          <div><div class="form-label">Full Name</div><div class="text-sm">{lead.full_name}</div></div>
          <div><div class="form-label">Company</div><div class="text-sm">{lead.company_name}</div></div>
          <div><div class="form-label">Email</div><div class="text-sm">{lead.work_email}</div></div>
          <div><div class="form-label">WhatsApp</div><div class="text-sm">{lead.whatsapp}</div></div>
          <div><div class="form-label">Job Title</div><div class="text-sm">{lead.job_title ?? '—'}</div></div>
          <div><div class="form-label">Submitted</div><div class="text-sm">{new Date(lead.created_at).toLocaleString('en-GB')}</div></div>
        </div>
      </div>

      <!-- Step 2 data -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Business Details</div>
        <div class="grid-2">
          <div><div class="form-label">Industry</div><div class="text-sm">{lead.industry ?? '—'}</div></div>
          <div><div class="form-label">Company Size</div><div class="text-sm">{lead.company_size ?? '—'}</div></div>
          <div><div class="form-label">Budget Range</div><div class="text-sm">{lead.budget_range ?? '—'}</div></div>
          <div><div class="form-label">AI Experience</div><div class="text-sm">{lead.ai_experience ?? '—'}</div></div>
          <div style="grid-column:1/-1;"><div class="form-label">Main Challenge</div><div class="text-sm" style="line-height:1.6;">{lead.main_challenge ?? '—'}</div></div>
        </div>
      </div>

      <!-- Step 3 data -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Meeting Preference</div>
        <div class="grid-2">
          <div><div class="form-label">Meeting Format</div><div class="text-sm">{lead.meeting_format ?? '—'}</div></div>
          <div><div class="form-label">Preferred Date</div><div class="text-sm">{lead.preferred_date ?? '—'}</div></div>
          <div><div class="form-label">Preferred Time</div><div class="text-sm">{lead.preferred_time ?? '—'}</div></div>
          {lead.notes && <div style="grid-column:1/-1;"><div class="form-label">Additional Notes</div><div class="text-sm" style="line-height:1.6;">{lead.notes}</div></div>}
        </div>
      </div>

      <!-- Activity feed -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Activity Log</div>
        {(activity ?? []).length === 0 && <p class="text-sm text-muted">No activity yet.</p>}
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
          {(activity ?? []).map(evt => (
            <div style="display:flex; gap:0.75rem; align-items:flex-start;">
              <div style="width:8px; height:8px; border-radius:50%; background:var(--accent); flex-shrink:0; margin-top:5px;"></div>
              <div>
                <div class="text-sm">{String(evt.action).replace(/\./g,' ')}</div>
                <div class="text-xs text-muted">{evt.admin_email} · {timeAgo(String(evt.created_at))}</div>
                {evt.before_value && evt.after_value && (
                  <div class="text-xs text-muted">{JSON.stringify(evt.before_value)} → {JSON.stringify(evt.after_value)}</div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Right: CRM panel -->
    <div style="display:flex; flex-direction:column; gap:1rem; position:sticky; top:calc(var(--topbar-h) + 1rem);">

      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">CRM Panel</div>
        <form id="crm-form" style="display:flex; flex-direction:column; gap:0.875rem;">

          <div class="form-group">
            <label class="form-label" for="status">Status</label>
            <select class="form-select" id="status" name="status">
              {Object.entries(statusLabels).map(([k, v]) => (
                <option value={k} selected={lead.status === k}>{v}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="assigned_to">Assigned To</label>
            <select class="form-select" id="assigned_to" name="assigned_to">
              <option value="">Unassigned</option>
              {adminUsers.map(u => (
                <option value={u.id} selected={lead.assigned_to === u.id}>{u.label}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="estimated_value_aed">Estimated Value (AED)</label>
            <input class="form-input" id="estimated_value_aed" name="estimated_value_aed" type="number" min="0" step="1000" value={lead.estimated_value_aed ?? ''} />
          </div>

          <div class="form-group">
            <label class="form-label" for="next_action">Next Action</label>
            <input class="form-input" id="next_action" name="next_action" type="text" placeholder="Send proposal..." value={lead.next_action ?? ''} />
          </div>

          <div class="form-group">
            <label class="form-label" for="next_action_date">Next Action Date</label>
            <input class="form-input" id="next_action_date" name="next_action_date" type="date" value={lead.next_action_date ?? ''} />
          </div>

          <div class="form-group">
            <label class="form-label" for="tags">Tags (comma-separated)</label>
            <input class="form-input" id="tags" name="tags" type="text" placeholder="hot, referral, event" value={(lead.tags ?? []).join(', ')} />
          </div>

          <div class="form-group">
            <label class="form-label" for="internal_notes">Internal Notes</label>
            <textarea class="form-textarea" id="internal_notes" name="internal_notes" rows="4" placeholder="Add notes here…">{lead.internal_notes ?? ''}</textarea>
          </div>

          <button type="submit" class="btn btn-primary" id="crm-save-btn">Save Changes</button>
          <div id="crm-save-msg" style="display:none; color:var(--success); font-size:0.8125rem; text-align:center;">Saved!</div>
        </form>
      </div>

    </div>

  </div>

</AdminLayout>

<script define:vars={{ leadId: lead.id }}>
  const form = document.getElementById('crm-form');
  const btn  = document.getElementById('crm-save-btn');
  const msg  = document.getElementById('crm-save-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Saving…';

    const tagsRaw = document.getElementById('tags').value;
    const tags = tagsRaw.split(',').map(t => t.trim()).filter(Boolean);

    const payload = {
      status:               document.getElementById('status').value,
      assigned_to:          document.getElementById('assigned_to').value.trim() || null,
      estimated_value_aed:  parseInt(document.getElementById('estimated_value_aed').value) || null,
      next_action:          document.getElementById('next_action').value.trim() || null,
      next_action_date:     document.getElementById('next_action_date').value || null,
      tags,
      internal_notes:       document.getElementById('internal_notes').value.trim() || null,
    };

    const res = await fetch(`/api/admin/leads/${leadId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    btn.disabled = false;
    btn.textContent = 'Save Changes';
    if (res.ok) {
      msg.style.display = 'block';
      setTimeout(() => { msg.style.display = 'none'; }, 2000);
    }
  });
</script>
