---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const today = new Date().toISOString().split('T')[0];
const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
const sevenDaysAgo  = new Date(Date.now() - 7  * 86400000).toISOString();
const thirtyDaysAgo = new Date(Date.now() - 30 * 86400000).toISOString();

const [
  { count: newToday },
  { count: qualifiedWeek },
  { data: pipeline },
  { count: unreadNotifs },
  { data: recentLeads },
  { data: hotLeads },
  { data: blogPosts },
  { data: allLeads },
  { data: sparkData },
  { data: monthData },
  { data: sourceData },
] = await Promise.all([
  supabase.from('leads').select('*', { count: 'exact', head: true }).gte('created_at', today),
  supabase.from('leads').select('*', { count: 'exact', head: true }).eq('status', 'qualified').gte('created_at', weekAgo),
  supabase.from('leads').select('status, estimated_value_aed').not('status', 'in', '(closed_won,closed_lost)'),
  supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false),
  supabase.from('leads').select('id, full_name, company_name, status, page_source, created_at, duplicate_email').order('created_at', { ascending: false }).limit(10),
  supabase.from('leads').select('id, full_name, company_name, whatsapp, status').eq('status', 'qualified').lt('updated_at', new Date(Date.now() - 5 * 24 * 60 * 60 * 1000).toISOString()).limit(5),
  supabase.from('blog_posts').select('status'),
  supabase.from('leads').select('status'),
  supabase.from('leads').select('created_at, status').gte('created_at', sevenDaysAgo),
  supabase.from('leads').select('created_at').gte('created_at', thirtyDaysAgo),
  supabase.from('leads').select('page_source, utm_source').gte('created_at', thirtyDaysAgo),
]);

const pipelineAED = (pipeline ?? []).reduce((s, l) => s + (l.estimated_value_aed ?? 0), 0);

const statusLabels: Record<string, string> = {
  new: 'New', contacted: 'Contacted', qualified: 'Qualified',
  proposal_sent: 'Proposal', closed_won: 'Won', closed_lost: 'Lost',
};
const statusColors: Record<string, string> = {
  new: 'badge-new', contacted: 'badge-contacted', qualified: 'badge-qualified',
  proposal_sent: 'badge-proposal', closed_won: 'badge-won', closed_lost: 'badge-lost',
};

function timeAgo(date: string) {
  const diff = Date.now() - new Date(date).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}

const publishedBlogs = (blogPosts ?? []).filter(p => p.status === 'published').length;
const draftBlogs     = (blogPosts ?? []).filter(p => p.status === 'draft').length;

// Funnel
const funnelOrder = ['new', 'contacted', 'qualified', 'proposal_sent', 'closed_won'];
const funnelLabels = ['New', 'Contacted', 'Qualified', 'Proposal', 'Won'];
const allStatuses: Record<string, number> = {};
for (const l of allLeads ?? []) allStatuses[l.status] = (allStatuses[l.status] ?? 0) + 1;
const funnelCounts = funnelOrder.map(s => allStatuses[s] ?? 0);

// 7-day sparklines
const sparkNew = Array(7).fill(0);
const sparkQualified = Array(7).fill(0);
const nowMs = Date.now();
for (const row of sparkData ?? []) {
  const dayIdx = 6 - Math.floor((nowMs - new Date(row.created_at).getTime()) / 86400000);
  if (dayIdx >= 0 && dayIdx < 7) {
    sparkNew[dayIdx]++;
    if (row.status === 'qualified') sparkQualified[dayIdx]++;
  }
}

// 30-day bar chart
const barCounts = Array(30).fill(0);
for (const row of monthData ?? []) {
  const dayIdx = 29 - Math.floor((nowMs - new Date(row.created_at).getTime()) / 86400000);
  if (dayIdx >= 0 && dayIdx < 30) barCounts[dayIdx]++;
}
const barLabels = Array.from({ length: 30 }, (_, i) => {
  const d = new Date(nowMs - (29 - i) * 86400000);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
});

// Source breakdown
const sourceCounts: Record<string, number> = {};
for (const row of sourceData ?? []) {
  const key = (row.utm_source || row.page_source || 'direct').replace(/_/g, ' ');
  sourceCounts[key] = (sourceCounts[key] ?? 0) + 1;
}
const sourceEntries = Object.entries(sourceCounts).sort((a, b) => b[1] - a[1]).slice(0, 6);
const sourceLabels = sourceEntries.map(([k]) => k);
const sourceValues = sourceEntries.map(([, v]) => v);
---

<AdminLayout title="Dashboard" user={user} unreadCount={unreadNotifs ?? 0}>

  <script slot="head" src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" is:inline></script>

  <!-- Stats row -->
  <div class="grid-4 mb-4">
    <div class="stat-card">
      <div class="stat-label">New Leads Today</div>
      <div class="stat-value">{newToday ?? 0}</div>
      <canvas id="spark-new" height="40" style="opacity:0.8;margin-top:0.5rem;"></canvas>
    </div>
    <div class="stat-card">
      <div class="stat-label">Qualified This Week</div>
      <div class="stat-value">{qualifiedWeek ?? 0}</div>
      <canvas id="spark-qualified" height="40" style="opacity:0.8;margin-top:0.5rem;"></canvas>
    </div>
    <div class="stat-card">
      <div class="stat-label">Pipeline Value</div>
      <div class="stat-value">AED {pipelineAED.toLocaleString()}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Unread Notifications</div>
      <div class="stat-value">{unreadNotifs ?? 0}</div>
    </div>
  </div>

  <!-- 30-day bar chart -->
  <div class="card mb-6">
    <div class="card-header" style="margin-bottom:1rem;">
      <div class="card-title">Lead Volume — Last 30 Days</div>
    </div>
    <canvas id="bar-chart" height="120"></canvas>
  </div>

  <div style="display:grid; grid-template-columns:2fr 1fr; gap:1.5rem; align-items:start;">

    <!-- Left column -->
    <div style="display:flex; flex-direction:column; gap:1.5rem;">

      <!-- Recent leads -->
      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Recent Leads</div>
            <div class="card-sub">Last 10 submissions</div>
          </div>
          <a href="/admin/leads" class="btn btn-secondary btn-sm">View All →</a>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Source</th>
                <th>Status</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              {(recentLeads ?? []).map(lead => (
                <tr>
                  <td>
                    <a href={`/admin/leads/${lead.id}`} style="color:var(--text-primary); text-decoration:none; font-weight:600;">
                      {lead.full_name}
                      {lead.duplicate_email && <span class="badge badge-lost" style="margin-left:6px; font-size:0.6rem;">DUP</span>}
                    </a>
                    <div class="text-xs text-muted">{lead.company_name}</div>
                  </td>
                  <td><span class="text-xs text-muted">{(lead.page_source ?? 'unknown').replace(/_/g, ' ')}</span></td>
                  <td><span class={`badge ${statusColors[lead.status] ?? 'badge-new'}`}>{statusLabels[lead.status] ?? lead.status}</span></td>
                  <td class="text-xs text-muted">{timeAgo(lead.created_at)}</td>
                </tr>
              ))}
              {(recentLeads ?? []).length === 0 && (
                <tr><td colspan="4" style="text-align:center; color:var(--text-dim); padding:2rem;">No leads yet</td></tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Lead funnel -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Lead Funnel</div>
        <div id="funnel-bars" style="display:flex;flex-direction:column;gap:0.5rem;"></div>
      </div>

      <!-- Hot leads -->
      {(hotLeads ?? []).length > 0 && (
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Hot Leads — Need Follow-Up</div>
              <div class="card-sub">Qualified, not contacted in 5+ days</div>
            </div>
          </div>
          <div style="display:flex; flex-direction:column; gap:0.75rem;">
            {(hotLeads ?? []).map(lead => (
              <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; padding:0.75rem; background:var(--bg-hover); border-radius:var(--radius);">
                <div>
                  <a href={`/admin/leads/${lead.id}`} style="font-weight:600; color:var(--text-primary); text-decoration:none;">{lead.full_name}</a>
                  <div class="text-xs text-muted">{lead.company_name}</div>
                </div>
                <div style="display:flex; gap:0.5rem;">
                  <a href={`https://wa.me/${lead.whatsapp?.replace(/\D/g,'')}`} target="_blank" rel="noopener" class="btn btn-sm" style="background:rgba(37,211,102,0.12);color:#25d366;border-color:rgba(37,211,102,0.25);">WhatsApp</a>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- Right column -->
    <div style="display:flex; flex-direction:column; gap:1.5rem;">

      <!-- Quick actions -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Quick Actions</div>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <a href="/admin/blog/new" class="btn btn-secondary" style="justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Blog Post
          </a>
          <a href="/admin/media" class="btn btn-secondary" style="justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Upload Media
          </a>
          <a href="/admin/settings/company" class="btn btn-secondary" style="justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
            Edit Company Info
          </a>
          <a href="/admin/leads" class="btn btn-secondary" style="justify-content:center;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            View All Leads
          </a>
        </div>
      </div>

      <!-- Content status -->
      <div class="card">
        <div class="card-title" style="margin-bottom:1rem;">Content Status</div>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span class="text-sm text-muted">Blog Posts Published</span>
            <span class="badge badge-published">{publishedBlogs}</span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <span class="text-sm text-muted">Blog Drafts</span>
            <span class="badge badge-draft">{draftBlogs}</span>
          </div>
        </div>
        <a href="/admin/blog" class="btn btn-ghost btn-sm" style="margin-top:1rem; width:100%; justify-content:center;">Manage Blog →</a>
      </div>

      <!-- Lead sources -->
      {sourceLabels.length > 0 && (
        <div class="card">
          <div class="card-title" style="margin-bottom:1rem;">Lead Sources (30d)</div>
          <canvas id="source-chart" height="180"></canvas>
        </div>
      )}

    </div>

  </div>

</AdminLayout>

<script define:vars={{ sparkNew, sparkQualified, barLabels, barCounts, sourceLabels, sourceValues, funnelLabels, funnelCounts }}>
  // Sparkline defaults
  const sparkDefaults = {
    type: 'line',
    options: {
      responsive: true,
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      scales: { x: { display: false }, y: { display: false } },
      elements: { point: { radius: 0 }, line: { tension: 0.4, borderWidth: 2 } },
      animation: { duration: 600 },
    },
  };

  const sparkNewEl = document.getElementById('spark-new');
  if (sparkNewEl && typeof Chart !== 'undefined') {
    new Chart(sparkNewEl, {
      ...sparkDefaults,
      data: {
        labels: Array.from({ length: 7 }, (_, i) => i),
        datasets: [{ data: sparkNew, borderColor: '#00e3fd', backgroundColor: 'rgba(0,227,253,0.08)', fill: true }],
      },
    });
  }

  const sparkQualEl = document.getElementById('spark-qualified');
  if (sparkQualEl && typeof Chart !== 'undefined') {
    new Chart(sparkQualEl, {
      ...sparkDefaults,
      data: {
        labels: Array.from({ length: 7 }, (_, i) => i),
        datasets: [{ data: sparkQualified, borderColor: '#fbbf24', backgroundColor: 'rgba(251,191,36,0.08)', fill: true }],
      },
    });
  }

  // 30-day bar chart
  const barEl = document.getElementById('bar-chart');
  if (barEl && typeof Chart !== 'undefined') {
    new Chart(barEl, {
      type: 'bar',
      data: {
        labels: barLabels,
        datasets: [{
          data: barCounts,
          backgroundColor: 'rgba(0,227,253,0.25)',
          borderColor: '#00e3fd',
          borderWidth: 1,
          borderRadius: 3,
        }],
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          x: {
            ticks: { color: '#64748b', font: { size: 10 }, maxTicksLimit: 10 },
            grid: { display: false },
          },
          y: {
            ticks: { color: '#64748b', stepSize: 1 },
            grid: { color: 'rgba(100,116,139,0.1)' },
            beginAtZero: true,
          },
        },
        animation: { duration: 800 },
      },
    });
  }

  // Lead funnel (CSS bars — no Chart.js)
  const funnelEl = document.getElementById('funnel-bars');
  if (funnelEl) {
    const maxCount = Math.max(...funnelCounts, 1);
    funnelLabels.forEach((label, i) => {
      const pct = Math.round((funnelCounts[i] / maxCount) * 100);
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;align-items:center;gap:0.75rem;';
      div.innerHTML = `
        <div style="width:80px;font-size:0.72rem;color:var(--text-muted);text-align:right;flex-shrink:0;">${label}</div>
        <div style="flex:1;background:var(--bg-hover);border-radius:4px;height:20px;overflow:hidden;">
          <div style="width:${pct}%;background:var(--accent);border-radius:4px;height:100%;transition:width 0.6s ease;"></div>
        </div>
        <div style="width:28px;font-size:0.72rem;color:var(--text-muted);flex-shrink:0;text-align:right;">${funnelCounts[i]}</div>
      `;
      funnelEl.appendChild(div);
    });
  }

  // Source doughnut
  const sourceEl = document.getElementById('source-chart');
  if (sourceEl && typeof Chart !== 'undefined' && sourceLabels.length > 0) {
    new Chart(sourceEl, {
      type: 'doughnut',
      data: {
        labels: sourceLabels,
        datasets: [{
          data: sourceValues,
          backgroundColor: [
            'rgba(0,227,253,0.75)',
            'rgba(251,191,36,0.75)',
            'rgba(167,139,250,0.75)',
            'rgba(74,222,128,0.75)',
            'rgba(248,113,113,0.75)',
            'rgba(251,146,60,0.75)',
          ],
          borderWidth: 0,
        }],
      },
      options: {
        responsive: true,
        cutout: '65%',
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#94a3b8', font: { size: 11 }, padding: 10, boxWidth: 12 },
          },
        },
        animation: { duration: 800 },
      },
    });
  }
</script>
