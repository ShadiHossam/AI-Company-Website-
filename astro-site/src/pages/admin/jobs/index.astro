---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const [{ data: jobs }, { count: unreadNotifs }] = await Promise.all([
  supabase.from('jobs').select('*').is('deleted_at', null).order('sort_order', { ascending: true }).order('created_at', { ascending: false }),
  supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false),
]);
---

<AdminLayout title="Jobs" user={user} unreadCount={unreadNotifs ?? 0}>

  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 style="font-size:1.25rem;font-weight:800;">Job Postings</h1>
      <p class="text-muted text-sm">{(jobs ?? []).length} total</p>
    </div>
    <a href="/admin/jobs/new" class="btn btn-primary">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Job
    </a>
  </div>

  <div class="card" style="padding:0;overflow:hidden;">
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Title</th>
            <th>Department</th>
            <th>Type</th>
            <th>Location</th>
            <th>Status</th>
            <th>Order</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {(jobs ?? []).map(job => (
            <tr>
              <td>
                <a href={`/admin/jobs/${job.id}`} style="font-weight:600;color:var(--text-primary);text-decoration:none;">{job.title}</a>
                <div class="text-xs text-muted">/jobs/{job.slug}</div>
              </td>
              <td class="text-sm">{job.department ?? '—'}</td>
              <td class="text-sm">{job.job_type}</td>
              <td class="text-sm">{job.location}</td>
              <td>
                <span
                  class={`badge ${job.published ? 'badge-won' : 'badge-lost'}`}
                  style="cursor:pointer;"
                  data-job-id={job.id}
                  data-published={String(job.published)}
                  onclick="togglePublished(this)"
                  title="Click to toggle"
                >
                  {job.published ? 'Published' : 'Draft'}
                </span>
              </td>
              <td class="text-sm text-muted">{job.sort_order}</td>
              <td>
                <div class="flex gap-2">
                  <a href={`/jobs/${job.slug}`} target="_blank" class="btn btn-ghost btn-sm" title="Preview">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  </a>
                  <a href={`/admin/jobs/${job.id}`} class="btn btn-ghost btn-sm">Edit</a>
                  <button class="btn btn-ghost btn-sm" style="color:var(--error);" data-job-id={job.id} onclick="deleteJob(this.dataset.jobId)">Delete</button>
                </div>
              </td>
            </tr>
          ))}
          {(jobs ?? []).length === 0 && (
            <tr><td colspan="7" style="text-align:center;color:var(--text-dim);padding:3rem;">No job postings yet. <a href="/admin/jobs/new">Create one →</a></td></tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

</AdminLayout>

<script>
  async function togglePublished(el: HTMLElement) {
    const id        = el.dataset.jobId!;
    const published = el.dataset.published === 'true';
    const next      = !published;
    const res = await fetch(`/api/admin/jobs/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ published: next }),
    });
    if (res.ok) {
      el.dataset.published = String(next);
      el.textContent = next ? 'Published' : 'Draft';
      el.className   = `badge ${next ? 'badge-won' : 'badge-lost'}`;
      el.style.cursor = 'pointer';
    }
  }

  async function deleteJob(id: string) {
    if (!confirm('Delete this job posting? All applications will also be deleted.')) return;
    const res = await fetch(`/api/admin/jobs/${id}`, { method: 'DELETE' });
    if (res.ok) location.reload();
    else alert('Delete failed');
  }

  Object.assign(window, { togglePublished, deleteJob });
</script>
