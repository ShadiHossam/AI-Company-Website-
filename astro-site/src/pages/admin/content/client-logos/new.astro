---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);
---

<AdminLayout title="Add Client Logo" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/client-logos" class="text-muted text-sm" style="text-decoration:none;">← Client Logos</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">Add Client Logo</h1>
    </div>
  </div>

  <div class="card" style="max-width:600px;">
    <div id="form-error" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

    <form id="new-logo-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label" for="company_name">Company Name *</label>
          <input class="form-input" id="company_name" name="company_name" type="text" required placeholder="Emaar Properties" />
        </div>
        <div class="form-group">
          <label class="form-label" for="industry">Industry</label>
          <select class="form-select" id="industry" name="industry">
            <option value="">Select industry...</option>
            <option value="Real Estate">Real Estate</option>
            <option value="Retail">Retail</option>
            <option value="Hospitality">Hospitality</option>
            <option value="Logistics">Logistics</option>
            <option value="Healthcare">Healthcare</option>
            <option value="Finance">Finance</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label" for="logo_url">Logo URL *</label>
        <input class="form-input" id="logo_url" name="logo_url" type="url" required placeholder="https://..." />
        <div id="logo-preview" style="margin-top:0.5rem;display:none;">
          <img id="logo-img" src="" alt="Preview" style="height:48px;object-fit:contain;border-radius:6px;background:var(--bg-hover);padding:6px;" />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label" for="website_url">Website URL</label>
        <input class="form-input" id="website_url" name="website_url" type="url" placeholder="https://emaar.com" />
      </div>

      <div class="grid-2 gap-4 mb-6">
        <div class="form-group">
          <label class="form-label" for="sort_order">Sort Order</label>
          <input class="form-input" id="sort_order" name="sort_order" type="number" value="0" min="0" />
        </div>
        <div class="form-group" style="display:flex;align-items:flex-end;gap:1rem;padding-bottom:0.25rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" id="show_on_homepage" name="show_on_homepage" style="width:16px;height:16px;accent-color:var(--accent);" />
            <span class="text-sm">Show on Homepage</span>
          </label>
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" id="active" name="active" checked style="width:16px;height:16px;accent-color:var(--accent);" />
            <span class="text-sm">Active</span>
          </label>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="submit-btn">Add Logo</button>
        <a href="/admin/content/client-logos" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  // Live logo preview
  const logoInput = document.getElementById('logo_url') as HTMLInputElement;
  const logoPreview = document.getElementById('logo-preview') as HTMLElement;
  const logoImg = document.getElementById('logo-img') as HTMLImageElement;

  logoInput.addEventListener('blur', () => {
    if (logoInput.value) {
      logoImg.src = logoInput.value;
      logoPreview.style.display = 'block';
    }
  });

  document.getElementById('new-logo-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorEl = document.getElementById('form-error') as HTMLElement;
    submitBtn.textContent = 'Adding...';
    submitBtn.disabled = true;
    errorEl.style.display = 'none';

    const form = e.target as HTMLFormElement;
    const payload = {
      company_name: (form.querySelector('#company_name') as HTMLInputElement).value,
      logo_url: (form.querySelector('#logo_url') as HTMLInputElement).value,
      website_url: (form.querySelector('#website_url') as HTMLInputElement).value || null,
      industry: (form.querySelector('#industry') as HTMLSelectElement).value || null,
      sort_order: parseInt((form.querySelector('#sort_order') as HTMLInputElement).value) || 0,
      show_on_homepage: (form.querySelector('#show_on_homepage') as HTMLInputElement).checked,
      active: (form.querySelector('#active') as HTMLInputElement).checked,
    };

    const res = await fetch('/api/admin/content/client-logos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      const data = await res.json();
      window.location.href = `/admin/content/client-logos/${data.id}`;
    } else {
      const err = await res.json();
      errorEl.textContent = err.error ?? 'An error occurred';
      errorEl.style.display = 'block';
      submitBtn.textContent = 'Add Logo';
      submitBtn.disabled = false;
    }
  });
</script>
