---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const { id } = Astro.params;
const { data: logo, error } = await supabase.from('client_logos').select('*').eq('id', id!).single();

if (error || !logo) {
  return Astro.redirect('/admin/content/client-logos');
}
---

<AdminLayout title={`Edit: ${logo.company_name}`} user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/client-logos" class="text-muted text-sm" style="text-decoration:none;">← Client Logos</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">Edit Client Logo</h1>
    </div>
    {logo.logo_url && (
      <img src={logo.logo_url} alt={logo.company_name} style="height:40px;object-fit:contain;border-radius:6px;background:var(--bg-hover);padding:6px;" onerror="this.style.display='none'" />
    )}
  </div>

  <div id="save-banner" style="display:none;background:var(--success-dim);border:1px solid rgba(34,197,94,0.3);color:var(--success);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;">
    Saved successfully.
  </div>
  <div id="error-banner" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

  <div class="card" style="max-width:600px;">
    <form id="edit-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Company Name *</label>
          <input class="form-input" name="company_name" type="text" required value={logo.company_name} />
        </div>
        <div class="form-group">
          <label class="form-label">Industry</label>
          <select class="form-select" name="industry">
            <option value="">Select industry...</option>
            {['Real Estate','Retail','Hospitality','Logistics','Healthcare','Finance','Other'].map(ind => (
              <option value={ind} selected={logo.industry === ind}>{ind}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Logo URL *</label>
        <input class="form-input" name="logo_url" type="url" required value={logo.logo_url} />
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Website URL</label>
        <input class="form-input" name="website_url" type="url" value={logo.website_url ?? ''} placeholder="https://..." />
      </div>

      <div class="flex items-center gap-4 mb-6">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="show_on_homepage" checked={logo.show_on_homepage} style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Show on Homepage</span>
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="active" checked={logo.active} style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Active</span>
        </label>
        <div class="form-group" style="margin:0;flex:1;max-width:120px;">
          <label class="form-label text-xs">Sort Order</label>
          <input class="form-input" name="sort_order" type="number" value={logo.sort_order ?? 0} />
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
        <a href="/admin/content/client-logos" class="btn btn-ghost">Back</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const logoId = window.location.pathname.split('/').at(-1)!;

  document.getElementById('edit-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const saveBanner = document.getElementById('save-banner') as HTMLElement;
    const errorBanner = document.getElementById('error-banner') as HTMLElement;
    saveBtn.textContent = 'Saving...';
    saveBtn.disabled = true;
    saveBanner.style.display = 'none';
    errorBanner.style.display = 'none';

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);

    const payload = {
      company_name: fd.get('company_name') as string,
      logo_url: fd.get('logo_url') as string,
      website_url: (fd.get('website_url') as string) || null,
      industry: (fd.get('industry') as string) || null,
      show_on_homepage: (form.querySelector('[name="show_on_homepage"]') as HTMLInputElement).checked,
      active: (form.querySelector('[name="active"]') as HTMLInputElement).checked,
      sort_order: parseInt(fd.get('sort_order') as string ?? '0', 10),
    };

    const res = await fetch(`/api/admin/content/client-logos/${logoId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      saveBanner.style.display = 'block';
      setTimeout(() => { saveBanner.style.display = 'none'; }, 3000);
    } else {
      const err = await res.json();
      errorBanner.textContent = err.error ?? 'Save failed';
      errorBanner.style.display = 'block';
    }
    saveBtn.textContent = 'Save Changes';
    saveBtn.disabled = false;
  });
</script>
