---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';
import { PAGE_CONFIGS, loadPageContent } from '../../../../lib/page-content';

const user = Astro.locals.user!;
const { slug } = Astro.params;

const pageConfig = PAGE_CONFIGS.find(p => p.slug === slug);
if (!pageConfig) return Astro.redirect('/admin/content/pages');

const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const dbValues = await loadPageContent(slug!);

const saved = Astro.url.searchParams.get('saved') === '1';
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title={`Edit: ${pageConfig.title}`} user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/pages" class="text-muted text-sm" style="text-decoration:none;">← Pages & Text</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">{pageConfig.title} Page</h1>
    </div>
    <div class="flex items-center gap-2">
      <a href={pageConfig.path} target="_blank" rel="noopener" class="btn btn-ghost btn-sm">Preview ↗</a>
    </div>
  </div>

  {saved && (
    <div style="background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3);border-radius:var(--radius-sm);padding:0.75rem 1rem;margin-bottom:1.5rem;color:#16a34a;font-size:0.875rem;font-weight:500;">
      Changes saved successfully.
    </div>
  )}
  {error && (
    <div style="background:rgba(239,68,68,0.10);border:1px solid rgba(239,68,68,0.25);border-radius:var(--radius-sm);padding:0.75rem 1rem;margin-bottom:1.5rem;color:#dc2626;font-size:0.875rem;font-weight:500;">
      Error saving: {error}
    </div>
  )}

  <form id="page-form">
    {pageConfig.sections.map(section => (
      <div class="card" style="margin-bottom:1.5rem;">
        <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--accent);margin-bottom:1.25rem;">{section.heading}</div>
        <div style="display:flex;flex-direction:column;gap:1.25rem;">
          {section.fields.map(field => (
            <div>
              <label style="display:block;font-size:0.8125rem;font-weight:500;color:var(--text-secondary);margin-bottom:0.375rem;">{field.label}</label>
              {field.type === 'textarea' ? (
                <textarea
                  name={field.key}
                  rows={3}
                  style="width:100%;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.625rem 0.75rem;color:var(--text-primary);font-size:0.9375rem;resize:vertical;font-family:inherit;line-height:1.6;"
                >{dbValues[field.key] ?? field.default}</textarea>
              ) : (
                <input
                  type="text"
                  name={field.key}
                  value={dbValues[field.key] ?? field.default}
                  style="width:100%;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.625rem 0.75rem;color:var(--text-primary);font-size:0.9375rem;"
                />
              )}
              <div style="font-size:0.75rem;color:var(--text-muted);margin-top:0.25rem;">Default: {field.default}</div>
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="flex items-center gap-3">
      <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
      <a href="/admin/content/pages" class="btn btn-ghost">Cancel</a>
      <span id="save-status" style="font-size:0.875rem;color:var(--text-muted);"></span>
    </div>
  </form>
</AdminLayout>

<script define:vars={{ slug }}>
  const form = document.getElementById('page-form');
  const saveBtn = document.getElementById('save-btn');
  const saveStatus = document.getElementById('save-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';
    saveStatus.textContent = '';

    const formData = new FormData(form);
    const fields = {};
    for (const [key, value] of formData.entries()) {
      fields[key] = value;
    }

    try {
      const res = await fetch(`/api/admin/content/pages/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ fields }),
      });
      if (!res.ok) {
        const body = await res.json();
        saveStatus.textContent = 'Error: ' + (body.error ?? 'Unknown error');
        saveStatus.style.color = '#dc2626';
      } else {
        saveStatus.textContent = 'Saved!';
        saveStatus.style.color = '#16a34a';
        setTimeout(() => { saveStatus.textContent = ''; }, 3000);
      }
    } catch (err) {
      saveStatus.textContent = 'Network error';
      saveStatus.style.color = '#dc2626';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });
</script>
