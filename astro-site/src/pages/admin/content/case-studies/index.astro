---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const { data: caseStudies } = await supabase
  .from('case_studies')
  .select('id, title, industry, delivery_time, featured, published, slug, sort_order')
  .is('deleted_at', null)
  .order('sort_order', { ascending: true });
---

<AdminLayout title="Case Studies" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content" class="text-muted text-sm" style="text-decoration:none;">← Content</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">Case Studies</h1>
    </div>
    <a href="/admin/content/case-studies/new" class="btn btn-primary btn-sm">+ New Case Study</a>
  </div>

  {(!caseStudies || caseStudies.length === 0) ? (
    <div class="card" style="text-align:center;padding:3rem;">
      <p class="text-muted">No case studies yet. Create your first one.</p>
      <a href="/admin/content/case-studies/new" class="btn btn-primary btn-sm" style="margin-top:1rem;">+ New Case Study</a>
    </div>
  ) : (
    <div class="card" style="padding:0;overflow:hidden;">
      <div class="table-wrap">
        <table style="width:100%;border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:1px solid var(--border);">
              <th style="padding:0.75rem 1rem;text-align:left;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Title</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Industry</th>
              <th style="padding:0.75rem 1rem;text-align:left;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Delivery</th>
              <th style="padding:0.75rem 1rem;text-align:center;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Featured</th>
              <th style="padding:0.75rem 1rem;text-align:center;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Published</th>
              <th style="padding:0.75rem 1rem;text-align:right;font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {caseStudies.map(cs => (
              <tr class="cs-row" data-id={cs.id} style="border-bottom:1px solid var(--border);transition:background 0.15s;">
                <td style="padding:0.875rem 1rem;">
                  <a href={`/admin/content/case-studies/${cs.id}`} style="font-weight:600;color:var(--text-primary);text-decoration:none;hover:color:var(--accent);">{cs.title}</a>
                  <div class="text-xs text-muted" style="margin-top:2px;">{cs.slug}</div>
                </td>
                <td style="padding:0.875rem 1rem;color:var(--text-muted);">{cs.industry ?? '—'}</td>
                <td style="padding:0.875rem 1rem;color:var(--text-muted);">{cs.delivery_time ?? '—'}</td>
                <td style="padding:0.875rem 1rem;text-align:center;">
                  {cs.featured
                    ? <span class="badge" style="background:var(--accent-dim);color:var(--accent);border:1px solid var(--border-accent);">Yes</span>
                    : <span class="badge" style="background:var(--bg-hover);color:var(--text-dim);">No</span>
                  }
                </td>
                <td style="padding:0.875rem 1rem;text-align:center;">
                  <button
                    class="publish-toggle badge"
                    data-id={cs.id}
                    data-published={cs.published ? 'true' : 'false'}
                    style={cs.published
                      ? 'background:var(--success-dim);color:var(--success);border:1px solid rgba(34,197,94,0.25);cursor:pointer;'
                      : 'background:var(--bg-hover);color:var(--text-dim);border:1px solid var(--border);cursor:pointer;'}
                  >
                    {cs.published ? 'Published' : 'Draft'}
                  </button>
                </td>
                <td style="padding:0.875rem 1rem;text-align:right;">
                  <div class="flex items-center gap-2" style="justify-content:flex-end;">
                    <a href={`/admin/content/case-studies/${cs.id}`} class="btn btn-ghost btn-sm">Edit</a>
                    <button class="btn btn-sm delete-cs" data-id={cs.id} data-title={cs.title} style="color:var(--danger);border-color:var(--danger-dim);background:var(--danger-dim);">Delete</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</AdminLayout>

<script>
  // Publish toggle
  document.querySelectorAll('.publish-toggle').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      const current = el.dataset.published === 'true';
      const next = !current;
      el.textContent = 'Saving...';
      const res = await fetch(`/api/admin/content/case-studies/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ published: next }),
      });
      if (res.ok) {
        el.dataset.published = next ? 'true' : 'false';
        el.textContent = next ? 'Published' : 'Draft';
        if (next) {
          el.style.background = 'var(--success-dim)';
          el.style.color = 'var(--success)';
          el.style.border = '1px solid rgba(34,197,94,0.25)';
        } else {
          el.style.background = 'var(--bg-hover)';
          el.style.color = 'var(--text-dim)';
          el.style.border = '1px solid var(--border)';
        }
      } else {
        el.textContent = 'Error';
      }
    });
  });

  // Delete
  document.querySelectorAll('.delete-cs').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLButtonElement;
      const id = el.dataset.id!;
      const title = el.dataset.title ?? 'this case study';
      if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;
      const res = await fetch(`/api/admin/content/case-studies/${id}`, { method: 'DELETE' });
      if (res.ok) {
        const row = el.closest('tr');
        row?.remove();
      } else {
        alert('Delete failed. Please try again.');
      }
    });
  });

  // Row hover
  document.querySelectorAll('.cs-row').forEach(row => {
    row.addEventListener('mouseenter', () => (row as HTMLElement).style.background = 'var(--bg-hover)');
    row.addEventListener('mouseleave', () => (row as HTMLElement).style.background = '');
  });
</script>
