---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);
---

<AdminLayout title="New Case Study" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/case-studies" class="text-muted text-sm" style="text-decoration:none;">← Case Studies</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">New Case Study</h1>
    </div>
  </div>

  <div class="card" style="max-width:720px;">
    <div id="form-error" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

    <form id="new-cs-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label" for="title">Title *</label>
          <input class="form-input" id="title" name="title" type="text" required placeholder="AI-Powered Property Matching" />
        </div>
        <div class="form-group">
          <label class="form-label" for="slug">Slug *</label>
          <input class="form-input" id="slug" name="slug" type="text" required placeholder="ai-property-matching" />
        </div>
      </div>

      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label" for="industry">Industry</label>
          <select class="form-select" id="industry" name="industry">
            <option value="">Select industry...</option>
            <option value="Real Estate">Real Estate</option>
            <option value="Retail">Retail</option>
            <option value="Hospitality">Hospitality</option>
            <option value="Logistics">Logistics</option>
            <option value="Healthcare">Healthcare</option>
            <option value="Finance">Finance</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="delivery_time">Delivery Time</label>
          <input class="form-input" id="delivery_time" name="delivery_time" type="text" placeholder="6 weeks" />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label" for="challenge">Challenge</label>
        <textarea class="form-textarea" id="challenge" name="challenge" rows="4" placeholder="Describe the client's challenge..."></textarea>
      </div>

      <div class="form-group mb-4">
        <label class="form-label" for="solution">Solution</label>
        <textarea class="form-textarea" id="solution" name="solution" rows="4" placeholder="Describe the solution delivered..."></textarea>
      </div>

      <div style="border-top:1px dashed var(--border);margin:1rem 0 1rem;padding-top:1rem;">
        <div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Arabic Translation (optional)</div>
        <div class="grid-2 gap-4 mb-4">
          <div class="form-group">
            <label class="form-label" for="ar_title">العنوان بالعربية</label>
            <input class="form-input" id="ar_title" name="ar_title" type="text" dir="rtl" style="text-align:right;" placeholder="العنوان بالعربية" />
          </div>
          <div class="form-group">
            <label class="form-label" for="ar_industry">الصناعة بالعربية</label>
            <input class="form-input" id="ar_industry" name="ar_industry" type="text" dir="rtl" style="text-align:right;" placeholder="الصناعة بالعربية" />
          </div>
        </div>
        <div class="form-group mb-4">
          <label class="form-label" for="ar_delivery_time">مدة التنفيذ بالعربية</label>
          <input class="form-input" id="ar_delivery_time" name="ar_delivery_time" type="text" dir="rtl" style="text-align:right;" placeholder="6 أسابيع" />
        </div>
        <div class="form-group mb-4">
          <label class="form-label" for="ar_challenge">التحدي بالعربية</label>
          <textarea class="form-textarea" id="ar_challenge" name="ar_challenge" rows="4" dir="rtl" style="text-align:right;" placeholder="التحدي بالعربية"></textarea>
        </div>
        <div class="form-group">
          <label class="form-label" for="ar_solution">الحل بالعربية</label>
          <textarea class="form-textarea" id="ar_solution" name="ar_solution" rows="4" dir="rtl" style="text-align:right;" placeholder="الحل بالعربية"></textarea>
        </div>
      </div>

      <!-- Media Sections -->
      <div class="form-group mb-4">
        <div class="flex items-center justify-between mb-2">
          <label class="form-label" style="margin:0;">Media &amp; Content Sections</label>
          <button type="button" id="add-media" class="btn btn-ghost btn-sm">+ Add Section</button>
        </div>
        <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:0.75rem;">Add images, videos, or text blocks that appear in the body of the case study.</p>
        <div id="media-list"></div>
      </div>

      <div class="flex items-center gap-4 mb-6">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" id="featured" name="featured" style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Featured</span>
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" id="published" name="published" style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Published</span>
        </label>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="submit-btn">Create Case Study</button>
        <a href="/admin/content/case-studies" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  // Auto-generate slug from title
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;
  let slugManuallyEdited = false;

  slugInput.addEventListener('input', () => { slugManuallyEdited = true; });

  titleInput.addEventListener('input', () => {
    if (!slugManuallyEdited) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-');
    }
  });

  // Media sections
  document.getElementById('add-media')!.addEventListener('click', () => {
    const list = document.getElementById('media-list')!;
    const idx = list.querySelectorAll('.media-row').length;
    const div = document.createElement('div');
    div.className = 'media-row card mb-3';
    div.style.cssText = 'background:var(--bg-elevated);border:1px solid var(--border);padding:1rem;';
    div.innerHTML = `
      <div class="flex items-center justify-between mb-3">
        <select class="form-select" style="width:140px;" name="media_type_${idx}" data-media-type>
          <option value="image">Image</option>
          <option value="video">Video</option>
          <option value="text">Text only</option>
        </select>
        <button type="button" class="btn btn-sm remove-media" style="color:var(--danger);background:var(--danger-dim);border-color:var(--danger-dim);">✕ Remove</button>
      </div>
      <div class="media-url-row mb-3">
        <label class="form-label text-xs">URL (image src or video embed URL)</label>
        <input class="form-input" name="media_url_${idx}" placeholder="https://..." data-media-url />
      </div>
      <div class="form-group mb-2">
        <label class="form-label text-xs">Caption / Short label</label>
        <input class="form-input" name="media_caption_${idx}" placeholder="Optional short label" data-media-caption />
      </div>
      <div class="form-group">
        <label class="form-label text-xs">Description / Body text</label>
        <textarea class="form-textarea" name="media_desc_${idx}" rows="3" placeholder="Detailed description for this section..." data-media-desc></textarea>
      </div>
    `;
    list.appendChild(div);
    div.querySelector('.remove-media')!.addEventListener('click', () => div.remove());
    (div.querySelector('[data-media-type]') as HTMLSelectElement).addEventListener('change', (ev) => {
      const sel = ev.target as HTMLSelectElement;
      const urlRow = div.querySelector('.media-url-row') as HTMLElement;
      urlRow.style.display = sel.value === 'text' ? 'none' : '';
    });
  });

  document.getElementById('new-cs-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errorEl = document.getElementById('form-error') as HTMLElement;
    submitBtn.textContent = 'Creating...';
    submitBtn.disabled = true;
    errorEl.style.display = 'none';

    const form = e.target as HTMLFormElement;

    const mediaRows = Array.from(document.querySelectorAll('.media-row'));
    const media_sections = mediaRows.map(row => ({
      type: (row.querySelector('[data-media-type]') as HTMLSelectElement).value,
      url: (row.querySelector('[data-media-url]') as HTMLInputElement)?.value ?? '',
      caption: (row.querySelector('[data-media-caption]') as HTMLInputElement)?.value ?? '',
      description: (row.querySelector('[data-media-desc]') as HTMLTextAreaElement)?.value ?? '',
    })).filter(m => m.url || m.description || m.caption);

    const payload = {
      title: (form.querySelector('#title') as HTMLInputElement).value,
      slug: (form.querySelector('#slug') as HTMLInputElement).value,
      industry: (form.querySelector('#industry') as HTMLSelectElement).value || null,
      delivery_time: (form.querySelector('#delivery_time') as HTMLInputElement).value || null,
      challenge: (form.querySelector('#challenge') as HTMLTextAreaElement).value || null,
      solution: (form.querySelector('#solution') as HTMLTextAreaElement).value || null,
      featured: (form.querySelector('#featured') as HTMLInputElement).checked,
      published: (form.querySelector('#published') as HTMLInputElement).checked,
      media_sections,
      ar_title: (form.querySelector('#ar_title') as HTMLInputElement).value || null,
      ar_industry: (form.querySelector('#ar_industry') as HTMLInputElement).value || null,
      ar_delivery_time: (form.querySelector('#ar_delivery_time') as HTMLInputElement).value || null,
      ar_challenge: (form.querySelector('#ar_challenge') as HTMLTextAreaElement).value || null,
      ar_solution: (form.querySelector('#ar_solution') as HTMLTextAreaElement).value || null,
    };

    const res = await fetch('/api/admin/content/case-studies', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      const data = await res.json();
      window.location.href = `/admin/content/case-studies/${data.id}`;
    } else {
      const err = await res.json();
      errorEl.textContent = err.error ?? 'An error occurred';
      errorEl.style.display = 'block';
      submitBtn.textContent = 'Create Case Study';
      submitBtn.disabled = false;
    }
  });
</script>
