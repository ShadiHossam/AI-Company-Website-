---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const { id } = Astro.params;
const { data: t, error } = await supabase.from('testimonials').select('*').eq('id', id!).single();

if (error || !t) {
  return Astro.redirect('/admin/content/testimonials');
}
---

<AdminLayout title={`Edit: ${t.client_name}`} user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/testimonials" class="text-muted text-sm" style="text-decoration:none;">← Testimonials</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">Edit Testimonial</h1>
    </div>
  </div>

  <div id="save-banner" style="display:none;background:var(--success-dim);border:1px solid rgba(34,197,94,0.3);color:var(--success);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;">
    Saved successfully.
  </div>
  <div id="error-banner" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

  <div class="card" style="max-width:720px;">
    <form id="edit-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Client Name *</label>
          <input class="form-input" name="client_name" type="text" required value={t.client_name} />
        </div>
        <div class="form-group">
          <label class="form-label">Job Title</label>
          <input class="form-input" name="client_title" type="text" value={t.client_title ?? ''} placeholder="CEO" />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Job Title (Arabic)</label>
        <input class="form-input" name="ar_client_title" type="text" dir="rtl" style="text-align:right;" value={t.ar_client_title ?? ''} placeholder="المسمى الوظيفي بالعربية" />
      </div>

      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Company</label>
          <input class="form-input" name="client_company" type="text" value={t.client_company ?? ''} />
        </div>
        <div class="form-group">
          <label class="form-label">Industry</label>
          <select class="form-select" name="industry">
            <option value="">Select industry...</option>
            {['Real Estate','Retail','Hospitality','Logistics','Healthcare','Finance','Other'].map(ind => (
              <option value={ind} selected={t.industry === ind}>{ind}</option>
            ))}
          </select>
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Client Photo URL</label>
        <input class="form-input" name="client_image_url" type="url" value={t.client_image_url ?? ''} placeholder="https://..." />
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Quote *</label>
        <textarea class="form-textarea" name="quote" rows="5" required>{t.quote}</textarea>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Quote (Arabic)</label>
        <textarea class="form-textarea" name="ar_quote" rows="5" dir="rtl" style="text-align:right;" placeholder="الاقتباس بالعربية">{t.ar_quote ?? ''}</textarea>
      </div>

      <div class="flex items-center gap-4 mb-6">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="featured" checked={t.featured} style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Featured</span>
        </label>
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="published" checked={t.published} style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Published</span>
        </label>
        <div class="form-group" style="margin:0;flex:1;max-width:120px;">
          <label class="form-label text-xs">Sort Order</label>
          <input class="form-input" name="sort_order" type="number" value={t.sort_order ?? 0} />
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
        <a href="/admin/content/testimonials" class="btn btn-ghost">Back</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const tId = window.location.pathname.split('/').at(-1)!;

  document.getElementById('edit-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const saveBanner = document.getElementById('save-banner') as HTMLElement;
    const errorBanner = document.getElementById('error-banner') as HTMLElement;
    saveBtn.textContent = 'Saving...';
    saveBtn.disabled = true;
    saveBanner.style.display = 'none';
    errorBanner.style.display = 'none';

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);

    const payload = {
      client_name: fd.get('client_name') as string,
      client_title: (fd.get('client_title') as string) || null,
      client_company: (fd.get('client_company') as string) || null,
      client_image_url: (fd.get('client_image_url') as string) || null,
      industry: (fd.get('industry') as string) || null,
      quote: fd.get('quote') as string,
      ar_quote: (fd.get('ar_quote') as string) || null,
      ar_client_title: (fd.get('ar_client_title') as string) || null,
      featured: (form.querySelector('[name="featured"]') as HTMLInputElement).checked,
      published: (form.querySelector('[name="published"]') as HTMLInputElement).checked,
      sort_order: parseInt(fd.get('sort_order') as string ?? '0', 10),
    };

    const res = await fetch(`/api/admin/content/testimonials/${tId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      saveBanner.style.display = 'block';
      setTimeout(() => { saveBanner.style.display = 'none'; }, 3000);
    } else {
      const err = await res.json();
      errorBanner.textContent = err.error ?? 'Save failed';
      errorBanner.style.display = 'block';
    }
    saveBtn.textContent = 'Save Changes';
    saveBtn.disabled = false;
  });
</script>
