---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const { id } = Astro.params;
const isNew = id === 'new';
let member: Record<string, unknown> | null = null;

if (!isNew) {
  const { data } = await supabase.from('team_members').select('*').eq('id', id!).single();
  if (!data) return Astro.redirect('/admin/content/team');
  member = data;
}

const pageTitle = isNew ? 'Add Team Member' : `Edit: ${member?.name}`;
---

<AdminLayout title={pageTitle} user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/team" class="text-muted text-sm" style="text-decoration:none;">← Team Members</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">{pageTitle}</h1>
    </div>
  </div>

  <div id="save-banner" style="display:none;background:var(--success-dim);border:1px solid rgba(34,197,94,0.3);color:var(--success);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;">
    {isNew ? 'Member created.' : 'Saved successfully.'}
  </div>
  <div id="error-banner" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

  <div class="card" style="max-width:640px;">
    <form id="member-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Name *</label>
          <input class="form-input" name="name" type="text" required value={member?.name as string ?? ''} placeholder="Jane Doe" />
        </div>
        <div class="form-group">
          <label class="form-label">Title *</label>
          <input class="form-input" name="title" type="text" required value={member?.title as string ?? ''} placeholder="Head of AI Strategy" />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Bio</label>
        <textarea class="form-textarea" name="bio" rows="5" placeholder="Brief professional bio...">{member?.bio as string ?? ''}</textarea>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Image URL</label>
        <input class="form-input" name="image_url" type="text" value={member?.image_url as string ?? ''} placeholder="https://..." />
      </div>

      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Sort Order</label>
          <input class="form-input" name="sort_order" type="number" value={member?.sort_order as number ?? 0} />
        </div>
        <div class="form-group" style="display:flex;align-items:flex-end;padding-bottom:0.25rem;">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" name="active" checked={isNew ? true : (member?.active as boolean)} style="width:16px;height:16px;accent-color:var(--accent);" />
            <span class="text-sm">Active</span>
          </label>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="save-btn">{isNew ? 'Create Member' : 'Save Changes'}</button>
        <a href="/admin/content/team" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const isNew = window.location.pathname.endsWith('/new');
  const memberId = isNew ? null : window.location.pathname.split('/').at(-1)!;

  document.getElementById('member-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const saveBanner = document.getElementById('save-banner') as HTMLElement;
    const errorBanner = document.getElementById('error-banner') as HTMLElement;
    saveBtn.textContent = 'Saving...';
    saveBtn.disabled = true;
    saveBanner.style.display = 'none';
    errorBanner.style.display = 'none';

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const payload = {
      name: fd.get('name') as string,
      title: fd.get('title') as string,
      bio: fd.get('bio') as string || null,
      image_url: fd.get('image_url') as string || null,
      sort_order: parseInt(fd.get('sort_order') as string ?? '0', 10),
      active: (form.querySelector('[name="active"]') as HTMLInputElement).checked,
    };

    const url = isNew ? '/api/admin/content/team' : `/api/admin/content/team/${memberId}`;
    const method = isNew ? 'POST' : 'PATCH';

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      if (isNew) {
        const data = await res.json();
        window.location.href = `/admin/content/team/${data.id}`;
      } else {
        saveBanner.style.display = 'block';
        setTimeout(() => { saveBanner.style.display = 'none'; }, 3000);
        saveBtn.textContent = 'Save Changes';
        saveBtn.disabled = false;
      }
    } else {
      const err = await res.json();
      errorBanner.textContent = err.error ?? 'Save failed';
      errorBanner.style.display = 'block';
      saveBtn.textContent = isNew ? 'Create Member' : 'Save Changes';
      saveBtn.disabled = false;
    }
  });
</script>
