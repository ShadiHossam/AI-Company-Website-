---
export const prerender = false;
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();
const { count: unreadNotifs } = await supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false);

const { id } = Astro.params;
const isNew = id === 'new';
let product: Record<string, unknown> | null = null;

if (!isNew) {
  const { data } = await supabase.from('products').select('*').eq('id', id!).single();
  if (!data) return Astro.redirect('/admin/content/products');
  product = data;
}

const featureTagsValue = isNew ? '' : ((product?.feature_tags as string[]) ?? []).join(', ');
const featuresValue = isNew ? '' : ((product?.features as string[]) ?? []).join('\n');
const arFeatureTagsValue = isNew ? '' : ((product?.ar_feature_tags as string[]) ?? []).join(', ');
const arFeaturesValue = isNew ? '' : ((product?.ar_features as string[]) ?? []).join('\n');
const pageTitle = isNew ? 'New Product' : `Edit: ${product?.name}`;
---

<AdminLayout title={pageTitle} user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <a href="/admin/content/products" class="text-muted text-sm" style="text-decoration:none;">← Products</a>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--text-primary);margin-top:0.25rem;">{pageTitle}</h1>
    </div>
  </div>

  <div id="save-banner" style="display:none;background:var(--success-dim);border:1px solid rgba(34,197,94,0.3);color:var(--success);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;">
    Saved successfully.
  </div>
  <div id="error-banner" style="display:none;background:var(--danger-dim);border:1px solid var(--danger);color:var(--danger);padding:0.75rem 1rem;border-radius:var(--radius-sm);margin-bottom:1rem;"></div>

  <div class="card" style="max-width:720px;">
    <form id="product-form">
      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Name *</label>
          <input class="form-input" name="name" type="text" required value={product?.name as string ?? ''} placeholder="AegisIQ" />
        </div>
        <div class="form-group">
          <label class="form-label">Slug *</label>
          <input class="form-input" name="slug" type="text" required value={product?.slug as string ?? ''} placeholder="aegisiq" />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Tagline</label>
        <input class="form-input" name="tagline" type="text" value={product?.tagline as string ?? ''} placeholder="AI that thinks ahead" />
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Description</label>
        <textarea class="form-textarea" name="description" rows="5" placeholder="Full product description...">{product?.description as string ?? ''}</textarea>
      </div>

      <div class="grid-2 gap-4 mb-4">
        <div class="form-group">
          <label class="form-label">Status Badge</label>
          <input class="form-input" name="status_badge" type="text" value={product?.status_badge as string ?? ''} placeholder="Available Now" />
        </div>
        <div class="form-group">
          <label class="form-label">Sort Order</label>
          <input class="form-input" name="sort_order" type="number" value={product?.sort_order as number ?? 0} />
        </div>
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Feature Tags <span class="text-dim text-xs">(comma-separated)</span></label>
        <input class="form-input" name="feature_tags" type="text" value={featureTagsValue} placeholder="Real-time, ML-Powered, API-first" />
      </div>

      <div class="form-group mb-4">
        <label class="form-label">Features <span class="text-dim text-xs">(one per line)</span></label>
        <textarea class="form-textarea" name="features" rows="6" placeholder="Automated lead scoring&#10;Real-time analytics&#10;CRM integration">{featuresValue}</textarea>
      </div>

      <div style="border-top:1px dashed var(--border);margin:1.5rem 0;padding-top:1rem;">
        <div style="font-size:0.75rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Arabic Translation (optional)</div>

        <div class="form-group mb-4">
          <label class="form-label">الاسم</label>
          <input class="form-input" name="ar_name" type="text" dir="rtl" style="text-align:right;" value={product?.ar_name as string ?? ''} placeholder="اسم المنتج" />
        </div>

        <div class="form-group mb-4">
          <label class="form-label">الشعار</label>
          <input class="form-input" name="ar_tagline" type="text" dir="rtl" style="text-align:right;" value={product?.ar_tagline as string ?? ''} placeholder="وصف مختصر للمنتج" />
        </div>

        <div class="form-group mb-4">
          <label class="form-label">الوصف</label>
          <textarea class="form-textarea" name="ar_description" rows="5" dir="rtl" style="text-align:right;" placeholder="الوصف الكامل للمنتج...">{product?.ar_description as string ?? ''}</textarea>
        </div>

        <div class="form-group mb-4">
          <label class="form-label">وسوم الميزات <span class="text-dim text-xs">(comma-separated)</span></label>
          <input class="form-input" name="ar_feature_tags" type="text" dir="rtl" style="text-align:right;" value={arFeatureTagsValue} placeholder="فوري، مدعوم بالذكاء الاصطناعي" />
        </div>

        <div class="form-group mb-4">
          <label class="form-label">الميزات <span class="text-dim text-xs">(one per line)</span></label>
          <textarea class="form-textarea" name="ar_features" rows="6" dir="rtl" style="text-align:right;" placeholder="تسجيل نقاط العملاء المحتملين تلقائياً">{arFeaturesValue}</textarea>
        </div>
      </div>

      <div class="flex items-center gap-4 mb-6">
        <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
          <input type="checkbox" name="published" checked={isNew ? false : (product?.published as boolean)} style="width:16px;height:16px;accent-color:var(--accent);" />
          <span class="text-sm">Published</span>
        </label>
      </div>

      <div class="flex items-center gap-3">
        <button type="submit" class="btn btn-primary" id="save-btn">{isNew ? 'Create Product' : 'Save Changes'}</button>
        <a href="/admin/content/products" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const isNew = window.location.pathname.endsWith('/new');
  const productId = isNew ? null : window.location.pathname.split('/').at(-1)!;

  document.getElementById('product-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const saveBanner = document.getElementById('save-banner') as HTMLElement;
    const errorBanner = document.getElementById('error-banner') as HTMLElement;
    saveBtn.textContent = 'Saving...';
    saveBtn.disabled = true;
    saveBanner.style.display = 'none';
    errorBanner.style.display = 'none';

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);

    const featureTagsRaw = fd.get('feature_tags') as string;
    const featuresRaw = fd.get('features') as string;
    const arFeatureTagsRaw = fd.get('ar_feature_tags') as string;
    const arFeaturesRaw = fd.get('ar_features') as string;

    const payload = {
      name: fd.get('name') as string,
      slug: fd.get('slug') as string,
      tagline: fd.get('tagline') as string || null,
      description: fd.get('description') as string || null,
      status_badge: fd.get('status_badge') as string || null,
      feature_tags: featureTagsRaw ? featureTagsRaw.split(',').map(s => s.trim()).filter(Boolean) : [],
      features: featuresRaw ? featuresRaw.split('\n').map(s => s.trim()).filter(Boolean) : [],
      sort_order: parseInt(fd.get('sort_order') as string ?? '0', 10),
      published: (form.querySelector('[name="published"]') as HTMLInputElement).checked,
      ar_name: fd.get('ar_name') as string || null,
      ar_tagline: fd.get('ar_tagline') as string || null,
      ar_description: fd.get('ar_description') as string || null,
      ar_feature_tags: arFeatureTagsRaw ? arFeatureTagsRaw.split(',').map(s => s.trim()).filter(Boolean) : [],
      ar_features: arFeaturesRaw ? arFeaturesRaw.split('\n').map(s => s.trim()).filter(Boolean) : [],
    };

    const url = isNew ? '/api/admin/content/products' : `/api/admin/content/products/${productId}`;
    const method = isNew ? 'POST' : 'PATCH';

    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (res.ok) {
      if (isNew) {
        const data = await res.json();
        window.location.href = `/admin/content/products/${data.id}`;
      } else {
        saveBanner.style.display = 'block';
        setTimeout(() => { saveBanner.style.display = 'none'; }, 3000);
        saveBtn.textContent = 'Save Changes';
        saveBtn.disabled = false;
      }
    } else {
      const err = await res.json();
      errorBanner.textContent = err.error ?? 'Save failed';
      errorBanner.style.display = 'block';
      saveBtn.textContent = isNew ? 'Create Product' : 'Save Changes';
      saveBtn.disabled = false;
    }
  });
</script>
