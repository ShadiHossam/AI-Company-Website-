---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;

// Super admin only
if (user.role !== 'super_admin') {
  return Astro.redirect('/admin');
}

const supabase = getSupabaseAdmin();

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') ?? '1', 10);
const actionFilter = url.searchParams.get('action') ?? '';
const PAGE_SIZE = 20;
const from = (page - 1) * PAGE_SIZE;
const to = from + PAGE_SIZE - 1;

let query = supabase
  .from('activity_log')
  .select('*', { count: 'exact' })
  .order('created_at', { ascending: false })
  .range(from, to);

if (actionFilter) {
  query = query.eq('action', actionFilter);
}

const { data: logs, count } = await query;

// Get distinct action types for filter
const { data: actionTypes } = await supabase
  .from('activity_log')
  .select('action')
  .order('action');
const uniqueActions = [...new Set((actionTypes ?? []).map(r => r.action))];

const { count: unreadNotifs } = await supabase
  .from('notifications')
  .select('*', { count: 'exact', head: true })
  .eq('read', false);

const totalPages = Math.ceil((count ?? 0) / PAGE_SIZE);

function timeAgo(dateStr: string): string {
  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);
  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
  return `${Math.floor(diff / 86400)}d ago`;
}

function entityLink(type: string, id: string): string | null {
  if (!id) return null;
  if (type === 'lead') return `/admin/leads/${id}`;
  if (type === 'user') return `/admin/settings/users`;
  return null;
}
---

<AdminLayout title="Activity Log" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold">Activity Log</h1>
      <p class="text-muted text-sm">{count ?? 0} total entries</p>
    </div>
    <form method="GET" style="display:flex;align-items:center;gap:0.75rem;">
      <select name="action" class="form-select" style="width:auto;" onchange="this.form.submit()">
        <option value="">All Actions</option>
        {uniqueActions.map(a => (
          <option value={a} selected={a === actionFilter}>{a}</option>
        ))}
      </select>
      {actionFilter && (
        <a href="/admin/activity" class="btn btn-ghost btn-sm">Clear</a>
      )}
    </form>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Admin</th>
            <th>Action</th>
            <th>Entity Type</th>
            <th>Entity ID</th>
            <th>Before → After</th>
          </tr>
        </thead>
        <tbody>
          {!logs || logs.length === 0 ? (
            <tr>
              <td colspan="6" style="text-align:center;padding:3rem;" class="text-muted">No activity recorded yet</td>
            </tr>
          ) : (
            logs.map(log => {
              const link = entityLink(log.entity_type, log.entity_id);
              return (
                <tr>
                  <td>
                    <span class="text-sm">{timeAgo(log.created_at)}</span>
                    <div class="text-xs text-muted">{new Date(log.created_at).toLocaleDateString('en-AE', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' })}</div>
                  </td>
                  <td class="text-sm">{log.admin_email}</td>
                  <td>
                    <code style="background:var(--bg-input);padding:2px 8px;border-radius:4px;font-size:0.75rem;color:var(--accent);">{log.action}</code>
                  </td>
                  <td class="text-sm text-muted">{log.entity_type}</td>
                  <td>
                    {link ? (
                      <a href={link} class="text-sm" style="color:var(--accent);text-decoration:underline;" title="View entity">
                        {log.entity_id ? log.entity_id.slice(0, 8) + '…' : '—'}
                      </a>
                    ) : (
                      <span class="text-sm text-muted">{log.entity_id ? log.entity_id.slice(0, 8) + '…' : '—'}</span>
                    )}
                  </td>
                  <td>
                    {(log.before_value || log.after_value) ? (
                      <button
                        class="btn btn-ghost btn-sm diff-toggle"
                        data-before={JSON.stringify(log.before_value ?? {})}
                        data-after={JSON.stringify(log.after_value ?? {})}
                        style="font-size:0.75rem;"
                      >
                        View diff
                      </button>
                    ) : (
                      <span class="text-xs text-muted">—</span>
                    )}
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>

    {totalPages > 1 && (
      <div class="flex items-center justify-between" style="padding:1rem 1.25rem;border-top:1px solid var(--border);">
        <span class="text-sm text-muted">Page {page} of {totalPages}</span>
        <div style="display:flex;gap:0.5rem;">
          {page > 1 && (
            <a href={`?page=${page - 1}${actionFilter ? `&action=${actionFilter}` : ''}`} class="btn btn-ghost btn-sm">← Prev</a>
          )}
          {page < totalPages && (
            <a href={`?page=${page + 1}${actionFilter ? `&action=${actionFilter}` : ''}`} class="btn btn-ghost btn-sm">Next →</a>
          )}
        </div>
      </div>
    )}
  </div>
</AdminLayout>

<!-- Diff Modal -->
<div id="diff-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9000;align-items:center;justify-content:center;padding:1rem;">
  <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;max-width:700px;width:100%;max-height:80vh;overflow:auto;">
    <div class="flex items-center justify-between mb-4">
      <h3 style="font-size:1rem;font-weight:700;">Before → After</h3>
      <button id="close-diff" class="btn btn-ghost btn-sm">✕</button>
    </div>
    <div class="grid-2 gap-3">
      <div>
        <div class="text-xs text-muted mb-2" style="font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">Before</div>
        <pre id="diff-before" style="background:var(--bg-input);padding:1rem;border-radius:8px;font-size:0.75rem;overflow:auto;margin:0;max-height:300px;"></pre>
      </div>
      <div>
        <div class="text-xs text-muted mb-2" style="font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">After</div>
        <pre id="diff-after" style="background:var(--bg-input);padding:1rem;border-radius:8px;font-size:0.75rem;overflow:auto;margin:0;max-height:300px;color:#4ade80;"></pre>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('diff-modal') as HTMLElement;
  const beforeEl = document.getElementById('diff-before') as HTMLPreElement;
  const afterEl = document.getElementById('diff-after') as HTMLPreElement;

  document.querySelectorAll<HTMLButtonElement>('.diff-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const before = JSON.parse(btn.dataset.before ?? '{}');
      const after = JSON.parse(btn.dataset.after ?? '{}');
      beforeEl.textContent = JSON.stringify(before, null, 2);
      afterEl.textContent = JSON.stringify(after, null, 2);
      modal.style.display = 'flex';
    });
  });

  document.getElementById('close-diff')?.addEventListener('click', () => {
    modal.style.display = 'none';
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) modal.style.display = 'none';
  });
</script>
