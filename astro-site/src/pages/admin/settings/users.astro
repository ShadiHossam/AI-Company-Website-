---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const { count: unreadNotifs } = await supabase
  .from('notifications')
  .select('*', { count: 'exact', head: true })
  .eq('read', false);

// Fetch users via admin API
let users: any[] = [];
let usersError = '';

try {
  const { data, error } = await supabase.auth.admin.listUsers();
  if (error) throw error;
  users = data.users ?? [];
} catch (err: any) {
  usersError = err.message ?? 'Unable to load users';
}

const roles = ['super_admin', 'editor', 'sales'];

function formatDate(dateStr: string): string {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleDateString('en-AE', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<AdminLayout title="Users" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/settings" class="btn btn-ghost btn-sm">← Back</a>
    <div>
      <h1 class="text-xl font-bold">Users</h1>
      <p class="text-muted text-sm">Manage admin access and roles.</p>
    </div>
  </div>

  {usersError && (
    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:1rem 1.25rem;margin-bottom:1.5rem;">
      <p class="text-sm" style="color:#ef4444;margin:0;">Error loading users: {usersError}</p>
    </div>
  )}

  <!-- Invite User Form -->
  <div class="card mb-4">
    <div style="padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);">
      <h2 style="font-size:0.95rem;font-weight:700;">Invite New User</h2>
    </div>
    <div style="padding:1.5rem;">
      <form id="invite-form" style="display:grid;grid-template-columns:1fr auto auto;gap:0.75rem;align-items:end;max-width:580px;">
        <div class="form-group" style="margin:0;">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-input" placeholder="user@company.com" required />
        </div>
        <div class="form-group" style="margin:0;">
          <label class="form-label">Role</label>
          <select name="role" class="form-select">
            {roles.map(r => (
              <option value={r}>{r.replace('_', ' ')}</option>
            ))}
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="white-space:nowrap;">Send Invite</button>
      </form>
      <div id="invite-msg" style="display:none;margin-top:0.75rem;font-size:0.875rem;"></div>
    </div>
  </div>

  <!-- Users Table -->
  <div class="card">
    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Last Sign In</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="users-body">
          {users.length === 0 && !usersError ? (
            <tr>
              <td colspan="5" style="text-align:center;padding:3rem;" class="text-muted">No users found</td>
            </tr>
          ) : (
            users.map(u => {
              const role = u.user_metadata?.role ?? 'editor';
              const isSelf = u.email === user.email;
              return (
                <tr data-uid={u.id}>
                  <td>
                    <div class="text-sm">{u.email}</div>
                    {isSelf && <div class="text-xs text-muted">(you)</div>}
                  </td>
                  <td>
                    <select
                      class="role-select form-select"
                      data-uid={u.id}
                      disabled={isSelf}
                      style="width:auto;font-size:0.8rem;padding:4px 8px;"
                    >
                      {roles.map(r => (
                        <option value={r} selected={r === role}>{r.replace('_', ' ')}</option>
                      ))}
                    </select>
                  </td>
                  <td class="text-sm text-muted">{formatDate(u.last_sign_in_at)}</td>
                  <td class="text-sm text-muted">{formatDate(u.created_at)}</td>
                  <td>
                    {!isSelf && (
                      <button
                        class="btn btn-ghost btn-sm delete-user-btn"
                        data-uid={u.id}
                        data-email={u.email}
                        style="color:#f87171;"
                      >
                        Delete
                      </button>
                    )}
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>
  </div>

  <div id="toast" style="display:none;position:fixed;bottom:1.5rem;right:1.5rem;background:#1e2a40;border:1px solid var(--border);color:var(--text-primary);padding:0.75rem 1.25rem;border-radius:8px;font-size:0.875rem;z-index:9999;"></div>
</AdminLayout>

<script>
  function toast(msg: string, ok = true) {
    const t = document.getElementById('toast') as HTMLElement;
    t.textContent = msg;
    t.style.borderColor = ok ? 'rgba(74,222,128,0.3)' : 'rgba(248,113,113,0.3)';
    t.style.display = 'block';
    setTimeout(() => { t.style.display = 'none'; }, 3500);
  }

  // Role change
  document.querySelectorAll<HTMLSelectElement>('.role-select').forEach(select => {
    select.addEventListener('change', async () => {
      const uid = select.dataset.uid!;
      const newRole = select.value;
      try {
        const res = await fetch('/api/admin/users/role', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ uid, role: newRole }),
        });
        if (!res.ok) throw new Error('Failed');
        toast('Role updated');
      } catch {
        toast('Error updating role', false);
        // Revert
        window.location.reload();
      }
    });
  });

  // Delete user
  document.querySelectorAll<HTMLButtonElement>('.delete-user-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const uid = btn.dataset.uid!;
      const email = btn.dataset.email!;
      if (!confirm(`Delete user "${email}"? This cannot be undone.`)) return;
      try {
        const res = await fetch('/api/admin/users/delete', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ uid }),
        });
        if (!res.ok) throw new Error('Failed');
        btn.closest('tr')?.remove();
        toast('User deleted');
      } catch {
        toast('Error deleting user', false);
      }
    });
  });

  // Invite form
  const inviteForm = document.getElementById('invite-form') as HTMLFormElement;
  const inviteMsg = document.getElementById('invite-msg') as HTMLElement;

  inviteForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(inviteForm);
    const payload = {
      email: fd.get('email') as string,
      role: fd.get('role') as string,
    };

    const submitBtn = inviteForm.querySelector<HTMLButtonElement>('[type="submit"]')!;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/admin/users/invite', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Failed');
      inviteForm.reset();
      inviteMsg.textContent = `✓ Invitation sent to ${payload.email}`;
      inviteMsg.style.color = '#4ade80';
      inviteMsg.style.display = 'block';
      setTimeout(() => {
        inviteMsg.style.display = 'none';
        window.location.reload();
      }, 2000);
    } catch (err: any) {
      inviteMsg.textContent = `✗ ${err.message ?? 'Error sending invite'}`;
      inviteMsg.style.color = '#f87171';
      inviteMsg.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Invite';
    }
  });
</script>
