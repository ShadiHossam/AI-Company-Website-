---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const { count: unreadNotifs } = await supabase
  .from('notifications')
  .select('*', { count: 'exact', head: true })
  .eq('read', false);

const settingCards = [
  {
    href: '/admin/settings/company',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2M5 21H3"/><path d="M9 7h1m-1 4h1m4-4h1m-1 4h1M9 15h6"/></svg>`,
    title: 'Company Info',
    description: 'Name, phone, email, address, business hours, social links.',
  },
  {
    href: '/admin/settings/integrations',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>`,
    title: 'Integrations',
    description: 'Calendly, Mailchimp, Google Analytics, notification emails.',
  },
  {
    href: '/admin/settings/banner',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><rect x="3" y="3" width="18" height="6" rx="2"/><path d="M3 12h18M3 17h18"/></svg>`,
    title: 'Announcement Banner',
    description: 'Site-wide banner with custom message, CTA, colors, and schedule.',
  },
  {
    href: '/admin/settings/redirects',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>`,
    title: 'Redirects',
    description: 'Manage 301/302 URL redirects for SEO and page moves.',
  },
  {
    href: '/admin/settings/maintenance',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Maintenance Mode',
    description: 'Put the site into maintenance mode with allowed IP exceptions.',
  },
  {
    href: '/admin/settings/users',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:24px;height:24px;"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Users',
    description: 'Manage admin users, invite new users, and assign roles.',
  },
];
---

<AdminLayout title="Settings" user={user} unreadCount={unreadNotifs ?? 0}>
  <div class="mb-6">
    <h1 class="text-xl font-bold">Settings</h1>
    <p class="text-muted text-sm">Configure your site, integrations, and admin access.</p>
  </div>

  <div class="grid-3" style="gap:1rem;">
    {settingCards.map(card => (
      <a
        href={card.href}
        class="card settings-card"
        style="padding:1.5rem;display:flex;flex-direction:column;gap:1rem;text-decoration:none;transition:border-color 0.2s,transform 0.15s;border:1px solid var(--border);"
      >
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.1);display:flex;align-items:center;justify-content:center;color:var(--accent);flex-shrink:0;">
          <Fragment set:html={card.icon} />
        </div>
        <div>
          <div style="font-weight:700;font-size:0.95rem;margin-bottom:0.35rem;">{card.title}</div>
          <div class="text-sm text-muted">{card.description}</div>
        </div>
      </a>
    ))}
  </div>
</AdminLayout>

<style>
  .settings-card:hover {
    border-color: var(--accent) !important;
    transform: translateY(-2px);
  }
</style>
