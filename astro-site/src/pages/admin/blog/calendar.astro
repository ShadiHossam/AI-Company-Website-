---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const year  = parseInt(Astro.url.searchParams.get('year')  ?? String(new Date().getFullYear()), 10);
const month = parseInt(Astro.url.searchParams.get('month') ?? String(new Date().getMonth() + 1), 10);

const startDate = `${year}-${String(month).padStart(2, '0')}-01`;
const lastDay   = new Date(year, month, 0).getDate();
const endDate   = `${year}-${String(month).padStart(2, '0')}-${String(lastDay).padStart(2, '0')}`;

const [{ data: posts }, { count: unreadNotifs }] = await Promise.all([
  supabase
    .from('blog_posts')
    .select('id, title, slug, status, pub_date, category')
    .is('deleted_at', null)
    .or(`pub_date.gte.${startDate},and(status.eq.draft,created_at.gte.${startDate})`)
    .order('pub_date', { ascending: true }),
  supabase.from('notifications').select('*', { count: 'exact', head: true }).eq('read', false),
]);

// Group by pub_date (date string YYYY-MM-DD)
const byDate: Record<string, typeof posts> = {};
for (const post of posts ?? []) {
  const key = post.pub_date ?? post.created_at?.split('T')[0];
  if (!key || key < startDate || key > endDate) continue;
  if (!byDate[key]) byDate[key] = [];
  byDate[key]!.push(post);
}

// Build calendar grid (Sun-first)
const firstDow = new Date(year, month - 1, 1).getDay();
const daysInMonth = new Date(year, month, 0).getDate();
const calCells: (number | null)[] = Array(firstDow).fill(null);
for (let d = 1; d <= daysInMonth; d++) calCells.push(d);
while (calCells.length % 7 !== 0) calCells.push(null);

const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const today = new Date().toISOString().split('T')[0];

const prevQ = month === 1 ? `?year=${year - 1}&month=12` : `?year=${year}&month=${month - 1}`;
const nextQ = month === 12 ? `?year=${year + 1}&month=1` : `?year=${year}&month=${month + 1}`;

// Count this month's posts by status
const monthPosts = Object.values(byDate).flat();
const publishedCount  = monthPosts.filter(p => p?.status === 'published').length;
const scheduledCount  = monthPosts.filter(p => p?.status === 'scheduled').length;
const draftCount      = monthPosts.filter(p => p?.status === 'draft').length;

const statusColor: Record<string, string> = {
  published: '#4ade80',
  scheduled: '#60a5fa',
  draft: '#64748b',
  archived: '#fb923c',
};
const statusBg: Record<string, string> = {
  published: 'rgba(74,222,128,0.15)',
  scheduled: 'rgba(96,165,250,0.15)',
  draft: 'rgba(100,116,139,0.15)',
  archived: 'rgba(251,146,60,0.15)',
};
---

<AdminLayout title="Blog Calendar" user={user} unreadCount={unreadNotifs ?? 0}>

  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <div>
      <h1 style="font-size:1.375rem; font-weight:800; color:var(--text-primary);">Blog Calendar</h1>
      <p class="text-muted text-sm">Plan and track content by publish date</p>
    </div>
    <div class="flex gap-2 items-center">
      <a href={`/admin/blog/calendar${prevQ}`} class="btn btn-secondary btn-sm">← Prev</a>
      <span style="font-weight:700; min-width:160px; text-align:center; color:var(--text-primary);">
        {monthNames[month - 1]} {year}
      </span>
      <a href={`/admin/blog/calendar${nextQ}`} class="btn btn-secondary btn-sm">Next →</a>
    </div>
  </div>

  <!-- Summary row -->
  <div style="display:flex; gap:0.75rem; margin-bottom:1.25rem; flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.2);border-radius:100px;">
      <span style="width:8px;height:8px;border-radius:50%;background:#4ade80;flex-shrink:0;"></span>
      <span style="font-size:0.8125rem;color:#4ade80;font-weight:600;">{publishedCount} published</span>
    </div>
    {scheduledCount > 0 && (
      <div style="display:flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:rgba(96,165,250,0.1);border:1px solid rgba(96,165,250,0.2);border-radius:100px;">
        <span style="width:8px;height:8px;border-radius:50%;background:#60a5fa;flex-shrink:0;"></span>
        <span style="font-size:0.8125rem;color:#60a5fa;font-weight:600;">{scheduledCount} scheduled</span>
      </div>
    )}
    {draftCount > 0 && (
      <div style="display:flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:rgba(100,116,139,0.1);border:1px solid rgba(100,116,139,0.2);border-radius:100px;">
        <span style="width:8px;height:8px;border-radius:50%;background:#64748b;flex-shrink:0;"></span>
        <span style="font-size:0.8125rem;color:#94a3b8;font-weight:600;">{draftCount} drafts</span>
      </div>
    )}
    <a href="/admin/blog/new" class="btn btn-primary btn-sm" style="margin-left:auto;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      New Post
    </a>
  </div>

  <!-- Calendar grid -->
  <div class="card" style="padding:0; overflow:hidden;">
    <!-- Day headers -->
    <div style="display:grid; grid-template-columns:repeat(7,1fr); border-bottom:1px solid var(--border);">
      {['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => (
        <div style="padding:0.625rem; text-align:center; font-size:0.75rem; font-weight:700; color:var(--text-dim); text-transform:uppercase; letter-spacing:0.04em;">{d}</div>
      ))}
    </div>

    <!-- Cells -->
    <div style="display:grid; grid-template-columns:repeat(7,1fr);">
      {calCells.map((day, i) => {
        const dateStr = day
          ? `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}`
          : '';
        const dayPosts = day ? (byDate[dateStr] ?? []) : [];
        const isToday = dateStr === today;
        const shown = dayPosts.slice(0, 3);
        const overflow = dayPosts.length - 3;
        return (
          <div style={`
            min-height:108px; padding:0.5rem; position:relative;
            border-bottom:1px solid var(--border);
            border-right:${(i + 1) % 7 === 0 ? 'none' : '1px solid var(--border)'};
            background:${isToday ? 'var(--accent-dim,rgba(0,227,253,0.05))' : !day ? 'rgba(0,0,0,0.12)' : 'transparent'};
          `}>
            {day && (
              <>
                <div style={`
                  font-size:0.8125rem; margin-bottom:0.375rem;
                  font-weight:${isToday ? '800' : '500'};
                  color:${isToday ? 'var(--accent)' : 'var(--text-muted)'};
                `}>{day}</div>
                {shown.map(post => (
                  <a
                    href={`/admin/blog/${post!.id}`}
                    title={`${post!.title} · ${post!.status}`}
                    style={`
                      display:block; padding:2px 6px; border-radius:4px; margin-bottom:3px;
                      font-size:0.6875rem; font-weight:600; line-height:1.35;
                      text-decoration:none; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;
                      background:${statusBg[post!.status] ?? statusBg.draft};
                      color:${statusColor[post!.status] ?? statusColor.draft};
                    `}
                  >
                    {post!.title}
                  </a>
                ))}
                {overflow > 0 && (
                  <span style="font-size:0.6875rem; color:var(--text-dim); padding:1px 4px;">
                    +{overflow} more
                  </span>
                )}
              </>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <!-- Legend -->
  <div style="display:flex; gap:1.5rem; margin-top:1rem; flex-wrap:wrap;">
    {Object.entries(statusColor).map(([status, color]) => (
      <div style="display:flex;align-items:center;gap:0.375rem;">
        <span style={`width:10px;height:10px;border-radius:2px;background:${statusBg[status]};border:1px solid ${color}40;flex-shrink:0;`}></span>
        <span style={`font-size:0.75rem;color:${color};font-weight:500;text-transform:capitalize;`}>{status}</span>
      </div>
    ))}
  </div>

  <!-- Today's posts (if any) -->
  {byDate[today] && byDate[today]!.length > 0 && (
    <div class="card" style="margin-top:1.5rem;">
      <div class="card-title" style="margin-bottom:1rem;">Today's Posts</div>
      <div style="display:flex; flex-direction:column; gap:0.625rem;">
        {byDate[today]!.map(post => (
          <div style="display:flex;align-items:center;justify-content:space-between;padding:0.625rem 0.875rem;background:var(--bg-hover);border-radius:var(--radius);gap:1rem;">
            <div style="min-width:0;">
              <a href={`/admin/blog/${post!.id}`} style="font-weight:600;color:var(--text-primary);text-decoration:none;display:block;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">
                {post!.title}
              </a>
              <span class="text-xs text-muted">{post!.category}</span>
            </div>
            <div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">
              <span style={`padding:2px 10px;border-radius:100px;font-size:0.6875rem;font-weight:700;background:${statusBg[post!.status] ?? statusBg.draft};color:${statusColor[post!.status] ?? statusColor.draft};`}>
                {post!.status}
              </span>
              {post!.status === 'published' && (
                <a href={`/blog/${post!.slug}`} target="_blank" rel="noopener" class="btn btn-ghost btn-sm" style="font-size:0.75rem;">View →</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

</AdminLayout>
