  @keyframes seo-fade { from { opacity:0; transform:translateY(3px); } to { opacity:1; transform:none; } }
  #seo-score-ring { transition:stroke-dashoffset 0.6s cubic-bezier(0.4,0,0.2,1),stroke 0.4s ease; }
  #seo-serp-box strong { font-weight:700; background:rgba(255,200,0,0.3); border-radius:2px; }
</style>
