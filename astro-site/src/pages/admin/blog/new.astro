  /* SEO Analysis Panel */
  .seo-tab { padding:0.5rem 0.875rem; font-size:0.8rem; font-weight:600; color:var(--text-muted); background:none; border:none; border-bottom:2px solid transparent; cursor:pointer; transition:color 0.15s,border-color 0.15s; font-family:var(--font); }
