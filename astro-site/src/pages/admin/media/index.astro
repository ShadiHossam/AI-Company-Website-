---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const { count: unreadNotifs } = await supabase
  .from('notifications')
  .select('*', { count: 'exact', head: true })
  .eq('read', false);

const { data: mediaItems, error } = await supabase
  .from('media')
  .select('*')
  .order('uploaded_at', { ascending: false })
  .range(0, 39);

function formatSize(bytes: number): string {
  if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  return `${(bytes / 1024).toFixed(0)} KB`;
}
---

<AdminLayout title="Media Library" user={user} unreadCount={unreadNotifs ?? 0}>

  <!-- Upload Section -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 style="font-size:1.375rem; font-weight:800; color:var(--text-primary);">Media Library</h1>
      <p class="text-muted text-sm" style="margin-top:2px;">{mediaItems?.length ?? 0} file{mediaItems?.length !== 1 ? 's' : ''}</p>
    </div>
  </div>

  <!-- Upload card -->
  <div class="card mb-6">
    <div class="card-title mb-4" style="margin-bottom:1rem;">Upload Image</div>

    <div
      id="drop-zone"
      style="border:2px dashed var(--border); border-radius:var(--radius); padding:2.5rem; text-align:center; cursor:pointer; transition:border-color 0.15s, background 0.15s;"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:36px;height:36px;margin:0 auto 0.75rem;display:block;color:var(--text-muted);"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      <p style="color:var(--text-muted); margin-bottom:0.5rem;">Drag & drop an image here, or <span style="color:var(--accent); text-decoration:underline; cursor:pointer;" id="click-to-upload">click to select</span></p>
      <p class="text-xs text-muted">Supported: PNG, JPG, GIF, WebP, SVG — max 10 MB</p>
      <input type="file" id="file-input" accept="image/*" style="display:none;" />
    </div>

    <!-- Preview area (hidden until file selected) -->
    <div id="upload-preview" style="display:none; margin-top:1rem;">
      <div class="flex gap-4 items-start">
        <img id="preview-img" src="" alt="Preview" style="width:120px; height:90px; object-fit:cover; border-radius:var(--radius-sm); border:1px solid var(--border); flex-shrink:0;" />
        <div style="flex:1;">
          <div id="preview-filename" class="text-sm font-bold mb-4" style="margin-bottom:0.5rem; color:var(--text-primary);"></div>
          <div id="preview-size" class="text-xs text-muted mb-4" style="margin-bottom:0.75rem;"></div>
          <div class="form-group mb-4" style="margin-bottom:0.75rem;">
            <label class="form-label" for="alt-text-input">Alt Text</label>
            <input id="alt-text-input" type="text" class="form-input" placeholder="Describe the image (for accessibility & SEO)" />
          </div>
          <div class="flex gap-2">
            <button id="upload-btn" class="btn btn-primary">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
              Upload
            </button>
            <button id="cancel-upload-btn" class="btn btn-ghost">Cancel</button>
          </div>
          <div id="upload-progress" style="display:none; margin-top:0.5rem; color:var(--text-muted); font-size:0.8125rem;">Uploading…</div>
          <div id="upload-error" style="display:none; margin-top:0.5rem; color:var(--danger); font-size:0.8125rem;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Media grid -->
  <div class="card" style="padding:1.25rem;">
    <div class="card-title mb-4" style="margin-bottom:1rem;">All Media</div>

    {error && (
      <p style="color:var(--danger);">Error loading media: {error.message}</p>
    )}

    {!mediaItems || mediaItems.length === 0 ? (
      <div style="padding:3rem; text-align:center; color:var(--text-muted);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:40px;height:40px;margin:0 auto 1rem;display:block;opacity:0.3;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p>No media uploaded yet. Upload your first image above.</p>
      </div>
    ) : (
      <div id="media-grid" class="grid-4" style="gap:1rem;">
        {mediaItems.map(item => (
          <div
            class="media-thumb"
            data-id={item.id}
            data-url={item.public_url}
            data-filename={item.filename}
            data-size={item.file_size}
            data-alt={item.alt_text ?? ''}
            style="cursor:pointer; border-radius:var(--radius); overflow:hidden; border:1px solid var(--border); background:var(--bg-input); transition:border-color 0.15s, transform 0.15s;"
          >
            <div style="height:140px; overflow:hidden; background:var(--bg-hover);">
              <img
                src={item.public_url}
                alt={item.alt_text ?? item.filename}
                style="width:100%; height:100%; object-fit:cover; display:block;"
                loading="lazy"
              />
            </div>
            <div style="padding:0.5rem 0.625rem;">
              <div class="truncate text-xs" style="color:var(--text-primary); font-weight:600;">{item.filename}</div>
              <div class="text-xs text-muted">{formatSize(item.file_size ?? 0)}</div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Media Detail Modal -->
  <div id="media-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:300; align-items:center; justify-content:center; padding:1rem;">
    <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); width:100%; max-width:560px; overflow:hidden;">
      <div style="padding:1.25rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between;">
        <span style="font-weight:700; color:var(--text-primary);" id="modal-filename">Filename</span>
        <button id="modal-close" class="btn btn-ghost btn-sm" style="padding:0.25rem;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div style="padding:1.25rem;">
        <div style="margin-bottom:1rem; border-radius:var(--radius-sm); overflow:hidden; background:var(--bg-hover); max-height:240px; display:flex; align-items:center; justify-content:center;">
          <img id="modal-img" src="" alt="" style="max-width:100%; max-height:240px; object-fit:contain;" />
        </div>

        <div style="margin-bottom:1rem;">
          <div class="form-label mb-4" style="margin-bottom:0.375rem;">Public URL</div>
          <div class="flex gap-2">
            <input id="modal-url" type="text" class="form-input" readonly style="flex:1;" />
            <button id="copy-url-btn" class="btn btn-secondary btn-sm" style="white-space:nowrap;">
              Copy URL
            </button>
          </div>
        </div>

        <div class="form-group mb-4" style="margin-bottom:1rem;">
          <label class="form-label" for="modal-alt">Alt Text</label>
          <input id="modal-alt" type="text" class="form-input" placeholder="Alt text" />
        </div>

        <div class="text-xs text-muted mb-4" style="margin-bottom:1rem;" id="modal-size"></div>
      </div>

      <div style="padding:1rem 1.25rem; border-top:1px solid var(--border); display:flex; gap:0.75rem; justify-content:flex-end;">
        <button id="modal-delete-btn" class="btn btn-danger btn-sm">Delete</button>
        <button id="modal-close-2" class="btn btn-secondary btn-sm">Close</button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  // ── Upload logic ────────────────────────────────────────
  const dropZone = document.getElementById('drop-zone')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const clickToUpload = document.getElementById('click-to-upload')!;
  const uploadPreview = document.getElementById('upload-preview')!;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const previewFilename = document.getElementById('preview-filename')!;
  const previewSize = document.getElementById('preview-size')!;
  const altTextInput = document.getElementById('alt-text-input') as HTMLInputElement;
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const cancelUploadBtn = document.getElementById('cancel-upload-btn')!;
  const uploadProgress = document.getElementById('upload-progress')!;
  const uploadError = document.getElementById('upload-error')!;

  let selectedFile: File | null = null;

  function showPreview(file: File) {
    selectedFile = file;
    const url = URL.createObjectURL(file);
    previewImg.src = url;
    previewFilename.textContent = file.name;
    const sizeFmt = file.size >= 1024 * 1024
      ? `${(file.size / (1024 * 1024)).toFixed(1)} MB`
      : `${(file.size / 1024).toFixed(0)} KB`;
    previewSize.textContent = sizeFmt;
    uploadPreview.style.display = 'block';
    dropZone.style.display = 'none';
    uploadError.style.display = 'none';
    uploadError.textContent = '';
  }

  clickToUpload.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) showPreview(file);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = 'var(--accent)';
    dropZone.style.background = 'var(--accent-dim)';
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.style.borderColor = '';
    dropZone.style.background = '';
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = '';
    dropZone.style.background = '';
    const file = e.dataTransfer?.files?.[0];
    if (file && file.type.startsWith('image/')) {
      showPreview(file);
    } else {
      alert('Please drop an image file.');
    }
  });

  cancelUploadBtn.addEventListener('click', () => {
    selectedFile = null;
    fileInput.value = '';
    uploadPreview.style.display = 'none';
    dropZone.style.display = 'block';
    altTextInput.value = '';
  });

  uploadBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    uploadBtn.disabled = true;
    uploadProgress.style.display = 'block';
    uploadError.style.display = 'none';

    const formData = new FormData();
    formData.append('file', selectedFile);
    const alt = altTextInput.value.trim();
    if (alt) formData.append('alt_text', alt);

    try {
      const res = await fetch('/api/admin/media/upload', {
        method: 'POST',
        body: formData,
      });
      const json = await res.json();
      if (res.ok) {
        uploadProgress.style.display = 'none';
        // Reset and reload
        selectedFile = null;
        fileInput.value = '';
        altTextInput.value = '';
        uploadPreview.style.display = 'none';
        dropZone.style.display = 'block';
        window.location.reload();
      } else {
        uploadProgress.style.display = 'none';
        uploadError.textContent = json.error ?? 'Upload failed.';
        uploadError.style.display = 'block';
        uploadBtn.disabled = false;
      }
    } catch {
      uploadProgress.style.display = 'none';
      uploadError.textContent = 'Network error. Please try again.';
      uploadError.style.display = 'block';
      uploadBtn.disabled = false;
    }
  });

  // ── Media grid thumbnails ───────────────────────────────
  const modal = document.getElementById('media-modal')!;
  const modalImg = document.getElementById('modal-img') as HTMLImageElement;
  const modalFilename = document.getElementById('modal-filename')!;
  const modalUrl = document.getElementById('modal-url') as HTMLInputElement;
  const modalAlt = document.getElementById('modal-alt') as HTMLInputElement;
  const modalSize = document.getElementById('modal-size')!;
  const copyUrlBtn = document.getElementById('copy-url-btn')!;
  const modalClose = document.getElementById('modal-close')!;
  const modalClose2 = document.getElementById('modal-close-2')!;
  const modalDeleteBtn = document.getElementById('modal-delete-btn') as HTMLButtonElement;

  let activeMediaId = '';

  function openModal(el: HTMLElement) {
    activeMediaId = el.dataset.id!;
    const url = el.dataset.url!;
    const filename = el.dataset.filename!;
    const size = parseInt(el.dataset.size ?? '0', 10);
    const alt = el.dataset.alt ?? '';

    modalImg.src = url;
    modalImg.alt = alt || filename;
    modalFilename.textContent = filename;
    modalUrl.value = url;
    modalAlt.value = alt;
    const sizeFmt = size >= 1024 * 1024
      ? `${(size / (1024 * 1024)).toFixed(1)} MB`
      : `${(size / 1024).toFixed(0)} KB`;
    modalSize.textContent = sizeFmt;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    activeMediaId = '';
  }

  document.querySelectorAll('.media-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => openModal(thumb as HTMLElement));
    (thumb as HTMLElement).addEventListener('mouseenter', () => {
      (thumb as HTMLElement).style.borderColor = 'var(--border-accent)';
      (thumb as HTMLElement).style.transform = 'translateY(-2px)';
    });
    (thumb as HTMLElement).addEventListener('mouseleave', () => {
      (thumb as HTMLElement).style.borderColor = '';
      (thumb as HTMLElement).style.transform = '';
    });
  });

  modalClose.addEventListener('click', closeModal);
  modalClose2.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Copy URL
  copyUrlBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(modalUrl.value);
      copyUrlBtn.textContent = 'Copied!';
      setTimeout(() => { copyUrlBtn.textContent = 'Copy URL'; }, 2000);
    } catch {
      modalUrl.select();
      document.execCommand('copy');
      copyUrlBtn.textContent = 'Copied!';
      setTimeout(() => { copyUrlBtn.textContent = 'Copy URL'; }, 2000);
    }
  });

  // Delete
  modalDeleteBtn.addEventListener('click', async () => {
    if (!confirm('Delete this media file? This cannot be undone.')) return;
    modalDeleteBtn.disabled = true;
    modalDeleteBtn.textContent = 'Deleting…';
    try {
      const res = await fetch(`/api/admin/media/${activeMediaId}`, { method: 'DELETE' });
      if (res.ok) {
        closeModal();
        window.location.reload();
      } else {
        const { error } = await res.json();
        alert(`Delete failed: ${error}`);
        modalDeleteBtn.disabled = false;
        modalDeleteBtn.textContent = 'Delete';
      }
    } catch {
      alert('Network error.');
      modalDeleteBtn.disabled = false;
      modalDeleteBtn.textContent = 'Delete';
    }
  });
</script>
