---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabaseAdmin } from '../../../lib/supabase';

const user = Astro.locals.user!;
const supabase = getSupabaseAdmin();

const { count: unreadNotifs } = await supabase
  .from('notifications')
  .select('*', { count: 'exact', head: true })
  .eq('read', false);

const { data: mediaItems, error } = await supabase
  .from('media')
  .select('*')
  .order('uploaded_at', { ascending: false })
  .range(0, 39);

function formatSize(bytes: number): string {
  if (bytes >= 1024 * 1024) return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
  return `${(bytes / 1024).toFixed(0)} KB`;
}
---

<AdminLayout title="Media Library" user={user} unreadCount={unreadNotifs ?? 0}>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 style="font-size:1.375rem; font-weight:800; color:var(--text-primary);">Media Library</h1>
      <p class="text-muted text-sm" style="margin-top:2px;" id="media-count">{mediaItems?.length ?? 0} file{mediaItems?.length !== 1 ? 's' : ''}</p>
    </div>
  </div>

  <!-- Upload card -->
  <div class="card mb-6">
    <div class="card-title mb-4" style="margin-bottom:1rem;">Upload Images</div>

    <div
      id="drop-zone"
      style="border:2px dashed var(--border); border-radius:var(--radius); padding:2.5rem; text-align:center; cursor:pointer; transition:border-color 0.15s, background 0.15s;"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:36px;height:36px;margin:0 auto 0.75rem;display:block;color:var(--text-muted);"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      <p style="color:var(--text-muted); margin-bottom:0.5rem;">Drag & drop images here, or <span style="color:var(--accent); text-decoration:underline; cursor:pointer;" id="click-to-upload">click to select</span></p>
      <p class="text-xs text-muted">Supported: PNG, JPG, GIF, WebP, SVG — max 10 MB each · Multiple files allowed</p>
      <input type="file" id="file-input" accept="image/*" multiple style="display:none;" />
    </div>

    <!-- Upload queue (hidden until files selected) -->
    <div id="upload-queue" style="display:none; margin-top:1rem;">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:0.75rem;">
        <span style="font-size:0.875rem; font-weight:600; color:var(--text-primary);" id="queue-label">0 files queued</span>
        <div class="flex gap-2">
          <button id="add-more-btn" class="btn btn-ghost btn-sm">+ Add More</button>
          <button id="upload-all-btn" class="btn btn-primary btn-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0018 9h-1.26A8 8 0 103 16.3"/></svg>
            Upload All
          </button>
          <button id="cancel-queue-btn" class="btn btn-ghost btn-sm">Cancel</button>
        </div>
      </div>
      <div id="queue-list" style="display:flex; flex-direction:column; gap:0.5rem; max-height:320px; overflow-y:auto;"></div>
    </div>
  </div>

  <!-- Media grid -->
  <div class="card" style="padding:1.25rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem;">
      <div class="card-title">All Media</div>
      <div class="flex gap-2" id="grid-actions">
        <button id="select-toggle-btn" class="btn btn-ghost btn-sm">Select</button>
      </div>
    </div>

    <!-- Search bar -->
    <div style="position:relative; margin-bottom:1rem;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="position:absolute; left:0.6rem; top:50%; transform:translateY(-50%); width:14px; height:14px; color:var(--text-muted); pointer-events:none;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="media-search" type="text" placeholder="Search by filename or alt text…" class="form-input" style="padding-left:2rem; font-size:0.875rem;" />
    </div>
    <div id="search-empty" style="display:none; padding:1.5rem; text-align:center; color:var(--text-muted); font-size:0.875rem;">No files match your search.</div>

    <!-- Bulk action bar (shown when items are selected) -->
    <div id="bulk-bar" style="display:none; align-items:center; gap:0.75rem; padding:0.625rem 0.875rem; background:var(--bg-hover); border-radius:var(--radius-sm); margin-bottom:1rem; border:1px solid var(--border);">
      <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer; font-size:0.875rem; color:var(--text-primary); font-weight:600;">
        <input type="checkbox" id="select-all-cb" style="width:14px; height:14px; accent-color:var(--accent);" />
        Select All
      </label>
      <span style="color:var(--text-muted); font-size:0.875rem;" id="selected-count">0 selected</span>
      <div style="margin-left:auto;" class="flex gap-2">
        <button id="bulk-alt-btn" class="btn btn-secondary btn-sm" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit Alt Text
        </button>
        <button id="bulk-delete-btn" class="btn btn-danger btn-sm" disabled>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:13px;height:13px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          Delete Selected
        </button>
      </div>
    </div>

    {error && (
      <p style="color:var(--danger);">Error loading media: {error.message}</p>
    )}

    {!mediaItems || mediaItems.length === 0 ? (
      <div id="empty-state" style="padding:3rem; text-align:center; color:var(--text-muted);">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="width:40px;height:40px;margin:0 auto 1rem;display:block;opacity:0.3;"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p>No media uploaded yet. Upload your first image above.</p>
      </div>
    ) : (
      <div id="media-grid" class="grid-4" style="gap:1rem;">
        {mediaItems.map(item => (
          <div
            class="media-thumb"
            data-id={item.id}
            data-url={item.public_url}
            data-filename={item.filename}
            data-size={item.file_size}
            data-alt={item.alt_text ?? ''}
            style="position:relative; cursor:pointer; border-radius:var(--radius); overflow:hidden; border:2px solid var(--border); background:var(--bg-input); transition:border-color 0.15s, transform 0.15s;"
          >
            <!-- Selection checkbox overlay -->
            <div class="thumb-checkbox" style="display:none; position:absolute; top:6px; left:6px; z-index:10;">
              <input type="checkbox" class="item-cb" data-id={item.id} style="width:16px; height:16px; accent-color:var(--accent); cursor:pointer;" />
            </div>
            <!-- Usage badge (populated client-side) -->
            <div class="usage-badge" style="display:none; position:absolute; top:6px; right:6px; z-index:10; font-size:0.65rem; font-weight:700; padding:2px 6px; border-radius:4px; letter-spacing:0.02em;"></div>
            <div style="height:140px; overflow:hidden; background:var(--bg-hover);">
              <img
                src={item.public_url}
                alt={item.alt_text ?? item.filename}
                style="width:100%; height:100%; object-fit:cover; display:block;"
                loading="lazy"
              />
            </div>
            <div style="padding:0.5rem 0.625rem;">
              <div class="truncate text-xs" style="color:var(--text-primary); font-weight:600;">{item.filename}</div>
              <div class="text-xs text-muted">{formatSize(item.file_size ?? 0)}</div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Bulk Alt-Text Modal -->
  <div id="bulk-alt-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:301; align-items:center; justify-content:center; padding:1rem;">
    <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); width:100%; max-width:440px; overflow:hidden;">
      <div style="padding:1.25rem; border-bottom:1px solid var(--border);">
        <div style="font-weight:700; color:var(--text-primary); margin-bottom:0.25rem;">Edit Alt Text</div>
        <div style="font-size:0.8125rem; color:var(--text-muted);" id="bulk-alt-desc">Apply to selected images</div>
      </div>
      <div style="padding:1.25rem;">
        <label class="form-label" for="bulk-alt-input" style="margin-bottom:0.375rem; display:block;">Alt Text</label>
        <input id="bulk-alt-input" type="text" class="form-input" placeholder="Describe the images (for accessibility & SEO)" />
        <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.5rem;">Leave blank to clear alt text on all selected images.</p>
      </div>
      <div style="padding:1rem 1.25rem; border-top:1px solid var(--border); display:flex; gap:0.75rem; justify-content:flex-end;">
        <button id="bulk-alt-cancel" class="btn btn-ghost btn-sm">Cancel</button>
        <button id="bulk-alt-confirm" class="btn btn-primary btn-sm">Apply to Selected</button>
      </div>
    </div>
  </div>

  <!-- Media Detail Modal -->
  <div id="media-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:300; align-items:center; justify-content:center; padding:1rem;">
    <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); width:100%; max-width:560px; overflow:hidden;">
      <div style="padding:1.25rem; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between;">
        <span style="font-weight:700; color:var(--text-primary);" id="modal-filename">Filename</span>
        <button id="modal-close" class="btn btn-ghost btn-sm" style="padding:0.25rem;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div style="padding:1.25rem;">
        <div style="margin-bottom:1rem; border-radius:var(--radius-sm); overflow:hidden; background:var(--bg-hover); max-height:240px; display:flex; align-items:center; justify-content:center;">
          <img id="modal-img" src="" alt="" style="max-width:100%; max-height:240px; object-fit:contain;" />
        </div>

        <div style="margin-bottom:1rem;">
          <div class="form-label mb-4" style="margin-bottom:0.375rem;">Public URL</div>
          <div class="flex gap-2">
            <input id="modal-url" type="text" class="form-input" readonly style="flex:1;" />
            <button id="copy-url-btn" class="btn btn-secondary btn-sm" style="white-space:nowrap;">Copy URL</button>
          </div>
        </div>

        <div class="form-group mb-4" style="margin-bottom:1rem;">
          <label class="form-label" for="modal-alt">Alt Text</label>
          <input id="modal-alt" type="text" class="form-input" placeholder="Alt text" />
        </div>

        <div class="text-xs text-muted mb-4" style="margin-bottom:1rem;" id="modal-size"></div>
      </div>

      <div style="padding:1rem 1.25rem; border-top:1px solid var(--border); display:flex; gap:0.75rem; justify-content:flex-end;">
        <button id="modal-delete-btn" class="btn btn-danger btn-sm">Delete</button>
        <button id="modal-close-2" class="btn btn-secondary btn-sm">Close</button>
      </div>
    </div>
  </div>

</AdminLayout>

<script>
  // ─── Helpers ────────────────────────────────────────────────────────────────
  function fmtSize(bytes: number): string {
    return bytes >= 1024 * 1024
      ? `${(bytes / (1024 * 1024)).toFixed(1)} MB`
      : `${(bytes / 1024).toFixed(0)} KB`;
  }

  // ─── Bulk Upload ─────────────────────────────────────────────────────────────
  const dropZone       = document.getElementById('drop-zone')!;
  const fileInput      = document.getElementById('file-input') as HTMLInputElement;
  const clickToUpload  = document.getElementById('click-to-upload')!;
  const uploadQueue    = document.getElementById('upload-queue')!;
  const queueLabel     = document.getElementById('queue-label')!;
  const queueList      = document.getElementById('queue-list')!;
  const uploadAllBtn   = document.getElementById('upload-all-btn') as HTMLButtonElement;
  const cancelQueueBtn = document.getElementById('cancel-queue-btn')!;
  const addMoreBtn     = document.getElementById('add-more-btn')!;

  interface QueueItem { file: File; id: string; altText: string; }
  let queue: QueueItem[] = [];

  function uid() { return Math.random().toString(36).slice(2); }

  function renderQueue() {
    queueLabel.textContent = `${queue.length} file${queue.length !== 1 ? 's' : ''} queued`;
    queueList.innerHTML = '';
    queue.forEach(item => {
      const row = document.createElement('div');
      row.id = `qrow-${item.id}`;
      row.style.cssText = 'display:flex; align-items:center; gap:0.75rem; padding:0.625rem 0.75rem; background:var(--bg-input); border-radius:var(--radius-sm); border:1px solid var(--border);';
      const previewUrl = URL.createObjectURL(item.file);
      row.innerHTML = `
        <img src="${previewUrl}" style="width:48px;height:36px;object-fit:cover;border-radius:4px;flex-shrink:0;" />
        <div style="flex:1; min-width:0;">
          <div style="font-size:0.8125rem; font-weight:600; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${item.file.name}</div>
          <div style="font-size:0.75rem; color:var(--text-muted);">${fmtSize(item.file.size)}</div>
        </div>
        <input type="text" placeholder="Alt text (optional)" value="${item.altText}"
          style="font-size:0.8125rem; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-sm); padding:0.3rem 0.5rem; color:var(--text-primary); width:180px; flex-shrink:0;"
          data-alt-for="${item.id}" />
        <span id="qstatus-${item.id}" style="font-size:0.75rem; color:var(--text-muted); width:70px; text-align:right; flex-shrink:0;">Pending</span>
        <button data-remove="${item.id}" style="background:none; border:none; cursor:pointer; color:var(--text-muted); padding:0.25rem; flex-shrink:0;" title="Remove">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>`;
      queueList.appendChild(row);

      row.querySelector(`[data-alt-for="${item.id}"]`)!.addEventListener('input', (e) => {
        const idx = queue.findIndex(q => q.id === item.id);
        if (idx !== -1) queue[idx].altText = (e.target as HTMLInputElement).value;
      });
      row.querySelector(`[data-remove="${item.id}"]`)!.addEventListener('click', () => {
        queue = queue.filter(q => q.id !== item.id);
        if (queue.length === 0) { resetQueue(); } else { renderQueue(); }
      });
    });
  }

  function addFiles(files: FileList | File[]) {
    for (const f of Array.from(files)) {
      if (!f.type.startsWith('image/')) continue;
      queue.push({ file: f, id: uid(), altText: '' });
    }
    if (queue.length > 0) {
      dropZone.style.display = 'none';
      uploadQueue.style.display = 'block';
      renderQueue();
    }
  }

  function resetQueue() {
    queue = [];
    fileInput.value = '';
    uploadQueue.style.display = 'none';
    dropZone.style.display = 'block';
  }

  clickToUpload.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('click', () => fileInput.click());
  addMoreBtn.addEventListener('click', () => fileInput.click());
  cancelQueueBtn.addEventListener('click', resetQueue);

  fileInput.addEventListener('change', () => {
    if (fileInput.files) addFiles(fileInput.files);
    fileInput.value = '';
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = 'var(--accent)';
    dropZone.style.background = 'var(--accent-dim)';
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.style.borderColor = '';
    dropZone.style.background = '';
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.style.borderColor = '';
    dropZone.style.background = '';
    if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
  });

  uploadAllBtn.addEventListener('click', async () => {
    if (queue.length === 0) return;
    uploadAllBtn.disabled = true;
    cancelQueueBtn.setAttribute('disabled', 'true');
    addMoreBtn.setAttribute('disabled', 'true');

    let anySuccess = false;
    for (const item of queue) {
      const statusEl = document.getElementById(`qstatus-${item.id}`);
      if (statusEl) { statusEl.textContent = 'Uploading…'; statusEl.style.color = 'var(--accent)'; }

      const fd = new FormData();
      fd.append('file', item.file);
      if (item.altText) fd.append('alt_text', item.altText);

      try {
        const res = await fetch('/api/admin/media/upload', { method: 'POST', body: fd });
        const json = await res.json();
        if (res.ok) {
          if (statusEl) { statusEl.textContent = 'Done ✓'; statusEl.style.color = 'var(--success, #22c55e)'; }
          anySuccess = true;
        } else {
          if (statusEl) { statusEl.textContent = 'Failed'; statusEl.style.color = 'var(--danger)'; }
          const row = document.getElementById(`qrow-${item.id}`);
          if (row) {
            let errEl = row.querySelector('.upload-err') as HTMLElement | null;
            if (!errEl) {
              errEl = document.createElement('div');
              errEl.className = 'upload-err';
              errEl.style.cssText = 'font-size:0.75rem; color:var(--danger); grid-column:1/-1; padding-left:0.75rem;';
              row.appendChild(errEl);
            }
            errEl.textContent = json.error ?? 'Upload failed';
          }
        }
      } catch {
        if (statusEl) { statusEl.textContent = 'Error'; statusEl.style.color = 'var(--danger)'; }
      }
    }

    if (anySuccess) {
      setTimeout(() => window.location.reload(), 600);
    } else {
      uploadAllBtn.disabled = false;
      cancelQueueBtn.removeAttribute('disabled');
      addMoreBtn.removeAttribute('disabled');
    }
  });

  // ─── Bulk Select & Delete ────────────────────────────────────────────────────
  const selectToggleBtn = document.getElementById('select-toggle-btn') as HTMLButtonElement;
  const bulkBar         = document.getElementById('bulk-bar')!;
  const selectAllCb     = document.getElementById('select-all-cb') as HTMLInputElement;
  const selectedCount   = document.getElementById('selected-count')!;
  const bulkDeleteBtn   = document.getElementById('bulk-delete-btn') as HTMLButtonElement;

  let selectMode = false;
  const selectedIds = new Set<string>();

  function enterSelectMode() {
    selectMode = true;
    selectToggleBtn.textContent = 'Done';
    bulkBar.style.display = 'flex';
    document.querySelectorAll('.thumb-checkbox').forEach(el => {
      (el as HTMLElement).style.display = 'block';
    });
    document.querySelectorAll('.media-thumb').forEach(thumb => {
      (thumb as HTMLElement).style.cursor = 'default';
    });
  }

  function exitSelectMode() {
    selectMode = false;
    selectToggleBtn.textContent = 'Select';
    bulkBar.style.display = 'none';
    selectedIds.clear();
    selectAllCb.checked = false;
    updateBulkBar();
    document.querySelectorAll('.thumb-checkbox').forEach(el => {
      (el as HTMLElement).style.display = 'none';
    });
    document.querySelectorAll('.item-cb').forEach(cb => {
      (cb as HTMLInputElement).checked = false;
    });
    document.querySelectorAll('.media-thumb').forEach(thumb => {
      (thumb as HTMLElement).style.borderColor = '';
      (thumb as HTMLElement).style.cursor = 'pointer';
    });
  }

  function updateBulkBar() {
    selectedCount.textContent = `${selectedIds.size} selected`;
    const none = selectedIds.size === 0;
    bulkDeleteBtn.disabled = none;
    (document.getElementById('bulk-alt-btn') as HTMLButtonElement).disabled = none;
    const allIds = Array.from(document.querySelectorAll('.item-cb')).map(cb => (cb as HTMLInputElement).dataset.id!);
    selectAllCb.checked = allIds.length > 0 && allIds.every(id => selectedIds.has(id));
    selectAllCb.indeterminate = selectedIds.size > 0 && !selectAllCb.checked;
  }

  selectToggleBtn.addEventListener('click', () => {
    if (selectMode) { exitSelectMode(); } else { enterSelectMode(); }
  });

  selectAllCb.addEventListener('change', () => {
    document.querySelectorAll('.item-cb').forEach(cb => {
      const input = cb as HTMLInputElement;
      input.checked = selectAllCb.checked;
      const id = input.dataset.id!;
      const thumb = document.querySelector(`.media-thumb[data-id="${id}"]`) as HTMLElement | null;
      if (selectAllCb.checked) {
        selectedIds.add(id);
        if (thumb) thumb.style.borderColor = 'var(--accent)';
      } else {
        selectedIds.delete(id);
        if (thumb) thumb.style.borderColor = '';
      }
    });
    updateBulkBar();
  });

  document.querySelectorAll('.media-thumb').forEach(thumb => {
    const el = thumb as HTMLElement;
    const id = el.dataset.id!;
    const cb = el.querySelector('.item-cb') as HTMLInputElement | null;

    cb?.addEventListener('click', (e) => e.stopPropagation());
    cb?.addEventListener('change', () => {
      if (cb.checked) { selectedIds.add(id); el.style.borderColor = 'var(--accent)'; }
      else { selectedIds.delete(id); el.style.borderColor = ''; }
      updateBulkBar();
    });

    el.addEventListener('click', () => {
      if (selectMode) {
        if (!cb) return;
        cb.checked = !cb.checked;
        if (cb.checked) { selectedIds.add(id); el.style.borderColor = 'var(--accent)'; }
        else { selectedIds.delete(id); el.style.borderColor = ''; }
        updateBulkBar();
      } else {
        openModal(el);
      }
    });

    el.addEventListener('mouseenter', () => {
      if (!selectMode) {
        el.style.borderColor = 'var(--border-accent)';
        el.style.transform = 'translateY(-2px)';
      }
    });
    el.addEventListener('mouseleave', () => {
      if (!selectMode) {
        el.style.borderColor = '';
        el.style.transform = '';
      } else if (!selectedIds.has(id)) {
        el.style.borderColor = '';
      }
    });
  });

  bulkDeleteBtn.addEventListener('click', async () => {
    const count = selectedIds.size;
    if (!confirm(`Delete ${count} file${count !== 1 ? 's' : ''}? This cannot be undone.`)) return;
    bulkDeleteBtn.disabled = true;
    bulkDeleteBtn.textContent = 'Deleting…';

    const ids = Array.from(selectedIds);
    await Promise.all(ids.map(id => fetch(`/api/admin/media/${id}`, { method: 'DELETE' })));
    window.location.reload();
  });

  // ─── Search / Filter ─────────────────────────────────────────────────────────
  const mediaSearch  = document.getElementById('media-search') as HTMLInputElement;
  const searchEmpty  = document.getElementById('search-empty')!;

  mediaSearch.addEventListener('input', () => {
    const q = mediaSearch.value.trim().toLowerCase();
    let visible = 0;
    document.querySelectorAll('.media-thumb').forEach(thumb => {
      const el = thumb as HTMLElement;
      const match = !q
        || (el.dataset.filename ?? '').toLowerCase().includes(q)
        || (el.dataset.alt ?? '').toLowerCase().includes(q);
      el.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    searchEmpty.style.display = visible === 0 && q ? 'block' : 'none';
  });

  // ─── Bulk Alt-Text ────────────────────────────────────────────────────────────
  const bulkAltBtn     = document.getElementById('bulk-alt-btn') as HTMLButtonElement;
  const bulkAltModal   = document.getElementById('bulk-alt-modal')!;
  const bulkAltDesc    = document.getElementById('bulk-alt-desc')!;
  const bulkAltInput   = document.getElementById('bulk-alt-input') as HTMLInputElement;
  const bulkAltCancel  = document.getElementById('bulk-alt-cancel')!;
  const bulkAltConfirm = document.getElementById('bulk-alt-confirm') as HTMLButtonElement;

  bulkAltBtn.addEventListener('click', () => {
    bulkAltDesc.textContent = `Apply to ${selectedIds.size} selected image${selectedIds.size !== 1 ? 's' : ''}`;
    bulkAltInput.value = '';
    bulkAltModal.style.display = 'flex';
    bulkAltInput.focus();
  });

  bulkAltCancel.addEventListener('click', () => { bulkAltModal.style.display = 'none'; });
  bulkAltModal.addEventListener('click', (e) => { if (e.target === bulkAltModal) bulkAltModal.style.display = 'none'; });

  bulkAltConfirm.addEventListener('click', async () => {
    const altText = bulkAltInput.value.trim() || null;
    bulkAltConfirm.disabled = true;
    bulkAltConfirm.textContent = 'Saving…';

    const ids = Array.from(selectedIds);
    await Promise.all(ids.map(id =>
      fetch(`/api/admin/media/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ alt_text: altText }),
      })
    ));

    // Update data-alt on thumbnails in the DOM without a full reload
    ids.forEach(id => {
      const thumb = document.querySelector(`.media-thumb[data-id="${id}"]`) as HTMLElement | null;
      if (thumb) thumb.dataset.alt = altText ?? '';
    });

    bulkAltModal.style.display = 'none';
    bulkAltConfirm.disabled = false;
    bulkAltConfirm.textContent = 'Apply to Selected';
  });

  // ─── Detail Modal ────────────────────────────────────────────────────────────
  const modal          = document.getElementById('media-modal')!;
  const modalImg       = document.getElementById('modal-img') as HTMLImageElement;
  const modalFilename  = document.getElementById('modal-filename')!;
  const modalUrl       = document.getElementById('modal-url') as HTMLInputElement;
  const modalAlt       = document.getElementById('modal-alt') as HTMLInputElement;
  const modalSize      = document.getElementById('modal-size')!;
  const copyUrlBtn     = document.getElementById('copy-url-btn')!;
  const modalClose     = document.getElementById('modal-close')!;
  const modalClose2    = document.getElementById('modal-close-2')!;
  const modalDeleteBtn = document.getElementById('modal-delete-btn') as HTMLButtonElement;

  let activeMediaId = '';

  function openModal(el: HTMLElement) {
    activeMediaId = el.dataset.id!;
    modalImg.src = el.dataset.url!;
    modalImg.alt = el.dataset.alt || el.dataset.filename!;
    modalFilename.textContent = el.dataset.filename!;
    modalUrl.value = el.dataset.url!;
    modalAlt.value = el.dataset.alt ?? '';
    modalSize.textContent = fmtSize(parseInt(el.dataset.size ?? '0', 10));
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    activeMediaId = '';
  }

  modalClose.addEventListener('click', closeModal);
  modalClose2.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  copyUrlBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(modalUrl.value);
    } catch {
      modalUrl.select();
      document.execCommand('copy');
    }
    copyUrlBtn.textContent = 'Copied!';
    setTimeout(() => { copyUrlBtn.textContent = 'Copy URL'; }, 2000);
  });

  modalDeleteBtn.addEventListener('click', async () => {
    if (!confirm('Delete this media file? This cannot be undone.')) return;
    modalDeleteBtn.disabled = true;
    modalDeleteBtn.textContent = 'Deleting…';
    try {
      const res = await fetch(`/api/admin/media/${activeMediaId}`, { method: 'DELETE' });
      if (res.ok) {
        closeModal();
        window.location.reload();
      } else {
        const { error } = await res.json();
        alert(`Delete failed: ${error}`);
        modalDeleteBtn.disabled = false;
        modalDeleteBtn.textContent = 'Delete';
      }
    } catch {
      alert('Network error.');
      modalDeleteBtn.disabled = false;
      modalDeleteBtn.textContent = 'Delete';
    }
  });

  // ─── Usage Badges ─────────────────────────────────────────────────────────────
  (async () => {
    try {
      const res = await fetch('/api/admin/media/usage');
      if (!res.ok) return;
      const { usage } = await res.json() as { usage: Record<string, number> };
      document.querySelectorAll<HTMLElement>('.media-thumb').forEach(thumb => {
        const id = thumb.dataset.id!;
        const badge = thumb.querySelector<HTMLElement>('.usage-badge');
        if (!badge) return;
        const count = usage[id] ?? 0;
        if (count > 0) {
          badge.textContent = `Used (${count})`;
          badge.style.background = 'rgba(74,222,128,0.2)';
          badge.style.color = '#4ade80';
          badge.style.border = '1px solid rgba(74,222,128,0.3)';
        } else {
          badge.textContent = 'Unused';
          badge.style.background = 'rgba(255,255,255,0.08)';
          badge.style.color = 'var(--text-muted)';
          badge.style.border = '1px solid rgba(255,255,255,0.1)';
        }
        badge.style.display = 'block';
      });
    } catch {
      // silently fail — badges are non-critical
    }
  })();
</script>
