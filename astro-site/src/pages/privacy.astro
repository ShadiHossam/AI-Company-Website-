---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

let dynamicSections: { heading: string; body: string }[] | null = null;
let dynamicLastUpdated: string | null = null;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('legal_pages')
    .select('sections, last_updated')
    .eq('slug', 'privacy')
    .single();

  if (!error && data && Array.isArray(data.sections) && data.sections.length > 0) {
    dynamicSections = data.sections;
    dynamicLastUpdated = data.last_updated ?? null;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Privacy Policy | Aegis AI"
  description="Privacy Policy for Aegis AI, outlining how we collect, use, and protect your personal data in accordance with UAE Personal Data Protection Law (PDPL)."
  canonicalPath="/privacy"
  ogImage="/assets/og-privacy.jpg"
  noindex={true}
  arPath="/ar/privacy"
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Privacy Policy</div>
    <h1>Privacy <span class="gradient-text">Policy</span></h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      {dynamicLastUpdated ? `Last Updated: ${dynamicLastUpdated}.` : "Last Updated: June 11, 2026."} How we manage and safeguard your data in compliance with UAE Federal Decree-Law No. 45 of 2021 on Personal Data Protection.
    </p>
  </div>
</header>


<main class="section">
  <div class="container" style="max-width:1100px;">
    <div class="legal-layout">

      <!-- TABLE OF CONTENTS (desktop sidebar) -->
      <aside class="legal-toc" aria-label="Table of contents">
        <div class="legal-toc-card">
          <p class="legal-toc-label">On this page</p>
          <nav id="legal-toc-nav"></nav>
        </div>
      </aside>

      <div style="max-width:760px;">

        <!-- JUMP NAV (mobile) -->
        <details class="legal-toc-mobile">
          <summary>On this page</summary>
          <nav id="legal-toc-nav-mobile"></nav>
        </details>

        <div class="prose" id="legal-prose">

      {dynamicSections ? (
        dynamicSections.map((section) => (
          <section>
            <h2 set:html={section.heading}></h2>
            <p set:html={section.body}></p>
          </section>
        ))
      ) : (
        <>
          <section>
            <h2>1. Interpretation and Definitions</h2>
            <p>The following definitions apply throughout this Privacy Policy:</p>
            <ul>
              <li><strong>Company</strong> (referred to as "we", "us", or "our") means <strong>Aegis AI</strong>, a technology consultancy operating in Dubai, United Arab Emirates.</li>
              <li><strong>Personal Data</strong> means any information that relates to an identified or identifiable individual as defined under UAE Federal Decree-Law No. 45 of 2021 (PDPL).</li>
              <li><strong>Processing</strong> means any operation performed on Personal Data, including collection, recording, storage, use, disclosure, or deletion.</li>
              <li><strong>Service</strong> means the Website at <strong>https://aegisai.ae</strong> and all associated services offered by Aegis AI.</li>
              <li><strong>You</strong> means the individual accessing or using the Service, or the company or legal entity on whose behalf such individual is acting.</li>
              <li><strong>Cookies</strong> means small files placed on your Device by a website, containing details of your browsing history.</li>
            </ul>
          </section>

          <section>
            <h2>2. Overview</h2>
            <p>At <strong>Aegis AI</strong>, we respect your privacy and are committed to protecting your personal data. This Privacy Policy explains how we collect, use, store, and share your personal information when you visit our Website, use our booking system, or engage with our custom AI development, strategy, and team training services in the United Arab Emirates.</p>
            <p>By accessing our Website and Services, you acknowledge that you have read and understood this Privacy Policy and consent to the processing of your personal information as described herein. If you do not agree with the terms of this policy, please discontinue use of our Website immediately.</p>
          </section>

          <section>
            <h2>3. Information We Collect</h2>
            <p>We may collect and process the following categories of personal data about you:</p>
            <ul>
              <li><strong>Identity Data:</strong> Full name, job title, and company name.</li>
              <li><strong>Contact Data:</strong> Email address, phone number, and WhatsApp number.</li>
              <li><strong>Business Insights:</strong> Industry, company size, custom AI challenges, budget estimates, and operational notes shared during booking or consultation calls.</li>
              <li><strong>Technical Data:</strong> IP address, browser type, time zone setting, operating system, and details about how you navigate and interact with our Website.</li>
              <li><strong>Usage Data:</strong> Pages visited, time spent on pages, links clicked, referral source, and other diagnostic data collected automatically when you access the Service.</li>
              <li><strong>Communication Data:</strong> Records of correspondence with us via email, WhatsApp, or our contact forms.</li>
            </ul>
            <p>We collect this data when you fill in our consultation booking form, contact us directly, or browse our Website. We do not knowingly collect personal data from individuals under the age of 18.</p>
          </section>

          <section>
            <h2>4. How We Use Your Data</h2>
            <p>We only process your personal data where we have a lawful basis to do so, including your consent, our legitimate business interests, or a legal obligation. Specifically, we use your data to:</p>
            <ul>
              <li>Register you as a new client and process your booking for our Free AI Strategy Consultation.</li>
              <li>Deliver and manage our custom AI models, automation workflows, and tailored training workshops.</li>
              <li>Communicate with you via phone, email, or WhatsApp to schedule calls, send updates, and provide operational support.</li>
              <li>Send relevant marketing communications about our services (you may opt out at any time).</li>
              <li>Analyse and improve our Website performance, marketing strategies, and user experience.</li>
              <li>Comply with legal and regulatory obligations in the UAE.</li>
              <li>Prevent fraud, abuse, and other harmful activity on the Website.</li>
            </ul>
          </section>

          <section>
            <h2>5. Data Security</h2>
            <p>We have implemented robust technical and organisational security measures to prevent your personal data from being accidentally lost, accessed, altered, disclosed, or destroyed in an unauthorised manner. These measures include:</p>
            <ul>
              <li><strong>HTTPS Encryption:</strong> All data submitted through our Website is transmitted over encrypted HTTPS connections.</li>
              <li><strong>Access Controls:</strong> Access to personal data is strictly restricted to authorised employees, contractors, and partners on a need-to-know basis.</li>
              <li><strong>Secure Infrastructure:</strong> Our systems are hosted on enterprise-grade cloud infrastructure with industry-standard security configurations.</li>
              <li><strong>Regular Reviews:</strong> We regularly review and update our security practices to address evolving threats.</li>
            </ul>
            <p>While we take every reasonable precaution to protect your data, no method of electronic transmission or storage is 100% secure. In the event of a data breach that is likely to result in a risk to your rights and freedoms, we will notify you and the relevant authorities in accordance with UAE law.</p>
          </section>

          <section>
            <h2>6. Data Sharing and Third Parties</h2>
            <p>We do not sell, rent, or trade your personal data to third parties for marketing purposes. We may share your information with trusted technology partners who assist us in operating our business, subject to strict confidentiality and data processing agreements, including:</p>
            <ul>
              <li><strong>Cloud &amp; Infrastructure:</strong> Enterprise cloud hosting and database providers.</li>
              <li><strong>AI Platforms:</strong> AI model providers and inference platforms (your data is not used to train their models without explicit consent).</li>
              <li><strong>Automation Tools:</strong> Workflow automation platforms.</li>
              <li><strong>Communication:</strong> Messaging API providers.</li>
            </ul>
            <p>We may also disclose your personal data if required by UAE law enforcement, a court order, or to protect the rights, safety, or security of Aegis AI or our clients. In all cases, we will only disclose the minimum necessary information.</p>
          </section>

          <section>
            <h2>7. Data Retention</h2>
            <p>We retain your personal data only for as long as is necessary to fulfil the purposes for which it was collected, including satisfying any legal, accounting, or reporting requirements.</p>
            <p>As a guide:</p>
            <ul>
              <li><strong>Enquiry and consultation data</strong> is retained for up to 2 years from the date of last contact.</li>
              <li><strong>Client project data</strong> is retained for up to 7 years following project completion in accordance with UAE commercial record-keeping requirements.</li>
              <li><strong>Website analytics data</strong> is retained for up to 13 months.</li>
            </ul>
            <p>After the applicable retention period, your data is securely deleted or anonymised.</p>
          </section>

          <section>
            <h2>8. Your Rights Under UAE Law</h2>
            <p>In accordance with the <strong>UAE Personal Data Protection Law (Federal Decree-Law No. 45 of 2021)</strong>, you have the following rights regarding your personal data:</p>
            <ul>
              <li><strong>Right to Access:</strong> You can request a copy of the personal data we hold about you.</li>
              <li><strong>Right to Correction:</strong> You can request that we update or correct any incomplete or inaccurate data.</li>
              <li><strong>Right to Erasure ("Right to be Forgotten"):</strong> You can request that we delete your personal data under certain conditions.</li>
              <li><strong>Right to Restrict Processing:</strong> You can request that we limit or pause the processing of your data.</li>
              <li><strong>Right to Data Portability:</strong> You can request a structured, machine-readable copy of your personal data.</li>
              <li><strong>Right to Object:</strong> You can object to our processing of your personal data for direct marketing at any time.</li>
              <li><strong>Right to Withdraw Consent:</strong> Where processing is based on consent, you can withdraw it at any time. This does not affect the lawfulness of processing before withdrawal.</li>
            </ul>
            <p>To exercise any of these rights, please contact our Data Protection Officer at <strong>hello@aegisai.ae</strong>. We will respond to verified requests within 30 days.</p>
          </section>

          <section>
            <h2>9. Cookies and Tracking Technologies</h2>
            <p>Our Website uses cookies and similar tracking technologies to enhance navigation, analyse site traffic, and deliver a personalised experience. We use the following types of cookies:</p>
            <ul>
              <li><strong>Essential Cookies:</strong> Required for the Website to function correctly. These cannot be disabled.</li>
              <li><strong>Analytics Cookies:</strong> Help us understand how visitors interact with the Website so we can improve performance and content.</li>
              <li><strong>Preference Cookies:</strong> Remember your settings and preferences to improve your experience on return visits.</li>
            </ul>
            <p>You can configure your browser to refuse all cookies or to alert you when cookies are being sent. However, disabling cookies may limit your ability to use certain interactive features of our Website, such as the multi-step consultation booking form.</p>
          </section>

          <section>
            <h2>10. International Data Transfers</h2>
            <p>Some of our trusted third-party service providers may be located outside the United Arab Emirates. Where we transfer your personal data internationally, we take steps to ensure that appropriate safeguards are in place to protect your data in accordance with UAE PDPL requirements and that the recipient country provides an adequate level of data protection.</p>
          </section>

          <section>
            <h2>11. Links to Other Websites</h2>
            <p>Our Website may contain links to third-party websites. This Privacy Policy applies only to our Website. We have no control over and assume no responsibility for the content or privacy practices of any third-party sites. We encourage you to review the privacy policy of every website you visit.</p>
          </section>

          <section>
            <h2>12. EU and GDPR Users</h2>
            <p>If you are accessing our Website from the European Economic Area (EEA), you benefit from additional data protection rights under the <strong>General Data Protection Regulation (GDPR)</strong>. These include the right to lodge a complaint with your local supervisory authority. Our lawful bases for processing EU residents' personal data include consent, contract performance, and legitimate interests.</p>
          </section>

          <section>
            <h2>13. Changes to This Privacy Policy</h2>
            <p>We may update this Privacy Policy from time to time to reflect changes in our practices, legal requirements, or the services we offer. We will notify you of any material changes by updating the "Last Updated" date at the top of this page and, where appropriate, by sending you an email notification.</p>
            <p>We encourage you to review this Privacy Policy periodically. Your continued use of the Website following the posting of changes constitutes your acceptance of the updated policy.</p>
          </section>

          <section>
            <h2>14. Contact Us</h2>
            <p>If you have any questions, concerns, or requests regarding this Privacy Policy or how your personal information is processed, please contact our Data Protection Officer at:</p>
            <div class="contact-box">
              <p><strong style="color:#00253b;">Aegis AI: Data Protection Officer</strong></p>
              <p>Dubai, United Arab Emirates</p>
              <p><strong>Email:</strong> hello@aegisai.ae</p>
              <p><strong>WhatsApp Support:</strong> +971 4 321 8888</p>
            </div>
          </section>
        </>
      )}

        </div>
      </div>

    </div>
  </div>
</main>

</BaseLayout>

<style>
.prose h2 { font-size: 1.375rem; font-weight: 700; color: #00253b; border-bottom: 1px solid rgba(0,37,59,0.10); padding-bottom: 0.625rem; margin-bottom: 1rem; margin-top: 0; scroll-margin-top: 90px; }
    .prose p { color: #42474e; line-height: 1.8; margin-bottom: 0.875rem; }
    .prose ul { color: #42474e; padding-left: 1.5rem; line-height: 1.8; }
    .prose li { margin-bottom: 0.5rem; }
    .prose strong { color: #111c2d; }
    .prose section { margin-bottom: 2.5rem; }
    .prose a { color: #006875; text-decoration: underline; }
    .contact-box { background: #f0f3ff; border: 1px solid rgba(0,37,59,0.10); border-radius: 12px; padding: 1.25rem; margin-top: 1rem; }
    .contact-box p { margin: 0 0 0.375rem; color: #42474e; font-size: 0.9rem; }

    /* Legal layout: sticky TOC sidebar + prose column */
    .legal-layout { display: grid; grid-template-columns: 240px 1fr; gap: 3rem; align-items: start; justify-content: center; }
    .legal-toc { position: sticky; top: 96px; }
    .legal-toc-card { background: #fff; border: 1px solid rgba(0,37,59,0.08); border-radius: 16px; padding: 1.25rem; box-shadow: var(--shadow-card); }
    .legal-toc-label { font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.09em; text-transform: uppercase; color: #006875; margin: 0 0 0.875rem; }
    .legal-toc-link { display: block; padding: 6px 8px; margin-bottom: 2px; border-radius: 8px; font-size: 0.8125rem; line-height: 1.4; color: #72787e; text-decoration: none; transition: background 0.15s, color 0.15s; }
    .legal-toc-link:hover { background: rgba(0,104,117,0.06); color: #006875; }
    .legal-toc-link.active { background: rgba(0,227,253,0.10); color: #00253b; font-weight: 600; }
    .legal-toc-mobile { display: none; background: #fff; border: 1px solid rgba(0,37,59,0.08); border-radius: 12px; padding: 0.5rem 1rem; margin-bottom: 1.5rem; }
    .legal-toc-mobile summary { cursor: pointer; font-weight: 700; color: #00253b; padding: 0.625rem 0; font-size: 0.9375rem; list-style: none; display: flex; align-items: center; justify-content: space-between; }
    .legal-toc-mobile summary::-webkit-details-marker { display: none; }
    .legal-toc-mobile summary::after { content: '+'; font-size: 1.125rem; color: #006875; }
    .legal-toc-mobile[open] summary::after { content: '\2212'; }
    .legal-toc-mobile nav { padding-bottom: 0.75rem; }
    @media (max-width: 900px) {
      .legal-layout { grid-template-columns: 1fr; gap: 0; }
      .legal-toc { display: none; }
      .legal-toc-mobile { display: block; }
    }
</style>

<script>
  const prose = document.getElementById('legal-prose');
  const navDesktop = document.getElementById('legal-toc-nav');
  const navMobile = document.getElementById('legal-toc-nav-mobile');

  function slugify(text: string): string {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }

  if (prose && (navDesktop || navMobile)) {
    const headings = Array.from(prose.querySelectorAll('h2'));
    headings.forEach((h, idx) => {
      if (!h.id) h.id = slugify(h.textContent ?? '') || `section-${idx}`;
      const label = h.textContent ?? '';
      const linkHtml = `<a class="legal-toc-link" href="#${h.id}" data-section="${h.id}">${label}</a>`;
      if (navDesktop) navDesktop.insertAdjacentHTML('beforeend', linkHtml);
      if (navMobile) navMobile.insertAdjacentHTML('beforeend', linkHtml);
    });

    const links = document.querySelectorAll<HTMLAnchorElement>('.legal-toc-link[data-section]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = (entry.target as HTMLElement).id;
          links.forEach((l) => l.classList.toggle('active', l.getAttribute('data-section') === id));
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
    headings.forEach((h) => observer.observe(h));

    // Close the mobile jump-nav after a link is tapped
    const mobileDetails = document.querySelector('.legal-toc-mobile') as HTMLDetailsElement | null;
    navMobile?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a') && mobileDetails) mobileDetails.open = false;
    });
  }
</script>
