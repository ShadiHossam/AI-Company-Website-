---
import BaseLayout from "../layouts/BaseLayout.astro";
import { COMPANY } from "../config/company";
import { loadPageContent, getVal } from "../lib/page-content";

export const prerender = false;

const pc = await loadPageContent('contact');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const contactFaqs = [
  { question: "How fast will you respond?", answer: "WhatsApp messages get a reply within 4 hours during business hours. Emails and form submissions get a same business day response. If you book a specific time slot in the form, we'll confirm it directly." },
  { question: "What should I prepare before the call?", answer: "Nothing formal. It helps if you can roughly describe the task or process that's eating your team's time, but you don't need numbers, a deck, or a technical brief. We'll ask the right questions on the call." },
  { question: "Is the consultation really free, no strings attached?", answer: "Yes. The 30-minute call costs nothing and carries no obligation. If AI doesn't make sense for your business right now, we'll tell you that directly instead of pushing a sale." },
  { question: "Can we talk in Arabic?", answer: "Yes. Our team is available in Arabic and English. Tell us your preference when you book, or just message us on WhatsApp in whichever language you're comfortable with." },
  { question: "Do you meet in person in Dubai?", answer: "Yes. Select \"In-Person\" as the meeting format in the booking form and we'll arrange a time to meet at our Business Bay office, or we can visit your premises depending on the project." },
];

const contactFaqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: contactFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const contactLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Aegis AI',
    url: 'https://lenooai.com/contact',
    description: 'Book a free 30-minute AI strategy call with Aegis AI. Available in Arabic and English.',
    mainEntity: {
      '@type': 'Organization',
      name: 'Aegis AI',
      url: 'https://lenooai.com',
      telephone: '+97143218888',
      email: 'hello@lenooai.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Business Bay',
        addressLocality: 'Dubai',
        addressCountry: 'AE',
      },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
        opens: '09:00',
        closes: '18:00',
      },
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer service',
        telephone: '+97143218888',
        email: 'hello@lenooai.com',
        availableLanguage: ['English', 'Arabic'],
        areaServed: 'AE',
      },
    },
  },
  contactFaqLdJson,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lenooai.com/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://lenooai.com/contact' },
    ],
  },
];
---

<BaseLayout
  title="Book a Free AI Strategy Call in Dubai, UAE | Aegis AI"
  description="Book a free 30-minute AI strategy call with Aegis AI, a Dubai AI agency. No sales pressure, just clarity on what AI can do for your UAE business."
  canonicalPath="/contact"
  arPath="/ar/contact"
  ogImage="/assets/og-contact.jpg"
  ldJson={contactLdJson}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Contact</div>
    <h1>{g('hero_h1', "Let's Talk About Your AI Opportunity.")}</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:600px; margin:1.5rem auto 2rem;">{g('hero_subtext', "Book a free 30-minute call. Tell us about your business. We'll tell you honestly if and how AI can help, and what it would cost.")}</p>
    <div style="display:flex; gap:2rem; justify-content:center; flex-wrap:wrap;">
      <div style="display:inline-flex; align-items:center; gap:8px; color:rgba(255,255,255,0.72); font-size:0.9375rem;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:18px;">check</span>No commitment required
      </div>
      <div style="display:inline-flex; align-items:center; gap:8px; color:rgba(255,255,255,0.72); font-size:0.9375rem;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:18px;">check</span>Reply within 4 hours
      </div>
      <div style="display:inline-flex; align-items:center; gap:8px; color:rgba(255,255,255,0.72); font-size:0.9375rem;">
        <span class="material-symbols-outlined" aria-hidden="true" style="color:#00e3fd; font-size:18px;">check</span>Available in Arabic &amp; English
      </div>
    </div>
  </div>
</header>

<!-- MAIN CONTENT -->
<section class="section" style="background:#f9f9ff;">
  <div class="container" style="max-width:1000px;">
    <div class="main-grid">

      <!-- LEFT: Contact info -->
      <div style="display:flex; flex-direction:column; gap:1.25rem;">

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">call</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">WhatsApp</p>
              <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener" style="color:#006875; font-size:0.875rem;">{COMPANY.phone}</a>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Arabic + English · Replies within 4h</p>
            </div>
          </div>
        </div>

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">mail</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">Email</p>
              <a href={`mailto:${COMPANY.email}`} style="color:#006875; font-size:0.875rem;">{COMPANY.email}</a>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Same business day response</p>
            </div>
          </div>
        </div>

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">location_on</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">Location</p>
              <p style="color:#42474e; font-size:0.875rem;">Dubai, UAE</p>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Sun – Thu · 9:00 am – 6:00 pm GST</p>
            </div>
          </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:8px; padding-top:0.5rem;">
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">star</span>
            100% free consultation, no obligations
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">translate</span>
            Available in Arabic &amp; English
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">shield</span>
            100% Satisfaction Guarantee on all AI builds
          </div>
        </div>
      </div>

      <!-- RIGHT: Booking Form -->
      <div>
        <div class="form-box">
          <h2 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.25rem;">Book Your Free Consultation</h2>
          <p style="color:#42474e; font-size:0.875rem; margin-bottom:1.5rem;">3 quick steps, takes about 2 minutes.</p>

          <div class="step-indicator" id="step-indicator">
            <div class="step-dot-sm active" id="ind-1">1</div>
            <div class="step-connector-sm" id="conn-1"></div>
            <div class="step-dot-sm" id="ind-2">2</div>
            <div class="step-connector-sm" id="conn-2"></div>
            <div class="step-dot-sm" id="ind-3">3</div>
          </div>

          <!-- STEP 1 -->
          <div class="form-step active" id="step-1">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 1 of 3: About You</p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label class="form-label" for="c-name">Full Name *</label>
                <input class="form-input" id="c-name" type="text" placeholder="Your name" required />
              </div>
              <div>
                <label class="form-label" for="c-company">Company Name *</label>
                <input class="form-input" id="c-company" type="text" placeholder="Your company" required />
              </div>
              <div>
                <label class="form-label" for="c-email">Email *</label>
                <input class="form-input" id="c-email" type="email" placeholder="you@email.com" required />
              </div>
              <div>
                <label class="form-label" for="c-whatsapp">WhatsApp Number *</label>
                <input class="form-input" id="c-whatsapp" type="tel" placeholder="+971 50 123 4567" required />
              </div>
              <div style="grid-column:1/-1;">
                <label class="form-label" for="c-title">Job Title / Role</label>
                <input class="form-input" id="c-title" type="text" placeholder="e.g. CEO, Operations Manager" />
              </div>
            </div>
            <div style="margin-top:1.5rem; display:flex; justify-content:flex-end;">
              <button onclick="contactStep(2)" class="btn-primary">Next: Your Business →</button>
            </div>
          </div>

          <!-- STEP 2 -->
          <div class="form-step" id="step-2">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 2 of 3: Your Business</p>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
              <div>
                <label class="form-label" for="c-industry">Industry *</label>
                <select class="form-select" id="c-industry" required>
                  <option value="">Select your industry</option>
                  <option>Real Estate</option>
                  <option>Retail &amp; E-commerce</option>
                  <option>Hospitality &amp; Tourism</option>
                  <option>Logistics &amp; Supply Chain</option>
                  <option>Healthcare</option>
                  <option>Finance &amp; Banking</option>
                  <option>Construction &amp; Property Development</option>
                  <option>Professional Services</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="c-size">Company Size *</label>
                <select class="form-select" id="c-size" required>
                  <option value="">Select size</option>
                  <option>1–20 employees</option>
                  <option>21–100 employees</option>
                  <option>101–500 employees</option>
                  <option>500+ employees</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="c-challenge">What is your main challenge or goal? *</label>
              <textarea class="form-textarea" id="c-challenge" rows="3" placeholder="e.g. We're spending too much time on manual lead qualification, or we want to automate customer support on WhatsApp..." required></textarea>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label class="form-label" for="c-budget">Budget Range</label>
                <select class="form-select" id="c-budget">
                  <option value="">Prefer not to say</option>
                  <option>Exploring (no budget set yet)</option>
                  <option>AED 10,000 – 50,000</option>
                  <option>AED 50,000 – 200,000</option>
                  <option>AED 200,000+</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="c-ai-exp">Have you tried AI tools before?</label>
                <select class="form-select" id="c-ai-exp">
                  <option>No, starting from scratch</option>
                  <option>A little, some personal AI tool use</option>
                  <option>Some team tools in use</option>
                  <option>Yes, we have AI systems already</option>
                </select>
              </div>
            </div>
            <div style="margin-top:1.5rem; display:flex; justify-content:space-between;">
              <button onclick="contactStep(1)" class="btn-outline">← Back</button>
              <button onclick="contactStep(3)" class="btn-primary">Next: Schedule →</button>
            </div>
          </div>

          <!-- STEP 3 -->
          <div class="form-step" id="step-3">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 3 of 3: Schedule Your Call</p>

            <label class="form-label" style="display:block; margin-bottom:0.75rem;">Preferred Meeting Format *</label>
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:1.25rem;">
              <div class="meeting-type-card selected" onclick="selectMeeting(this, 'Video call')" id="meet-video">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:24px; color:#006875; display:block; margin:0 auto 6px;">videocam</span>
                <p class="meet-label" style="font-size:0.75rem; font-weight:600; color:#006875; margin:0;">Video Call</p>
              </div>
              <div class="meeting-type-card" onclick="selectMeeting(this, 'Phone call')" id="meet-phone">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:24px; color:#72787e; display:block; margin:0 auto 6px;">call</span>
                <p class="meet-label" style="font-size:0.75rem; font-weight:600; color:#72787e; margin:0;">Phone Call</p>
              </div>
              <div class="meeting-type-card" onclick="selectMeeting(this, 'In-person Dubai')" id="meet-inperson">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:24px; color:#72787e; display:block; margin:0 auto 6px;">location_on</span>
                <p class="meet-label" style="font-size:0.75rem; font-weight:600; color:#72787e; margin:0;">In-Person</p>
              </div>
            </div>
            <input type="hidden" id="c-meeting-type" value="Video call" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
              <div>
                <label class="form-label" for="c-date">Preferred Date *</label>
                <input class="form-input" id="c-date" type="date" required />
              </div>
              <div>
                <label class="form-label" for="c-time">Preferred Time</label>
                <select class="form-select" id="c-time">
                  <option>Morning (9am – 12pm)</option>
                  <option>Afternoon (12pm – 4pm)</option>
                  <option>Late Afternoon (4pm – 6pm)</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="c-notes">Anything else we should know? (optional)</label>
              <textarea class="form-textarea" id="c-notes" rows="2" placeholder="Any specific questions or context that would help us prepare..."></textarea>
            </div>

            <div style="background:rgba(0,104,117,0.06); border:1px solid rgba(0,104,117,0.20); border-radius:12px; padding:1rem; margin-bottom:1.25rem; display:flex; align-items:flex-start; gap:12px;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#d97706; font-size:20px; flex-shrink:0; margin-top:2px;">shield</span>
              <p style="color:#42474e; font-size:0.8125rem; line-height:1.6; margin:0;"><strong style="color:#00253b;">100% risk-free.</strong> The call is free. If you proceed and aren't satisfied with the AI system we build, we refund 100% of your investment. No conditions.</p>
            </div>

            <!-- Honeypot: leave empty — bots fill this -->
            <input type="text" id="c-honeypot" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

            <div id="contact-submit-error" style="display:none; background:rgba(239,68,68,0.1); color:#ef4444; border:1px solid rgba(239,68,68,0.3); border-radius:10px; padding:0.75rem 1rem; font-size:0.8125rem; margin-bottom:1rem;">
              Something went wrong. Please <a href={`https://wa.me/${COMPANY.whatsapp}`} style="color:#ef4444;font-weight:bold;">message us on WhatsApp</a> or email <a href={`mailto:${COMPANY.email}`} style="color:#ef4444;font-weight:bold;">{COMPANY.email}</a>.
            </div>

            <div style="display:flex; justify-content:space-between;">
              <button onclick="contactStep(2)" class="btn-outline">← Back</button>
              <button id="contact-submit-btn" onclick="submitContact()" class="btn-primary">Book Consultation →</button>
            </div>
          </div>

          <!-- SUCCESS SCREEN -->
          <div id="success-screen" style="text-align:center; padding:2rem 0;">
            <div style="width:64px; height:64px; border-radius:50%; background:rgba(0,227,253,0.12); border:2px solid rgba(0,227,253,0.35); display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:32px;">check_circle</span>
            </div>
            <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.5rem;">Request Received!</h3>
            <p style="color:#42474e; font-size:0.875rem; margin-bottom:1.5rem; max-width:360px; margin-left:auto; margin-right:auto; line-height:1.6;">Thank you. We'll reach out shortly to confirm your consultation time, via WhatsApp or email, whichever you prefer.</p>
            <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.10); border:1px solid rgba(0,227,253,0.25); border-radius:100px; padding:8px 20px; font-size:0.8125rem; font-weight:600; color:#004f58;">
              <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;">shield</span>
              100% Satisfaction Guarantee applies to everything we build
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- WHAT TO EXPECT -->
<section class="section" aria-labelledby="expect-heading">
  <div class="container" style="max-width:960px;">
    <div class="section-header">
      <h2 id="expect-heading">What Happens in Your Free 30-Minute Consultation</h2>
    </div>
    <div class="feature-ledger">
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">01</div>
        <h3 style="font-weight:700; color:#00253b;">We Listen First</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6;">You tell us about your business, your team, and your biggest operational headaches. No pitching yet.</p>
      </div>
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">02</div>
        <h3 style="font-weight:700; color:#00253b;">We Identify AI Opportunities</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6;">Based on what you've shared, we'll identify the top 2–3 areas where AI can save you time or increase revenue.</p>
      </div>
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">03</div>
        <h3 style="font-weight:700; color:#00253b;">Honest Recommendation</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6;">We'll tell you if it makes business sense, and we'll tell you if it doesn't. We won't sell you AI you don't need.</p>
      </div>
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">04</div>
        <h3 style="font-weight:700; color:#00253b;">Clear Next Step</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6;">You leave with a clear picture of what's possible, what it costs, and how long it takes. No vague proposals.</p>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT FAQ -->
<section class="section" style="background:#f0f3ff;" aria-labelledby="contact-faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="contact-faq-heading">Before You Reach Out</h2>
      <p>Quick answers to the questions we get most.</p>
    </div>
    <div>
      {contactFaqs.map((item) => (
        <div class="faq-item">
          <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
            {item.question}
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-body">{item.answer}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- WHATSAPP CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container" style="max-width:640px; text-align:center;">
    <h2 style="font-size:1.75rem; font-weight:800; color:#00253b; margin-bottom:0.75rem;">Prefer to Chat First?</h2>
    <p style="color:#42474e; margin-bottom:1.5rem;">Send us a WhatsApp message in Arabic or English. We reply fast.</p>
    <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener" class="btn-primary" style="display:inline-flex; align-items:center; gap:12px; font-size:1rem; padding:1rem 2rem;">
      <svg viewBox="0 0 24 24" fill="currentColor" style="width:20px; height:20px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.852L0 24l6.335-1.652A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.814 9.814 0 01-5.001-1.369l-.359-.213-3.76.98 1.006-3.659-.234-.375A9.818 9.818 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/></svg>
      Message Us on WhatsApp
    </a>
    <p style="color:#72787e; font-size:0.75rem; margin-top:1rem;">Available Sunday – Thursday, 9am – 6pm GST</p>
