---
import BaseLayout from "../layouts/BaseLayout.astro";
import { COMPANY } from "../config/company";
import { loadPageContent, getVal } from "../lib/page-content";
import { getSiteConfig } from "../lib/config";
import FaqAccordion from "../components/FaqAccordion.astro";

export const prerender = false;

const pc = await loadPageContent('contact');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);
const siteConfig = await getSiteConfig();
const calendlyUrl = siteConfig['integration.calendly_url'] || COMPANY.calendlyUrl;

const contactFaqs = [
  { question: "How fast will you respond?", answer: "WhatsApp messages get a reply within 4 hours during business hours. Emails and form submissions get a same business day response. If you book a specific time slot in the form, we'll confirm it directly." },
  { question: "What should I prepare before the call?", answer: "Nothing formal. It helps if you can roughly describe the task or process that's eating your team's time, but you don't need numbers, a deck, or a technical brief. We'll ask the right questions on the call." },
  { question: "Is the consultation really free, no strings attached?", answer: "Yes. The 30-minute call costs nothing and carries no obligation. If AI doesn't make sense for your business right now, we'll tell you that directly instead of pushing a sale." },
  { question: "Can we talk in Arabic?", answer: "Yes. Our team is available in Arabic and English. Tell us your preference when you book, or just message us on WhatsApp in whichever language you're comfortable with." },
  { question: "Do you meet in person in Dubai?", answer: "Yes. Mention it in the notes field when booking, or just tell us on WhatsApp, and we'll arrange a time to meet at our Business Bay office, or we can visit your premises depending on the project." },
];

const contactFaqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: contactFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const contactLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Lenoo AI',
    url: 'https://lenooai.com/contact',
    description: 'Book a free 30-minute AI strategy call with Lenoo AI. Available in Arabic and English.',
    mainEntity: {
      '@type': 'Organization',
      name: 'Lenoo AI',
      url: 'https://lenooai.com',
      telephone: '+97143218888',
      email: 'hello@lenooai.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Business Bay',
        addressLocality: 'Dubai',
        addressCountry: 'AE',
      },
      openingHoursSpecification: {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday'],
        opens: '09:00',
        closes: '18:00',
      },
      contactPoint: {
        '@type': 'ContactPoint',
        contactType: 'customer service',
        telephone: '+97143218888',
        email: 'hello@lenooai.com',
        availableLanguage: ['English', 'Arabic'],
        areaServed: 'AE',
      },
    },
  },
  contactFaqLdJson,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lenooai.com/' },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: 'https://lenooai.com/contact' },
    ],
  },
];
---

<BaseLayout
  title="Book a Free AI Strategy Call in Dubai, UAE | Lenoo AI"
  description="Book a free 30-minute AI strategy call with Lenoo AI, a Dubai AI agency. No sales pressure, just clarity on what AI can do for your UAE business."
  canonicalPath="/contact"
  arPath="/ar/contact"
  ogImage="/assets/og-contact.jpg"
  ldJson={contactLdJson}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Contact</div>
    <h1>{g('hero_h1', "Let's Talk About Your AI Opportunity.")}</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:600px; margin:1.5rem auto 0;">{g('hero_subtext', "Book a free 30-minute call. Tell us about your business. We'll tell you honestly if and how AI can help, and what it would cost.")}</p>
    <div class="trust-chips" style="justify-content:center; margin:1.75rem 0 2rem;">
      <span class="tchip">No commitment required</span>
      <span class="tchip">Reply within 4 hours</span>
      <span class="tchip">Available in Arabic &amp; English</span>
    </div>
    <a href="#book" class="btn-primary">Book Your Free Consultation</a>
  </div>
</header>

<!-- MAIN CONTENT -->
<section class="section" style="background:#f9f9ff;" id="book">
  <div class="container" style="max-width:1000px;">
    <div class="main-grid">

      <!-- LEFT: Contact info -->
      <div style="display:flex; flex-direction:column; gap:1.25rem;">

        <div class="split-media" style="margin-bottom:0.25rem;">
          <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=900&q=80&auto=format&fit=crop" alt="Dubai skyscrapers rising above the clouds" loading="lazy" width="900" height="240" style="height:200px;" />
        </div>

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">call</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">WhatsApp</p>
              <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener" style="color:#006875; font-size:0.875rem;">{COMPANY.phone}</a>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Arabic + English · Replies within 4h</p>
            </div>
          </div>
        </div>

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">mail</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">Email</p>
              <a href={`mailto:${COMPANY.email}`} style="color:#006875; font-size:0.875rem;">{COMPANY.email}</a>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Same business day response</p>
            </div>
          </div>
        </div>

        <div class="contact-card">
          <div style="display:flex; align-items:flex-start; gap:1rem;">
            <div style="width:40px; height:40px; border-radius:12px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:20px;">location_on</span>
            </div>
            <div>
              <p style="font-weight:700; font-size:0.875rem; color:#00253b; margin-bottom:2px;">Location</p>
              <p style="color:#42474e; font-size:0.875rem;">Dubai, UAE</p>
              <p style="color:#72787e; font-size:0.75rem; margin-top:2px;">Sun – Thu · 9:00 am – 6:00 pm GST</p>
            </div>
          </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:8px; padding-top:0.5rem;">
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">star</span>
            100% free consultation, no obligations
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">translate</span>
            Available in Arabic &amp; English
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:16px; flex-shrink:0;">shield</span>
            100% Satisfaction Guarantee on all AI builds
          </div>
        </div>

        <div style="margin-top:0.5rem;">
          <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:1rem;">What Happens in Your Free 30-Minute Consultation</h3>
          <div style="display:flex; flex-direction:column; gap:0.875rem;">
            <div style="display:flex; gap:11px; align-items:flex-start;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#0f9d63; font-size:18px; flex-shrink:0; margin-top:2px;">check_circle</span>
              <span style="font-size:0.875rem; color:#42474e; line-height:1.6;"><b style="color:#00253b;">We Listen First.</b> You tell us about your business, your team, and your biggest operational headaches. No pitching yet.</span>
            </div>
            <div style="display:flex; gap:11px; align-items:flex-start;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#0f9d63; font-size:18px; flex-shrink:0; margin-top:2px;">check_circle</span>
              <span style="font-size:0.875rem; color:#42474e; line-height:1.6;"><b style="color:#00253b;">We Identify AI Opportunities.</b> Based on what you've shared, we'll identify the top 2–3 areas where AI can save you time or increase revenue.</span>
            </div>
            <div style="display:flex; gap:11px; align-items:flex-start;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#0f9d63; font-size:18px; flex-shrink:0; margin-top:2px;">check_circle</span>
              <span style="font-size:0.875rem; color:#42474e; line-height:1.6;"><b style="color:#00253b;">Honest Recommendation.</b> We'll tell you if it makes business sense, and we'll tell you if it doesn't. We won't sell you AI you don't need.</span>
            </div>
            <div style="display:flex; gap:11px; align-items:flex-start;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#0f9d63; font-size:18px; flex-shrink:0; margin-top:2px;">check_circle</span>
              <span style="font-size:0.875rem; color:#42474e; line-height:1.6;"><b style="color:#00253b;">Clear Next Step.</b> You leave with a clear picture of what's possible, what it costs, and how long it takes. No vague proposals.</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Booking Form -->
      <div>
        <div class="form-box">
          <h2 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.25rem;">Book Your Free Consultation</h2>
          <p style="color:#42474e; font-size:0.875rem; margin-bottom:1.5rem;">3 quick steps, takes about 2 minutes.</p>

          <div class="step-indicator" id="step-indicator">
            <div class="step-dot-sm active" id="ind-1">1</div>
            <div class="step-connector-sm" id="conn-1"></div>
            <div class="step-dot-sm" id="ind-2">2</div>
            <div class="step-connector-sm" id="conn-2"></div>
            <div class="step-dot-sm" id="ind-3">3</div>
          </div>

          <form id="contact-form" novalidate>

          <!-- STEP 1 -->
          <div class="form-step active" id="step-1">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 1 of 3: About You</p>
            <div id="step-1-error-summary" role="alert" class="step-error-summary" style="display:none;">Please fill in the required fields below.</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label class="form-label" for="c-name">Full Name *</label>
                <input class="form-input" id="c-name" type="text" autocomplete="name" placeholder="Your name" required />
              </div>
              <div>
                <label class="form-label" for="c-company">Company Name *</label>
                <input class="form-input" id="c-company" type="text" autocomplete="organization" placeholder="Your company" required />
              </div>
              <div>
                <label class="form-label" for="c-email">Email *</label>
                <input class="form-input" id="c-email" type="email" autocomplete="email" placeholder="you@email.com" required />
              </div>
              <div>
                <label class="form-label" for="c-whatsapp">WhatsApp Number *</label>
                <input class="form-input" id="c-whatsapp" type="tel" autocomplete="tel" placeholder="+971 50 123 4567" required />
              </div>
              <div style="grid-column:1/-1;">
                <label class="form-label" for="c-title">Job Title / Role</label>
                <input class="form-input" id="c-title" type="text" autocomplete="organization-title" placeholder="e.g. CEO, Operations Manager" />
              </div>
            </div>
            <div style="margin-top:1.5rem; display:flex; justify-content:flex-end;">
              <button type="button" onclick="contactStep(2)" class="btn-primary">Next: Your Business →</button>
            </div>
          </div>

          <!-- STEP 2 -->
          <div class="form-step" id="step-2">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 2 of 3: Your Business</p>
            <div id="step-2-error-summary" role="alert" class="step-error-summary" style="display:none;">Please fill in the required fields below.</div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
              <div>
                <label class="form-label" for="c-industry">Industry *</label>
                <select class="form-select" id="c-industry" required>
                  <option value="">Select your industry</option>
                  <option>Real Estate</option>
                  <option>Retail &amp; E-commerce</option>
                  <option>Hospitality &amp; Tourism</option>
                  <option>Logistics &amp; Supply Chain</option>
                  <option>Healthcare</option>
                  <option>Finance &amp; Banking</option>
                  <option>Construction &amp; Property Development</option>
                  <option>Professional Services</option>
                  <option>Other</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="c-size">Company Size *</label>
                <select class="form-select" id="c-size" required>
                  <option value="">Select size</option>
                  <option>1–20 employees</option>
                  <option>21–100 employees</option>
                  <option>101–500 employees</option>
                  <option>500+ employees</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="c-challenge">What is your main challenge or goal? *</label>
              <textarea class="form-textarea" id="c-challenge" rows="3" placeholder="e.g. We're spending too much time on manual lead qualification, or we want to automate customer support on WhatsApp..." required></textarea>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label class="form-label" for="c-budget">Budget Range</label>
                <select class="form-select" id="c-budget">
                  <option value="">Prefer not to say</option>
                  <option>Exploring (no budget set yet)</option>
                  <option>AED 10,000 – 50,000</option>
                  <option>AED 50,000 – 200,000</option>
                  <option>AED 200,000+</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="c-ai-exp">Have you tried AI tools before?</label>
                <select class="form-select" id="c-ai-exp">
                  <option>No, starting from scratch</option>
                  <option>A little, some personal AI tool use</option>
                  <option>Some team tools in use</option>
                  <option>Yes, we have AI systems already</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="c-notes">Anything else we should know? (optional)</label>
              <textarea class="form-textarea" id="c-notes" rows="2" placeholder="Any specific questions or context that would help us prepare..."></textarea>
            </div>

            <!-- Honeypot: leave empty — bots fill this -->
            <input type="text" id="c-honeypot" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

            <div style="margin-top:1.5rem; display:flex; justify-content:space-between;">
              <button type="button" onclick="contactStep(1)" class="btn-outline">← Back</button>
              <button type="button" id="contact-submit-btn" onclick="continueToScheduleContact()" class="btn-primary">Next: Schedule →</button>
            </div>
          </div>

          <!-- STEP 3 -->
          <div class="form-step" id="step-3">
            <p style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1rem;">Step 3 of 3: Schedule Your Call</p>

            <div class="calendly-inline-widget" data-url={calendlyUrl} style="min-width:280px;height:650px;"></div>

            <div style="background:rgba(0,104,117,0.06); border:1px solid rgba(0,104,117,0.20); border-radius:12px; padding:1rem; margin-top:1.25rem; display:flex; align-items:flex-start; gap:12px;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#d97706; font-size:20px; flex-shrink:0; margin-top:2px;">shield</span>
              <p style="color:#42474e; font-size:0.8125rem; line-height:1.6; margin:0;"><strong style="color:#00253b;">100% risk-free.</strong> The call is free. If you proceed and aren't satisfied with the AI system we build, we refund 100% of your investment. No conditions.</p>
            </div>

            <div style="margin-top:1.5rem;">
              <button type="button" onclick="contactStep(2)" class="btn-outline">← Back</button>
            </div>
          </div>

          </form>

          <!-- SUCCESS SCREEN -->
          <div id="success-screen" style="text-align:center; padding:2rem 0;">
            <div style="width:64px; height:64px; border-radius:50%; background:rgba(0,227,253,0.12); border:2px solid rgba(0,227,253,0.35); display:flex; align-items:center; justify-content:center; margin:0 auto 1.25rem;">
              <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:32px;">check_circle</span>
            </div>
            <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.5rem;">You're Booked!</h3>
            <p style="color:#42474e; font-size:0.875rem; margin-bottom:1.5rem; max-width:360px; margin-left:auto; margin-right:auto; line-height:1.6;">Check your email for the calendar invite from Calendly. We'll reach out on WhatsApp beforehand if we need anything from you.</p>
            <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.10); border:1px solid rgba(0,227,253,0.25); border-radius:100px; padding:8px 20px; font-size:0.8125rem; font-weight:600; color:#004f58;">
              <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;">shield</span>
              100% Satisfaction Guarantee applies to everything we build
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- CONTACT FAQ -->
<section class="section" style="background:#f0f3ff;" aria-labelledby="contact-faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="contact-faq-heading">Before You Reach Out</h2>
      <p>Quick answers to the questions we get most.</p>
    </div>
    <FaqAccordion items={contactFaqs} />
  </div>
</section>

<!-- FINAL CTA -->
<section class="section">
  <div class="container">
    <div class="cta-band">
      <h2>Prefer to Chat First?</h2>
      <p style="max-width:480px; margin:1rem auto 2rem;">Send us a WhatsApp message in Arabic or English. We reply fast. Available Sunday – Thursday, 9am – 6pm GST.</p>
      <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener" class="btn-primary">
        Message Us on WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  let currentContactStep = 1;

  type ValidatableField = HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

  function clearFieldError(field: ValidatableField) {
    field.classList.remove('field-invalid');
    field.removeAttribute('aria-invalid');
    const errEl = document.getElementById(field.id + '-error');
    if (errEl) errEl.remove();
  }

  function showFieldError(field: ValidatableField, message: string) {
    field.classList.add('field-invalid');
    field.setAttribute('aria-invalid', 'true');
    const errId = field.id + '-error';
    let errEl = document.getElementById(errId);
    if (!errEl) {
      errEl = document.createElement('p');
      errEl.id = errId;
      errEl.className = 'field-error-msg';
      errEl.setAttribute('role', 'alert');
      field.insertAdjacentElement('afterend', errEl);
    }
    errEl.textContent = message;
    field.setAttribute('aria-describedby', errId);
  }

  function validateContactStep(n: number): boolean {
    const step = document.getElementById('step-' + n);
    if (!step) return true;
    const fields = step.querySelectorAll<ValidatableField>(
      'input[required], select[required], textarea[required]'
    );
    let firstInvalid: ValidatableField | null = null;
    for (const field of fields) {
      if (!field.checkValidity()) {
        showFieldError(field, field.validationMessage);
        if (!firstInvalid) firstInvalid = field;
      } else {
        clearFieldError(field);
      }
    }
    const summary = document.getElementById('step-' + n + '-error-summary');
    if (summary) summary.style.display = firstInvalid ? 'block' : 'none';
    if (firstInvalid) firstInvalid.focus();
    return !firstInvalid;
  }

  function contactStep(n) {
    if (n > currentContactStep && !validateContactStep(currentContactStep)) return;
    document.getElementById('step-' + currentContactStep).classList.remove('active');
    document.getElementById('step-' + n).classList.add('active');
    for (let i = 1; i <= 3; i++) {
      const dot = document.getElementById('ind-' + i);
      dot.classList.remove('active', 'done');
      if (i < n) dot.classList.add('done');
      else if (i === n) dot.classList.add('active');
    }
    for (let i = 1; i <= 2; i++) {
      document.getElementById('conn-' + i).classList.toggle('done', i < n);
    }
    currentContactStep = n;
    document.querySelector('.form-box').scrollIntoView({behavior:'smooth', block:'start'});
  }

  // Submits the qualification data collected in steps 1-2, then reveals the Calendly
  // widget in step 3. Best-effort: scheduling shouldn't be blocked by a CRM hiccup, so a
  // failed submit doesn't stop the user from reaching the calendar.
  async function continueToScheduleContact() {
    const name    = (document.getElementById('c-name') as HTMLInputElement).value.trim();
    const email   = (document.getElementById('c-email') as HTMLInputElement).value.trim();
    const wa      = (document.getElementById('c-whatsapp') as HTMLInputElement).value.trim();
    const company = (document.getElementById('c-company') as HTMLInputElement).value.trim();
    if (!name || !email || !wa || !company) {
      contactStep(1);
      validateContactStep(1);
      return;
    }
    if (!validateContactStep(2)) return;

    const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
    btn.disabled = true;

    const payload = {
      full_name:      name,
      company_name:   company,
      work_email:     email,
      whatsapp:       wa.startsWith('+') ? wa : '+971' + wa.replace(/^0+/, '').replace(/\D/g, ''),
      job_title:      (document.getElementById('c-title') as HTMLInputElement)?.value?.trim() ?? '',
      industry:       (document.getElementById('c-industry') as HTMLSelectElement)?.value ?? '',
      company_size:   (document.getElementById('c-size') as HTMLSelectElement)?.value ?? '',
      main_challenge: (document.getElementById('c-challenge') as HTMLTextAreaElement)?.value?.trim() ?? '',
      budget_range:   (document.getElementById('c-budget') as HTMLSelectElement)?.value ?? '',
      ai_experience:  (document.getElementById('c-ai-exp') as HTMLSelectElement)?.value ?? '',
      notes:          (document.getElementById('c-notes') as HTMLTextAreaElement)?.value?.trim() ?? '',
      source:         'contact_form',
      page_source:    'contact_page',
      utm_source:     sessionStorage.getItem('utm_source') ?? '',
      utm_medium:     sessionStorage.getItem('utm_medium') ?? '',
      utm_campaign:   sessionStorage.getItem('utm_campaign') ?? '',
      website:        (document.getElementById('c-honeypot') as HTMLInputElement)?.value ?? '',
    };

    try {
      await fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    } catch {
      // Silent — Calendly scheduling still proceeds even if the CRM lead write failed.
    }
    btn.disabled = false;
    contactStep(3);
  }

  // Calendly posts this message to the parent window once a slot is actually booked.
  // Guard on the sitewide modal not being open — if it is, its own listener in site.ts
  // owns the event instead, since this page's step ids match the modal's.
  window.addEventListener('message', (e: MessageEvent) => {
    if (!(e.origin ?? '').includes('calendly.com')) return;
    if ((e.data as { event?: string })?.event !== 'calendly.event_scheduled') return;
    const modal = document.getElementById('modal');
    if (modal?.classList.contains('open')) return;
    for (let i = 1; i <= 3; i++) {
      const s = document.getElementById('step-' + i);
      if (s) s.classList.remove('active');
    }
    document.getElementById('step-indicator')!.style.display = 'none';
    document.getElementById('success-screen')!.style.display = 'block';
  });

  // Enter key inside step 1/2 submits the nearest <form> — route that to the same
  // step-advance logic the buttons use, instead of a native full-page submit.
  const contactForm = document.getElementById('contact-form');
  if (contactForm) {
    contactForm.addEventListener('submit', (e) => {
      e.preventDefault();
      if (currentContactStep === 1) contactStep(2);
      else if (currentContactStep === 2) continueToScheduleContact();
    });
  }

  /* This script compiles to an ES module, so top-level functions are module-scoped,
     not global — the inline onclick="" attributes above need them on window. */
  declare global {
    interface Window {
      contactStep: typeof contactStep;
      continueToScheduleContact: typeof continueToScheduleContact;
    }
  }
  Object.assign(window, { contactStep, continueToScheduleContact });
</script>

</BaseLayout>

