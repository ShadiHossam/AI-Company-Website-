    .step-dot-sm { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.78rem; font-weight:700; border:1px solid rgba(0,37,59,0.15); color:#9ca3af; background:#fff; transition:all 0.3s; position:relative; z-index:1; }
    .step-dot-sm.active { border-color:#00e3fd; background:#00e3fd; color:#00253b; }
    .step-dot-sm.done { border-color:#006875; background:rgba(0,104,117,0.10); color:#006875; }
    .step-connector-sm { width:48px; height:2px; background:rgba(0,37,59,0.10); transition:background 0.3s; }
    .step-connector-sm.done { background:#006875; }
    .form-step { display:none; }
    .form-step.active { display:block; }
    #success-screen { display:none; }
    .main-grid { display:grid; grid-template-columns:2fr 3fr; gap:3rem; align-items:start; }
