</section>

<script>
  let currentContactStep = 1;

  function validateContactStep(n: number): boolean {
    const step = document.getElementById('step-' + n);
    if (!step) return true;
    const fields = step.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
      'input[required], select[required], textarea[required]'
    );
    for (const field of fields) {
      if (!field.checkValidity()) {
        field.reportValidity();
        return false;
      }
    }
    return true;
  }

  function contactStep(n) {
    if (n > currentContactStep && !validateContactStep(currentContactStep)) return;
    document.getElementById('step-' + currentContactStep).classList.remove('active');
    document.getElementById('step-' + n).classList.add('active');
    for (let i = 1; i <= 3; i++) {
      const dot = document.getElementById('ind-' + i);
      dot.classList.remove('active', 'done');
      if (i < n) dot.classList.add('done');
      else if (i === n) dot.classList.add('active');
    }
    for (let i = 1; i <= 2; i++) {
      document.getElementById('conn-' + i).classList.toggle('done', i < n);
    }
    currentContactStep = n;
    document.querySelector('.form-box').scrollIntoView({behavior:'smooth', block:'start'});
  }

  function selectMeeting(el, type) {
    document.querySelectorAll('.meeting-type-card').forEach(c => {
      c.classList.remove('selected');
      const lbl = c.querySelector('.meet-label');
      const ico = c.querySelector('.material-symbols-outlined');
      if (lbl) lbl.style.color = '#72787e';
      if (ico) ico.style.color = '#72787e';
    });
    el.classList.add('selected');
    const lbl = el.querySelector('.meet-label');
    const ico = el.querySelector('.material-symbols-outlined');
    if (lbl) lbl.style.color = '#006875';
    if (ico) ico.style.color = '#006875';
    document.getElementById('c-meeting-type').value = type;
  }

  async function submitContact() {
    const name    = (document.getElementById('c-name') as HTMLInputElement).value.trim();
    const email   = (document.getElementById('c-email') as HTMLInputElement).value.trim();
    const wa      = (document.getElementById('c-whatsapp') as HTMLInputElement).value.trim();
    const company = (document.getElementById('c-company') as HTMLInputElement).value.trim();
    if (!name || !email || !wa || !company) {
      contactStep(1);
      validateContactStep(1);
      return;
    }
    if (!validateContactStep(2)) {
      contactStep(2);
      return;
    }

    const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Submitting…';

    const payload = {
      full_name:      name,
      company_name:   company,
      work_email:     email,
      whatsapp:       wa.startsWith('+') ? wa : '+971' + wa.replace(/^0+/, '').replace(/\D/g, ''),
      job_title:      (document.getElementById('c-title') as HTMLInputElement)?.value?.trim() ?? '',
      industry:       (document.getElementById('c-industry') as HTMLSelectElement)?.value ?? '',
      company_size:   (document.getElementById('c-size') as HTMLSelectElement)?.value ?? '',
      main_challenge: (document.getElementById('c-challenge') as HTMLTextAreaElement)?.value?.trim() ?? '',
      budget_range:   (document.getElementById('c-budget') as HTMLSelectElement)?.value ?? '',
      ai_experience:  (document.getElementById('c-ai-exp') as HTMLSelectElement)?.value ?? '',
      meeting_format: (document.getElementById('c-meeting-type') as HTMLInputElement)?.value ?? '',
      preferred_date: (document.getElementById('c-date') as HTMLInputElement)?.value ?? '',
      preferred_time: (document.getElementById('c-time') as HTMLSelectElement)?.value ?? '',
      notes:          (document.getElementById('c-notes') as HTMLTextAreaElement)?.value?.trim() ?? '',
      source:         'contact_form',
      page_source:    'contact_page',
      utm_source:     sessionStorage.getItem('utm_source') ?? '',
      utm_medium:     sessionStorage.getItem('utm_medium') ?? '',
      utm_campaign:   sessionStorage.getItem('utm_campaign') ?? '',
      website:        (document.getElementById('c-honeypot') as HTMLInputElement)?.value ?? '',
    };

    try {
      const res = await fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Failed');
      for (let i = 1; i <= 3; i++) {
        const s = document.getElementById('step-' + i);
        if (s) s.classList.remove('active');
      }
      document.getElementById('step-indicator')!.style.display = 'none';
      document.getElementById('success-screen')!.style.display = 'block';
    } catch {
      btn.disabled = false;
      btn.textContent = 'Book Consultation →';
      const errEl = document.getElementById('contact-submit-error') as HTMLElement;
      if (errEl) errEl.style.display = 'block';
    }
  }

  const dateInput = document.getElementById('c-date');
  if (dateInput) dateInput.setAttribute('min', new Date().toISOString().split('T')[0]);

  /* This script compiles to an ES module, so top-level functions are module-scoped,
     not global — the inline onclick="" attributes above need them on window. */
  declare global {
    interface Window {
      contactStep: typeof contactStep;
      selectMeeting: typeof selectMeeting;
      submitContact: typeof submitContact;
    }
  }
  Object.assign(window, { contactStep, selectMeeting, submitContact });
</script>

</BaseLayout>

