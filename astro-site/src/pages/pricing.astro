---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPageContent, getVal } from "../lib/page-content";

export const prerender = false;

const pc = await loadPageContent('pricing');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const pricingSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Aegis AI: Custom AI Pricing',
  description: 'Every AI project is scoped and priced specifically for your business, goals, and scale.',
  url: 'https://aegisai.ae/pricing',
  areaServed: { '@type': 'City', name: 'Dubai' },
  priceRange: 'Custom pricing',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'AI Services',
    itemListElement: [
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', name: 'Custom AI Development', url: 'https://aegisai.ae/services/custom-ai-development' }, description: 'Custom pricing based on project scope' },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', name: 'AI Training & Workshops', url: 'https://aegisai.ae/services/ai-training' }, description: 'Custom pricing based on team size' },
      { '@type': 'Offer', 'itemOffered': { '@type': 'Service', name: 'AI Strategy Consulting', url: 'https://aegisai.ae/services/ai-strategy' }, description: 'Custom pricing based on business complexity' },
    ],
  },
};

const pricingFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does an AI project with Aegis AI cost?',
      acceptedAnswer: { '@type': 'Answer', text: 'All pricing is scoped specifically to your project. The final cost depends on workflow complexity, number of integrations, data readiness, team size, and timeline. Book a free discovery call for an exact quote.' },
    },
    {
      '@type': 'Question',
      name: 'How does the 100% refund guarantee work?',
      acceptedAnswer: { '@type': 'Answer', text: 'If you are not completely satisfied with what we deliver, we refund the full project investment within 5 business days, no conditions, no disputes. We agree on success criteria upfront; claims must be made within 30 days of delivery.' },
    },
    {
      '@type': 'Question',
      name: 'What if we change direction halfway through the project?',
      acceptedAnswer: { '@type': 'Answer', text: 'Small scope changes are usually absorbed. Major pivots get a revised scope document. If you decide not to continue, you pay only for work completed to that point.' },
    },
    {
      '@type': 'Question',
      name: 'What size companies do you work with?',
      acceptedAnswer: { '@type': 'Answer', text: 'Most clients have between 15 and 300 employees. We have worked with companies as small as 8 people and as large as 600. The key factor is a clear business problem AI can solve, not company size.' },
    },
  ],
};
---

<BaseLayout
  title="Custom AI Pricing Dubai: Tailored to Your Business | Aegis AI"
  description="Every AI project is different. We scope and price each engagement specifically for your business, goals, and scale. Book a free discovery call to get your custom quote."
  canonicalPath="/pricing"
  arPath="/ar/pricing"
  ldJson={[pricingSchema, pricingFaqSchema]}
>

<header class="page-hero" style="padding-top:10rem; padding-bottom:5rem; text-align:center;">
  <div class="container" style="position:relative; z-index:1;">
    <nav class="page-breadcrumb mb-8 justify-center" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Pricing</span>
    </nav>
    <div class="hero-badge mb-6">
      <span class="material-symbols-outlined" style="font-size:16px; color:#006875;">payments</span>
      {g('hero_eyebrow', 'Customized Pricing')}
    </div>
    <h1 style="max-width:48rem; margin:0 auto 1.5rem;">
      {g('hero_h1', 'Every Project is Scoped Specifically for You.')}
    </h1>
    <p style="color:#42474e; font-size:1.125rem; line-height:1.75; max-width:38rem; margin:0 auto 2.5rem;">
      {g('hero_subtext', "We don't believe in one-size-fits-all pricing. Your business, workflow complexity, and goals are unique, so your quote will be too. Book a free 30-minute discovery call and we'll give you a clear, honest number.")}
    </p>
    <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
      <button onclick="openModal(this)" data-source="pricing_hero" class="btn-primary" style="font-size:1rem;">{g('hero_cta_primary', 'Book Free Discovery Call →')}</button>
      <a href="/contact" class="btn-outline" style="font-size:1rem;">{g('hero_cta_secondary', 'Send Us a Message')}</a>
    </div>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:240px;">
  <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=1400&q=80&auto=format&fit=crop" alt="Custom AI project pricing and scoping for businesses" loading="eager" fetchpriority="high" width="1400" height="240" style="width:100%; height:100%; object-fit:cover; object-position:center 35%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<section class="section" style="background:#fff;">
  <div class="container" style="max-width:800px;">
    <div class="section-header">
      <h2>What We Look At When We Price a Project</h2>
      <p style="color:#42474e; font-size:1.0625rem;">No hidden variables. These are the factors that determine scope and cost for every engagement.</p>
    </div>
    <div style="display:inline-flex; align-items:center; gap:0.875rem; background:rgba(0,104,117,0.06); border:1px solid rgba(0,104,117,0.20); border-radius:14px; padding:1rem 1.5rem; margin-bottom:2rem; width:100%; box-sizing:border-box;">
      <span class="material-symbols-outlined" style="color:#006875; font-size:28px; flex-shrink:0;">payments</span>
      <p style="color:#42474e; font-size:0.9375rem; line-height:1.6; margin:0;"><strong style="color:#00253b;">Every project is scoped and priced specifically for your business.</strong> The factors below determine where yours lands. Book a free call and we'll give you an exact number.</p>
    </div>
    <div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">account_tree</span></div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.25rem;">Complexity of the workflow</p>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.65; margin:0;">A single chatbot is different from a full multi-system automation pipeline. The number of integrations, data sources, and decision points all affect scope.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">storage</span></div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.25rem;">Data readiness</p>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.65; margin:0;">How much data cleaning, structuring, or migration is needed before we can build anything useful.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">extension</span></div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.25rem;">Number of integrations</p>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.65; margin:0;">CRMs, ERPs, WhatsApp, property portals, POS systems. Each integration adds development time.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">group</span></div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.25rem;">Team size and training scope</p>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.65; margin:0;">How many people need to be onboarded and trained affects the delivery and support phase.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875; font-size:20px;">speed</span></div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.25rem;">Timeline requirements</p>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.65; margin:0;">Standard timelines give us the best output. Compressed timelines require additional resources and affect cost.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section" style="background:#e7eeff;">
  <div class="container" style="max-width:720px; text-align:center;">
    <h2 style="margin-bottom:1rem;">Whatever the Price, You're Protected</h2>
    <p style="color:#42474e; font-size:1.0625rem; line-height:1.75; max-width:560px; margin:0 auto 2rem;">
      Regardless of the project scope, every engagement comes with our 100% satisfaction guarantee. If you're not happy with what we build, you get a full refund. No questions asked.
    </p>
    <div style="display:inline-flex; align-items:center; gap:.875rem; background:#fff; border:1px solid rgba(245,158,11,0.30); border-radius:16px; padding:1rem 1.5rem; text-align:left;">
      <span class="material-symbols-outlined" style="color:#d97706; font-size:32px; flex-shrink:0;">shield</span>
      <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;"><strong style="color:#00253b;">100% Satisfaction Guarantee.</strong> The only AI company in the UAE offering a full refund on a completed project.</p>
    </div>
  </div>
</section>

<section class="section" style="background:#fff;">
  <div class="container" style="max-width:720px; text-align:center;">
    <h2 style="margin-bottom:1rem;">Book a Free 30-Minute Call</h2>
    <p style="color:#42474e; font-size:1.0625rem; line-height:1.75; max-width:540px; margin:0 auto 2rem;">
      Tell us your biggest operational headache. We'll tell you honestly whether AI can help, what it would look like, and what it would cost. No pitch. No pressure.
    </p>
    <div style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
      <button onclick="openModal(this)" data-source="pricing_cta" class="btn-primary" style="font-size:1rem;">Book Discovery Call →</button>
      <a href="/contact" class="btn-outline" style="font-size:1rem;">Send a Message Instead</a>
    </div>
  </div>
</section>


<div id="contact-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title"></div>

</BaseLayout>

<style>
.value-row { display:flex; align-items:flex-start; gap:1rem; padding:1.25rem 0; border-bottom:1px solid rgba(0,37,59,0.08); }
    .value-row:last-child { border-bottom:none; }
    .value-icon-sm { width:40px; height:40px; border-radius:10px; background:rgba(0,104,117,0.10); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
</style>