  <link rel="alternate" hreflang="en-ae" href="https://aegisai.ae/" />
  <link rel="alternate" hreflang="x-default" href="https://aegisai.ae/" />
  <link rel="sitemap" type="application/xml" href="/sitemap_index.xml" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Aegis AI" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="حلول الذكاء الاصطناعي للشركات في دبي | Aegis AI" />
  <meta property="og:description" content="Aegis AI تبني أنظمة ذكاء اصطناعي مخصصة لعملياتك وتُدرّب فريقك على استخدامها — لخدمة الشركات في دبي." />
  <meta property="og:url" content="https://aegisai.ae/ar" />
  <meta property="og:image" content="https://aegisai.ae/assets/og-home.jpg" />
  <meta property="og:locale" content="ar_AE" />
  <meta property="og:locale:alternate" content="en_AE" />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Arabic:wght@300;400;500;600;700&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal: #006875;
      --teal-light: #00e3fd;
      --navy: #00253b;
      --text: #42474e;
      --muted: #72787e;
      --border: rgba(0,37,59,0.10);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'IBM Plex Arabic', system-ui, -apple-system, sans-serif;
      background: #fff;
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    .section { padding: 5rem 0; }

    /* Navbar */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }
    .navbar-inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .logo { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 1.125rem; color: var(--navy); letter-spacing: -0.02em; }
    .logo-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, var(--navy), var(--teal)); display: flex; align-items: center; justify-content: center; }
    .logo-icon svg { width: 20px; height: 20px; }
    .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
    .lang-link { font-size: 0.8125rem; font-weight: 600; color: var(--muted); padding: 6px 12px; border: 1px solid var(--border); border-radius: 8px; transition: color .2s, border-color .2s; }
    .lang-link:hover { color: var(--teal); border-color: var(--teal); }

    /* Buttons */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, var(--navy) 0%, var(--teal) 100%);
      color: #fff; font-weight: 700; font-size: 1rem; font-family: inherit;
      border: none; border-radius: 12px; padding: 0.875rem 2rem; cursor: pointer;
      transition: opacity .2s, transform .2s; text-decoration: none;
    }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; color: var(--navy); font-weight: 600;
      font-size: 1rem; font-family: inherit; border: 2px solid var(--border);
      border-radius: 12px; padding: 0.875rem 2rem; cursor: pointer;
      transition: border-color .2s, color .2s; text-decoration: none;
    }
    .btn-outline:hover { border-color: var(--teal); color: var(--teal); }

    /* Hero */
    .hero { background: linear-gradient(160deg, #f0f9ff 0%, #e7eeff 50%, #f8f9fe 100%); padding: 7rem 0 5rem; text-align: center; }
    .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(0,227,253,0.12); border: 1px solid rgba(0,227,253,0.30); border-radius: 100px; padding: 6px 18px; color: #004f58; font-size: 0.875rem; font-weight: 600; margin-bottom: 1.75rem; }
    .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--teal-light); animation: pulse 2s ease-in-out infinite; flex-shrink: 0; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.85)} }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: var(--navy); line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1.5rem; }
    .hero p { font-size: 1.125rem; color: var(--text); line-height: 1.9; max-width: 580px; margin: 0 auto 2.5rem; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

    /* Trust strip */
    .trust-strip { background: #fff; border-bottom: 1px solid var(--border); padding: 1.25rem 0; }
    .trust-inner { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 2.5rem; align-items: center; }
    .trust-item { display: flex; align-items: center; gap: 8px; font-size: 0.875rem; font-weight: 600; color: var(--text); }

    /* Cards */
    .card { background: #fff; border: 1px solid var(--border); border-radius: 20px; padding: 2rem; box-shadow: 0 4px 24px rgba(0,59,92,0.05); }
    .grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
    .grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 1.5rem; }

    /* Section header */
    .section-eyebrow { display: inline-block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.10em; color: var(--teal); background: rgba(0,104,117,0.10); border-radius: 100px; padding: 5px 14px; margin-bottom: 1rem; }
    .section-header { text-align: center; max-width: 640px; margin: 0 auto 3rem; }
    .section-header h2 { font-size: clamp(1.625rem, 3.5vw, 2.5rem); font-weight: 800; color: var(--navy); line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 1rem; }
    .section-header p { color: var(--text); font-size: 1rem; line-height: 1.8; }

    /* Industry badge */
    .industry-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(0,104,117,0.10); border-radius: 8px; padding: 5px 10px; margin-bottom: 1rem; font-size: 0.75rem; font-weight: 700; color: var(--teal); text-transform: uppercase; letter-spacing: 0.05em; }

    /* Metric */
    .metric-val { font-size: 1.5rem; font-weight: 800; color: var(--teal); margin: 0 0 2px; }
    .metric-label { font-size: 0.75rem; color: var(--muted); margin: 0; }

    /* Guarantee */
    .guarantee-section { background: #e7eeff; padding: 5rem 0; text-align: center; }
    .guarantee-pill { display: inline-flex; align-items: center; gap: 6px; background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.30); border-radius: 100px; padding: 5px 14px; color: #d97706; font-weight: 600; font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 1.25rem; }
    .guarantee-steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; max-width: 900px; margin: 2.5rem auto; }
    .step-card { background: #f0f3ff; border: 1px solid rgba(0,37,59,0.08); border-radius: 20px; padding: 1.75rem; text-align: center; }
    .step-num { width: 48px; height: 48px; border-radius: 50%; background: var(--teal-light); color: var(--navy); font-weight: 800; font-size: 1.125rem; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; }
    .step-card h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.5rem; }
    .step-card p { font-size: 0.9rem; color: var(--text); line-height: 1.7; margin: 0; }
    .refund-card { background: rgba(245,158,11,0.07); border-color: rgba(245,158,11,0.25); }

    /* CTA Band */
    .cta-band { background: linear-gradient(160deg, var(--navy) 0%, #003d56 100%); padding: 5rem 0; text-align: center; }
    .cta-band h2 { font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 800; color: #fff; margin-bottom: 1.25rem; }
    .cta-band p { color: rgba(255,255,255,0.65); font-size: 1rem; line-height: 1.85; max-width: 500px; margin: 0 auto 2.5rem; }

    /* Footer mini */
    .footer-mini { background: var(--navy); padding: 2.5rem 0; }
    .footer-inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1.25rem; }
    .footer-mini p { color: rgba(255,255,255,0.45); font-size: 0.8125rem; margin: 0; }
    .footer-mini a { color: rgba(255,255,255,0.65); font-size: 0.8125rem; transition: color .2s; }
    .footer-mini a:hover { color: var(--teal-light); }

    /* Material icon helpers */
    .material-symbols-outlined {
      font-family: 'Material Symbols Outlined';
      font-weight: normal; font-style: normal; font-size: 24px;
      line-height: 1; letter-spacing: normal; text-transform: none;
      display: inline-block; white-space: nowrap; direction: ltr;
      -webkit-font-smoothing: antialiased;
    }

    @media (max-width: 768px) {
      .grid-3, .guarantee-steps { grid-template-columns: 1fr; }
      .grid-2 { grid-template-columns: 1fr; }
      .hero { padding: 5rem 0 3.5rem; }
    }
    @media (max-width: 480px) {
      .nav-actions .lang-link { display: none; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar" role="navigation" aria-label="التنقل الرئيسي">
  <div class="container">
