---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "logo": "https://aegisai.ae/favicon-192.png",
    "description": "شركة Aegis AI تبني أنظمة ذكاء اصطناعي مخصصة وتُدرّب الفرق على استخدامها، لخدمة الشركات في دبي والإمارات.",
    "email": "hello@aegisai.ae",
    "telephone": "+97143218888",
    "areaServed": [
      {"@type": "Country", "name": "United Arab Emirates"}
    ],
    "inLanguage": "ar",
    "sameAs": ["https://www.linkedin.com/company/aegis-ai-dubai"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "حلول الذكاء الاصطناعي للشركات في دبي | Aegis AI",
    "url": "https://aegisai.ae/ar",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  }
];
---

<ArBaseLayout
  title="حلول تبني الذكاء الاصطناعي للشركات في الإمارات: بناء وتدريب ونتائج حقيقية | Aegis AI"
  description="Aegis AI تساعد الشركات في الإمارات على تبني الذكاء الاصطناعي وتحقيق نتائج حقيقية منه. تطوير مخصص، تدريب الفرق، استراتيجية، وأتمتة لشركات دبي وأنحاء الإمارات في قطاعات العقارات والتجزئة والضيافة والخدمات اللوجستية. ضمان استرداد ١٠٠٪."
  canonicalPath="/ar"
  enPath="/"
  ldJson={ldJson}
>

<!-- HERO -->
<header class="hero" role="banner">
  <div class="container">
    <div class="hero-badge">
      <span class="pulse" aria-hidden="true"></span>
      شركاؤك في الذكاء الاصطناعي بدبي · ضمان استرداد ١٠٠٪
    </div>
    <h1>
      حلول الذكاء الاصطناعي<br>
      <span class="gradient-text">لشركتك في دبي</span>
    </h1>
    <p>
      نبني أنظمة ذكاء اصطناعي مخصصة لعملياتك ونُدرّب فريقك على استخدامها، لخدمة الشركات الصغيرة والمتوسطة في دبي في قطاعات العقارات والتجزئة والضيافة والخدمات اللوجستية.
    </p>
    <div class="hero-ctas">
      <button onclick="openModal(this)" data-source="ar_home_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/" class="btn-outline" lang="en">عرض بالإنجليزية</a>
    </div>

    <div class="hero-stats">
      <div style="text-align:center;">
        <p class="stat-val">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد الأموال</p>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div style="text-align:center;">
        <p class="stat-val">عربي + إنجليزي</p>
        <p class="stat-lbl">دعم ثنائي اللغة</p>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div style="text-align:center;">
        <p class="stat-val">٩٠ يوم</p>
        <p class="stat-lbl">دعم ما بعد الإطلاق</p>
      </div>
    </div>
  </div>
</header>

<!-- TRUST STRIP -->
<div class="trust-strip" aria-label="مؤشرات الثقة">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#d97706;font-size:20px;direction:ltr;" aria-hidden="true">shield</span>
        لا تدفع شيئاً إذا لم تكن راضياً
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">location_on</span>
        فريق مقيم في دبي
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">language</span>
        دعم عربي وإنجليزي
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">schedule</span>
        دعم ٩٠ يوم بعد الإطلاق
      </div>
    </div>
  </div>
</div>

<!-- WHO THIS IS FOR -->
<section class="section" style="background:#fff;" aria-labelledby="who-heading">
  <div class="container">
    <div class="sec-header">
      <h2 id="who-heading">بُنينا لأجل الشركات المستعدة للتحرك</h2>
      <p>إذا بدا لك أي مما يلي مألوفاً، فأنت في المكان الصحيح.</p>
    </div>
    <div class="grid-3">
      <div class="card">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">timer</span></div>
        <h3 style="font-size:1.125rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;text-align:center;">فريقك لا يستطيع مجاراة حجم العمل.</h3>
        <p class="card-body" style="text-align:center;">العملاء المحتملون يبردون. الاستفسارات تتراكم. فريقك مشدود إلى أقصى حد. المشكلة ليست في الجهد، بل في الحجم. الذكاء الاصطناعي يتولى الأعمال المتكررة ليتفرّغ فريقك لما يحتاج فعلاً إلى إنسان.</p>
      </div>
      <div class="card">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">tune</span></div>
        <h3 style="font-size:1.125rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;text-align:center;">جرّبت أدوات ذكاء اصطناعي. لم تناسب شركتك أياً منها.</h3>
        <p class="card-body" style="text-align:center;">ChatGPT لا يعرف منتجاتك. قوالب Zapier لا تطابق طريقة عملك. الأدوات الجاهزة تُعطي نتائج عامة. أنت تحتاج شيئاً مبنياً حول طريقة عمل شركتك فعلياً.</p>
      </div>
      <div class="card">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">explore</span></div>
        <h3 style="font-size:1.125rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;text-align:center;">تعرف أن الذكاء الاصطناعي قد يساعد. لكنك لا تعرف من أين تبدأ.</h3>
        <p class="card-body" style="text-align:center;">كل مزود يعدك بتحوّل كامل. قلة من يعطيك خطة فعلية. نبدأ بأكبر مشكلة تشغيلية عندك، نحدد ما هو واقعي، ونخبرك بصراحة إن كان الذكاء الاصطناعي هو الخيار الصحيح قبل أن تصرف أي شيء.</p>
      </div>
    </div>
  </div>
</section>

<!-- CASE STUDIES -->
<section class="section" aria-labelledby="results-heading">
  <div class="container">
    <div class="sec-header">
      <div class="eyebrow">نتائج العملاء</div>
      <h2 id="results-heading">ماذا بنت Aegis AI للشركات في الإمارات</h2>
      <p>مشاريع حقيقية، نتائج حقيقية، عبر أبرز القطاعات في دبي.</p>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">home</span>
          وكالة عقارية · دبي
        </div>
        <p class="card-body">وكالة من ٣٠ موظفاً كانت تخسر عملاءها بسبب بطء الرد. متوسط وقت الرد كان ٤ ساعات. بنينا نظام ذكاء اصطناعي للمراسلة الفورية يرد على كل استفسار في أقل من دقيقتين، على مدار الساعة، بالعربي والإنجليزي.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">٤٧٪</p><p class="metric-lbl">ارتفاع في تحويل العملاء</p></div>
          <div><p class="metric-val">أقل من ٢ دقيقة</p><p class="metric-lbl">متوسط وقت الرد الأول</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shopping_bag</span>
          سلسلة تجزئة · الإمارات
        </div>
        <p class="card-body">سلسلة متاجر من ١٢ فرعاً كانت تدير مخزونها يدوياً عبر Excel، مما أدى إلى فائض مستمر ونفاد في المخزون. بنينا لوحة ذكاء اصطناعي تُزامن جميع الفروع في الوقت الفعلي وتتنبأ بالطلب.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">٣ ساعات</p><p class="metric-lbl">توفير يومي في التقارير</p></div>
          <div><p class="metric-val">٣٠٪</p><p class="metric-lbl">تخفيض تكاليف الفائض</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">hotel</span>
          مجموعة فندقية · دبي
        </div>
        <p class="card-body">مجموعة فندقية كانت تدير جميع طلبات الضيوف عبر قناة مراسلة واحدة. موظف واحد، تأخيرات مستمرة. نشرنا كونسيرج ذكاء اصطناعي ثنائي اللغة يتعامل مع ٨٠٪ من الطلبات بشكل مستقل.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">٨٠٪</p><p class="metric-lbl">من الاستفسارات يجيبها الذكاء الاصطناعي</p></div>
          <div><p class="metric-val">٢٤/٧</p><p class="metric-lbl">دعم ثنائي اللغة للضيوف</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">local_shipping</span>
          شركة لوجستية · الإمارات
        </div>
        <p class="card-body">شركة توصيل كانت تخطط لمسارات التوصيل يدوياً. سائقون يتداخلون في نفس المناطق، وقود يُهدر، وتأخيرات في التسليم. بنينا لوحة تحسين مسارات بالذكاء الاصطناعي تُخطط لكل رحلة تلقائياً.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">−٢٢٪</p><p class="metric-lbl">تخفيض تكاليف التوصيل</p></div>
          <div><p class="metric-val">+١٨٪</p><p class="metric-lbl">ارتفاع معدل التسليم في الوقت</p></div>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/ar/results" style="display:inline-flex;align-items:center;gap:6px;font-weight:600;font-size:0.9375rem;color:#006875;">
        عرض جميع نتائج العملاء
        <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_back</span>
      </a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" style="background:#e7eeff;" aria-labelledby="services-heading">
  <div class="container">
    <div class="sec-header">
      <div class="eyebrow">خدماتنا</div>
      <h2 id="services-heading">ذكاء اصطناعي يعمل. فرق تعرف كيف تستخدمه.</h2>
      <p>ثلاث خدمات، مهمة واحدة: جعل شركتك جاهزة للذكاء الاصطناعي حقاً، وليس مجرد فضول تجاهه.</p>
    </div>
    <div class="grid-3">
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">monitor_heart</span></div>
        <h3>تطوير أنظمة ذكاء اصطناعي مخصصة</h3>
        <p class="card-body">نبني أنظمة ذكاء اصطناعي مصممة خصيصاً لعملياتك: روبوتات محادثة، وأتمتة، ولوحات تحكم، وأدوات تنبؤية. مدمجة مع ما تستخدمه بالفعل.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">group</span></div>
        <h3>تدريب الفرق على الذكاء الاصطناعي</h3>
        <p class="card-body">ندرّب فريقك على استخدام الذكاء الاصطناعي بثقة. ورش عمل عملية بالعربي والإنجليزي، مُصمَّمة لقطاعك وأدواتك.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">bar_chart</span></div>
        <h3>استشارات استراتيجية للذكاء الاصطناعي</h3>
        <p class="card-body">نضع خارطة طريق الذكاء الاصطناعي لشركتك، ونحسب العائد على الاستثمار لكل فرصة، ونُقدّم لك خطة تنفيذ واضحة لـ ١٢ شهراً.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/ar/services" class="btn-outline">عرض جميع الخدمات ←</a>
    </div>
  </div>
</section>

<!-- INDUSTRIES -->
<section class="section" style="background:#fff;" aria-labelledby="industries-heading">
  <div class="container">
    <div class="sec-header">
      <h2 id="industries-heading">القطاعات التي نخدمها</h2>
      <p>نركّز على عدد محدود من القطاعات ونتعمّق فيها. هذا يعني مفاجآت أقل، وبناء أسرع، وذكاء اصطناعي يناسب سياق عملك من اليوم الأول.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <a href="/ar/industries/real-estate" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">apartment</span>
        </div>
        <h3 style="font-size:1.25rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;">العقارات</h3>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.5rem;">روبوتات محادثة على واتساب، وأتمتة لأنظمة CRM، وذكاء اصطناعي يؤهّل المشترين ويحجز المعاينات على مدار الساعة، بالعربي والإنجليزي.</p>
        <span class="industry-link">استكشف ذكاء العقارات <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_forward</span></span>
      </a>
      <a href="/ar/industries/retail" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">shopping_bag</span>
        </div>
        <h3 style="font-size:1.25rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;">التجزئة</h3>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.5rem;">توقّع الطلب، وأتمتة إدارة المخزون، ودعم عملاء يتوسّع عبر الفروع دون زيادة عدد الموظفين.</p>
        <span class="industry-link">استكشف ذكاء التجزئة <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_forward</span></span>
      </a>
      <a href="/ar/industries/hospitality" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">hotel</span>
        </div>
        <h3 style="font-size:1.25rem;font-weight:700;color:#00253b;margin-bottom:0.75rem;">الضيافة</h3>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.5rem;">مساعدو استقبال بالذكاء الاصطناعي يتعاملون مع طلبات الضيوف على مدار الساعة، ليتفرّغ فريقك للتفاعلات التي تحتاج لمسة إنسانية.</p>
        <span class="industry-link">استكشف ذكاء الضيافة <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_forward</span></span>
      </a>
    </div>
  </div>
</section>

<!-- COMPARISON TABLE -->
<section class="section" style="background:#e7eeff;" aria-labelledby="compare-heading">
  <div class="container">
    <div class="sec-header">
      <h2 id="compare-heading">شريك الذكاء الاصطناعي الذي يبني ويدعم ويضمن النتائج</h2>
    </div>
    <div class="compare-wrap" style="overflow-x:auto;">
      <table class="compare-table">
        <thead>
          <tr>
            <th style="width:40%;text-align:right;border-radius:0;">الميزة</th>
            <th style="text-align:center;color:#006875;">
              <span style="display:inline-flex;align-items:center;gap:6px;">
                <span class="material-symbols-outlined" style="font-size:16px;color:#d97706;" aria-hidden="true">shield</span>
                Aegis AI
              </span>
            </th>
            <th style="text-align:center;color:#72787e;font-weight:600;">وكالات ذكاء اصطناعي أخرى</th>
            <th style="text-align:center;color:#72787e;font-weight:600;">شركات التدريب</th>
          </tr>
        </thead>
        <tbody>
          <tr><td style="font-weight:500;color:#111c2d;">أنظمة ذكاء اصطناعي مخصصة</td><td class="check-yes">✓</td><td class="check-yes">✓</td><td class="check-no">✗</td></tr>
          <tr><td style="font-weight:500;color:#111c2d;">تدريب الموظفين مشمول</td><td class="check-yes">✓</td><td class="check-no">✗</td><td class="check-yes">✓</td></tr>
          <tr><td style="font-weight:500;color:#111c2d;">تسعير مخصص</td><td class="check-yes">✓</td><td class="check-no">✗</td><td class="check-rarely">يختلف</td></tr>
          <tr><td style="font-weight:500;color:#111c2d;">دعم مستمر</td><td class="check-yes">✓</td><td class="check-rarely">نادراً</td><td class="check-no">✗</td></tr>
          <tr><td style="font-weight:500;color:#111c2d;">ضمان استرداد ١٠٠٪</td><td class="check-yes">✓</td><td class="check-no">✗</td><td class="check-no">✗</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div class="sec-header">
      <h2 id="process-heading">من المكالمة الأولى إلى شركة مدعومة بالذكاء الاصطناعي</h2>
    </div>
    <div class="process-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:24px;">
      <div class="process-step">
        <div class="process-num">١</div>
        <h3 style="font-size:1.0625rem;font-weight:700;color:#00253b;margin-bottom:0.625rem;">مكالمة استكشافية</h3>
