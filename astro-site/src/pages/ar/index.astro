---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "logo": "https://aegisai.ae/favicon-192.png",
    "description": "شركة Aegis AI تبني أنظمة ذكاء اصطناعي مخصصة وتُدرّب الفرق على استخدامها — لخدمة الشركات الصغيرة والمتوسطة في دبي.",
    "email": "hello@aegisai.ae",
    "telephone": "+97143218888",
    "areaServed": { "@type": "City", "name": "Dubai" },
    "inLanguage": "ar",
    "sameAs": ["https://www.linkedin.com/company/aegis-ai-dubai"]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "حلول الذكاء الاصطناعي للشركات في دبي | Aegis AI",
    "url": "https://aegisai.ae/ar",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  }
];
---

<ArBaseLayout
  title="حلول الذكاء الاصطناعي للشركات في دبي | Aegis AI"
  description="Aegis AI تبني أنظمة ذكاء اصطناعي مخصصة لعملياتك وتُدرّب فريقك على استخدامها. نخدم الشركات في دبي في قطاعات العقارات والتجزئة والضيافة والخدمات اللوجستية. ضمان استرداد 100%."
  canonicalPath="/ar"
  enPath="/"
  ldJson={ldJson}
>

<!-- HERO -->
<header class="hero" role="banner">
  <div class="container">
    <div class="hero-badge">
      <span class="pulse" aria-hidden="true"></span>
      شركاؤك في الذكاء الاصطناعي بدبي · ضمان استرداد 100%
    </div>
    <h1>
      حلول الذكاء الاصطناعي<br>
      <span class="gradient-text">لشركتك في دبي</span>
    </h1>
    <p>
      نبني أنظمة ذكاء اصطناعي مخصصة لعملياتك ونُدرّب فريقك على استخدامها — لخدمة الشركات الصغيرة والمتوسطة في دبي في قطاعات العقارات والتجزئة والضيافة والخدمات اللوجستية.
    </p>
    <div class="hero-ctas">
      <button onclick="openModal(this)" data-source="ar_home_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/" class="btn-outline" lang="en">View in English</a>
    </div>

    <div class="hero-stats">
      <div style="text-align:center;">
        <p class="stat-val">100%</p>
        <p class="stat-lbl">ضمان استرداد الأموال</p>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div style="text-align:center;">
        <p class="stat-val">عربي + إنجليزي</p>
        <p class="stat-lbl">دعم ثنائي اللغة</p>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div style="text-align:center;">
        <p class="stat-val">90 يوم</p>
        <p class="stat-lbl">دعم ما بعد الإطلاق</p>
      </div>
    </div>
  </div>
</header>

<!-- TRUST STRIP -->
<div class="trust-strip" aria-label="مؤشرات الثقة">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#d97706;font-size:20px;direction:ltr;" aria-hidden="true">shield</span>
        لا تدفع شيئاً إذا لم تكن راضياً
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">location_on</span>
        فريق مقيم في دبي
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">language</span>
        دعم عربي وإنجليزي
      </div>
      <div class="trust-sep" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">schedule</span>
        دعم 90 يوم بعد الإطلاق
      </div>
    </div>
  </div>
</div>

<!-- CASE STUDIES -->
<section class="section" aria-labelledby="results-heading">
  <div class="container">
    <div class="sec-header">
      <div class="eyebrow">نتائج العملاء</div>
      <h2 id="results-heading">ماذا بنت Aegis AI للشركات في الإمارات</h2>
      <p>مشاريع حقيقية، نتائج حقيقية — عبر أبرز القطاعات في دبي.</p>
    </div>
    <div class="grid-2">
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">home</span>
          وكالة عقارية · دبي
        </div>
        <p class="card-body">وكالة من 30 موظفاً كانت تخسر عملاءها بسبب بطء الرد — متوسط وقت الرد كان 4 ساعات. بنينا نظام ذكاء اصطناعي على WhatsApp يرد على كل استفسار في أقل من دقيقتين، على مدار الساعة، بالعربي والإنجليزي.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">47%</p><p class="metric-lbl">ارتفاع في تحويل العملاء</p></div>
          <div><p class="metric-val">&lt;2 دقيقة</p><p class="metric-lbl">متوسط وقت الرد الأول</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shopping_bag</span>
          سلسلة تجزئة · الإمارات
        </div>
        <p class="card-body">سلسلة متاجر من 12 فرعاً كانت تدير مخزونها يدوياً عبر Excel، مما أدى إلى فائض مستمر ونفاد في المخزون. بنينا لوحة ذكاء اصطناعي تُزامن جميع الفروع في الوقت الفعلي وتتنبأ بالطلب.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">3 ساعات</p><p class="metric-lbl">توفير يومي في التقارير</p></div>
          <div><p class="metric-val">30%</p><p class="metric-lbl">تخفيض تكاليف الفائض</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">hotel</span>
          مجموعة فندقية · دبي
        </div>
        <p class="card-body">مجموعة فندقية كانت تدير جميع طلبات الضيوف عبر خط WhatsApp واحد — موظف واحد، تأخيرات مستمرة. نشرنا كونسيرج ذكاء اصطناعي ثنائي اللغة يتعامل مع 80% من الطلبات بشكل مستقل.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">80%</p><p class="metric-lbl">من الاستفسارات يجيبها الذكاء الاصطناعي</p></div>
          <div><p class="metric-val">24/7</p><p class="metric-lbl">دعم ثنائي اللغة للضيوف</p></div>
        </div>
      </div>
      <div class="card">
        <div class="industry-badge">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">local_shipping</span>
          شركة لوجستية · الإمارات
        </div>
        <p class="card-body">شركة توصيل كانت تخطط لمسارات التوصيل يدوياً عبر Excel — سائقون يتداخلون في نفس المناطق، وقود يُهدر، وتأخيرات في التسليم. بنينا لوحة تحسين مسارات بالذكاء الاصطناعي تُخطط لكل رحلة تلقائياً.</p>
        <div style="display:flex;gap:2rem;">
          <div><p class="metric-val">−22%</p><p class="metric-lbl">تخفيض تكاليف التوصيل</p></div>
          <div><p class="metric-val">+18%</p><p class="metric-lbl">ارتفاع معدل التسليم في الوقت</p></div>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/ar/results" style="display:inline-flex;align-items:center;gap:6px;font-weight:600;font-size:0.9375rem;color:#006875;">
        عرض جميع نتائج العملاء
        <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_back</span>
      </a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section class="section" style="background:#e7eeff;" aria-labelledby="services-heading">
  <div class="container">
    <div class="sec-header">
      <div class="eyebrow">خدماتنا</div>
      <h2 id="services-heading">ذكاء اصطناعي يعمل. فرق تعرف كيف تستخدمه.</h2>
      <p>ثلاث خدمات، مهمة واحدة: جعل شركتك جاهزة للذكاء الاصطناعي حقاً — وليس مجرد فضول تجاهه.</p>
    </div>
    <div class="grid-3">
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">monitor_heart</span></div>
        <h3>تطوير أنظمة ذكاء اصطناعي مخصصة</h3>
        <p class="card-body">نبني أنظمة ذكاء اصطناعي مصممة خصيصاً لعملياتك — روبوتات محادثة، وأتمتة، ولوحات تحكم، وأدوات تنبؤية. مدمجة مع ما تستخدمه بالفعل.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">group</span></div>
        <h3>تدريب الفرق على الذكاء الاصطناعي</h3>
        <p class="card-body">ندرّب فريقك على استخدام الذكاء الاصطناعي بثقة — ورش عمل عملية بالعربي والإنجليزي، مُصمَّمة لقطاعك وأدواتك.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
      <div class="card" style="text-align:center;">
        <div class="svc-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">bar_chart</span></div>
        <h3>استشارات استراتيجية للذكاء الاصطناعي</h3>
        <p class="card-body">نضع خارطة طريق الذكاء الاصطناعي لشركتك، ونحسب العائد على الاستثمار لكل فرصة، ونُقدّم لك خطة تنفيذ واضحة لـ 12 شهراً.</p>
        <div class="guarantee-pill-sm">
          <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">shield</span>
          مشمولة بضمان الاسترداد الكامل
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/ar/services" class="btn-outline">عرض جميع الخدمات ←</a>
    </div>
  </div>
</section>

<!-- GUARANTEE -->
<section class="guarantee-section" aria-labelledby="guarantee-heading">
  <div class="container">
    <div style="text-align:center;max-width:720px;margin:0 auto;">
      <div class="shield-icon">
        <span class="material-symbols-outlined" style="color:#d97706;font-size:36px;direction:ltr;" aria-hidden="true">shield</span>
      </div>
      <div class="guarantee-pill">الضمان الوحيد من نوعه في الإمارات</div>
      <h2 id="guarantee-heading">
        إذا لم تكن راضياً عمّا نبنيه —<br>
        <span style="color:#d97706;">لا تدفع أي شيء.</span>
      </h2>
      <p style="color:#42474e;font-size:1.0625rem;line-height:1.8;margin:0 auto 2.5rem;">نحن نتحمل كل المخاطرة. تحصل على نتائج تفخر بها، أو تغادر باسترداد كل درهم.</p>
    </div>
    <div class="guarantee-steps">
      <div class="step-card">
        <div class="step-num">1</div>
        <h3>نبني نظام الذكاء الاصطناعي الخاص بك</h3>
        <p>نصمم ونبني وننشر نظام الذكاء الاصطناعي المخصص لك — مدمج بالكامل مع عملياتك وأدواتك.</p>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <h3>فريقك يختبره في الواقع</h3>
        <p>استخدمه مع فريقك في العمل الحقيقي. تحقق إذا كان يوفر الوقت ويخفض التكاليف ويُنجز ما وعد به.</p>
      </div>
      <div class="step-card refund-card">
        <div style="width:48px;height:48px;border-radius:50%;background:#f59e0b;display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
          <span class="material-symbols-outlined" style="color:#fff;font-size:22px;direction:ltr;" aria-hidden="true">shield</span>
        </div>
        <h3>غير راضٍ؟ استرداد كامل.</h3>
        <p>إذا لم تكن راضياً تماماً، فقط أخبرنا. نردّ 100% — دون أسئلة ودون تأخير. الطلب خلال 30 يوماً من التسليم.</p>
      </div>
    </div>
    <div style="text-align:center;">
      <div class="guarantee-badge-box">
        <span class="material-symbols-outlined" style="color:#d97706;font-size:32px;flex-shrink:0;direction:ltr;" aria-hidden="true">shield</span>
        <p><strong style="color:#00253b;">ضمان الرضا 100%</strong> — شركة الذكاء الاصطناعي الوحيدة في الإمارات التي تقدم استرداداً كاملاً للمشاريع المكتملة.</p>
      </div>
      <br>
      <button onclick="openModal(this)" data-source="ar_home_guarantee" class="btn-primary" style="font-size:1.0625rem;padding:0.9375rem 2.5rem;">
        ابدأ بدون مخاطرة اليوم ←
      </button>
      <p style="font-size:0.875rem;color:#72787e;margin-top:1rem;">استشارة مجانية · بدون التزام مسبق · بدون مخاطرة</p>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="cta-band" style="border-radius:0;margin:0;" aria-labelledby="cta-heading">
  <div class="container">
    <div style="max-width:640px;margin:0 auto;text-align:center;">
      <div class="cta-badge">
        <span class="pulse" aria-hidden="true"></span>
        <span>استشارة مجانية — بدون التزام</span>
      </div>
      <h2 id="cta-heading">
        هل أنت مستعد لجعل<br>
        <span style="background:linear-gradient(135deg,#00e3fd,#9cf0ff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">شركتك مدعومة بالذكاء الاصطناعي؟</span>
      </h2>
      <p>احجز مكالمة استراتيجية مجانية لمدة 30 دقيقة. لا ضغط مبيعات. فقط وضوح تام حول ما يمكن للذكاء الاصطناعي تحقيقه لشركتك.</p>
      <button onclick="openModal(this)" data-source="ar_home_cta" class="btn-primary" style="font-size:1.0625rem;padding:1rem 2.75rem;margin-bottom:2rem;">
        احجز مكالمة استراتيجية مجانية ←
      </button>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:1.5rem;color:rgba(255,255,255,0.45);font-size:0.875rem;margin-top:1rem;">
        <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">language</span> بالعربي والإنجليزي</span>
        <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">location_on</span> مقيمون في دبي</span>
        <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">schedule</span> رد خلال 4 ساعات</span>
      </div>
    </div>
  </div>
</section>

</ArBaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(160deg, #f0f9ff 0%, #e7eeff 50%, #f8f9fe 100%);
    padding: 8rem 0 5rem;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(0,227,253,0.12); border: 1px solid rgba(0,227,253,0.30);
    border-radius: 100px; padding: 6px 18px; color: #004f58;
    font-size: 0.875rem; font-weight: 600; margin-bottom: 1.75rem;
  }
  .pulse {
    width: 8px; height: 8px; border-radius: 50%;
    background: #00e3fd; flex-shrink: 0;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.85)} }
  .hero h1 { margin-bottom: 1.5rem; }
  .hero p { font-size: 1.125rem; color: #42474e; line-height: 1.9; max-width: 580px; margin: 0 auto 2.5rem; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
  .hero-stats {
    display: inline-flex; flex-wrap: wrap; gap: 1.5rem;
    background: #fff; border: 1px solid rgba(0,37,59,0.10);
    border-radius: 16px; padding: 1.25rem 1.75rem;
    box-shadow: 0 8px 32px rgba(0,59,92,0.06); margin-top: 3rem;
  }
  .stat-val { font-size: 1.25rem; font-weight: 800; color: #00253b; margin: 0; }
  .stat-lbl { font-size: 0.75rem; color: #72787e; margin: 0; }
  .stat-divider { width: 1px; background: rgba(0,37,59,0.10); }

  /* Trust strip */
  .trust-strip { background: #fff; border-bottom: 1px solid rgba(0,37,59,0.08); padding: 1.25rem 0; }
  .trust-inner { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem 2.5rem; align-items: center; }
  .trust-item { display: flex; align-items: center; gap: 8px; font-size: 0.875rem; font-weight: 600; color: #42474e; }
  .trust-sep { width: 1px; height: 20px; background: rgba(0,37,59,0.12); }

  /* Section header */
  .sec-header { text-align: center; max-width: 640px; margin: 0 auto 3rem; }
  .sec-header h2 { margin-bottom: 1rem; }
  .sec-header p { color: #42474e; font-size: 1rem; line-height: 1.8; }
  .eyebrow {
    display: inline-block; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.10em; color: #006875;
    background: rgba(0,104,117,0.10); border-radius: 100px;
    padding: 5px 14px; margin-bottom: 1rem;
  }

  /* Industry badge */
  .industry-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(0,104,117,0.10); border-radius: 8px;
    padding: 5px 10px; margin-bottom: 1rem;
    font-size: 0.75rem; font-weight: 700; color: #006875; text-transform: uppercase;
  }

  /* Cards */
  .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .card-body { font-size: 0.9375rem; line-height: 1.75; margin-bottom: 1.5rem; color: #42474e; }
  .metric-val { font-size: 1.5rem; font-weight: 800; color: #006875; margin: 0 0 2px; }
  .metric-lbl { font-size: 0.75rem; color: #72787e; margin: 0; }

  /* Service cards */
  .svc-icon {
    width: 56px; height: 56px; border-radius: 16px;
    background: rgba(0,227,253,0.12); display: flex; align-items: center;
    justify-content: center; margin: 0 auto 1.5rem; color: #006875;
  }
  .guarantee-pill-sm {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.25);
    border-radius: 8px; padding: 6px 12px; color: #d97706; font-size: 0.75rem; font-weight: 600;
  }

  /* Guarantee section */
  .guarantee-section { background: #e7eeff; padding: 5rem 0; text-align: center; }
