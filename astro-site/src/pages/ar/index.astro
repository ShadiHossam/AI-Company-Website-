---
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';
import '../../styles/homepage-redesign.css';

export const prerender = false;

type Testimonial = {
  client_name: string;
  client_title: string | null;
  ar_client_title: string | null;
  client_company: string | null;
  industry: string | null;
  client_image_url: string | null;
  quote: string;
  ar_quote: string | null;
};

const industryAr: Record<string, string> = {
  'Real Estate': 'العقارات',
  'Retail': 'التجزئة',
  'Hospitality': 'الضيافة',
  'Logistics': 'الخدمات اللوجستية',
};

const fallbackTestimonials: Testimonial[] = [
  {
    client_name: 'Ahmed Al Rashidi',
    client_title: 'CEO',
    ar_client_title: 'الرئيس التنفيذي',
    client_company: 'Al Rashidi Properties',
    industry: 'Real Estate',
    quote: '',
    ar_quote: 'بنت لنا Lenoo AI روبوت محادثة على واتساب يرد على كل استفسار خلال ثوانٍ. فريقنا يوفر ساعات كل أسبوع ونتابع عملاء محتملين أكثر من أي وقت مضى. أفضل استثمار قمنا به.',
    client_image_url: null,
  },
  {
    client_name: 'Sarah Mitchell',
    client_title: 'Operations Director',
    ar_client_title: 'مديرة العمليات',
    client_company: 'Bloom Retail Group',
    industry: 'Retail',
    quote: '',
    ar_quote: 'نظام المخزون بالذكاء الاصطناعي الذي بنوه حلّ مشكلة نفاد المخزون لدينا بالكامل. كنا نخسر مبيعات كل نهاية أسبوع، والآن يتولى النظام إعادة الطلب تلقائياً. عاد علينا بالفائدة أسرع مما توقعنا.',
    client_image_url: null,
  },
  {
    client_name: 'Khalid Al Mansoori',
    client_title: 'General Manager',
    ar_client_title: 'المدير العام',
    client_company: 'Noor Hospitality Group',
    industry: 'Hospitality',
    quote: '',
    ar_quote: 'مساعد الاستقبال بالذكاء الاصطناعي يتعامل مع طلبات الضيوف على مدار الساعة. أصبح فريقنا يركّز على التفاعلات المهمة بدلاً من تكرار نفس الإجابات. غيّر طريقة إدارتنا للفندق.',
    client_image_url: null,
  },
];

const supabase = getSupabaseAdmin();
const { data: rawTestimonials } = await supabase
  .from('testimonials')
  .select('client_name, client_title, ar_client_title, client_company, industry, client_image_url, quote, ar_quote')
  .eq('published', true)
  .is('deleted_at', null)
  .order('sort_order', { ascending: true })
  .limit(6);

const testimonials: Testimonial[] = (rawTestimonials && rawTestimonials.length > 0)
  ? (rawTestimonials as Testimonial[]).filter(t => t.ar_quote)
  : [];
const finalTestimonials = testimonials.length > 0 ? testimonials : fallbackTestimonials;

const getInitials = (name: string): string => {
  const parts = name.trim().split(/\s+/).filter(Boolean);
  if (parts.length === 0) return '';
  const first = parts[0].charAt(0);
  const last = parts.length > 1 ? parts[parts.length - 1].charAt(0) : '';
  return (first + last).toUpperCase();
};

type HomeBlogPost = {
  id: string;
  ar_title: string;
  slug: string;
  ar_description: string | null;
  category: string | null;
  pub_date: string | null;
  author_name: string | null;
  og_image: string | null;
};

let latestPosts: HomeBlogPost[] = [];
try {
  const { data, error } = await supabase
    .from('blog_posts')
    .select('id, ar_title, slug, ar_description, category, pub_date, author_name, og_image')
    .eq('status', 'published')
    .is('deleted_at', null)
    .not('ar_title', 'is', null)
    .order('pub_date', { ascending: false })
    .limit(3);
  if (!error && data) {
    latestPosts = data as HomeBlogPost[];
  }
} catch {
  latestPosts = [];
}

const truncate = (text: string | null, max = 110): string => {
  if (!text) return '';
  if (text.length <= max) return text;
  return text.slice(0, max).replace(/\s+\S*$/, '') + '…';
};

