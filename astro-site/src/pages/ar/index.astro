      </div>
      <div style="width:1px;height:20px;background:rgba(0,37,59,0.12);" aria-hidden="true"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">location_on</span>
        فريق مقيم في دبي
      </div>
      <div style="width:1px;height:20px;background:rgba(0,37,59,0.12);" aria-hidden="true"></div>
      <div class="trust-item">
