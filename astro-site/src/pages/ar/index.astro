---
export const prerender = false;

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "logo": "https://aegisai.ae/favicon-192.png",
    "description": "شركة Aegis AI تبني أنظمة ذكاء اصطناعي مخصصة وتُدرّب الفرق على استخدامها — لخدمة الشركات الصغيرة والمتوسطة في دبي.",
    "email": "hello@aegisai.ae",
    "telephone": "+97143218888",
    "areaServed": { "@type": "City", "name": "Dubai" },
    "sameAs": ["https://www.linkedin.com/company/aegis-ai-dubai"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "حلول الذكاء الاصطناعي للشركات في دبي | Aegis AI",
    "url": "https://aegisai.ae/ar",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" },
  }
];
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#00253b" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
