---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

interface TeamMember {
  name: string;
  title: string;
  bio: string | null;
  image_url: string | null;
  ar_name: string | null;
  ar_title: string | null;
  ar_bio: string | null;
}

let teamMembers: TeamMember[] = [];

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('team_members')
    .select('name, title, bio, image_url, ar_name, ar_title, ar_bio, sort_order')
    .eq('active', true)
    .is('deleted_at', null)
    .order('sort_order');

  if (!error && data) {
    teamMembers = data;
  }
} catch (err) {
  // No team section if the query fails; rest of the page still renders.
}

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "من نحن | Aegis AI دبي",
    "url": "https://lenooai.com/ar/about",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" },
    "about": {
      "@type": "Organization",
      "name": "Aegis AI",
      "url": "https://lenooai.com",
      "areaServed": [
        {"@type": "Country", "name": "United Arab Emirates"}
      ],
      "description": "شركة Aegis AI متخصصة في بناء أنظمة ذكاء اصطناعي مخصصة للشركات في الإمارات."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "من نحن", "item": "https://lenooai.com/ar/about" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "أين يقع فريقكم؟ وهل يمكن اللقاء وجهاً لوجه؟",
        "acceptedAnswer": { "@type": "Answer", "text": "فريقنا مقيم في دبي، في الخليج التجاري. يمكننا الاجتماع بك في مكتبنا أو في مقر شركتك في أي إمارة، أو عبر مكالمة فيديو إذا كان ذلك أنسب لك." }
      },
      {
        "@type": "Question",
        "name": "هل تعملون فقط مع الشركات الكبيرة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "لا. معظم عملائنا شركات صغيرة ومتوسطة في الإمارات. نحدد نطاق كل مشروع وسعره حسب حجم الشركة وأهدافها، دون عقود مؤسسية مبالغ فيها." }
      },
      {
        "@type": "Question",
        "name": "ما الذي يغطيه ضمان الاسترداد بالضبط؟",
        "acceptedAnswer": { "@type": "Answer", "text": "إذا لم تكن راضياً عن النظام الذي بنيناه خلال ٣٠ يوماً من التسليم، نرد لك كامل المبلغ. بدون شروط مخفية وبدون نقاش طويل." }
      },
      {
        "@type": "Question",
        "name": "هل تُدرّبون فريقنا على استخدام النظام؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، التدريب جزء أساسي من كل مشروع. نُدرّب فريقك بالعربية أو الإنجليزية، ونبقى معك ٩٠ يوماً بعد الإطلاق للدعم والتعديلات." }
      },
      {
        "@type": "Question",
        "name": "هل أنظمتكم تعمل بالعربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "كل ما نبنيه ثنائي اللغة منذ اليوم الأول: الأنظمة، مواد التدريب، والدعم. فريقنا نفسه يعمل بالعربية والإنجليزية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="من نحن: فريق الذكاء الاصطناعي خلف نجاح الشركات في الإمارات | Aegis AI"
  description="Aegis AI وكالة ذكاء اصطناعي في دبي، تبني حلول مخصصة وتُدرّب الفرق على استخدامها، وتخدم شركات الإمارات من كل الأحجام وفي مختلف القطاعات."
  canonicalPath="/ar/about"
  enPath="/about"
  ldJson={ldJson}
>

<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>من نحن</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">groups</span>
      من نحن
    </div>
    <h1>شركاؤك في الذكاء الاصطناعي<br><span class="gradient-text">بدبي</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      نحن فريق متخصص مقيم في دبي، نبني أنظمة ذكاء اصطناعي حقيقية للشركات الصغيرة والمتوسطة في الإمارات، بدعم كامل بالعربي والإنجليزي.
    </p>
  </div>
</header>

<!-- HERO IMAGE + MISSION STATS -->
<div style="position:relative; overflow:hidden;">
  <img src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1400&q=80&auto=format&fit=crop" alt="أفق مدينة عالمي يمثل عمل Aegis AI مع الشركات حول العالم" loading="eager" fetchpriority="high" width="1400" height="280" style="position:absolute; inset:0; width:100%;height:100%;object-fit:cover;object-position:center 60%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0) 45%),linear-gradient(to top,rgba(0,19,32,0.40) 0%,transparent 60%);"></div>
  <div style="position:relative; padding:3.5rem 2rem;">
    <div class="glass-dark mission-stats-grid" style="max-width:960px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem;">
      <div>
        <p class="stat-number">٧٠٪</p>
        <p style="color:rgba(255,255,255,0.72); font-size:0.875rem; margin:0; line-height:1.6;">من مشاريع الذكاء الاصطناعي حول العالم لا تصل إلى مرحلة التشغيل الفعلي، ليس بسبب ضعف التقنية، بل لأن الفرق لم تكن جاهزة لها</p>
      </div>
      <div>
        <p class="stat-number">$4.4T</p>
        <p style="color:rgba(255,255,255,0.72); font-size:0.875rem; margin:0; line-height:1.6;">القيمة السنوية المقدّرة التي يمكن أن يضيفها الذكاء الاصطناعي للاقتصاد العالمي، ومعظمها لم تستفد منه بعد الشركات الصغيرة والمتوسطة</p>
      </div>
      <div>
        <p class="stat-number">٣-٥×</p>
        <p style="color:rgba(255,255,255,0.72); font-size:0.875rem; margin:0; line-height:1.6;">الفارق في الأداء بين الشركات التي تبنّت الذكاء الاصطناعي والشركات التي لا تزال مترددة، من حيث السرعة والتكلفة وسرعة الاستجابة للعملاء</p>
      </div>
    </div>
  </div>
</div>

<!-- Mission & Vision -->
<section class="section" aria-labelledby="mv-heading">
  <div class="container" style="max-width:900px;">
    <div style="text-align:center;max-width:640px;margin:0 auto 3rem;">
      <h2 id="mv-heading">لماذا أسسنا هذه الشركة</h2>
    </div>
    <div class="mv-grid">
      <div class="mv-card mv-card-dark">
        <p class="mv-label" style="color:#00e3fd;">مهمتنا</p>
        <p class="mv-title" style="color:#fff;">مساعدة كل شركة على تبني الذكاء الاصطناعي وتحقيق نتائج حقيقية منه.</p>
        <p class="mv-body" style="color:rgba(255,255,255,0.60);">ليس فقط الشركات التي تملك ميزانيات ضخمة وفرق علوم بيانات. كل شركة تستحق استخدام الذكاء الاصطناعي بطريقة تجعل فريقها أكثر قدرة ونتائجها أفضل. نساعدك على الوصول إلى ذلك، دون استبدال موظفيك.</p>
      </div>
      <div class="mv-card mv-card-light">
        <p class="mv-label" style="color:#006875;">رؤيتنا</p>
        <p class="mv-title" style="color:#00253b;">عالم يستطيع فيه أي صاحب عمل استخدام الذكاء الاصطناعي ليحصل على نتائج أفضل من فريقه.</p>
        <p class="mv-body" style="color:#42474e;">أي قطاع، في دبي والإمارات. ذكاء اصطناعي يجعل الفرق الجيدة فرقاً متميزة، دون استبدال الأشخاص الذين بنوا الشركة من الأساس.</p>
      </div>
    </div>
  </div>
</section>

<!-- Mission -->
<section class="section">
  <div class="container">
    <div class="about-split">
      <div>
        <div class="eyebrow">مهمتنا</div>
        <h2>الذكاء الاصطناعي لا يجب أن يكون بعيد المنال</h2>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">
          كثير من الشركات الصغيرة والمتوسطة في دبي تسمع عن الذكاء الاصطناعي ولكنها لا تعرف كيف تبدأ، أو تجد أن الحلول المتاحة مصممة للشركات الكبرى فقط.
        </p>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">
          أُسست Aegis AI لتغيير هذا. نبني أنظمة ذكاء اصطناعي مخصصة لعمليات شركتك بالتحديد، لا حلول جاهزة ولا قوالب عامة.
        </p>
        <p style="color:#42474e;line-height:1.8;">
          وبما أننا وكالة ذكاء اصطناعي مقيمة في دبي، نفهم بيئة العمل المحلية: ثنائية اللغة، متعددة الجنسيات، وسريعة التغير.
        </p>
      </div>
      <div class="about-values">
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">shield</span>
          </div>
          <h3>نتحمل المخاطرة</h3>
          <p>ضمان استرداد ١٠٠٪: إذا لم تكن راضياً عما نبنيه، تحصل على كل درهم. نحن نتحمل المخاطرة، لا أنت.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">handshake</span>
          </div>
          <h3>شراكة حقيقية</h3>
          <p>نعمل معك لفهم عملياتك، لا لبيعك أداة جاهزة. نجاحك هو مقياس نجاحنا.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">language</span>
          </div>
          <h3>ثنائي اللغة بالكامل</h3>
          <p>فريقنا يعمل بالعربي والإنجليزي. الأنظمة التي نبنيها تعمل بالعربي والإنجليزي. لا حواجز لغوية.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Our Story -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="story-heading">
  <div class="container" style="max-width:960px;">
    <div class="story-grid">
      <div>
        <h2 id="story-heading" style="font-size:2rem;margin-bottom:1.25rem;">تأسست بعد مشاهدة مشاريع ذكاء اصطناعي تفشل</h2>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1rem;">أسسنا Aegis AI بعد أن شاهدنا عشرات مشاريع الذكاء الاصطناعي الواعدة تفشل، ليس بسبب خلل في التقنية، بل لأن الفريق الذي يستخدمها لم يكن جاهزاً، ولأن الأنظمة كانت مبنية لشركة غير شركتهم.</p>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1rem;">رأينا شركات ذكاء اصطناعي كبرى تتقاضى ملايين الدراهم من المؤسسات الكبيرة، بينما تُترك الشركات الصغيرة والمتوسطة في دبي والإمارات خارج المعادلة تماماً، لا تزال تعمل بجداول إكسل وحدس فردي.</p>
        <p style="color:#42474e;line-height:1.8;">قررنا أن نفعل الأمر بطريقة مختلفة. نبني ذكاءً اصطناعياً مخصصاً لسير عملك، وندرّب فريقك على استخدامه فعلياً. هذا وعدنا، مدعوم بضمان استرداد كامل إذا لم نُنجزه.</p>
      </div>
      <div>
        <div class="story-timeline-box">
          <p class="eyebrow" style="margin-bottom:1.5rem;">ما يميزنا</p>
          <div class="timeline-item">
            <div class="timeline-dot">٠١</div>
            <div>
              <p class="timeline-title">البناء والتدريب في شراكة واحدة</p>
              <p class="timeline-desc">لا يجب أن تختار بين بناء الذكاء الاصطناعي وتدريب فريقك. نحن نقوم بالاثنين معاً.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">٠٢</div>
            <div>
              <p class="timeline-title">مبني للشركات الحقيقية</p>
              <p class="timeline-desc">بدون عقود مؤسسية مبالغ فيها. كل مشروع يُحدَّد نطاقه وسعره خصيصاً لشركتك وحجمها وأهدافك.</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-dot">٠٣</div>
            <div>
              <p class="timeline-title">ثنائي اللغة منذ اليوم الأول</p>
              <p class="timeline-desc">نُسلّم بلغة فريقك. مواد التدريب والدعم والتوثيق، مُهيّأة لموظفيك من البداية.</p>
            </div>
          </div>
          <div class="timeline-item" style="margin-bottom:0;">
            <div class="timeline-dot">٠٤</div>
            <div>
              <p class="timeline-title">ضمان استرداد كامل: بدون شروط مخفية</p>
              <p class="timeline-desc">إذا لم تكن راضياً عمّا نبنيه، نرد لك ١٠٠٪ من استثمارك. نقطة.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section" style="background:#e7eeff;padding:4rem 0;">
  <div class="container">
    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان استرداد: الوحيد في الإمارات</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">٩٠ يوم</div>
        <div class="stat-label">دعم ما بعد الإطلاق المجاني</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">عربي + إنجليزي</div>
        <div class="stat-label">دعم ثنائي اللغة كامل</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">دبي</div>
        <div class="stat-label">فريق مقيم محلياً</div>
      </div>
    </div>
  </div>
</section>

{teamMembers.length > 0 && (
<section class="section">
  <div class="container">
    <div style="text-align:center;max-width:600px;margin:0 auto 3rem;">
      <div class="eyebrow">فريقنا</div>
      <h2>تعرف على فريق Aegis AI</h2>
    </div>
    <div class="team-grid">
      {teamMembers.map(m => (
        <div class="team-card">
          {m.image_url && <img src={m.image_url} alt={m.ar_name ?? m.name} loading="lazy" />}
          <h3>{m.ar_name ?? m.name}</h3>
          <p class="team-title">{m.ar_title ?? m.title}</p>
          {(m.ar_bio ?? m.bio) && <p class="team-bio">{m.ar_bio ?? m.bio}</p>}
        </div>
      ))}
    </div>
  </div>
</section>
)}

<!-- Business Owner Message -->
<section class="section" style="background:#00253b;padding:5rem 0;" aria-labelledby="owner-heading">
  <div class="container" style="max-width:820px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <p style="color:#00e3fd;font-size:0.75rem;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;margin-bottom:0.75rem;">لأصحاب الأعمال</p>
      <h2 id="owner-heading" style="color:#fff;font-size:clamp(1.375rem,2.5vw,1.75rem);font-weight:800;margin-bottom:0;">إذا كنت تدير شركة الآن، فأنت تشعر بذلك بالفعل.</h2>
    </div>
    <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(0,227,253,0.15);border-radius:20px;padding:2rem 2.5rem;">
      <p style="color:rgba(255,255,255,0.80);font-size:0.9375rem;line-height:1.8;margin-bottom:1rem;">القرارات التي كانت تستغرق يوماً كاملاً أصبحت تحتاج ساعة واحدة. عملاؤك يتوقعون ردوداً أسرع، وتسليماً أسرع، وكل شيء أسرع. هوامش ربحك أضيق مما كانت عليه قبل ثلاث سنوات. وفي مكان ما في قطاعك، بدأ منافس باستخدام الذكاء الاصطناعي، وفريقه ينجز أكثر دون أن يُرهق.</p>
      <p style="color:rgba(255,255,255,0.80);font-size:0.9375rem;line-height:1.8;margin-bottom:1rem;">هذه ليست مشكلة تقنية. إنها مشكلة تشغيلية. وهي قابلة للحل.</p>
      <p style="color:rgba(255,255,255,0.80);font-size:0.9375rem;line-height:1.8;margin-bottom:1.5rem;">نعمل مع أصحاب الأعمال الذين يريدون استخدام الذكاء الاصطناعي لتنمية شركاتهم، لا لاستبدال موظفيهم. نساعدك على معرفة أين يناسب الذكاء الاصطناعي عملك، نبنيه حول طريقة عمل فريقك الفعلية، ونتأكد أن موظفيك يعرفون كيفية استخدامه جيداً. الهدف دائماً واحد: نتائج أفضل بنفس الفريق الذي لديك.</p>
      <p style="color:#00e3fd;font-size:0.9375rem;font-weight:700;margin:0;">تبني الذكاء الاصطناعي، بالطريقة الصحيحة. هذا ما نحن هنا من أجله.</p>
    </div>
    <div class="owner-outcomes-grid">
      <div class="owner-outcome-card">
        <span class="material-symbols-outlined" style="color:#00e3fd;font-size:28px;margin-bottom:0.75rem;display:block;direction:ltr;" aria-hidden="true">trending_up</span>
        <p style="color:#fff;font-weight:700;font-size:0.9375rem;margin-bottom:0.25rem;">إيرادات أكثر</p>
        <p style="color:rgba(255,255,255,0.50);font-size:0.8125rem;margin:0;line-height:1.5;">متابعة العملاء المحتملين بالذكاء الاصطناعي تعمل أثناء نومك</p>
      </div>
      <div class="owner-outcome-card">
        <span class="material-symbols-outlined" style="color:#00e3fd;font-size:28px;margin-bottom:0.75rem;display:block;direction:ltr;" aria-hidden="true">schedule</span>
        <p style="color:#fff;font-weight:700;font-size:0.9375rem;margin-bottom:0.25rem;">وقت أقل مهدور</p>
        <p style="color:rgba(255,255,255,0.50);font-size:0.8125rem;margin:0;line-height:1.5;">أتمتة المهام المتكررة التي تستنزف فريقك كل يوم</p>
      </div>
      <div class="owner-outcome-card">
