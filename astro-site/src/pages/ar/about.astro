---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": "من نحن | Aegis AI دبي",
    "url": "https://aegisai.ae/ar/about",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" },
    "about": {
      "@type": "Organization",
      "name": "Aegis AI",
      "url": "https://aegisai.ae",
      "areaServed": [
        {"@type": "Country", "name": "United Arab Emirates"},
        {"@type": "Country", "name": "Saudi Arabia"},
        {"@type": "Country", "name": "Kuwait"},
        {"@type": "Country", "name": "Qatar"}
      ],
      "description": "شركة Aegis AI متخصصة في بناء أنظمة ذكاء اصطناعي مخصصة للشركات في الإمارات والسعودية والكويت وقطر."
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "من نحن", "item": "https://aegisai.ae/ar/about" }
    ]
  }
];
---

<ArBaseLayout
  title="من نحن: شركة ذكاء اصطناعي في دبي تخدم دول الخليج | Aegis AI"
  description="Aegis AI شركة متخصصة في بناء أنظمة ذكاء اصطناعي مخصصة للشركات في الإمارات والسعودية والكويت وقطر. فريق مقيم في دبي، دعم ثنائي اللغة، وضمان استرداد 100%."
  canonicalPath="/ar/about"
  enPath="/about"
  ldJson={ldJson}
>

<header class="page-hero">
  <div class="container">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a><span class="sep">/</span><strong class="current">من نحن</strong>
    </nav>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">groups</span>
      من نحن
    </div>
    <h1>شركاؤك في الذكاء الاصطناعي<br><span class="gradient-text">بدبي</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      نحن فريق متخصص مقيم في دبي، نبني أنظمة ذكاء اصطناعي حقيقية للشركات الصغيرة والمتوسطة في الإمارات، بدعم كامل بالعربي والإنجليزي.
    </p>
  </div>
</header>

<!-- Mission -->
<section class="section">
  <div class="container">
    <div class="about-split">
      <div>
        <div class="eyebrow">مهمتنا</div>
        <h2>الذكاء الاصطناعي لا يجب أن يكون بعيد المنال</h2>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">
          كثير من الشركات الصغيرة والمتوسطة في دبي تسمع عن الذكاء الاصطناعي ولكنها لا تعرف كيف تبدأ، أو تجد أن الحلول المتاحة مصممة للشركات الكبرى فقط.
        </p>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">
          أُسست Aegis AI لتغيير هذا. نبني أنظمة ذكاء اصطناعي مخصصة لعمليات شركتك بالتحديد، لا حلول جاهزة ولا قوالب عامة.
        </p>
        <p style="color:#42474e;line-height:1.8;">
          وبما أن فريقنا مقيم في دبي، نفهم بيئة العمل المحلية: ثنائية اللغة، متعددة الجنسيات، وسريعة التغير.
        </p>
      </div>
      <div class="about-values">
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">shield</span>
          </div>
          <h3>نتحمل المخاطرة</h3>
          <p>ضمان استرداد 100%: إذا لم تكن راضياً عما نبنيه، تحصل على كل درهم. نحن نتحمل المخاطرة، لا أنت.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">handshake</span>
          </div>
          <h3>شراكة حقيقية</h3>
          <p>نعمل معك لفهم عملياتك، لا لبيعك أداة جاهزة. نجاحك هو مقياس نجاحنا.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">
            <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">language</span>
          </div>
          <h3>ثنائي اللغة بالكامل</h3>
          <p>فريقنا يعمل بالعربي والإنجليزي. الأنظمة التي نبنيها تعمل بالعربي والإنجليزي. لا حواجز لغوية.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="section" style="background:#e7eeff;padding:4rem 0;">
  <div class="container">
    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-number">100%</div>
        <div class="stat-label">ضمان استرداد: الوحيد في الإمارات</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">90 يوم</div>
        <div class="stat-label">دعم ما بعد الإطلاق المجاني</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">عربي + EN</div>
        <div class="stat-label">دعم ثنائي اللغة كامل</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">دبي</div>
        <div class="stat-label">فريق مقيم محلياً</div>
      </div>
    </div>
  </div>
</section>

<!-- What makes us different -->
<section class="section">
  <div class="container">
    <div style="text-align:center;max-width:600px;margin:0 auto 3rem;">
      <div class="eyebrow">ما يميزنا</div>
      <h2>لماذا تختار Aegis AI؟</h2>
    </div>
    <div class="diff-grid">
      <div class="diff-card">
        <span class="material-symbols-outlined" style="font-size:28px;color:#006875;direction:ltr;margin-bottom:.75rem;" aria-hidden="true">location_city</span>
        <h3>مقيمون في دبي</h3>
        <p style="color:#42474e;line-height:1.7;">فريقنا في دبي، يفهم قوانين العمل والمتطلبات المحلية ويمكنه الاجتماع بك وجهاً لوجه.</p>
      </div>
      <div class="diff-card">
        <span class="material-symbols-outlined" style="font-size:28px;color:#006875;direction:ltr;margin-bottom:.75rem;" aria-hidden="true">precision_manufacturing</span>
        <h3>حلول مخصصة فقط</h3>
        <p style="color:#42474e;line-height:1.7;">لا نبيع برامج جاهزة. كل ما نبنيه مصمم لعمليات شركتك بالتحديد وليس لأي شركة أخرى.</p>
      </div>
      <div class="diff-card">
        <span class="material-symbols-outlined" style="font-size:28px;color:#006875;direction:ltr;margin-bottom:.75rem;" aria-hidden="true">groups_3</span>
        <h3>نُدرّب فريقك</h3>
        <p style="color:#42474e;line-height:1.7;">النظام وحده لا يكفي. ندرّب فريقك على استخدامه بثقة حتى لا يجمع الغبار بعد الإطلاق.</p>
      </div>
      <div class="diff-card">
        <span class="material-symbols-outlined" style="font-size:28px;color:#d97706;direction:ltr;margin-bottom:.75rem;" aria-hidden="true">shield</span>
        <h3>الضمان الوحيد في الإمارات</h3>
        <p style="color:#42474e;line-height:1.7;">إذا لم تكن راضياً تماماً عما نبنيه خلال 30 يوماً، نردّ كل درهم. لا استثناءات.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-band section" style="border-radius:24px;margin:0 2rem 4rem;">
  <div class="container">
    <div style="text-align:center;max-width:560px;margin:0 auto;">
      <h2 style="margin-bottom:1rem;">هل أنت مستعد للبدء؟</h2>
      <p style="margin-bottom:2rem;">احجز مكالمة استراتيجية مجانية. 30 دقيقة، بدون ضغط مبيعات.</p>
      <button onclick="openModal(this)" data-source="ar_about_cta" class="btn-primary">احجز استشارة مجانية ←</button>
    </div>
  </div>
</section>

</ArBaseLayout>

<style>
  .eyebrow {
    display: inline-block; font-size: 0.75rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.10em; color: #006875;
    background: rgba(0,104,117,0.10); border-radius: 100px;
    padding: 5px 14px; margin-bottom: 1rem;
  }
  .about-split {
    display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start;
  }
  .about-split h2 { margin-bottom: 1.5rem; }
  .about-values { display: flex; flex-direction: column; gap: 1.25rem; }
  .value-card {
    background: #fff; border: 1px solid #E2E8F0; border-radius: 16px;
    padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem;
  }
  .value-icon { color: #006875; }
  .value-card h3 { font-size: 1rem; font-weight: 700; color: #00253b; margin: 0; }
  .value-card p { font-size: 0.875rem; color: #42474e; line-height: 1.7; margin: 0; }
  .stats-row {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center;
  }
  .stat-item .stat-number { font-size: clamp(1.5rem, 3vw, 2.5rem); font-weight: 800; color: #00253b; line-height: 1.1; }
  .stat-item .stat-label { font-size: 0.875rem; color: #42474e; margin-top: 0.5rem; }
  .diff-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .diff-card {
    background: #f9f9ff; border: 1px solid #E2E8F0; border-radius: 16px;
    padding: 1.75rem; display: flex; flex-direction: column;
  }
  .diff-card h3 { font-size: 1rem; font-weight: 700; color: #00253b; margin: 0 0 0.5rem; }
  @media (max-width: 1024px) { .diff-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .about-split { grid-template-columns: 1fr; gap: 2rem; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .diff-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .stats-row { grid-template-columns: 1fr; }
    .diff-grid { grid-template-columns: 1fr; }
  }
</style>
