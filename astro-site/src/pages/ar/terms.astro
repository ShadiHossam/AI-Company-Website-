---
export const prerender = false;
import ArBaseLayout from "../../layouts/ArBaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

let dynamicTitle: string | null = null;
let dynamicSections: { heading: string; body: string }[] | null = null;
let dynamicLastUpdated: string | null = null;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('legal_pages')
    .select('title, sections, ar_title, ar_sections, last_updated')
    .eq('slug', 'terms')
    .single();

  if (!error && data) {
    const arSections = Array.isArray(data.ar_sections) && data.ar_sections.length > 0 ? data.ar_sections : null;
    const enSections = Array.isArray(data.sections) && data.sections.length > 0 ? data.sections : null;
    dynamicTitle = data.ar_title ?? data.title ?? null;
    dynamicSections = arSections ?? enSections;
    dynamicLastUpdated = data.last_updated ?? null;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<ArBaseLayout
  title={dynamicTitle ? `${dynamicTitle} | Aegis AI` : "شروط الخدمة | Aegis AI"}
  description="شروط وأحكام Aegis AI لخدمات تطوير الذكاء الاصطناعي المخصص والاستشارات والتدريب في دولة الإمارات."
  canonicalPath="/ar/terms"
  enPath="/terms"
  ogImage="/assets/og-terms.jpg"
  noindex={true}
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>شروط الخدمة</div>
    <h1>{dynamicTitle ?? <>شروط <span class="gradient-text">الخدمة</span></>}</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      {dynamicLastUpdated ? `آخر تحديث: ${dynamicLastUpdated}.` : "آخر تحديث: 11 يونيو 2026."} يُرجى قراءة هذه الشروط بعناية قبل استخدام موقعنا أو التعاقد على خدماتنا.
    </p>
  </div>
</header>

<main class="section">
  <div class="container" style="max-width:760px;">
    <div class="prose">

      {dynamicSections ? (
        dynamicSections.map((section) => (
          <section>
            <h2 set:html={section.heading}></h2>
            <p set:html={section.body}></p>
          </section>
        ))
      ) : (
        <>
          <section>
            <h2>1. التعريفات</h2>
            <p>تنطبق التعريفات التالية في جميع أنحاء شروط الخدمة هذه.</p>
            <ul>
              <li><strong>الشركة</strong> (يُشار إليها بـ "نحن" أو "لنا") تعني <strong>Aegis AI</strong>، وهي شركة استشارات تقنية تعمل في دبي، الإمارات العربية المتحدة.</li>
              <li><strong>الموقع</strong> يعني الموقع الإلكتروني المتاح على <strong>https://aegisai.ae</strong>.</li>
              <li><strong>الخدمة</strong> تعني الموقع وجميع خدمات تطوير الذكاء الاصطناعي المخصص والاستشارات الاستراتيجية والتدريب التي تقدمها الشركة.</li>
              <li><strong>أنت</strong> (يُشار إليك بـ "العميل" أو "المستخدم") تعني الفرد الذي يستخدم الخدمة، أو الشركة أو الكيان القانوني الذي يتصرف نيابة عنه.</li>
              <li><strong>بيان نطاق العمل (SOW)</strong> يعني وثيقة موقعة منفصلة تحدد مخرجات المشروع والجداول الزمنية وشروط الدفع.</li>
              <li><strong>الدولة</strong> تعني الإمارات العربية المتحدة.</li>
              <li><strong>الجهاز</strong> يعني أي جهاز (حاسوب أو هاتف محمول أو جهاز لوحي) يمكنه الوصول إلى الموقع.</li>
            </ul>
          </section>

          <section>
            <h2>2. الإقرار والموافقة</h2>
            <p>تحكم شروط الخدمة هذه استخدامك لخدمتنا وتشكل اتفاقية ملزمة قانونياً بينك وبين Aegis AI. بدخولك إلى الموقع أو حجزك لاستشارة أو تعاقدك على خدماتنا، فإنك تقر بأنك قرأت هذه الشروط وفهمتها وتوافق على الالتزام بها بالكامل.</p>
            <p>تقر بأن عمرك 18 عاماً على الأقل. إذا كنت تستخدم الخدمة نيابة عن شركة أو مؤسسة، فإنك تقر بأن لديك الصلاحية لإلزام تلك الجهة بهذه الشروط.</p>
            <p>إذا كنت لا توافق على أي جزء من هذه الشروط، يجب عليك التوقف عن استخدام الموقع وخدماتنا فوراً. الوصول إلى الخدمة مشروط أيضاً بموافقتك على <a href="/ar/privacy">سياسة الخصوصية</a> الخاصة بنا، والتي توضح كيفية جمع بياناتك الشخصية وحمايتها واستخدامها.</p>
          </section>

          <section>
            <h2>3. الخدمات المقدمة</h2>
            <p>تقدم Aegis AI خدمات استشارات تقنية مصممة للشركات الصغيرة والمتوسطة في دبي والإمارات، متخصصة في:</p>
            <ul>
              <li><strong>تطوير الذكاء الاصطناعي المخصص:</strong> تصميم ونشر وكلاء ذكاء اصطناعي مخصصين، وأتمتة محادثات الواتساب، وقواعد بيانات، ولوحات تحكم تشغيلية مدمجة مع عمليات العميل.</li>
              <li><strong>تدريب وورش عمل الذكاء الاصطناعي:</strong> تقديم ورش تأهيل للأقسام باللغتين العربية والإنجليزية لضمان تبني الفريق الداخلي.</li>
              <li><strong>استراتيجية الذكاء الاصطناعي والاستشارات:</strong> وضع خطط لـ12 شهراً، وحساب العائد على الاستثمار، ومراجعات تقنية محايدة تجاه الموردين.</li>
            </ul>
            <p>سيتم تحديد جميع المخرجات والجداول الزمنية وشروط الدفع في بيان نطاق عمل (SOW) أو اتفاقية خدمة موقعة منفصلة، والتي تكون لها الأولوية على هذه الشروط العامة في حال وجود تعارض.</p>
          </section>

          <section>
            <h2>4. سياسة ضمان الاسترداد 100٪</h2>
            <div class="guarantee-box">
              <p class="title">ضمان خالٍ من المخاطر بالكامل</p>
              <p>نفخر بتقديم سياسة استرداد كاملة لمشاريع تطوير الذكاء الاصطناعي المخصص وورش العمل. يخضع ضماننا للمعايير التالية لحماية الطرفين:</p>
              <ul>
                <li><strong>معايير نجاح محددة:</strong> يحتوي كل مشروع على معالم واضحة وقابلة للقياس الموضوعي، مُحددة كتابياً ضمن بيان نطاق العمل (SOW) قبل بدء العمل.</li>
                <li><strong>مشاركة فعالة:</strong> يجب على العميل تقديم بيانات الاعتماد اللازمة وعينات المستندات وحضور جلسات المواءمة المجدولة اللازمة لبناء النظام.</li>
                <li><strong>مُحفّز الضمان:</strong> إذا فشل النظام أو التدريب المخصص، عند مرحلة التسليم النهائية للنطاق المحدد الأولي، في تحقيق معايير النجاح المُتفق عليها رغم التعاون الفعّال، يحق للعميل طلب استرداد 100٪ من رسوم التطوير المدفوعة حتى ذلك التاريخ.</li>
                <li><strong>حماية الملكية الفكرية:</strong> عند تفعيل الاسترداد الكامل، تبقى جميع التراخيص والشيفرة البرمجية المبنية والإعدادات المخصصة والملكية الفكرية المطورة أثناء المشروع ملكاً حصرياً لـ Aegis AI ولا يجوز للعميل استخدامها.</li>
              </ul>
            </div>
          </section>

          <section>
            <h2>5. رسوم واجهات برمجة الطرف الثالث والاشتراكات</h2>
            <p>ما لم يُنص صراحة في بيان نطاق العمل، لا تشمل رسوم المشروع رسوم استخدام الطرف الثالث المباشرة (مثل رسوم واجهات برمجة نماذج الذكاء الاصطناعي، أو البنية التحتية السحابية، أو منصات الأتمتة، أو واجهات الرسائل). يتم إعداد هذه الرسوم مباشرة على حسابات الفوترة الخاصة بالعميل أو تُحسب بشفافية دون أي هامش ربح.</p>
            <p>تشمل مشاريع التطوير لدينا <strong>90 يوماً من الدعم المجاني بعد الإطلاق</strong> (إصلاح الأخطاء ومراقبة الأداء). التحديثات المستمرة وباقات الاشتراك التشغيلي ووحدات التدريب الإضافية تخضع لاتفاقيات شهرية منفصلة.</p>
          </section>

          <section>
            <h2>6. حقوق الملكية الفكرية</h2>
            <p>ما لم يُتفق على خلاف ذلك في بيان نطاق عمل موقع، يُمنح العميل عند السداد الكامل والنهائي لجميع الفواتير ترخيصاً دائماً وعالمياً وغير حصري وغير قابل للتحويل لاستخدام البرمجيات وسير العمل والإعدادات المخصصة المطورة خصيصاً لمؤسسته.</p>
            <p>تحتفظ Aegis AI بجميع الحقوق في وحداتها البرمجية الجاهزة والأطر الأساسية ومنهجيات التدريب ووكلاء الذكاء الاصطناعي المملوكة التي طُوّرت قبل أو خارج نطاق بيان العمل المحدد. جميع محتوى الموقع (بما في ذلك النصوص والرسومات والشعارات والتصميم) هو ملكية فكرية حصرية لـ Aegis AI ولا يجوز إعادة إنتاجه دون موافقة كتابية مسبقة.</p>
          </section>

          <section>
            <h2>7. مسؤوليات العميل</h2>
            <p>لضمان تسليم المشروع في وقته، توافق على تقديم:</p>
            <ul>
              <li>مصادر بيانات دقيقة وأوراق عمليات وعينات مستندات لازمة لتدريب أنظمة الذكاء الاصطناعي المخصصة.</li>
              <li>مراجعات وتعليقات وموافقات تشغيلية في الوقت المناسب خلال 3 أيام عمل من عرض المعالم.</li>
              <li>إتاحة وصول الأقسام لورش التدريب لضمان مشاركة الموظفين.</li>
            </ul>
            <p>التأخيرات الناتجة عن عدم توفير الوصول أو البيانات أو الردود لفترة طويلة قد تؤدي إلى تعديل الجداول الزمنية النهائية للإطلاق. لا تتحمل Aegis AI مسؤولية تأخيرات التسليم الناتجة عن تأخيرات من جانب العميل.</p>
          </section>

          <section>
            <h2>8. روابط لمواقع أخرى</h2>
            <p>قد يحتوي موقعنا على روابط لمواقع أو خدمات تابعة لأطراف ثالثة لا تملكها Aegis AI أو تتحكم بها. لا نتحمل أي مسؤولية عن محتوى أو سياسات خصوصية أو ممارسات أي موقع تابع لطرف ثالث. لا نضمن عروض أي من هذه الجهات أو الأفراد أو مواقعهم.</p>
            <p>ننصحك بشدة بقراءة الشروط والأحكام وسياسات الخصوصية لأي مواقع تابعة لطرف ثالث تزورها. لا تتحمل Aegis AI مسؤولية أي خسارة أو ضرر ناتج عن استخدامك أو اعتمادك على أي محتوى أو سلع أو خدمات متاحة عبر هذه الروابط.</p>
          </section>

          <section>
            <h2>9. الإنهاء</h2>
            <p>نحتفظ بالحق في إنهاء أو تعليق وصولك إلى الموقع وخدماتنا فوراً، دون إشعار مسبق أو مسؤولية، لأي سبب، بما في ذلك مخالفتك لشروط الخدمة هذه.</p>
            <p>عند الإنهاء، يتوقف حقك في استخدام الخدمة فوراً. إذا رغبت في إنهاء علاقتك معنا، يمكنك ببساطة التوقف عن استخدام الموقع. بالنسبة للمشاريع النشطة، تخضع بنود الإنهاء والرسوم المرتبطة بها لبيان نطاق العمل الموقع.</p>
          </section>

          <section>
            <h2>10. إخلاء المسؤولية "كما هي" و"كما هو متاح"</h2>
            <p>يُقدَّم الموقع ومحتواه على أساس "كما هو" و"كما هو متاح" دون أي ضمانات من أي نوع، صريحة أو ضمنية، بما في ذلك على سبيل المثال لا الحصر الضمانات الضمنية للتسويق أو الملاءمة لغرض معين أو عدم الانتهاك.</p>
            <p>لا تضمن Aegis AI أن الموقع سيكون متواصلاً أو خالياً من الأخطاء أو الفيروسات أو أي مكونات ضارة أخرى. لا نضمن دقة أو اكتمال أو فائدة أي معلومات على الموقع، وأنت تعتمد على هذه المعلومات على مسؤوليتك الخاصة بالكامل.</p>
            <p>لا تسمح بعض الأنظمة القضائية باستثناء الضمانات الضمنية، لذا قد لا تنطبق بعض القيود المذكورة أعلاه عليك.</p>
          </section>

          <section>
            <h2>11. تحديد المسؤولية</h2>
            <p>إلى أقصى حد يسمح به القانون الإماراتي المعمول به، لن تتحمل Aegis AI ومديروها وموظفوها وشركاؤها ووكلاؤها وموردوها أو الشركات التابعة لها المسؤولية عن أي أضرار غير مباشرة أو عرضية أو خاصة أو تبعية (بما في ذلك خسارة الأرباح أو الإيرادات أو البيانات أو السمعة التجارية أو انقطاع الأعمال) الناتجة عن وصولك إلى الموقع أو خدماتنا أو استخدامها أو عدم القدرة على استخدامها.</p>
            <p>لا تتجاوز مسؤوليتنا الإجمالية تجاهك عن أي مطالبة ناشئة عن هذه الشروط أو الخدمة القيمة الأكبر بين (أ) إجمالي الرسوم التي دفعتها لـ Aegis AI بموجب بيان نطاق العمل المعمول به أو (ب) 500 درهم إماراتي.</p>
          </section>

          <section>
            <h2>12. تسوية النزاعات</h2>
            <p>إذا كان لديك مخاوف أو نزاع بشأن الخدمة، فإنك توافق على محاولة حل النزاع ودياً أولاً بالتواصل معنا على <strong>hello@aegisai.ae</strong>. سنبذل جهوداً معقولة لحل النزاعات ودياً خلال 30 يوماً من استلام الإشعار الكتابي.</p>
            <p>إذا لم يتم التوصل إلى حل ودي، يوافق الطرفان على إحالة النزاع إلى الوساطة قبل اللجوء إلى التقاضي. إذا فشلت الوساطة، يُحل النزاع وفقاً للقانون الحاكم والاختصاص القضائي المحدد في القسم 13 أدناه.</p>
          </section>

          <section>
            <h2>13. القانون الحاكم والاختصاص القضائي</h2>
            <p>تخضع شروط الخدمة هذه وأي نزاع أو مطالبة ناشئة عنها أو مرتبطة بها لقوانين <strong>إمارة دبي</strong> والقوانين الاتحادية لـ<strong>دولة الإمارات العربية المتحدة</strong>، دون اعتبار لتعارض أحكام القانون.</p>
            <p>توافق على أن أي إجراء أو دعوى قانونية تتعلق باستخدامك للخدمة تُرفع حصرياً أمام محاكم إمارة دبي، وتُقر بخضوعك لاختصاصها القضائي بشكل نهائي.</p>
          </section>

          <section>
            <h2>14. مستخدمو الاتحاد الأوروبي</h2>
            <p>إذا كنت مستهلكاً مقيماً في الاتحاد الأوروبي، فإنك تستفيد من أي أحكام إلزامية بموجب قانون البلد الذي تقيم فيه. لا يؤثر أي شيء في شروط الخدمة هذه على حقوقك كمستهلك في الاعتماد على هذه الأحكام القانونية المحلية الإلزامية.</p>
          </section>

          <section>
            <h2>15. قابلية الفصل والتنازل</h2>
            <p>إذا اعتُبر أي بند من شروط الخدمة هذه غير صالح أو غير قابل للتنفيذ من قبل محكمة مختصة، تظل باقي البنود سارية المفعول بالكامل. سيُعدَّل أي بند غير صالح أو غير قابل للتنفيذ إلى الحد الأدنى اللازم لجعله صالحاً وقابلاً للتنفيذ.</p>
            <p>عدم إنفاذنا لأي حق أو بند من هذه الشروط لا يشكل تنازلاً عن ذلك الحق أو البند. لا يكون التنازل سارياً إلا إذا كان مكتوباً وموقعاً من ممثل مفوض حسب الأصول لدى Aegis AI.</p>
          </section>

          <section>
            <h2>16. الترجمة</h2>
            <p>قد تُترجم شروط الخدمة هذه إلى العربية أو لغات أخرى للتسهيل. في حال وجود أي تعارض أو تباين بين النسخة الإنجليزية وأي ترجمة، تسود <strong>النسخة الإنجليزية الأصلية</strong>.</p>
          </section>

          <section>
            <h2>17. التغييرات على هذه الشروط</h2>
            <p>نحتفظ بالحق في تعديل أو استبدال شروط الخدمة هذه في أي وقت وفق تقديرنا المطلق. إذا كان التعديل جوهرياً، سنقدم إشعاراً لا يقل عن <strong>30 يوماً</strong> قبل سريان الشروط الجديدة، من خلال تحديث تاريخ "آخر تحديث" أعلى هذه الصفحة، وعند الاقتضاء عبر إشعار بالبريد الإلكتروني.</p>
            <p>يُحدَّد ما يشكل تغييراً جوهرياً وفق تقديرنا المطلق. استمرارك في الوصول إلى خدمتنا أو استخدامها بعد سريان أي تعديلات يعني موافقتك على الالتزام بالشروط المُعدَّلة.</p>
          </section>

          <section>
            <h2>18. تواصل معنا</h2>
            <p>إذا كانت لديك أي أسئلة بشأن شروط الخدمة هذه أو ترغب في حل شكوى بخصوص خدماتنا، يُرجى التواصل معنا على:</p>
            <div class="contact-box">
              <p><strong style="color:#00253b;">Aegis AI</strong></p>
              <p>دبي، الإمارات العربية المتحدة</p>
              <p><strong>البريد الإلكتروني:</strong> hello@aegisai.ae</p>
              <p><strong>الواتساب:</strong> +971 4 321 8888</p>
            </div>
          </section>
        </>
      )}

    </div>
  </div>
