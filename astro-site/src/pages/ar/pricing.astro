---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "أسعار خدمات الذكاء الاصطناعي في الإمارات والخليج | Aegis AI",
    "url": "https://aegisai.ae/ar/pricing",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الأسعار", "item": "https://aegisai.ae/ar/pricing" }
    ]
  }
];
---

<ArBaseLayout
  title="أسعار خدمات الذكاء الاصطناعي في الإمارات والخليج | Aegis AI"
  description="تعرف على تكلفة خدمات الذكاء الاصطناعي من Aegis AI في الإمارات والسعودية والكويت وقطر. مشاريع مخصصة وفق احتياجات شركتك، مع ضمان استرداد 100%."
  canonicalPath="/ar/pricing"
  enPath="/pricing"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>الأسعار</div>
    <h1>أسعار واضحة<br><span class="gradient-text">بدون مفاجآت</span></h1>
    <p style="max-width:600px;margin:1.5rem auto;line-height:1.8;color:#42474e;">
      لا نبيع اشتراكات شهرية لبرامج جاهزة. نبني لك حلاً مخصصاً لاحتياجات شركتك، والتكلفة تعكس ما نبنيه فعلاً، لا تسعيرة موحّدة لكل شركة.
    </p>
  </div>
</header>

<!-- 2. Why No Fixed Prices -->
<section class="section" style="padding-bottom:0;">
  <div class="container">
    <div class="why-box">
      <h2 style="margin-bottom:1.25rem;">لماذا لا يوجد سعر ثابت؟</h2>
      <p style="color:#42474e;line-height:1.8;margin-bottom:1rem;">
        شركة عقارية تحتاج روبوت محادثة لتأهيل العملاء تختلف تماماً عن سلسلة تجزئة تحتاج نظام مخزون لـ ٢٠ فرعاً. نفس الكلمتين "ذكاء اصطناعي" قد تعنيان مشروعين مختلفين تماماً في الحجم والتعقيد. السعر الثابت إما أن يُقلّص ما تحصل عليه أو يُضخّم ما تدفعه.
      </p>
      <p style="color:#42474e;line-height:1.8;margin:0;">
        ما نقدمه بدلاً من ذلك: نطاقات سعرية شفافة حسب حجم المشروع، وعرض سعر دقيق بعد جلسة تشخيص مجانية. لا مفاجآت بعدها.
      </p>
    </div>
  </div>
</section>

<!-- 3. Pricing Tiers -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">نطاقات الأسعار</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:540px;margin-inline:auto;">ثلاثة مستويات بناءً على حجم المشروع. اختر ما يقترب من احتياجك وتواصل للحصول على عرض دقيق.</p>
    <div class="pricing-grid">

      <!-- Tier 1 -->
      <div class="pricing-card">
        <div class="pricing-card-top">
          <div class="tier-icon">
            <span class="material-symbols-outlined" style="font-size:28px;direction:ltr;" aria-hidden="true">autorenew</span>
          </div>
          <h3>مشاريع الأتمتة والتكامل</h3>
          <div class="price-display">
            <span class="price-from">يبدأ من</span>
            <span class="price-amount">٨٬٠٠٠ درهم</span>
          </div>
          <div class="timeline-badge">
            <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">schedule</span>
            جدول زمني مرن
          </div>
        </div>
        <ul class="pricing-features">
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            أتمتة عملية أو عمليتين متكررتين
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            تكامل بين نظامين أو ثلاثة
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            روبوت واتساب بسيط أو متابعات آلية
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            تدريب الفريق على النظام
          </li>
        </ul>
        <button onclick="openModal(this)" data-source="ar_pricing_tier1" class="btn-outline" style="width:100%;justify-content:center;">احصل على عرض سعر</button>
      </div>

      <!-- Tier 2 — Featured -->
      <div class="pricing-card pricing-card--featured">
        <div class="featured-label">الأكثر طلباً</div>
        <div class="pricing-card-top">
          <div class="tier-icon tier-icon--featured">
            <span class="material-symbols-outlined" style="font-size:28px;direction:ltr;" aria-hidden="true">smart_toy</span>
          </div>
          <h3>الأنظمة المخصصة</h3>
          <div class="price-display">
            <span class="price-from">يبدأ من</span>
            <span class="price-amount">١٨٬٠٠٠ درهم</span>
          </div>
          <div class="timeline-badge timeline-badge--featured">
            <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">schedule</span>
            جدول زمني مرن
          </div>
        </div>
        <ul class="pricing-features">
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">check_circle</span>
            تطوير ذكاء اصطناعي مخصص لاحتياجك
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">check_circle</span>
            وكيل ذكاء اصطناعي أو نموذج لغوي مخصص
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">check_circle</span>
            لوحة تحكم وتقارير مخصصة
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">check_circle</span>
            تكامل مع جميع أنظمتك الحالية
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">check_circle</span>
            تدريب الفريق + وثائق كاملة
          </li>
        </ul>
        <button onclick="openModal(this)" data-source="ar_pricing_tier2" class="btn-primary" style="width:100%;justify-content:center;">احصل على عرض سعر</button>
      </div>

      <!-- Tier 3 -->
      <div class="pricing-card">
        <div class="pricing-card-top">
          <div class="tier-icon">
            <span class="material-symbols-outlined" style="font-size:28px;direction:ltr;" aria-hidden="true">corporate_fare</span>
          </div>
          <h3>المشاريع المتكاملة</h3>
          <div class="price-display">
            <span class="price-from">يبدأ من</span>
            <span class="price-amount">٣٥٬٠٠٠ درهم</span>
          </div>
          <div class="timeline-badge">
            <span class="material-symbols-outlined" style="font-size:14px;direction:ltr;" aria-hidden="true">schedule</span>
            جدول زمني مرن
          </div>
        </div>
        <ul class="pricing-features">
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            تحوّل ذكاء اصطناعي شامل للعمليات
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            أنظمة متعددة مترابطة
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            برنامج تدريب الفريق الكامل
          </li>
          <li>
            <span class="material-symbols-outlined" style="font-size:16px;color:#1d4ed8;direction:ltr;" aria-hidden="true">check_circle</span>
            إدارة مشروع مخصصة طوال المدة
          </li>
        </ul>
        <button onclick="openModal(this)" data-source="ar_pricing_tier3" class="btn-outline" style="width:100%;justify-content:center;">احصل على عرض سعر</button>
      </div>

    </div>
  </div>
</section>

<!-- 4. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل: الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم، دون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_pricing_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 5. Pricing FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة عن الأسعار</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما شروط الدفع؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نقسّم الدفع على مراحل المشروع، عادةً ٥٠٪ عند بدء العمل و٥٠٪ عند التسليم النهائي. للمشاريع الكبيرة نقسّم على ثلاث دفعات مرتبطة بمراحل التسليم. لا دفع كامل مسبق.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الذي يشمله السعر تحديداً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">السعر يشمل: التحليل والتصميم، البناء والاختبار، التكامل مع أنظمتك، تدريب الفريق، الوثائق، ودعم ٣٠ يوماً بعد الإطلاق. لا تكاليف مخفية. رسوم استضافة الخوادم إن وُجدت تُذكر مسبقاً في عرض السعر.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن أن يتغير السعر بعد الاتفاق؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">السعر المتفق عليه في العقد ثابت. إذا طلبت إضافة ميزات جديدة أثناء المشروع لم تكن في النطاق الأصلي، نقدم عرضاً إضافياً للموافقة. لا مفاجآت في الفاتورة النهائية.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف أحصل على عرض سعر دقيق لشركتي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">احجز جلسة تشخيص مجانية (٣٠ دقيقة). نفهم فيها عملياتك واحتياجاتك، ثم نرسل لك عرض سعر تفصيلياً خلال ٤٨ ساعة، يشمل النطاق الكامل والجدول الزمني والتكلفة النهائية.</div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز للحصول على عرض سعر مخصص؟</h2>
    <p style="margin-bottom:2rem;max-width:500px;margin-inline:auto;line-height:1.7;">جلسة تشخيص مجانية (٣٠ دقيقة). نفهم احتياجك ونرسل لك عرض سعر دقيق خلال ٤٨ ساعة.</p>
    <button onclick="openModal(this)" data-source="ar_pricing_cta" class="btn-primary">احجز الاستشارة المجانية ←</button>
  </div>
</section>

<style>
  .why-box {
    background: #f0f4ff;
    border: 1px solid #c7d7ff;
    border-radius: 16px;
    padding: 2rem 2.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .why-box h2 {
    font-size: 1.25rem;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }
  .pricing-card {
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 20px;
    padding: 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .pricing-card--featured {
    border-color: #1d4ed8;
    border-width: 2px;
    box-shadow: 0 4px 24px rgba(29,78,216,0.12);
  }
  .featured-label {
    position: absolute;
    top: -14px;
    right: 50%;
    transform: translateX(50%);
    background: #1d4ed8;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 20px;
    white-space: nowrap;
  }
  .pricing-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .tier-icon {
    width: 52px;
    height: 52px;
    background: #e7eeff;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1d4ed8;
  }
  .tier-icon--featured {
    background: #1d4ed8;
    color: #fff;
  }
  .pricing-card--featured h3 {
    color: #1d4ed8;
  }
  .price-display {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .price-from {
    font-size: 0.8rem;
    color: #6b7280;
  }
  .price-amount {
    font-size: 1.75rem;
    font-weight: 800;
    color: #111827;
    line-height: 1.2;
  }
  .pricing-card--featured .price-amount {
    color: #1d4ed8;
  }
  .timeline-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #f3f4f6;
    color: #42474e;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    width: fit-content;
  }
  .timeline-badge--featured {
    background: #e7eeff;
    color: #1d4ed8;
  }
  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }
  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #374151;
    line-height: 1.5;
  }
  .pricing-card--featured .pricing-features li {
    color: #1e3a8a;
  }
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }
  @media (max-width: 900px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
    .why-box { padding: 1.5rem; }
  }
  @media (max-width: 580px) {
    .pricing-grid { max-width: 100%; }
    .why-box { padding: 1.25rem; }
  }
</style>

</ArBaseLayout>
