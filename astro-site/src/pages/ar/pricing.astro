---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "أسعار خدمات الذكاء الاصطناعي في الإمارات والخليج | Aegis AI",
    "url": "https://aegisai.ae/ar/pricing",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الأسعار", "item": "https://aegisai.ae/ar/pricing" }
    ]
  }
];
---

<ArBaseLayout
  title="أسعار خدمات الذكاء الاصطناعي المخصصة في دبي | Aegis AI"
  description="كل مشروع ذكاء اصطناعي مختلف. نحدد النطاق والسعر لكل مشروع حسب شركتك وأهدافك وحجمك. احجز جلسة تشخيص مجانية لعرض سعر مخصص."
  canonicalPath="/ar/pricing"
  enPath="/pricing"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero" style="padding-top:10rem;padding-bottom:5rem;text-align:center;">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>الأسعار</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">payments</span>
      تسعير مخصص
    </div>
    <h1 style="max-width:48rem;margin:0 auto 1.5rem;">كل مشروع يُحدَّد نطاقه<br><span class="gradient-text">خصيصاً لك</span></h1>
    <p style="color:#42474e;font-size:1.125rem;line-height:1.75;max-width:38rem;margin:0 auto 2.5rem;">
      لا نؤمن بتسعير موحّد لجميع الشركات. عملك وتعقيد سير عملك وأهدافك فريدة، ولذلك عرض السعر سيكون فريداً أيضاً. احجز مكالمة تشخيص مجانية لمدة ٣٠ دقيقة وسنعطيك رقماً واضحاً وصريحاً.
    </p>
    <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
      <button onclick="openModal(this)" data-source="ar_pricing_hero" class="btn-primary" style="font-size:1rem;">احجز استشارة مجانية ←</button>
      <a href="/ar/contact" class="btn-outline" style="font-size:1rem;">تواصل معنا</a>
    </div>
  </div>
</header>

<!-- 2. What We Look At -->
<section class="section" style="background:#fff;">
  <div class="container" style="max-width:800px;">
    <div class="section-header">
      <h2>ما الذي يحدد سعر مشروعك</h2>
      <p style="color:#42474e;font-size:1.0625rem;">لا متغيرات خفية. هذه هي العوامل التي تحدد النطاق والتكلفة لكل مشروع.</p>
    </div>
    <div style="display:inline-flex;align-items:center;gap:0.875rem;background:rgba(0,104,117,0.06);border:1px solid rgba(0,104,117,0.20);border-radius:14px;padding:1rem 1.5rem;margin-bottom:2rem;width:100%;box-sizing:border-box;">
      <span class="material-symbols-outlined" style="color:#006875;font-size:28px;flex-shrink:0;" aria-hidden="true">payments</span>
      <p style="color:#42474e;font-size:0.9375rem;line-height:1.6;margin:0;"><strong style="color:#00253b;">كل مشروع يُحدَّد نطاقه ويُسعَّر خصيصاً لشركتك.</strong> العوامل التالية تحدد أين يقع مشروعك. احجز مكالمة مجانية وسنعطيك رقماً دقيقاً.</p>
    </div>
    <div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">account_tree</span></div>
        <div>
          <p style="font-weight:700;color:#00253b;margin-bottom:0.25rem;">تعقيد سير العمل</p>
          <p style="color:#42474e;font-size:0.9375rem;line-height:1.65;margin:0;">روبوت محادثة واحد يختلف عن خط أتمتة كامل بأنظمة متعددة. عدد التكاملات ومصادر البيانات ونقاط القرار كلها تؤثر على النطاق.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">storage</span></div>
        <div>
          <p style="font-weight:700;color:#00253b;margin-bottom:0.25rem;">جاهزية البيانات</p>
          <p style="color:#42474e;font-size:0.9375rem;line-height:1.65;margin:0;">مقدار تنظيف البيانات أو هيكلتها أو ترحيلها المطلوب قبل أن نتمكن من بناء أي شيء مفيد.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">extension</span></div>
        <div>
          <p style="font-weight:700;color:#00253b;margin-bottom:0.25rem;">عدد التكاملات</p>
          <p style="color:#42474e;font-size:0.9375rem;line-height:1.65;margin:0;">أنظمة CRM وERP، واتساب، منصات العقارات، أنظمة نقاط البيع. كل تكامل يضيف وقت تطوير.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">group</span></div>
        <div>
          <p style="font-weight:700;color:#00253b;margin-bottom:0.25rem;">حجم الفريق ونطاق التدريب</p>
          <p style="color:#42474e;font-size:0.9375rem;line-height:1.65;margin:0;">عدد الأشخاص الذين يحتاجون للتأهيل والتدريب يؤثر على مرحلة التسليم والدعم.</p>
        </div>
      </div>
      <div class="value-row">
        <div class="value-icon-sm"><span class="material-symbols-outlined" style="color:#006875;font-size:20px;" aria-hidden="true">speed</span></div>
        <div>
          <p style="font-weight:700;color:#00253b;margin-bottom:0.25rem;">الجدول الزمني المطلوب</p>
          <p style="color:#42474e;font-size:0.9375rem;line-height:1.65;margin:0;">الجداول الزمنية القياسية تمنحنا أفضل نتيجة. الجداول المضغوطة تتطلب موارد إضافية وتؤثر على التكلفة.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 3. Guarantee -->
<section class="section" style="background:#e7eeff;">
  <div class="container" style="max-width:720px;text-align:center;">
    <h2 style="margin-bottom:1rem;">مهما كان السعر، أنت محمي</h2>
    <p style="color:#42474e;font-size:1.0625rem;line-height:1.75;max-width:560px;margin:0 auto 2rem;">
      بغض النظر عن نطاق المشروع، كل تعاقد معنا مشمول بضمان الرضا ١٠٠٪. إذا لم تكن راضياً عما نبنيه، تحصل على استرداد كامل، دون أي أسئلة.
    </p>
    <div style="display:inline-flex;align-items:center;gap:.875rem;background:#fff;border:1px solid rgba(245,158,11,0.30);border-radius:16px;padding:1rem 1.5rem;text-align:right;">
      <span class="material-symbols-outlined" style="color:#d97706;font-size:32px;flex-shrink:0;" aria-hidden="true">shield</span>
      <p style="color:#42474e;font-size:0.875rem;line-height:1.6;margin:0;"><strong style="color:#00253b;">ضمان الرضا ١٠٠٪.</strong> شركة الذكاء الاصطناعي الوحيدة في الإمارات التي تقدم استرداداً كاملاً لمشروع مكتمل.</p>
    </div>
  </div>
</section>

<!-- 4. Pricing FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة عن الأسعار</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم تكلفة مشروع ذكاء اصطناعي مع Aegis AI؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">كل عرض سعر يُحدَّد خصيصاً لمشروعك. التكلفة النهائية تعتمد على تعقيد سير العمل، وعدد التكاملات، وجاهزية البيانات، وحجم الفريق، والجدول الزمني. احجز مكالمة تشخيص مجانية للحصول على عرض سعر دقيق.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يعمل ضمان الاسترداد ١٠٠٪؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">إذا لم تكن راضياً تماماً عما نسلّمه، نرد كامل قيمة المشروع خلال ٥ أيام عمل، دون شروط ودون نقاش. نتفق على معايير النجاح مسبقاً؛ ويجب تقديم الطلب خلال ٣٠ يوماً من التسليم.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا لو غيّرنا الاتجاه في منتصف المشروع؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">التغييرات الصغيرة في النطاق نستوعبها عادةً دون رسوم إضافية. التحولات الكبيرة تحتاج وثيقة نطاق منقّحة. إذا قررت عدم المتابعة، تدفع فقط مقابل العمل المُنجز حتى تلك اللحظة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما حجم الشركات التي تعملون معها؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">معظم عملائنا لديهم بين ١٥ و٣٠٠ موظف. عملنا مع شركات بعدد ٨ موظفين فقط وأخرى بـ ٦٠٠ موظف. العامل الأهم هو وجود مشكلة عمل واضحة يمكن للذكاء الاصطناعي حلها، وليس حجم الشركة.</div>
      </div>
    </div>
  </div>
</section>

<!-- 5. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز للحصول على عرض سعر مخصص؟</h2>
    <p style="margin-bottom:2rem;max-width:500px;margin-inline:auto;line-height:1.7;">مكالمة تشخيص مجانية لمدة ٣٠ دقيقة. أخبرنا عن أكبر مشكلة تشغيلية لديك، وسنكون صريحين حول ما إذا كان الذكاء الاصطناعي يساعد وما هي التكلفة. بدون ضغط مبيعات.</p>
    <button onclick="openModal(this)" data-source="ar_pricing_cta" class="btn-primary">احجز الاستشارة المجانية ←</button>
  </div>
</section>

<style>
  .value-row { display:flex; align-items:flex-start; gap:1rem; padding:1.25rem 0; border-bottom:1px solid rgba(0,37,59,0.08); }
  .value-row:last-child { border-bottom:none; }
  .value-icon-sm { width:40px; height:40px; border-radius:10px; background:rgba(0,104,117,0.10); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .faq-list { display: grid; gap: 0.75rem; }
</style>

</ArBaseLayout>
