---
export const prerender = false;
import ArBaseLayout from "../../layouts/ArBaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

let jobs: { id: string; title: string; slug: string; department: string | null; location: string; job_type: string; salary_range: string | null }[] = [];
try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('jobs')
    .select('id, title, slug, department, location, job_type, salary_range')
    .eq('published', true)
    .is('deleted_at', null)
    .order('sort_order', { ascending: true })
    .order('created_at', { ascending: false });
  jobs = data ?? [];
} catch {}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const careersSchema = jobs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Job Openings at Lenoo AI',
  url: 'https://lenooai.com/ar/careers',
  itemListElement: jobs.map((j, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'JobPosting',
      title: j.title,
      url: `https://lenooai.com/ar/jobs/${j.slug}`,
      hiringOrganization: { '@type': 'Organization', name: 'Lenoo AI', sameAs: 'https://lenooai.com' },
      jobLocation: {
        '@type': 'Place',
        address: j.location ? { '@type': 'PostalAddress', addressLocality: j.location } : undefined,
      },
      employmentType: 'FULL_TIME',
    },
  })),
} : undefined;

const careersFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "كيف تسير عملية المقابلة لديكم؟",
      "acceptedAnswer": { "@type": "Answer", "text": "مكالمة تعارف قصيرة، ثم مهمة عملية قريبة من العمل الفعلي، ثم لقاء مع الفريق. لا جولات مقابلات لا نهاية لها. عادة نُنهي العملية خلال أسبوعين." }
    },
    {
      "@type": "Question",
      "name": "هل العمل عن بُعد متاح فعلاً؟",
      "acceptedAnswer": { "@type": "Answer", "text": "نعم. فريقنا موزّع، والتوقيت ليس عائقاً. نهتم بما تُنجزه لا بمكان جلوسك أو ساعات حضورك." }
    },
    {
      "@type": "Question",
      "name": "هل أحتاج خبرة سابقة في الذكاء الاصطناعي للتقديم؟",
      "acceptedAnswer": { "@type": "Answer", "text": "لا. نبحث عن فضول ودافع ذاتي أكثر من شهادات أو سنوات خبرة محددة. إذا كنت تتعلم بسرعة وتُنجز عملاً حقيقياً، هذا يكفي." }
    },
    {
      "@type": "Question",
      "name": "كيف تُراجعون الرواتب والترقيات؟",
      "acceptedAnswer": { "@type": "Answer", "text": "مراجعة سنوية شفافة، مبنية على الأثر الفعلي لعملك لا على الأقدمية وحدها. تغذية راجعة صادقة على مدار العام، لا مفاجآت في وقت التقييم." }
    },
    {
      "@type": "Question",
      "name": "ماذا لو لم أجد وظيفة مناسبة معلنة الآن؟",
      "acceptedAnswer": { "@type": "Answer", "text": "أرسل لنا سيرتك الذاتية على careers@lenooai.com على أي حال. نقرأ كل طلب ونتواصل حين يظهر دور مناسب." }
    }
  ]
};

const combinedLdJson = careersSchema ? [careersSchema, careersFaqSchema] : careersFaqSchema;
---

<ArBaseLayout
  title="وظائف في Lenoo AI: انضم إلى وكالة الذكاء الاصطناعي في دبي"
  description="Lenoo AI وكالة ذكاء اصطناعي في دبي، توظف في جميع أنحاء الإمارات. نوظف عقولاً مبدعة ومدفوعة ذاتياً، بلا حد أدنى للعمر. إذا كنت تبني وتتعلم، نريدك معنا."
  canonicalPath="/ar/careers"
  enPath="/careers"
  ldJson={combinedLdJson}
>

<!-- HERO -->
<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>الوظائف</div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      المستقبل يبنيه أشخاص<br>لا يتوقفون عن <span class="gradient-text">الابتكار.</span>
    </h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      نحن شركة ذكاء اصطناعي عالمية نُنجز منتجات حقيقية لعملاء حقيقيين. لا يهمنا من أين أتيت أو كم عمرك. يهمنا ما تبنيه. إذا كنت مدفوعاً ذاتياً، فضولياً، ومتحمساً لصنع شيء، فمكانك هنا.
    </p>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:280px;">
  <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&q=80&auto=format&fit=crop" alt="فريق يعمل على منتجات ذكاء اصطناعي" loading="eager" fetchpriority="high" width="1400" height="280" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0) 45%),linear-gradient(to top,rgba(0,19,32,0.30) 0%,transparent 55%);"></div>
</div>

<!-- WHY JOIN US -->
<section class="section" style="padding:5rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2>حيث لعملك <span class="gradient-text">أثر حقيقي</span></h2>
      <p style="color:#42474e; max-width:560px; margin:1rem auto 0;">لا نبني نماذج تجريبية. كل نظام نُطلقه يعمل فعلياً في شركة حقيقية، يستخدمه أشخاص حقيقيون كل يوم.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;" class="ar-careers-grid-3">
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875;font-size:24px;">rocket_launch</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">ملكية حقيقية للعمل</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">لن تقضي ستة أشهر تراقب من بعيد. من أول يوم، تتولى عملاً حقيقياً يصل إلى مستخدمين حقيقيين.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875;font-size:24px;">globe</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">فريق عالمي، عملاء عالميون</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">نعمل مع عملاء في قارات مختلفة. لا حدود للأفكار، ولا سقف لما يمكن أن يوصلك إليه هذا العمل.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875;font-size:24px;">school</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">تعلّم لا يتوقف</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">الذكاء الاصطناعي يتطور بسرعة. نمنحك الأدوات والوقت والفريق لتبقى في المقدمة، لا لمجرد اللحاق بالركب.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHO WE'RE LOOKING FOR -->
<section class="section" style="padding:5rem 0; background:#f9f9ff;">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2>نبحث عن <span class="gradient-text">أشخاص، لا سِيَر ذاتية.</span></h2>
      <p style="color:#42474e; max-width:540px; margin:1rem auto 0;">لا قالب ثابت للسيرة الذاتية. لا حد أدنى للعمر. لا سلم وظيفي عليك تسلّقه قبل أن تُنجز عملاً حقيقياً. أربعة أشياء فقط نبحث عنها في كل من نوظفه.</p>
    </div>
    <div class="feature-ledger" style="margin-bottom:3rem;">
      {[
        { icon: 'self_improvement', title: 'مدفوع ذاتياً', desc: "لا تنتظر من يخبرك بما يجب فعله. تكتشف المشكلة، تفهمها، وتحلّها لأنها تحتاج إلى حل." },
        { icon: 'lightbulb', title: 'يحب التعلّم', desc: "الفضول ليس رفاهية بالنسبة لك، بل طريقة تفكيرك. تقرأ، تجرّب، وتتحمس حين ينكسر شيء ما." },
        { icon: 'payments', title: 'يريد أن يكسب', desc: "نؤمن أن العمل الجيد يستحق أجراً جيداً. لا \"خبرة مجانية\" هنا. مال حقيقي مقابل نتائج حقيقية، تُراجَع بانتظام." },
        { icon: 'draw', title: 'يبتكر أفكاره الخاصة', desc: "عندك فكرة جامحة؟ شاركها. أفضل ما بنيناه بدأ كخاطرة عابرة في حديث عادي." },
      ].map(t => (
        <div class="card">
          <span class="material-symbols-outlined" aria-hidden="true">{t.icon}</span>
          <h3>{t.title}</h3>
          <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">{t.desc}</p>
        </div>
      ))}
    </div>

    <!-- No-age callout -->
    <div style="text-align:center;">
      <span style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:8px 20px; color:#004f58; font-size:.9375rem; font-weight:600;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:18px;">verified</span>
        لا شهادة مطلوبة. لا حد أدنى للعمر. فقط أرِنا ما يمكنك فعله.
      </span>
    </div>
  </div>
</section>

<!-- QUOTE BAND -->
<div style="position:relative; overflow:hidden; background:linear-gradient(135deg,#006875,#00253b);">
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.18),rgba(0,37,59,0.35));"></div>
  <div style="position:relative; padding:4.5rem 2rem;">
    <div class="glass" style="max-width:720px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem; border-inline-start:4px solid #00e3fd;">
      <p style="font-size:1.25rem; font-style:italic; color:#00253b; line-height:1.7; margin:0 0 .75rem;">
        "أخطر شخص في أي غرفة ليس الأكثر خبرة. إنه من لم يُخبَر بعد بما هو مستحيل."
      </p>
      <span style="font-size:.875rem; font-weight:600; color:#006875;">Lenoo AI</span>
    </div>
  </div>
</div>

<!-- PERKS -->
<section class="section" style="background:#e7eeff; padding:4rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <h2>مبني لمن <span class="gradient-text">يُنجز عملاً رائعاً</span></h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem;" class="ar-careers-grid-4">
      {[
        { icon: 'payments', label: 'راتب تنافسي', desc: 'مال حقيقي يوازي قيمة العمل الرائع، يُراجَع كل عام' },
        { icon: 'menu_book', label: 'ميزانية تعلّم', desc: 'ميزانية سنوية للدورات والكتب والأدوات وكل ما يصقل مهاراتك' },
        { icon: 'wb_sunny', label: 'ساعات مرنة', desc: 'اعمل في الوقت الذي تُفكّر فيه بأفضل شكل. نهتم بالنتيجة لا بالجدول' },
        { icon: 'laptop_mac', label: 'أحدث الأجهزة', desc: 'جهاز بمواصفات عالية من اختيارك، مُجهّز كما تريد' },
        { icon: 'trending_up', label: 'مسار نمو واضح', desc: 'سلّم شفاف، تغذية راجعة صادقة، وفريق يريدك أن تتطور' },
        { icon: 'lightbulb', label: 'أفكارك مهمة', desc: "شاركنا فكرة. إذا كانت جيدة، نبنيها معاً وتملك حصة منها" },
        { icon: 'public', label: 'اعمل من أي مكان', desc: 'عمل عن بُعد وفريق موزّع عالمياً. توقيتك ليس عائقاً' },
        { icon: 'volunteer_activism', label: 'نسندك دائماً', desc: 'نقف خلف كل ما نبنيه، وخلف كل فرد في الفريق' },
      ].map(p => (
        <div class="stat-pill" style="flex-direction:column;align-items:flex-start;gap:.5rem;padding:1.25rem;">
          <span class="material-symbols-outlined" aria-hidden="true" style="color:#006875;font-size:22px;">{p.icon}</span>
          <div>
            <div style="font-weight:700;font-size:.9375rem;color:#00253b;">{p.label}</div>
            <div style="font-size:.8125rem;color:#42474e;margin-top:.25rem;line-height:1.5;">{p.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- TEAM PHOTO -->
<div style="position:relative; overflow:hidden; height:260px;">
  <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1600&q=80&auto=format&fit=crop" alt="فريق شاب يتعاون على مشروع في مساحة عمل مفتوحة" loading="lazy" width="1600" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:rgba(0,104,117,0.10);"></div>
</div>

<!-- FAQ -->
<section class="section" aria-labelledby="careers-faq-heading">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2 id="careers-faq-heading">أسئلة قبل التقديم</h2>
      <p style="color:#42474e; max-width:520px; margin:1rem auto 0; line-height:1.8;">ما يسأل عنه أغلب المتقدمين قبل إرسال سيرتهم الذاتية.</p>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف تسير عملية المقابلة لديكم؟
