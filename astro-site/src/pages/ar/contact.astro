---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "تواصل معنا | Aegis AI دبي",
  "url": "https://aegisai.ae/ar/contact",
  "inLanguage": "ar",
  "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
};
---

<ArBaseLayout
  title="تواصل معنا | Aegis AI: ذكاء اصطناعي في دبي ودول الخليج"
  description="تواصل مع فريق Aegis AI في دبي. احجز استشارة مجانية لمدة ٣٠ دقيقة، أو راسلنا مباشرة. نخدم الشركات في الإمارات والسعودية والكويت وقطر. رد خلال ٤ ساعات."
  canonicalPath="/ar/contact"
  enPath="/contact"
  ldJson={ldJson}
>

<header class="page-hero">
  <div class="container">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a><span class="sep">/</span><strong class="current">تواصل معنا</strong>
    </nav>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">chat_bubble</span>
      تواصل معنا
    </div>
    <h1>نحن هنا للمساعدة<br><span class="gradient-text">ابدأ المحادثة</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:580px;margin:1.5rem auto 0;line-height:1.8;">
      احجز مكالمة استراتيجية مجانية أو راسلنا مباشرة. فريقنا في دبي يرد خلال ٤ ساعات بالعربي أو الإنجليزي.
    </p>
  </div>
</header>

<section class="section">
  <div class="container">
    <div class="contact-grid">

      <!-- Book call -->
      <div class="contact-main">
        <div class="badge badge-amber" style="margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">shield</span>
          استشارة مجانية، بدون ضغط مبيعات
        </div>
        <h2>احجز مكالمة استراتيجية مجانية</h2>
        <p style="color:#42474e;line-height:1.8;margin-bottom:2rem;">
          ٣٠ دقيقة مع أحد خبرائنا: نفهم تحدياتك، نُقيّم الفرص المتاحة، ونعطيك صورة واضحة حول ما يمكن للذكاء الاصطناعي فعله لشركتك. بدون أي التزام.
        </p>
        <div class="contact-features">
          <div class="contact-feat">
            <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">check_circle</span>
            ٣٠ دقيقة مجانية مع خبير
          </div>
          <div class="contact-feat">
            <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">check_circle</span>
            دعم بالعربي والإنجليزي
          </div>
          <div class="contact-feat">
            <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">check_circle</span>
            لقاء شخصي في دبي أو فيديو
          </div>
          <div class="contact-feat">
            <span class="material-symbols-outlined" style="color:#006875;font-size:20px;direction:ltr;" aria-hidden="true">check_circle</span>
            بدون التزام أو ضغط مبيعات
          </div>
        </div>
        <div style="margin-top:2rem;">
          <button onclick="openModal(this)" data-source="ar_contact_hero" class="btn-primary" style="font-size:1.0625rem;padding:1rem 2.5rem;">
            احجز استشارتك المجانية الآن ←
          </button>
        </div>
      </div>

      <!-- Direct contact -->
      <div class="contact-side">
        <div class="contact-info-card">
          <h3>تواصل مباشر</h3>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(37,211,102,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#22c55e" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            </div>
            <div>
              <p class="channel-label">واتساب (الأسرع)</p>
              <a href="https://wa.me/971501234567" class="channel-value">+971 50 123 4567</a>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,104,117,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#006875" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="channel-label">البريد الإلكتروني</p>
              <a href="mailto:hello@aegisai.ae" class="channel-value">hello@aegisai.ae</a>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,37,59,0.08);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#00253b" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="channel-label">الموقع</p>
              <p class="channel-value">Business Bay، دبي، الإمارات</p>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,104,117,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#006875" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="channel-label">وقت الرد</p>
              <p class="channel-value">خلال ٤ ساعات في أيام العمل</p>
            </div>
          </div>
        </div>

        <div class="guarantee-box">
          <span class="material-symbols-outlined" style="color:#d97706;font-size:24px;direction:ltr;" aria-hidden="true">shield</span>
          <p><strong style="color:#00253b;">ضمان استرداد ١٠٠٪</strong>: إذا لم تكن راضياً عما نبنيه، نردّ كل درهم.</p>
        </div>
      </div>
    </div>
  </div>
</section>

</ArBaseLayout>

<style>
  .contact-grid {
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start;
  }
  .contact-main h2 { margin-bottom: 1rem; }
  .contact-features { display: flex; flex-direction: column; gap: 0.875rem; }
  .contact-feat { display: flex; align-items: center; gap: 0.75rem; font-size: 0.9375rem; color: #42474e; }
  .contact-side { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-info-card {
    background: #fff; border: 1px solid #E2E8F0; border-radius: 20px; padding: 1.75rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }
  .contact-info-card h3 { font-size: 1.125rem; font-weight: 700; color: #00253b; margin: 0; }
  .contact-channel { display: flex; align-items: flex-start; gap: 0.875rem; }
  .channel-icon {
    width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .channel-label { font-size: 0.75rem; color: #72787e; font-weight: 600; margin: 0 0 2px; text-transform: uppercase; letter-spacing: 0.04em; }
  .channel-value { font-size: 0.9375rem; color: #00253b; font-weight: 600; text-decoration: none; margin: 0; }
  a.channel-value:hover { color: #006875; }
  .guarantee-box {
    display: flex; align-items: flex-start; gap: 0.875rem;
    background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.25);
    border-radius: 16px; padding: 1.25rem;
  }
  .guarantee-box p { font-size: 0.875rem; line-height: 1.6; color: #42474e; margin: 0; }
  @media (max-width: 900px) { .contact-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
</style>
