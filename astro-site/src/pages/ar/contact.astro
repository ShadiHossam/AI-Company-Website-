<script>
  let currentArContactStep = 1;

  function validateArContactStep(n: number): boolean {
    const step = document.getElementById('cf-step-' + n);
    if (!step) return true;
    const fields = step.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
      'input[required], select[required], textarea[required]'
    );
    for (const field of fields) {
      if (!field.checkValidity()) {
        field.reportValidity();
        return false;
      }
    }
    return true;
  }

  function arContactStep(n) {
    if (n > currentArContactStep && !validateArContactStep(currentArContactStep)) return;
    document.getElementById('cf-step-' + currentArContactStep).classList.remove('active');
    document.getElementById('cf-step-' + n).classList.add('active');
    for (let i = 1; i <= 3; i++) {
      const dot = document.getElementById('cf-ind-' + i);
      dot.classList.remove('active', 'done');
      if (i < n) dot.classList.add('done');
      else if (i === n) dot.classList.add('active');
    }
    for (let i = 1; i <= 2; i++) {
      document.getElementById('cf-conn-' + i).classList.toggle('done', i < n);
    }
    currentArContactStep = n;
    document.querySelector('.form-box').scrollIntoView({behavior:'smooth', block:'start'});
  }

  function arSelectMeeting(el, type) {
    document.querySelectorAll('.meeting-type-card').forEach(c => {
      c.classList.remove('selected');
      const lbl = c.querySelector('.meet-label');
      const ico = c.querySelector('.material-symbols-outlined');
      if (lbl) lbl.style.color = '#72787e';
      if (ico) ico.style.color = '#72787e';
    });
    el.classList.add('selected');
    const lbl = el.querySelector('.meet-label');
    const ico = el.querySelector('.material-symbols-outlined');
    if (lbl) lbl.style.color = '#006875';
    if (ico) ico.style.color = '#006875';
    document.getElementById('cf-meeting-type').value = type;
  }

  async function arSubmitContact() {
    const name    = (document.getElementById('cf-name') as HTMLInputElement).value.trim();
    const email   = (document.getElementById('cf-email') as HTMLInputElement).value.trim();
    const wa      = (document.getElementById('cf-whatsapp') as HTMLInputElement).value.trim();
    const company = (document.getElementById('cf-company') as HTMLInputElement).value.trim();
    if (!name || !email || !wa || !company) {
      arContactStep(1);
      validateArContactStep(1);
      return;
    }
    if (!validateArContactStep(2)) {
      arContactStep(2);
      return;
    }

    const btn = document.getElementById('cf-submit-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'جارٍ الإرسال…';

    const payload = {
      full_name:      name,
      company_name:   company,
      work_email:     email,
      whatsapp:       wa.startsWith('+') ? wa : '+971' + wa.replace(/^0+/, '').replace(/\D/g, ''),
      job_title:      (document.getElementById('cf-title') as HTMLInputElement)?.value?.trim() ?? '',
      industry:       (document.getElementById('cf-industry') as HTMLSelectElement)?.value ?? '',
      company_size:   (document.getElementById('cf-size') as HTMLSelectElement)?.value ?? '',
      main_challenge: (document.getElementById('cf-challenge') as HTMLTextAreaElement)?.value?.trim() ?? '',
      budget_range:   (document.getElementById('cf-budget') as HTMLSelectElement)?.value ?? '',
      ai_experience:  (document.getElementById('cf-ai-exp') as HTMLSelectElement)?.value ?? '',
      meeting_format: (document.getElementById('cf-meeting-type') as HTMLInputElement)?.value ?? '',
      preferred_date: (document.getElementById('cf-date') as HTMLInputElement)?.value ?? '',
      preferred_time: (document.getElementById('cf-time') as HTMLSelectElement)?.value ?? '',
      notes:          (document.getElementById('cf-notes') as HTMLTextAreaElement)?.value?.trim() ?? '',
      source:         'contact_form',
      page_source:    'ar_contact_page',
      utm_source:     sessionStorage.getItem('utm_source') ?? '',
      utm_medium:     sessionStorage.getItem('utm_medium') ?? '',
      utm_campaign:   sessionStorage.getItem('utm_campaign') ?? '',
      website:        (document.getElementById('cf-honeypot') as HTMLInputElement)?.value ?? '',
    };

    try {
      const res = await fetch('/api/submit-lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Failed');
      for (let i = 1; i <= 3; i++) {
        const s = document.getElementById('cf-step-' + i);
        if (s) s.classList.remove('active');
      }
      document.getElementById('cf-step-indicator')!.style.display = 'none';
      document.getElementById('cf-success-screen')!.style.display = 'block';
    } catch {
      btn.disabled = false;
      btn.textContent = 'احجز استشارتك ←';
      const errEl = document.getElementById('cf-submit-error') as HTMLElement;
      if (errEl) errEl.style.display = 'block';
    }
  }

  const cfDateInput = document.getElementById('cf-date');
  if (cfDateInput) cfDateInput.setAttribute('min', new Date().toISOString().split('T')[0]);

  /* This script compiles to an ES module, so top-level functions are module-scoped,
     not global — the inline onclick="" attributes above need them on window. */
  declare global {
    interface Window {
      arContactStep: typeof arContactStep;
      arSelectMeeting: typeof arSelectMeeting;
      arSubmitContact: typeof arSubmitContact;
    }
  }
  Object.assign(window, { arContactStep, arSelectMeeting, arSubmitContact });
</script>

