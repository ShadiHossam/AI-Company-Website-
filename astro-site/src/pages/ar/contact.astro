---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { COMPANY } from '../../config/company';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "name": "تواصل معنا | Aegis AI دبي",
    "url": "https://aegisai.ae/ar/contact",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "كم من الوقت يستغرق الرد على رسالتي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نرد خلال ٤ ساعات على أيام العمل، الأحد إلى الخميس. رسائل واتساب عادة تحصل على رد أسرع من ذلك." }
      },
      {
        "@type": "Question",
        "name": "هل الاستشارة الأولى مجانية فعلاً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، مجانية بالكامل ولا تلتزم بأي شيء بعدها. ٣٠ دقيقة نستمع فيها لتحدياتك ونخبرك بصراحة إذا كان الذكاء الاصطناعي مناسباً لعملك." }
      },
      {
        "@type": "Question",
        "name": "هل يمكنني حجز لقاء شخصي في دبي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالتأكيد. اختر لقاء شخصي في الخطوة الثالثة من نموذج الحجز، ونحدد موعداً في مكتبنا في Business Bay أو في مقر شركتك." }
      },
      {
        "@type": "Question",
        "name": "بأي لغة يمكنني التواصل معكم؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالعربية أو الإنجليزية، كما يناسبك. فريقنا يعمل باللغتين في كل قناة تواصل، من واتساب إلى المكالمات." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="تواصل معنا | Aegis AI: احجز مكالمة استراتيجية في دبي، الإمارات"
  description="تواصل مع Aegis AI، وكالة الذكاء الاصطناعي في دبي. احجز استشارة مجانية لمدة ٣٠ دقيقة، أو راسلنا مباشرة. نخدم الشركات في جميع أنحاء الإمارات. رد خلال ٤ ساعات."
  canonicalPath="/ar/contact"
  enPath="/contact"
  ldJson={ldJson}
>

<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>تواصل معنا</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">chat_bubble</span>
      تواصل معنا
    </div>
    <h1>نحن هنا للمساعدة<br><span class="gradient-text">ابدأ المحادثة</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:580px;margin:1.5rem auto 0;line-height:1.8;">
      احجز مكالمة استراتيجية مجانية لمدة ٣٠ دقيقة، أو راسلنا مباشرة. فريقنا في دبي يرد خلال ٤ ساعات بالعربي أو الإنجليزي.
    </p>
  </div>
</header>

<section class="section">
  <div class="container" style="max-width:1000px;">
    <div class="contact-grid">

      <!-- RIGHT (visually, first in source order): Booking Form -->
      <div>
        <div class="form-box">
          <div class="badge badge-amber" style="margin-bottom:1rem;">
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">shield</span>
            استشارة مجانية، بدون ضغط مبيعات
          </div>
          <h2 style="font-size:1.25rem;font-weight:700;color:#00253b;margin-bottom:0.25rem;">احجز استشارتك المجانية</h2>
          <p style="color:#42474e;font-size:0.875rem;margin-bottom:1.5rem;">٣ خطوات سريعة، تستغرق حوالي دقيقتين.</p>

          <div class="step-indicator" id="cf-step-indicator">
            <div class="step-dot-sm active" id="cf-ind-1">١</div>
            <div class="step-connector-sm" id="cf-conn-1"></div>
            <div class="step-dot-sm" id="cf-ind-2">٢</div>
            <div class="step-connector-sm" id="cf-conn-2"></div>
            <div class="step-dot-sm" id="cf-ind-3">٣</div>
          </div>

          <!-- STEP 1 -->
          <div class="form-step active" id="cf-step-1">
            <p style="color:#006875;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">الخطوة ١ من ٣: عنك</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
              <div>
                <label class="form-label" for="cf-name">الاسم الكامل *</label>
                <input class="form-input" id="cf-name" type="text" placeholder="اسمك" required />
              </div>
              <div>
                <label class="form-label" for="cf-company">اسم الشركة *</label>
                <input class="form-input" id="cf-company" type="text" placeholder="اسم شركتك" required />
              </div>
              <div>
                <label class="form-label" for="cf-email">البريد الإلكتروني *</label>
                <input class="form-input" id="cf-email" type="email" placeholder="you@email.com" required style="direction:ltr;" />
              </div>
              <div>
                <label class="form-label" for="cf-whatsapp">رقم الواتساب *</label>
                <input class="form-input" id="cf-whatsapp" type="tel" placeholder="+971 50 123 4567" required style="direction:ltr;" />
              </div>
              <div style="grid-column:1/-1;">
                <label class="form-label" for="cf-title">المسمى الوظيفي</label>
                <input class="form-input" id="cf-title" type="text" placeholder="مثال: المدير التنفيذي، مدير العمليات" />
              </div>
            </div>
            <div style="margin-top:1.5rem;display:flex;justify-content:flex-start;">
              <button onclick="arContactStep(2)" class="btn-primary">التالي: عن شركتك ←</button>
            </div>
          </div>

          <!-- STEP 2 -->
          <div class="form-step" id="cf-step-2">
            <p style="color:#006875;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">الخطوة ٢ من ٣: عن شركتك</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
              <div>
                <label class="form-label" for="cf-industry">القطاع *</label>
                <select class="form-select" id="cf-industry" required>
                  <option value="">اختر قطاعك</option>
                  <option value="Real Estate">العقارات</option>
                  <option value="Retail &amp; E-commerce">التجزئة والتجارة الإلكترونية</option>
                  <option value="Hospitality &amp; Tourism">الضيافة والسياحة</option>
                  <option value="Logistics &amp; Supply Chain">اللوجستيات وسلاسل التوريد</option>
                  <option value="Healthcare">الرعاية الصحية</option>
                  <option value="Finance &amp; Banking">المال والأعمال المصرفية</option>
                  <option value="Construction &amp; Property Development">الإنشاءات وتطوير العقارات</option>
                  <option value="Professional Services">الخدمات المهنية</option>
                  <option value="Other">أخرى</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="cf-size">حجم الشركة *</label>
                <select class="form-select" id="cf-size" required>
                  <option value="">اختر الحجم</option>
                  <option value="1–20 employees">١ – ٢٠ موظف</option>
                  <option value="21–100 employees">٢١ – ١٠٠ موظف</option>
                  <option value="101–500 employees">١٠١ – ٥٠٠ موظف</option>
                  <option value="500+ employees">٥٠٠+ موظف</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="cf-challenge">ما هو التحدي أو الهدف الرئيسي لديك؟ *</label>
              <textarea class="form-textarea" id="cf-challenge" rows="3" placeholder="مثال: نقضي وقتاً طويلاً في تأهيل العملاء يدوياً، أو نريد أتمتة خدمة العملاء عبر واتساب..." required></textarea>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
              <div>
                <label class="form-label" for="cf-budget">نطاق الميزانية</label>
                <select class="form-select" id="cf-budget">
                  <option value="">أفضل عدم الإفصاح</option>
                  <option value="Exploring (no budget set yet)">نستكشف الخيارات (لا ميزانية محددة بعد)</option>
                  <option value="AED 10,000 – 50,000">١٠,٠٠٠ – ٥٠,٠٠٠ درهم</option>
                  <option value="AED 50,000 – 200,000">٥٠,٠٠٠ – ٢٠٠,٠٠٠ درهم</option>
                  <option value="AED 200,000+">٢٠٠,٠٠٠+ درهم</option>
                </select>
              </div>
              <div>
                <label class="form-label" for="cf-ai-exp">هل جربت أدوات الذكاء الاصطناعي من قبل؟</label>
                <select class="form-select" id="cf-ai-exp">
                  <option value="No, starting from scratch">لا، سنبدأ من الصفر</option>
                  <option value="A little, some personal AI tool use">قليلاً، استخدام شخصي بسيط</option>
                  <option value="Some team tools in use">نعم، فريقنا يستخدم بعض الأدوات</option>
                  <option value="Yes, we have AI systems already">نعم، لدينا أنظمة ذكاء اصطناعي بالفعل</option>
                </select>
              </div>
            </div>
            <div style="margin-top:1.5rem;display:flex;justify-content:space-between;">
              <button onclick="arContactStep(1)" class="btn-outline">→ رجوع</button>
              <button onclick="arContactStep(3)" class="btn-primary">التالي: حدد الموعد ←</button>
            </div>
          </div>

          <!-- STEP 3 -->
          <div class="form-step" id="cf-step-3">
            <p style="color:#006875;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">الخطوة ٣ من ٣: حدد موعد مكالمتك</p>

            <label class="form-label" style="display:block;margin-bottom:0.75rem;">صيغة الاجتماع المفضلة *</label>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:1.25rem;">
              <div class="meeting-type-card selected" onclick="arSelectMeeting(this, 'Video call')" id="cf-meet-video">
                <span class="material-symbols-outlined" style="font-size:24px;color:#006875;display:block;margin:0 auto 6px;">videocam</span>
                <p class="meet-label" style="font-size:0.75rem;font-weight:600;color:#006875;margin:0;">مكالمة فيديو</p>
              </div>
              <div class="meeting-type-card" onclick="arSelectMeeting(this, 'Phone call')" id="cf-meet-phone">
                <span class="material-symbols-outlined" style="font-size:24px;color:#72787e;display:block;margin:0 auto 6px;">call</span>
                <p class="meet-label" style="font-size:0.75rem;font-weight:600;color:#72787e;margin:0;">مكالمة هاتفية</p>
              </div>
              <div class="meeting-type-card" onclick="arSelectMeeting(this, 'In-person Dubai')" id="cf-meet-inperson">
                <span class="material-symbols-outlined" style="font-size:24px;color:#72787e;display:block;margin:0 auto 6px;">location_on</span>
                <p class="meet-label" style="font-size:0.75rem;font-weight:600;color:#72787e;margin:0;">لقاء شخصي</p>
              </div>
            </div>
            <input type="hidden" id="cf-meeting-type" value="Video call" />

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
              <div>
                <label class="form-label" for="cf-date">التاريخ المفضل *</label>
                <input class="form-input" id="cf-date" type="date" required style="direction:ltr;" />
              </div>
              <div>
                <label class="form-label" for="cf-time">الوقت المفضل</label>
                <select class="form-select" id="cf-time">
                  <option value="Morning (9am – 12pm)">صباحاً (٩ص – ١٢ظ)</option>
                  <option value="Afternoon (12pm – 4pm)">بعد الظهر (١٢ظ – ٤م)</option>
                  <option value="Late Afternoon (4pm – 6pm)">عصراً (٤م – ٦م)</option>
                </select>
              </div>
            </div>
            <div style="margin-bottom:1rem;">
              <label class="form-label" for="cf-notes">أي شيء آخر تريد إخبارنا به؟ (اختياري)</label>
              <textarea class="form-textarea" id="cf-notes" rows="2" placeholder="أي أسئلة أو سياق محدد يساعدنا على التحضير..."></textarea>
            </div>

            <div style="background:rgba(0,104,117,0.06);border:1px solid rgba(0,104,117,0.20);border-radius:12px;padding:1rem;margin-bottom:1.25rem;display:flex;align-items:flex-start;gap:12px;">
              <span class="material-symbols-outlined" style="color:#d97706;font-size:20px;flex-shrink:0;margin-top:2px;">shield</span>
              <p style="color:#42474e;font-size:0.8125rem;line-height:1.6;margin:0;"><strong style="color:#00253b;">بدون مخاطرة، ١٠٠٪.</strong> المكالمة مجانية. وإذا تابعت معنا ولم تكن راضياً عن نظام الذكاء الاصطناعي الذي نبنيه، نرد لك كامل استثمارك. بدون أي شروط.</p>
            </div>

            <!-- Honeypot: leave empty, bots fill this -->
            <input type="text" id="cf-honeypot" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />

            <div id="cf-submit-error" style="display:none;background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:0.75rem 1rem;font-size:0.8125rem;margin-bottom:1rem;">
              حدث خطأ ما. يرجى <a href={`https://wa.me/${COMPANY.whatsapp}`} style="color:#ef4444;font-weight:bold;">مراسلتنا عبر واتساب</a> أو البريد الإلكتروني <a href={`mailto:${COMPANY.email}`} style="color:#ef4444;font-weight:bold;">{COMPANY.email}</a>.
            </div>

            <div style="display:flex;justify-content:space-between;">
              <button onclick="arContactStep(2)" class="btn-outline">→ رجوع</button>
              <button id="cf-submit-btn" onclick="arSubmitContact()" class="btn-primary">احجز استشارتك ←</button>
            </div>
          </div>

          <!-- SUCCESS SCREEN -->
          <div id="cf-success-screen" style="text-align:center;padding:2rem 0;">
            <div style="width:64px;height:64px;border-radius:50%;background:rgba(0,227,253,0.12);border:2px solid rgba(0,227,253,0.35);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;">
              <span class="material-symbols-outlined" style="color:#006875;font-size:32px;">check_circle</span>
            </div>
            <h3 style="font-size:1.25rem;font-weight:700;color:#00253b;margin-bottom:0.5rem;">تم استلام طلبك!</h3>
            <p style="color:#42474e;font-size:0.875rem;margin-bottom:1.5rem;max-width:360px;margin-left:auto;margin-right:auto;line-height:1.6;">شكراً لك. سنتواصل معك قريباً لتأكيد موعد استشارتك، عبر واتساب أو البريد الإلكتروني، أيهما تفضل.</p>
            <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,227,253,0.10);border:1px solid rgba(0,227,253,0.25);border-radius:100px;padding:8px 20px;font-size:0.8125rem;font-weight:600;color:#004f58;">
              <span class="material-symbols-outlined" style="font-size:16px;">shield</span>
              ضمان الرضا ١٠٠٪ يشمل كل ما نبنيه
            </div>
          </div>
        </div>
      </div>

      <!-- LEFT (visually): Direct contact -->
      <div class="contact-side">
        <div class="contact-info-card">
          <h3>تواصل مباشر</h3>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(37,211,102,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#22c55e" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
            </div>
            <div>
              <p class="channel-label">واتساب (الأسرع)</p>
              <a href={`https://wa.me/${COMPANY.whatsapp}`} target="_blank" rel="noopener" class="channel-value">{COMPANY.phone}</a>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,104,117,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#006875" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="channel-label">البريد الإلكتروني</p>
              <a href={`mailto:${COMPANY.email}`} class="channel-value">{COMPANY.email}</a>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,37,59,0.08);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#00253b" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="channel-label">الموقع</p>
              <p class="channel-value">Business Bay، دبي، الإمارات</p>
            </div>
          </div>
          <div class="contact-channel">
            <div class="channel-icon" style="background:rgba(0,104,117,0.12);">
              <svg viewBox="0 0 24 24" fill="none" width="20" height="20" stroke="#006875" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="channel-label">ساعات العمل</p>
              <p class="channel-value">الأحد – الخميس، ٩:٠٠ صباحاً – ٦:٠٠ مساءً بتوقيت الإمارات</p>
            </div>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:8px;">
          <div class="trust-pill">
            <span class="material-symbols-outlined" style="color:#006875;font-size:16px;flex-shrink:0;">star</span>
            استشارة مجانية ١٠٠٪، بدون التزام
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" style="color:#006875;font-size:16px;flex-shrink:0;">translate</span>
            متوفر بالعربي والإنجليزي
          </div>
          <div class="trust-pill">
            <span class="material-symbols-outlined" style="color:#006875;font-size:16px;flex-shrink:0;">shield</span>
            ضمان استرداد ١٠٠٪ على جميع أنظمة الذكاء الاصطناعي التي نبنيها
          </div>
        </div>

        <div class="guarantee-box">
          <span class="material-symbols-outlined" style="color:#d97706;font-size:24px;direction:ltr;" aria-hidden="true">shield</span>
          <p><strong style="color:#00253b;">ضمان استرداد ١٠٠٪</strong>: إذا لم تكن راضياً عما نبنيه، نرد لك كل درهم.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT TO EXPECT -->
<section class="section" aria-labelledby="expect-heading">
  <div class="container" style="max-width:960px;">
    <div class="section-header">
      <h2 id="expect-heading">ماذا يحدث في استشارتك المجانية لمدة ٣٠ دقيقة</h2>
    </div>
    <div class="feature-ledger">
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">٠١</div>
        <h3 style="font-weight:700;color:#00253b;">نستمع أولاً</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.6;">تخبرنا عن شركتك وفريقك وأكبر التحديات التشغيلية لديك. بدون أي عرض مبيعات في هذه المرحلة.</p>
      </div>
      <div class="card">
        <div class="stat-number" style="font-size:1.875rem; grid-row:1 / span 2; align-self:start;">٠٢</div>
        <h3 style="font-weight:700;color:#00253b;">نحدد فرص الذكاء الاصطناعي</h3>
