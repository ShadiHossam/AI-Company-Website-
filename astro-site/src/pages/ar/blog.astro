---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

interface DbPost {
  id: string;
  ar_title: string;
  ar_description: string;
  slug: string;
  category: string;
  pub_date: string;
  author_name: string;
  og_image: string;
}

let posts: DbPost[] = [];

try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('blog_posts')
    .select('id, ar_title, ar_description, slug, category, pub_date, author_name, og_image')
    .eq('status', 'published')
    .is('deleted_at', null)
    .not('ar_title', 'is', null)
    .order('pub_date', { ascending: false });

  if (data) posts = data as DbPost[];
} catch {
  posts = [];
}

const blogLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'مدونة Lenoo AI',
    url: 'https://lenooai.com/ar/blog',
    description: 'رؤى وأدلة ودراسات حالة في الذكاء الاصطناعي لشركات دبي والإمارات.',
    publisher: { '@type': 'Organization', name: 'Lenoo AI', url: 'https://lenooai.com' },
    inLanguage: 'ar',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: 'https://lenooai.com/ar' },
      { '@type': 'ListItem', position: 2, name: 'المدونة', item: 'https://lenooai.com/ar/blog' },
    ],
  },
];
---

<ArBaseLayout
  title="مدونة الذكاء الاصطناعي في دبي: رؤى للشركات في الإمارات | Lenoo AI"
  description="رؤى وأدلة ودراسات حالة في الذكاء الاصطناعي من Lenoo AI، وكالة الذكاء الاصطناعي في دبي، لشركات الإمارات الصغيرة والمتوسطة. تعلّم كيف تطبق الذكاء الاصطناعي وتحسب العائد على الاستثمار."
  canonicalPath="/ar/blog"
  enPath="/blog"
  ogImage="/assets/og-blog.jpg"
  ldJson={blogLdJson}
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>المدونة</div>
    <h1>مدونة الذكاء الاصطناعي: <span class="gradient-text">نسخة الإمارات</span></h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      أدلة عملية ودراسات حالة ورؤى استراتيجية، مبنية لشركات دبي الصغيرة والمتوسطة.
    </p>
  </div>
</header>

<!-- BANNER IMAGE -->
<div style="position:relative; overflow:hidden; height:220px;">
  <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&q=80&auto=format&fit=crop" alt="كتابة وبحث في مقال استراتيجية ذكاء اصطناعي على حاسوب محمول" loading="lazy" width="1400" height="220" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.55) 0%,rgba(249,249,255,0) 45%),linear-gradient(to top,rgba(0,19,32,0.25) 0%,transparent 55%);"></div>
</div>

<!-- ALL POSTS -->
<section class="section" style="padding-top:3rem;">
  <div class="container">

    <div class="section-header">
      <h2>أحدث <span class="gradient-text">المقالات</span></h2>
      <p>إرشادات عملية لتبني الذكاء الاصطناعي في شركتك، بلا مصطلحات معقدة وبلا مبالغة.</p>
    </div>

    <!-- SEARCH -->
    <div style="max-width:420px; margin:0 auto 2rem;">
      <div class="search-box">
        <span class="material-symbols-outlined search-icon" style="direction:ltr;" aria-hidden="true">search</span>
        <input type="search" id="post-search" class="search-input" placeholder="ابحث في المقالات..." aria-label="ابحث في مقالات المدونة" />
      </div>
    </div>

    {posts.length > 0 ? (
      <div>
        <div id="posts-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
          {posts.map(post => (
            <article class="blog-card" data-category={post.category}>
              {post.og_image ? (
                <div class="blog-card-media">
                  <img src={post.og_image} alt={post.ar_title} class="blog-card-img" loading="lazy" />
                </div>
              ) : (
                <div class="blog-card-placeholder">
                  <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;direction:ltr;" aria-hidden="true">edit_note</span>
                </div>
              )}
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span class="tag tag-teal">{post.category}</span>
                  {post.pub_date && (
                    <span class="blog-card-date">
                      {new Date(post.pub_date).toLocaleDateString('ar-AE', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                  )}
                </div>
                <h3 class="blog-card-title">
                  <a href={`/ar/blog/${post.slug}`}>{post.ar_title}</a>
                </h3>
                <p class="blog-card-excerpt">{post.ar_description}</p>
                <a href={`/ar/blog/${post.slug}`} class="blog-card-link">
                  اقرأ المزيد ←
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    ) : (
      <div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;direction:ltr;" aria-hidden="true">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta"><span class="tag tag-coming">قريباً</span></div>
              <h3 class="blog-card-title">استراتيجية الذكاء الاصطناعي في الإمارات ٢٠٣١: ماذا تعني لشركتك</h3>
              <p class="blog-card-excerpt" style="margin-bottom:0;">شرح عملي لاستراتيجية الذكاء الاصطناعي الوطنية في الإمارات، وكيف تُوائم الشركات الصغيرة والمتوسطة استثماراتها في الذكاء الاصطناعي مع الأولويات الوطنية.</p>
            </div>
          </article>

          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;direction:ltr;" aria-hidden="true">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta"><span class="tag tag-coming">قريباً</span></div>
              <h3 class="blog-card-title">روبوتات المحادثة العربية بالذكاء الاصطناعي: دليل شامل لشركات الإمارات</h3>
              <p class="blog-card-excerpt" style="margin-bottom:0;">كل ما تحتاج معرفته عن نشر ذكاء اصطناعي باللغة العربية: الدقة، التعامل مع اللهجات، والتكامل مع قنوات خدمة العملاء في الإمارات.</p>
            </div>
          </article>
        </div>
      </div>
    )}

    <p id="no-results" class="no-results">لا توجد مقالات مطابقة لبحثك. جرّب كلمة أو تصنيفاً مختلفاً.</p>

  </div>
</section>

<!-- FINAL CTA -->
<section class="section" style="background:#e7eeff; padding:4rem 0;">
  <div class="container">
    <div class="cta-band" style="text-align:center; max-width:680px; margin:0 auto;">
      <div style="position:relative; z-index:1; text-align:center;">
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:1rem;">تريد تطبيق هذا على شركتك، لا مجرد قراءته؟</h2>
        <p style="font-size:1.0625rem; max-width:36rem; margin:0 auto 2rem; line-height:1.7;">احجز مكالمة مجانية لمدة ٣٠ دقيقة. سنخبرك بصراحة إن كان الذكاء الاصطناعي سيساعد وكيف، وما ستكلفه العملية.</p>
        <button onclick="openModal(this)" data-source="ar_blog_cta" class="btn-primary" style="font-size:1.125rem; padding:1.125rem 2.75rem;">احجز استشارتك المجانية</button>
      </div>
    </div>
  </div>
</section>

</ArBaseLayout>

<style>
.blog-card {
  background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:var(--radius-lg);
  overflow:hidden; display:flex; flex-direction:column;
  box-shadow:var(--shadow-card);
  transition:transform .3s var(--ease), box-shadow .3s var(--ease), border-color .3s;
}
.blog-card:hover { transform:translateY(-5px); border-color:rgba(0,104,117,0.16); box-shadow:var(--shadow-card-hover); }
.blog-card-media { height:200px; overflow:hidden; position:relative; }
.blog-card-media::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(to top, rgba(0,37,59,0.10), transparent 40%);
  pointer-events:none;
}
.blog-card-img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .6s var(--ease); }
.blog-card:hover .blog-card-img { transform:scale(1.05); }
.blog-card-placeholder { height:200px; background:linear-gradient(135deg,#e7eeff,#f0f8ff); display:flex; align-items:center; justify-content:center; }
.blog-card-body { padding:1.625rem 1.625rem 1.5rem; flex:1; display:flex; flex-direction:column; }
.blog-card-meta { margin-bottom:0.875rem; display:flex; align-items:center; gap:8px; justify-content:space-between; }
.blog-card-date { font-size:0.75rem; color:#72787e; font-variant-numeric:tabular-nums; }
.blog-card-title { font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.42; letter-spacing:-0.015em; }
.blog-card-title a { color:inherit; text-decoration:none; transition:color .2s; }
.blog-card-title a:hover { color:#006875; }
.blog-card-excerpt { color:#72787e; font-size:0.875rem; line-height:1.65; margin:0 0 1.125rem; }
.blog-card-link { font-size:0.8125rem; font-weight:700; color:#006875; text-decoration:none; margin-top:auto; align-self:flex-start; transition:transform .25s var(--ease), color .2s; }
.blog-card-link:hover { color:#004f58; transform:translateX(-3px); }
.tag { display:inline-flex; align-items:center; padding:3px 12px; border-radius:100px; font-size:0.75rem; font-weight:600; }
.tag-coming { background:rgba(245,158,11,0.12); color:#d97706; border:1px solid rgba(245,158,11,0.25); }
.tag-teal { background:rgba(0,104,117,0.10); color:#004f58; border:1px solid rgba(0,104,117,0.20); }
.search-box {
  position: relative; display: flex; align-items: center;
}
.search-icon {
  position: absolute; inset-inline-start: 14px; font-size: 20px; color: #72787e; pointer-events: none;
}
.search-input {
  width: 100%; padding: .75rem 1rem; padding-inline-start: 2.75rem;
  border: 1px solid #c2c7ce; border-radius: 100px; font-size: .9375rem; font-family: inherit;
  color: #111c2d; background: #ffffff;
  transition: border-color .2s, box-shadow .2s; outline: none;
}
.search-input::placeholder { color: #72787e; }
.search-input:focus { border-color: #006875; box-shadow: 0 0 0 3px rgba(0,104,117,0.12); }
.no-results { text-align: center; color: #72787e; padding: 3rem 1rem; display: none; }
.no-results.show { display: block; }
</style>

<script>
  const searchInput = document.getElementById('post-search') as HTMLInputElement | null;
  const noResults   = document.getElementById('no-results');

  function applyFilters() {
    const grid = document.getElementById('posts-grid');
    if (!grid) return;
    const query = (searchInput?.value ?? '').trim().toLowerCase();
    let visibleCount = 0;

    grid.querySelectorAll<HTMLElement>('.blog-card').forEach(card => {
      const text = (card.textContent ?? '').toLowerCase();
      const match = query === '' || text.includes(query);
      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    if (noResults) noResults.classList.toggle('show', visibleCount === 0);
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => applyFilters());
  }
</script>
