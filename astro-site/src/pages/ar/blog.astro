---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

interface DbPost {
  id: string;
  ar_title: string;
  ar_description: string;
  slug: string;
  category: string;
  pub_date: string;
  author_name: string;
  og_image: string;
}

let posts: DbPost[] = [];

try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('blog_posts')
    .select('id, ar_title, ar_description, slug, category, pub_date, author_name, og_image')
    .eq('status', 'published')
    .is('deleted_at', null)
    .not('ar_title', 'is', null)
    .order('pub_date', { ascending: false });

  if (data) posts = data as DbPost[];
} catch {
  // show empty state
}

const allCategories = [...new Set(posts.map(p => p.category).filter(Boolean))];

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'مدونة Lenoo AI',
  url: 'https://lenooai.com/ar/blog',
  inLanguage: 'ar',
  description: 'رؤى وأدلة وحالات نجاح في مجال الذكاء الاصطناعي للشركات في دبي والإمارات.',
  isPartOf: { '@type': 'WebSite', url: 'https://lenooai.com' },
};
---

<ArBaseLayout
  title="مدونة الذكاء الاصطناعي في دبي: رؤى للشركات في الإمارات | Lenoo AI"
  description="رؤى وأدلة ودراسات حالة في الذكاء الاصطناعي من Lenoo AI، وكالة الذكاء الاصطناعي في دبي. تعلّم كيف تطبق الذكاء الاصطناعي وتحسب العائد على الاستثمار."
  canonicalPath="/ar/blog"
  enPath="/blog"
  ogImage="/assets/og-blog.jpg"
  ldJson={ldJson}
>

<header style="background:linear-gradient(160deg,#f0f9ff 0%,#e7eeff 50%,#f8f9fe 100%);padding:8rem 0 5rem;text-align:center;">
  <div class="container">
    <nav style="display:flex;align-items:center;justify-content:center;gap:8px;font-size:0.875rem;color:#72787e;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar" style="color:#006875;font-weight:600;">الرئيسية</a>
      <span aria-hidden="true">/</span>
      <strong style="color:#00253b;">المدونة</strong>
    </nav>
    <h1 style="font-size:clamp(2rem,5vw,3rem);font-weight:900;color:#00253b;margin-bottom:1rem;">مدونة Lenoo AI</h1>
    <p style="font-size:1.125rem;color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">رؤى عملية ودراسات حالة وأدلة من الفريق الميداني في دبي.</p>
    <a href="/blog" style="font-size:0.875rem;color:#006875;font-weight:600;" lang="en">عرض بالإنجليزية ←</a>
  </div>
</header>

<!-- BANNER IMAGE -->
<div style="position:relative;overflow:hidden;height:240px;">
  <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1400&q=80&auto=format&fit=crop" alt="فريق عمل يناقش بيانات ورؤى الذكاء الاصطناعي أثناء إعداد محتوى المدونة" loading="eager" fetchpriority="high" width="1400" height="240" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,37,59,0.35),transparent 55%);"></div>
</div>

<section style="padding:4rem 0 6rem;">
  <div class="container">
    {posts.length === 0 ? (
      <div style="text-align:center;padding:5rem 0;color:#72787e;">
        <p style="font-size:1.125rem;">لا توجد مقالات بالعربية حتى الآن.</p>
        <a href="/blog" class="btn-outline" style="display:inline-block;margin-top:1.5rem;" lang="en">تصفح المدونة الإنجليزية ←</a>
      </div>
    ) : (
      <div>
        {allCategories.length > 1 && (
          <div id="filter-bar" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:2rem;">
            <button class="filter-btn active" data-filter="all">الكل</button>
            {allCategories.map(cat => (
              <button class="filter-btn" data-filter={cat}>{cat}</button>
            ))}
          </div>
        )}
        <div id="posts-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.5rem;">
          {posts.map(post => {
            const date = post.pub_date
              ? new Date(post.pub_date).toLocaleDateString('ar-AE', { day: 'numeric', month: 'long', year: 'numeric' })
              : '';
            return (
              <a href={`/ar/blog/${post.slug}`} data-category={post.category} style="text-decoration:none;display:block;" class="card card-hover">
                {post.og_image && post.og_image !== '/assets/og-blog.jpg' && (
                  <img src={post.og_image} alt="" role="presentation" style="width:100%;height:180px;object-fit:cover;border-radius:12px 12px 0 0;margin:-1.5rem -1.5rem 1.25rem;width:calc(100% + 3rem);" loading="lazy" />
                )}
                <div style="display:inline-flex;align-items:center;gap:6px;background:rgba(0,104,117,0.1);border-radius:8px;padding:4px 10px;margin-bottom:0.75rem;font-size:0.75rem;font-weight:700;color:#006875;text-transform:uppercase;">
                  {post.category}
                </div>
                <h2 style="font-size:1.0625rem;font-weight:800;color:#00253b;margin-bottom:0.75rem;line-height:1.4;">{post.ar_title}</h2>
                {post.ar_description && (
                  <p style="font-size:0.9rem;color:#42474e;line-height:1.7;margin-bottom:1rem;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{post.ar_description}</p>
                )}
                <div style="display:flex;align-items:center;justify-content:space-between;margin-top:auto;padding-top:0.75rem;border-top:1px solid rgba(0,37,59,0.08);">
                  <span style="font-size:0.8125rem;color:#72787e;">{post.author_name ?? 'Lenoo AI'}</span>
                  <span style="font-size:0.8125rem;color:#72787e;">{date}</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>

</ArBaseLayout>

<script>
  const filterBar = document.getElementById('filter-bar');
  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter;
      filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const grid = document.getElementById('posts-grid');
      if (!grid) return;
      grid.querySelectorAll<HTMLElement>('[data-category]').forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  }
</script>

<style>
  .card-hover { transition: box-shadow 0.2s, transform 0.2s; }
  .card-hover:hover { box-shadow: 0 12px 40px rgba(0,37,59,0.12); transform: translateY(-2px); }
  .filter-btn {
    padding:7px 18px; border-radius:100px; font-size:0.8125rem; font-weight:600; cursor:pointer;
    border:1px solid rgba(0,37,59,0.16); background:#fff; color:#42474e;
    box-shadow:0 1px 2px rgba(0,37,59,0.04);
    transition:color .2s, border-color .2s, background .2s, transform .2s ease, box-shadow .2s ease;
  }
  .filter-btn:hover { border-color:#006875; color:#006875; transform:translateY(-1px); box-shadow:0 1px 2px rgba(0,37,59,0.05), 0 6px 14px rgba(0,59,92,0.08); }
  .filter-btn.active { background:#006875; color:#fff; border-color:#006875; box-shadow:0 1px 2px rgba(0,37,59,0.10), 0 6px 16px rgba(0,104,117,0.26); }
</style>
