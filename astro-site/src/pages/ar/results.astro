---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "نتائج عملائنا — قصص نجاح الذكاء الاصطناعي في دبي | Aegis AI",
    "url": "https://aegisai.ae/ar/results",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "النتائج", "item": "https://aegisai.ae/ar/results" }
    ]
  }
];
---

<ArBaseLayout
  title="نتائج عملائنا — قصص نجاح الذكاء الاصطناعي في دبي | Aegis AI"
  description="نتائج حقيقية من شركات في دبي والإمارات استخدمت Aegis AI — توفير في الوقت، زيادة في المبيعات، وأنظمة ذكاء اصطناعي تعمل فعلاً. ضمان 100%."
  canonicalPath="/ar/results"
  enPath="/results"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a><span class="sep">/</span><strong class="current">النتائج</strong>
    </nav>
    <h1>نتائج حقيقية من شركات في دبي<br><span class="gradient-text">أرقام فعلية، لا وعود</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:#42474e;">
      كل قصة هنا من شركة حقيقية في دبي والإمارات. نُبيّن المشكلة التي كانت تعاني منها، ما بنيناه لها، والنتائج بأرقام قابلة للقياس.
    </p>
    <button onclick="openModal(this)" data-source="ar_results_hero" class="btn-primary">احجز استشارة مجانية ←</button>
  </div>
</header>

<!-- 2. Stats Strip -->
<section style="background:#f8f9fa;padding:2.5rem 0;border-top:1px solid #e8eaed;border-bottom:1px solid #e8eaed;">
  <div class="container">
    <div class="results-stats-grid">
      <div class="stat-item">
        <p class="stat-num">+40</p>
        <p class="stat-lbl">مشروع مُنجز في دبي والإمارات</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">4</p>
        <p class="stat-lbl">قطاعات رئيسية نخدمها</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">100%</p>
        <p class="stat-lbl">ضمان استرداد الأموال</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">دبي</p>
        <p class="stat-lbl">فريقنا مقيم ويعمل محلياً</p>
      </div>
    </div>
  </div>
</section>

<!-- 3. Results Grid -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">قصص النجاح</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:540px;margin-inline:auto;">ستة مشاريع حقيقية في قطاعات مختلفة — مشكلة واضحة، حل ملموس، ونتائج قابلة للقياس.</p>
    <div class="results-grid">

      <!-- Card 1: Real Estate -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-cyan" style="font-size:0.75rem;">العقارات</span>
          <h3>وكالة عقارية في دبي</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> متوسط وقت الرد على الاستفسارات كان 4 ساعات — عملاء كثيرون يتحولون للمنافسين في هذه الفترة.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> روبوت واتساب يرد فوراً بالعربي والإنجليزي، يُأهّل العملاء، ويطابقهم مع العقارات المناسبة.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">دقيقتان</span>
            <span class="metric-lbl">متوسط وقت الرد</span>
          </div>
          <div class="metric">
            <span class="metric-num">+47%</span>
            <span class="metric-lbl">معدل تحويل العملاء</span>
          </div>
        </div>
      </div>

      <!-- Card 2: Hospitality -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-cyan" style="font-size:0.75rem;">الضيافة</span>
          <h3>مجموعة فنادق في دبي</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> فريق الكونسيرج كان يُمضي معظم وقته في طلبات روتينية متكررة، مما أثّر على جودة الخدمة الشخصية.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> كونسيرج ذكي عبر واتساب بالعربي والإنجليزي والهندي — يعالج الطلبات تلقائياً ويحوّل المعقد للفريق.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">80%</span>
            <span class="metric-lbl">طلبات معالجة آلياً</span>
          </div>
          <div class="metric">
            <span class="metric-num">تفرّغ كامل</span>
            <span class="metric-lbl">للطلبات التي تحتاج بشراً</span>
          </div>
        </div>
      </div>

      <!-- Card 3: Retail -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-cyan" style="font-size:0.75rem;">التجزئة</span>
          <h3>سلسلة تجزئة — 12 فرعاً</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> إدارة مخزون 12 فرعاً عبر الإكسل يدوياً — نفاد غير متوقع في بعض الفروع وإفراط في فروع أخرى.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> لوحة تتبع مخزون لحظية موحدة مع نظام تنبؤ بالطلب وتنبيهات إعادة طلب تلقائية.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">-30%</span>
            <span class="metric-lbl">تكاليف الإفراط في المخزون</span>
          </div>
          <div class="metric">
            <span class="metric-num">3 ساعات</span>
            <span class="metric-lbl">توفير يومي في التتبع اليدوي</span>
          </div>
        </div>
      </div>

      <!-- Card 4: Logistics -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-cyan" style="font-size:0.75rem;">اللوجستيات</span>
          <h3>شركة شحن في دبي</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> 180,000 درهم سنوياً على الوقود، ومسارات تُخطَّط يدوياً، وفريق يُمضي وقته في اتصالات تحديث العملاء.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> نظام تحسين مسارات يومي مع إشعارات واتساب تلقائية للعملاء في كل مرحلة توصيل.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">-22%</span>
            <span class="metric-lbl">تكاليف الوقود السنوية</span>
          </div>
          <div class="metric">
            <span class="metric-num">صفر</span>
            <span class="metric-lbl">مكالمات يدوية لتحديث العملاء</span>
          </div>
        </div>
      </div>

      <!-- Card 5: Professional Services -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-amber" style="font-size:0.75rem;">الخدمات المهنية</span>
          <h3>شركة محاسبة وضرائب في دبي</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> فريق المحاسبة يُمضي ساعات يومياً في إدخال بيانات يدوي وإعداد تقارير روتينية متكررة.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> منظومة أتمتة لإدخال البيانات وإعداد التقارير الشهرية تلقائياً مع تنبيهات المواعيد الضريبية.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">15 ساعة</span>
            <span class="metric-lbl">توفير أسبوعي للفريق</span>
          </div>
          <div class="metric">
            <span class="metric-num">صفر</span>
            <span class="metric-lbl">مواعيد ضريبية فائتة</span>
          </div>
        </div>
      </div>

      <!-- Card 6: Training -->
      <div class="result-card">
        <div class="result-card-top">
          <span class="badge badge-amber" style="font-size:0.75rem;">تدريب الفرق</span>
          <h3>شركة مالية — 45 موظفاً</h3>
          <p class="problem-text">
            <strong>المشكلة:</strong> الفريق يسمع عن الذكاء الاصطناعي لكن لا أحد يعرف كيف يُطبّقه فعلياً في عمله اليومي.
          </p>
          <p class="solution-text">
            <strong>ما بنيناه:</strong> برنامج تدريب مخصص من 8 جلسات يُعلّم الفريق استخدام الذكاء الاصطناعي في مهامهم الفعلية.
          </p>
        </div>
        <div class="result-card-metrics">
          <div class="metric">
            <span class="metric-num">45</span>
            <span class="metric-lbl">موظفاً استفادوا من التدريب</span>
          </div>
          <div class="metric">
            <span class="metric-num">2× أسرع</span>
            <span class="metric-lbl">في إنجاز المهام الروتينية</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">شركتك يمكن أن تكون القصة التالية</h2>
    <p style="margin-bottom:2rem;opacity:0.9;max-width:500px;margin-inline:auto;line-height:1.7;">احجز جلسة تشخيص مجانية — نحلل عملياتك ونحدد أين يحقق الذكاء الاصطناعي أكبر تأثير لشركتك.</p>
    <button onclick="openModal(this)" data-source="ar_results_cta" class="btn-primary" style="background:#fff;color:#1d4ed8;">ابدأ الآن ←</button>
  </div>
</section>

<style>
  .results-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: #1d4ed8;
    margin: 0 0 0.25rem;
  }
  .stat-lbl {
    color: #42474e;
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .result-card {
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .result-card-top {
    padding: 1.5rem;
    flex: 1;
  }
  .result-card-top h3 {
    font-size: 1rem;
    margin: 0.75rem 0 1rem;
  }
  .problem-text, .solution-text {
    font-size: 0.875rem;
    color: #42474e;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }
  .result-card-metrics {
    background: #f0f4ff;
    padding: 1rem 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid #e0e8ff;
  }
  .metric {
    text-align: center;
  }
  .metric-num {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: #1d4ed8;
  }
  .metric-lbl {
    display: block;
    font-size: 0.75rem;
    color: #42474e;
    margin-top: 0.2rem;
    line-height: 1.4;
  }
  @media (max-width: 900px) {
    .results-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .results-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .results-grid { grid-template-columns: 1fr; }
  }
</style>

</ArBaseLayout>
