---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';
import { getSupabaseAdmin } from '../../lib/supabase';

interface ResultItem { value: string; label: string }
interface TimelineItem { step: string; description: string }
interface MediaSection { type: string; url: string; caption: string; description: string }

interface CaseStudyView {
  industry: string | null;
  title: string;
  delivery_time: string | null;
  challenge: string | null;
  solution: string | null;
  results: ResultItem[];
  timeline: TimelineItem[];
  media_sections: MediaSection[];
}

let caseStudies: CaseStudyView[] = [];

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('case_studies')
    .select('industry, ar_industry, title, ar_title, delivery_time, ar_delivery_time, challenge, ar_challenge, solution, ar_solution, results, ar_results, timeline_items, ar_timeline_items, media_sections')
    .eq('published', true)
    .is('deleted_at', null)
    .order('sort_order');

  if (!error && data) {
    caseStudies = data.map((cs) => ({
      industry: cs.ar_industry ?? cs.industry,
      title: cs.ar_title ?? cs.title,
      delivery_time: cs.ar_delivery_time ?? cs.delivery_time,
      challenge: cs.ar_challenge ?? cs.challenge,
      solution: cs.ar_solution ?? cs.solution,
      results: (cs.ar_results ?? cs.results) as ResultItem[] ?? [],
      timeline: (cs.ar_timeline_items ?? cs.timeline_items) as TimelineItem[] ?? [],
      media_sections: Array.isArray(cs.media_sections) ? cs.media_sections : [],
    }));
  }
} catch (err) {
  // Leave caseStudies empty on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "نتائج عملائنا: قصص نجاح الذكاء الاصطناعي في دبي والخليج | Aegis AI",
    "url": "https://aegisai.ae/ar/results",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "النتائج", "item": "https://aegisai.ae/ar/results" }
    ]
  }
];
---

<ArBaseLayout
  title="نتائج عملائنا: قصص نجاح الذكاء الاصطناعي في دبي والخليج | Aegis AI"
  description="نتائج حقيقية من شركات في الإمارات والسعودية والكويت وقطر استخدمت Aegis AI: توفير في الوقت، زيادة في المبيعات، وأنظمة ذكاء اصطناعي تعمل فعلاً. ضمان 100%."
  canonicalPath="/ar/results"
  enPath="/results"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>النتائج</div>
    <h1>نتائج حقيقية من شركات في دبي<br><span class="gradient-text">أرقام فعلية، لا وعود</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:#42474e;">
      كل قصة هنا من شركة حقيقية في دبي والإمارات. نُبيّن المشكلة التي كانت تعاني منها، ما بنيناه لها، والنتائج بأرقام قابلة للقياس.
    </p>
    <button onclick="openModal(this)" data-source="ar_results_hero" class="btn-primary">احجز استشارة مجانية ←</button>
  </div>
</header>

<!-- 2. Stats Strip -->
<section style="background:#f8f9fa;padding:2.5rem 0;border-top:1px solid #e8eaed;border-bottom:1px solid #e8eaed;">
  <div class="container">
    <div class="results-stats-grid">
      <div class="stat-item">
        <p class="stat-num">+٤٠</p>
        <p class="stat-lbl">مشروع مُنجز في دبي والإمارات</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">٤</p>
        <p class="stat-lbl">قطاعات رئيسية نخدمها</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد الأموال</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">دبي</p>
        <p class="stat-lbl">فريقنا مقيم ويعمل محلياً</p>
      </div>
    </div>
  </div>
</section>

<!-- 3. Results Grid -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">قصص النجاح</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:540px;margin-inline:auto;">مشاريع حقيقية في قطاعات مختلفة: مشكلة واضحة، حل ملموس، ونتائج قابلة للقياس.</p>
    <div class="results-grid">

      {caseStudies.map((cs) => (
        <div class="result-card">
          <div class="result-card-top">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">
              {cs.industry && <span class="badge badge-cyan" style="font-size:0.75rem;">{cs.industry}</span>}
              {cs.delivery_time && <span style="color:#42474e;font-size:0.75rem;">{cs.delivery_time}</span>}
            </div>
            <h3>{cs.title}</h3>
            {cs.challenge && (
              <p class="problem-text">
                <strong>المشكلة:</strong> {cs.challenge}
              </p>
            )}
            {cs.solution && (
              <p class="solution-text">
                <strong>ما بنيناه:</strong> {cs.solution}
              </p>
            )}
            {cs.timeline.length > 0 && (
              <div class="mini-timeline">
                {cs.timeline.map((t) => (
                  <div class="mini-timeline-row">
                    <span class="mini-timeline-dot"></span>
                    <p><strong>{t.step}</strong>{t.description ? `: ${t.description}` : ''}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
          {cs.results.length > 0 && (
            <div class="result-card-metrics" style={`grid-template-columns:repeat(${Math.min(cs.results.length, 3)},1fr);`}>
              {cs.results.map((r) => (
                <div class="metric">
                  <span class="metric-num">{r.value}</span>
                  <span class="metric-lbl">{r.label}</span>
                </div>
              ))}
            </div>
          )}
          {cs.media_sections.length > 0 && (
            <div class="result-card-media">
              {cs.media_sections.map((m) => (
                <div>
                  {m.type === 'image' && m.url && (
                    <img src={m.url} alt={m.caption || m.description || ''} loading="lazy" style="width:100%;border-radius:10px;display:block;object-fit:cover;max-height:220px;" />
                  )}
                  {m.type === 'video' && m.url && (
                    <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:10px;">
                      <iframe src={m.url} title={m.caption || 'Video'} allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy" style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;border-radius:10px;"></iframe>
                    </div>
                  )}
                  {m.description && <p style="color:#42474e;font-size:0.8125rem;line-height:1.6;margin:0.5rem 0 0;">{m.description}</p>}
                </div>
              ))}
            </div>
          )}
        </div>
      ))}

    </div>
  </div>
</section>

<!-- INDUSTRIES COVERED -->
<section class="section" aria-labelledby="ar-industries-heading">
  <div class="container">
    <h2 id="ar-industries-heading" style="text-align:center;margin-bottom:2rem;">القطاعات التي حققنا فيها نتائج</h2>
    <div class="ar-industries-grid">
      <a href="/ar/industries/real-estate" class="ar-industry-link-card">
        <div class="ar-industry-link-icon"><span class="material-symbols-outlined">home</span></div>
        <h3>العقارات</h3>
        <p>تأهيل العملاء، روبوت واتساب، أتمتة أنظمة إدارة العملاء</p>
        <p class="ar-industry-link-cta">شاهد الحلول ←</p>
      </a>
      <a href="/ar/industries/retail" class="ar-industry-link-card">
        <div class="ar-industry-link-icon"><span class="material-symbols-outlined">shopping_bag</span></div>
        <h3>التجزئة والتجارة الإلكترونية</h3>
        <p>التنبؤ بالطلب، التسعير، التخصيص</p>
        <p class="ar-industry-link-cta">شاهد الحلول ←</p>
      </a>
      <a href="/ar/industries/hospitality" class="ar-industry-link-card">
        <div class="ar-industry-link-icon"><span class="material-symbols-outlined">hotel</span></div>
        <h3>الضيافة</h3>
        <p>كونسيرج ذكي، إدارة الإيرادات، جدولة الفريق</p>
        <p class="ar-industry-link-cta">شاهد الحلول ←</p>
      </a>
      <a href="/ar/industries/logistics" class="ar-industry-link-card">
        <div class="ar-industry-link-icon"><span class="material-symbols-outlined">local_shipping</span></div>
        <h3>اللوجستيات</h3>
        <p>تحسين المسارات، ذكاء اصطناعي للأسطول، التنبؤ بالطلب</p>
        <p class="ar-industry-link-cta">شاهد الحلول ←</p>
      </a>
    </div>
  </div>
</section>

<!-- CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">شركتك يمكن أن تكون القصة التالية</h2>
    <p style="margin-bottom:2rem;max-width:500px;margin-inline:auto;line-height:1.7;">احجز جلسة تشخيص مجانية. نحلل عملياتك ونحدد أين يحقق الذكاء الاصطناعي أكبر تأثير لشركتك.</p>
    <button onclick="openModal(this)" data-source="ar_results_cta" class="btn-primary">ابدأ الآن ←</button>
  </div>
</section>

<style>
  .results-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: #1d4ed8;
    margin: 0 0 0.25rem;
  }
  .stat-lbl {
    color: #42474e;
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }
  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .result-card {
    background: #fff;
    border: 1px solid #e8eaed;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .result-card-top {
    padding: 1.5rem;
    flex: 1;
  }
  .result-card-top h3 {
    font-size: 1rem;
    margin: 0.75rem 0 1rem;
  }
  .problem-text, .solution-text {
    font-size: 0.875rem;
    color: #42474e;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }
  .mini-timeline {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed #e8eaed;
  }
  .mini-timeline-row {
    display: grid;
    grid-template-columns: 8px 1fr;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.5rem;
  }
  .mini-timeline-row p {
    font-size: 0.8125rem;
    color: #42474e;
    line-height: 1.6;
    margin: 0;
  }
  .mini-timeline-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #1d4ed8;
    margin-top: 5px;
    flex-shrink: 0;
  }
  .result-card-metrics {
    background: #f0f4ff;
    padding: 1rem 1.5rem;
    display: grid;
    gap: 1rem;
    border-top: 1px solid #e0e8ff;
  }
  .result-card-media {
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .metric {
    text-align: center;
  }
  .metric-num {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: #1d4ed8;
  }
  .metric-lbl {
    display: block;
    font-size: 0.75rem;
    color: #42474e;
    margin-top: 0.2rem;
    line-height: 1.4;
  }
  .ar-industries-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 840px;
    margin: 0 auto;
  }
  .ar-industry-link-card {
    background: #fff;
    border: 1px solid rgba(0,37,59,0.08);
    border-radius: 20px;
    padding: 1.75rem;
    text-align: center;
    box-shadow: 0 20px 40px rgba(0,59,92,0.04);
    text-decoration: none;
    display: block;
    transition: transform .25s, box-shadow .25s;
  }
  .ar-industry-link-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 56px rgba(0,59,92,0.10);
  }
  .ar-industry-link-icon {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: rgba(0,227,253,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 0.875rem;
    color: #006875;
  }
  .ar-industry-link-card h3 {
    font-weight: 700;
    color: #00253b;
    font-size: 1rem;
    margin-bottom: 4px;
  }
  .ar-industry-link-card p {
    color: #42474e;
    font-size: 0.8125rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .ar-industry-link-cta {
    color: #006875;
    font-size: 0.8125rem;
    font-weight: 600;
    margin: 0 !important;
  }
  @media (max-width: 900px) {
    .results-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .results-grid { grid-template-columns: repeat(2, 1fr); }
    .ar-industries-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    .results-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .results-grid { grid-template-columns: 1fr; }
    .ar-industries-grid { grid-template-columns: 1fr; }
  }
</style>

</ArBaseLayout>
