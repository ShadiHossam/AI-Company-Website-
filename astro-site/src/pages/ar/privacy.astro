---
export const prerender = false;
import ArBaseLayout from "../../layouts/ArBaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";
import { sanitizeRichText } from "../../lib/sanitize";

let dynamicTitle: string | null = null;
let dynamicSections: { heading: string; body: string }[] | null = null;
let dynamicLastUpdated: string | null = null;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('legal_pages')
    .select('title, sections, ar_title, ar_sections, last_updated')
    .eq('slug', 'privacy')
    .single();

  if (!error && data) {
    const arSections = Array.isArray(data.ar_sections) && data.ar_sections.length > 0 ? data.ar_sections : null;
    const enSections = Array.isArray(data.sections) && data.sections.length > 0 ? data.sections : null;
    dynamicTitle = data.ar_title ?? data.title ?? null;
    dynamicSections = arSections ?? enSections;
    dynamicLastUpdated = data.last_updated ?? null;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const stripHtml = (str: string) => str.replace(/<[^>]+>/g, '').trim();

const staticToc = [
  '1. التعريفات',
  '2. نظرة عامة',
  '3. المعلومات التي نجمعها',
  '4. كيف نستخدم بياناتك',
  '5. أمن البيانات',
  '6. مشاركة البيانات مع أطراف ثالثة',
  '7. الاحتفاظ بالبيانات',
  '8. حقوقك بموجب القانون الإماراتي',
  '9. ملفات تعريف الارتباط وتقنيات التتبع',
  '10. نقل البيانات دولياً',
  '11. روابط لمواقع أخرى',
  '12. مستخدمو الاتحاد الأوروبي وGDPR',
  '13. التغييرات على سياسة الخصوصية',
  '14. تواصل معنا',
];

const tocItems = dynamicSections
  ? dynamicSections.map((s, i) => ({ id: `section-${i}`, label: stripHtml(s.heading) }))
  : staticToc.map((label, i) => ({ id: `section-${i}`, label }));
---

<ArBaseLayout
  title={dynamicTitle ? `${dynamicTitle} | Lenoo AI` : "سياسة الخصوصية | Lenoo AI"}
  description="سياسة الخصوصية الخاصة بـ Lenoo AI، وتوضح كيفية جمع بياناتك الشخصية واستخدامها وحمايتها بما يتوافق مع قانون حماية البيانات الشخصية في دولة الإمارات."
  canonicalPath="/ar/privacy"
  enPath="/privacy"
  ogImage="/assets/og-privacy.jpg"
  noindex={true}
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>سياسة الخصوصية</div>
    <h1>{dynamicTitle ?? <>سياسة <span class="gradient-text">الخصوصية</span></>}</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      {dynamicLastUpdated ? `آخر تحديث: ${dynamicLastUpdated}.` : "آخر تحديث: 11 يونيو 2026."} كيف ندير بياناتك ونحميها بما يتوافق مع المرسوم بقانون اتحادي رقم 45 لسنة 2021 بشأن حماية البيانات الشخصية.
    </p>
  </div>
</header>

<!-- MOBILE JUMP NAV -->
<div class="toc-mobile">
  <div class="container">
    <label for="toc-select" class="toc-mobile-label">الانتقال إلى قسم</label>
    <select id="toc-select" class="toc-select">
      {tocItems.map(item => (
        <option value={`#${item.id}`}>{item.label}</option>
      ))}
    </select>
  </div>
</div>

<main class="section">
  <div class="container" style="max-width:1060px;">
    <div class="legal-layout">
    <div class="prose">

      {dynamicSections ? (
        dynamicSections.map((section, i) => (
          <section id={`section-${i}`}>
            <h2 set:html={sanitizeRichText(section.heading)}></h2>
            <p set:html={sanitizeRichText(section.body)}></p>
          </section>
        ))
      ) : (
        <>
          <section id="section-0">
            <h2>1. التعريفات</h2>
            <p>تنطبق التعريفات التالية في جميع أنحاء سياسة الخصوصية هذه:</p>
            <ul>
              <li><strong>الشركة</strong> (يُشار إليها بـ "نحن" أو "لنا") تعني <strong>Lenoo AI</strong>، وهي شركة استشارات تقنية تعمل في دبي، الإمارات العربية المتحدة.</li>
              <li><strong>البيانات الشخصية</strong> تعني أي معلومة تتعلق بفرد محدد أو يمكن التعرف عليه بحسب المرسوم بقانون اتحادي رقم 45 لسنة 2021.</li>
              <li><strong>المعالجة</strong> تعني أي عملية تُجرى على البيانات الشخصية، بما في ذلك الجمع والتسجيل والتخزين والاستخدام والإفصاح أو الحذف.</li>
              <li><strong>الخدمة</strong> تعني الموقع الإلكتروني <strong>https://lenooai.com</strong> وجميع الخدمات المرتبطة به التي تقدمها Lenoo AI.</li>
              <li><strong>أنت</strong> تعني الفرد الذي يستخدم الخدمة، أو الشركة أو الكيان القانوني الذي يتصرف الفرد نيابة عنه.</li>
              <li><strong>ملفات تعريف الارتباط</strong> تعني ملفات صغيرة يضعها الموقع على جهازك وتحتوي على تفاصيل تصفحك.</li>
            </ul>
          </section>

          <section id="section-1">
            <h2>2. نظرة عامة</h2>
            <p>في <strong>Lenoo AI</strong>، نحترم خصوصيتك ونلتزم بحماية بياناتك الشخصية. توضح سياسة الخصوصية هذه كيفية جمع معلوماتك الشخصية واستخدامها وتخزينها ومشاركتها عند زيارتك لموقعنا أو استخدامك نظام الحجز أو تعاملك مع خدماتنا في تطوير الذكاء الاصطناعي المخصص والاستشارات والتدريب في دولة الإمارات.</p>
            <p>بدخولك إلى موقعنا واستخدامك لخدماتنا، فإنك تقر بأنك قرأت هذه السياسة وفهمتها، وتوافق على معالجة معلوماتك الشخصية كما هو موضح فيها. إذا كنت لا توافق على شروط هذه السياسة، يُرجى التوقف عن استخدام موقعنا فوراً.</p>
          </section>

          <section id="section-2">
            <h2>3. المعلومات التي نجمعها</h2>
            <p>قد نجمع ونعالج الفئات التالية من بياناتك الشخصية:</p>
            <ul>
              <li><strong>بيانات الهوية:</strong> الاسم الكامل والمسمى الوظيفي واسم الشركة.</li>
              <li><strong>بيانات التواصل:</strong> البريد الإلكتروني ورقم الهاتف ورقم الواتساب.</li>
              <li><strong>معلومات العمل:</strong> القطاع، حجم الشركة، تحديات الذكاء الاصطناعي، تقديرات الميزانية، وملاحظات تشغيلية تُشارك أثناء الحجز أو مكالمات الاستشارة.</li>
              <li><strong>البيانات التقنية:</strong> عنوان IP، نوع المتصفح، المنطقة الزمنية، نظام التشغيل، وتفاصيل تصفحك للموقع.</li>
              <li><strong>بيانات الاستخدام:</strong> الصفحات التي تمت زيارتها، الوقت المستغرق، الروابط التي تم النقر عليها، ومصدر الإحالة.</li>
              <li><strong>بيانات التواصل:</strong> سجلات المراسلات معنا عبر البريد الإلكتروني أو الواتساب أو نماذج التواصل.</li>
            </ul>
            <p>نجمع هذه البيانات عند تعبئتك لنموذج حجز الاستشارة، أو تواصلك المباشر معنا، أو تصفحك للموقع. نحن لا نجمع بيانات شخصية عن قصد من أفراد تقل أعمارهم عن 18 عاماً.</p>
          </section>

          <section id="section-3">
            <h2>4. كيف نستخدم بياناتك</h2>
            <p>نعالج بياناتك الشخصية فقط عندما يكون لدينا أساس قانوني للقيام بذلك، سواء موافقتك أو مصالحنا التجارية المشروعة أو التزام قانوني. على وجه التحديد، نستخدم بياناتك من أجل:</p>
            <ul>
              <li>تسجيلك كعميل جديد ومعالجة حجزك لجلسة الاستشارة المجانية.</li>
              <li>تقديم وإدارة أنظمة الذكاء الاصطناعي المخصصة وأتمتة العمليات وورش التدريب المصممة لشركتك.</li>
              <li>التواصل معك عبر الهاتف أو البريد الإلكتروني أو الواتساب لجدولة المكالمات وتقديم التحديثات والدعم.</li>
              <li>إرسال مواد تسويقية ذات صلة بخدماتنا (يمكنك إلغاء الاشتراك في أي وقت).</li>
              <li>تحليل وتحسين أداء الموقع واستراتيجيات التسويق وتجربة المستخدم.</li>
              <li>الامتثال للالتزامات القانونية والتنظيمية في الإمارات.</li>
              <li>منع الاحتيال وإساءة الاستخدام وأي نشاط ضار على الموقع.</li>
            </ul>
          </section>

          <section id="section-4">
            <h2>5. أمن البيانات</h2>
            <p>طبّقنا تدابير أمنية تقنية وتنظيمية لحماية بياناتك الشخصية من الفقدان أو الوصول أو التعديل أو الإفصاح أو الإتلاف غير المصرح به. تشمل هذه التدابير:</p>
            <ul>
              <li><strong>تشفير HTTPS:</strong> جميع البيانات المُرسلة عبر الموقع تُنقل عبر اتصالات مشفرة.</li>
              <li><strong>ضوابط الوصول:</strong> الوصول إلى البيانات الشخصية مقتصر على الموظفين والمتعاقدين المصرح لهم فقط.</li>
              <li><strong>بنية تحتية آمنة:</strong> أنظمتنا مستضافة على بنية تحتية سحابية بمعايير أمان عالية.</li>
              <li><strong>مراجعات دورية:</strong> نراجع ونحدّث ممارساتنا الأمنية باستمرار لمواجهة التهديدات المتطورة.</li>
            </ul>
            <p>رغم اتخاذنا كل احتياط معقول لحماية بياناتك، لا توجد طريقة نقل أو تخزين إلكتروني آمنة بنسبة 100٪. في حال وقوع خرق للبيانات قد يشكل خطراً على حقوقك، سنبلغك والجهات المعنية وفق القانون الإماراتي.</p>
          </section>

          <section id="section-5">
            <h2>6. مشاركة البيانات مع أطراف ثالثة</h2>
            <p>نحن لا نبيع أو نؤجر أو نتاجر ببياناتك الشخصية لأغراض تسويقية. قد نشارك معلوماتك مع شركاء تقنيين موثوقين يساعدوننا في إدارة أعمالنا، بموجب اتفاقيات سرية صارمة، ومن ذلك:</p>
            <ul>
              <li><strong>الحوسبة السحابية والبنية التحتية:</strong> مزودو استضافة وقواعد بيانات على مستوى المؤسسات.</li>
              <li><strong>منصات الذكاء الاصطناعي:</strong> مزودو نماذج الذكاء الاصطناعي (لا تُستخدم بياناتك لتدريب نماذجهم دون موافقتك الصريحة).</li>
              <li><strong>أدوات الأتمتة:</strong> منصات أتمتة سير العمل.</li>
              <li><strong>التواصل:</strong> مزودو واجهات برمجة الرسائل.</li>
            </ul>
            <p>قد نفصح أيضاً عن بياناتك الشخصية إذا طلبت ذلك جهات إنفاذ القانون الإماراتية أو أمر قضائي، أو لحماية حقوق وسلامة Lenoo AI أو عملائنا. في جميع الحالات، لن نفصح إلا عن الحد الأدنى الضروري من المعلومات.</p>
          </section>

          <section id="section-6">
            <h2>7. الاحتفاظ بالبيانات</h2>
            <p>نحتفظ ببياناتك الشخصية فقط للمدة اللازمة لتحقيق الأغراض التي جُمعت من أجلها، بما يشمل أي متطلبات محاسبية أو تنظيمية.</p>
            <p>كإرشاد عام:</p>
            <ul>
              <li><strong>بيانات الاستفسار والاستشارة</strong> تُحفظ لمدة تصل إلى سنتين من تاريخ آخر تواصل.</li>
              <li><strong>بيانات مشاريع العملاء</strong> تُحفظ لمدة تصل إلى 7 سنوات بعد اكتمال المشروع وفق متطلبات حفظ السجلات التجارية في الإمارات.</li>
              <li><strong>بيانات تحليلات الموقع</strong> تُحفظ لمدة تصل إلى 13 شهراً.</li>
            </ul>
            <p>بعد انتهاء مدة الاحتفاظ المطبقة، يتم حذف بياناتك أو إخفاء هويتها بشكل آمن.</p>
          </section>

          <section id="section-7">
            <h2>8. حقوقك بموجب القانون الإماراتي</h2>
            <p>بموجب <strong>قانون حماية البيانات الشخصية الإماراتي (المرسوم بقانون اتحادي رقم 45 لسنة 2021)</strong>، لديك الحقوق التالية بشأن بياناتك الشخصية:</p>
            <ul>
              <li><strong>حق الوصول:</strong> يمكنك طلب نسخة من البيانات الشخصية التي نحتفظ بها عنك.</li>
              <li><strong>حق التصحيح:</strong> يمكنك طلب تحديث أو تصحيح أي بيانات غير دقيقة أو ناقصة.</li>
              <li><strong>حق المحو ("الحق في النسيان"):</strong> يمكنك طلب حذف بياناتك الشخصية في ظروف معينة.</li>
              <li><strong>حق تقييد المعالجة:</strong> يمكنك طلب الحد من معالجة بياناتك أو إيقافها مؤقتاً.</li>
              <li><strong>حق نقل البيانات:</strong> يمكنك طلب نسخة منظمة وقابلة للقراءة الآلية من بياناتك.</li>
              <li><strong>حق الاعتراض:</strong> يمكنك الاعتراض على معالجة بياناتك لأغراض التسويق المباشر في أي وقت.</li>
              <li><strong>حق سحب الموافقة:</strong> عندما تستند المعالجة إلى موافقتك، يمكنك سحبها في أي وقت دون التأثير على مشروعية المعالجة السابقة.</li>
            </ul>
            <p>لممارسة أي من هذه الحقوق، يُرجى التواصل مع مسؤول حماية البيانات لدينا على <strong>hello@lenooai.com</strong>. سنرد على الطلبات الموثقة خلال 30 يوماً.</p>
          </section>

          <section id="section-8">
            <h2>9. ملفات تعريف الارتباط وتقنيات التتبع</h2>
            <p>يستخدم موقعنا ملفات تعريف الارتباط وتقنيات تتبع مشابهة لتحسين التصفح وتحليل حركة الزوار وتقديم تجربة مخصصة. نستخدم الأنواع التالية:</p>
            <ul>
              <li><strong>ملفات أساسية:</strong> ضرورية لعمل الموقع بشكل صحيح ولا يمكن تعطيلها.</li>
              <li><strong>ملفات تحليلية:</strong> تساعدنا على فهم كيفية تفاعل الزوار مع الموقع لتحسين الأداء والمحتوى.</li>
              <li><strong>ملفات التفضيلات:</strong> تحفظ إعداداتك وتفضيلاتك لتحسين تجربتك في الزيارات القادمة.</li>
            </ul>
            <p>يمكنك ضبط متصفحك لرفض جميع ملفات تعريف الارتباط أو تنبيهك عند إرسالها، لكن تعطيلها قد يحد من قدرتك على استخدام بعض الميزات التفاعلية للموقع، مثل نموذج حجز الاستشارة متعدد الخطوات.</p>
          </section>

          <section id="section-9">
            <h2>10. نقل البيانات دولياً</h2>
            <p>قد يكون بعض مزودي الخدمة الموثوقين لدينا خارج دولة الإمارات العربية المتحدة. عند نقل بياناتك الشخصية دولياً، نتخذ خطوات لضمان وجود ضمانات كافية لحماية بياناتك بما يتوافق مع متطلبات قانون حماية البيانات الإماراتي، وأن الدولة المستقبِلة توفر مستوى ملائماً من الحماية.</p>
          </section>

          <section id="section-10">
            <h2>11. روابط لمواقع أخرى</h2>
            <p>قد يحتوي موقعنا على روابط لمواقع تابعة لأطراف ثالثة. تنطبق سياسة الخصوصية هذه على موقعنا فقط. لا نتحمل أي مسؤولية عن محتوى أو ممارسات الخصوصية لأي موقع تابع لطرف ثالث، ونشجعك على مراجعة سياسة الخصوصية لكل موقع تزوره.</p>
          </section>

          <section id="section-11">
            <h2>12. مستخدمو الاتحاد الأوروبي وGDPR</h2>
            <p>إذا كنت تصل إلى موقعنا من المنطقة الاقتصادية الأوروبية، فإنك تستفيد من حقوق إضافية لحماية البيانات بموجب <strong>اللائحة العامة لحماية البيانات (GDPR)</strong>، بما في ذلك الحق في تقديم شكوى لدى السلطة الرقابية المحلية. تشمل الأسس القانونية لمعالجتنا لبيانات المقيمين في الاتحاد الأوروبي الموافقة وتنفيذ العقود والمصالح المشروعة.</p>
          </section>

          <section id="section-12">
            <h2>13. التغييرات على سياسة الخصوصية</h2>
            <p>قد نُحدّث سياسة الخصوصية هذه من وقت لآخر لتعكس تغييرات في ممارساتنا أو المتطلبات القانونية أو خدماتنا. سنُخطرك بأي تغييرات جوهرية من خلال تحديث تاريخ "آخر تحديث" أعلى هذه الصفحة، وعند الاقتضاء عبر إشعار بريد إلكتروني.</p>
            <p>نشجعك على مراجعة سياسة الخصوصية هذه بشكل دوري. استمرارك في استخدام الموقع بعد نشر التغييرات يُعد قبولاً منك للسياسة المحدثة.</p>
          </section>

          <section id="section-13">
            <h2>14. تواصل معنا</h2>
            <p>إذا كانت لديك أي أسئلة أو مخاوف بشأن سياسة الخصوصية هذه أو كيفية معالجة معلوماتك الشخصية، يُرجى التواصل مع مسؤول حماية البيانات لدينا على:</p>
            <div class="contact-box">
              <p><strong style="color:#00253b;">Lenoo AI: مسؤول حماية البيانات</strong></p>
              <p>دبي، الإمارات العربية المتحدة</p>
              <p><strong>البريد الإلكتروني:</strong> hello@lenooai.com</p>
              <p><strong>الواتساب:</strong> +971 4 321 8888</p>
            </div>
          </section>
        </>
      )}

    </div>

    <aside class="toc-aside">
      <div class="card toc-card">
        <div class="toc-title">محتويات الصفحة</div>
        <nav aria-label="محتويات سياسة الخصوصية">
          {tocItems.map(item => (
            <a href={`#${item.id}`} class="toc-link">{item.label}</a>
          ))}
        </nav>
      </div>
    </aside>

    </div>
  </div>
</main>

</ArBaseLayout>

<script>
