---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";
import { getSupabaseAdmin } from "../../../lib/supabase";

const { slug } = Astro.params;

const supabase = getSupabaseAdmin();
const { data: job } = await supabase
  .from('jobs')
  .select('*')
  .eq('slug', slug!)
  .eq('published', true)
  .is('deleted_at', null)
  .single();

if (!job) return Astro.redirect('/ar/careers');

const requirements: string[] = Array.isArray(job.requirements) ? job.requirements : [];
const niceToHave: string[]   = Array.isArray(job.nice_to_have) ? job.nice_to_have : [];
const benefits: string[]     = Array.isArray(job.benefits)     ? job.benefits     : [];

const empTypeMap: Record<string, string> = {
  'full-time': 'FULL_TIME', 'full time': 'FULL_TIME',
  'part-time': 'PART_TIME', 'part time': 'PART_TIME',
  'contract': 'CONTRACTOR', 'freelance': 'CONTRACTOR',
  'intern': 'INTERN', 'internship': 'INTERN',
  'temporary': 'TEMPORARY', 'volunteer': 'VOLUNTEER',
};
const empType = empTypeMap[(job.job_type ?? '').toLowerCase()] ?? 'FULL_TIME';

const jobSchema = {
  '@context': 'https://schema.org',
  '@type': 'JobPosting',
  title: job.title,
  description: job.description ?? `Apply for ${job.title} at Aegis AI in ${job.location}.`,
  datePosted: job.created_at ?? new Date().toISOString(),
  hiringOrganization: {
    '@type': 'Organization',
    name: 'Aegis AI',
    sameAs: 'https://lenooai.com',
    logo: 'https://lenooai.com/assets/logo.svg',
  },
  jobLocation: {
    '@type': 'Place',
    address: {
      '@type': 'PostalAddress',
      addressLocality: job.location ?? 'Dubai',
      addressCountry: 'AE',
    },
  },
  employmentType: empType,
  ...(job.salary_range ? {
    baseSalary: {
      '@type': 'MonetaryAmount',
      currency: 'AED',
      value: { '@type': 'QuantitativeValue', description: job.salary_range },
    },
  } : {}),
};
---

<ArBaseLayout
  title={`${job.title} | وظائف في Aegis AI`}
  description={`تقدّم لوظيفة ${job.title} في Aegis AI بموقع ${job.location}. وظيفة ${job.job_type}.`}
  canonicalPath={`/ar/jobs/${job.slug}`}
  enPath={`/jobs/${job.slug}`}
  ldJson={jobSchema}
>

<!-- HERO -->
<header class="hero-section" style="padding-bottom:2rem;">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/careers" style="color:inherit;text-decoration:none;opacity:0.65;">الوظائف</a><span style="opacity:0.4;padding:0 4px;"> / </span>{job.title}</div>
    <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;margin-bottom:1rem;">
      {job.department && (
        <span style="background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:4px 12px;font-size:.8125rem;font-weight:600;color:#a8f2ff;">{job.department}</span>
      )}
      <span style="display:inline-flex;align-items:center;gap:4px;font-size:.875rem;color:rgba(255,255,255,0.72);">
        <span class="material-symbols-outlined" style="font-size:16px;">location_on</span>{job.location}
      </span>
      <span style="display:inline-flex;align-items:center;gap:4px;font-size:.875rem;color:rgba(255,255,255,0.72);">
        <span class="material-symbols-outlined" style="font-size:16px;">schedule</span>{job.job_type}
      </span>
      {job.salary_range && (
        <span style="display:inline-flex;align-items:center;gap:4px;font-size:.875rem;color:rgba(255,255,255,0.72);">
          <span class="material-symbols-outlined" style="font-size:16px;">payments</span>{job.salary_range}
        </span>
      )}
    </div>
    <h1 style="margin-bottom:0;">{job.title}</h1>
  </div>
</header>

<!-- CONTENT -->
<div class="container" style="padding-top:2rem;padding-bottom:5rem;">
  <div class="job-layout">

    <!-- Role Details -->
    <div class="job-details">

      <div class="card" style="margin-bottom:1.5rem;">
        <h2 style="font-size:1.125rem;margin-bottom:1rem;">عن الدور</h2>
        <div class="prose" style="color:#42474e;line-height:1.75;white-space:pre-wrap;">{job.description}</div>
      </div>

      {requirements.length > 0 && (
        <div class="card" style="margin-bottom:1.5rem;">
          <h2 style="font-size:1.125rem;margin-bottom:1rem;">ما نبحث عنه</h2>
          <ul class="req-list">
            {requirements.map((r: string) => (
              <li>
                <span class="material-symbols-outlined" style="color:#006875;font-size:18px;flex-shrink:0;">check_circle</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {niceToHave.length > 0 && (
        <div class="card" style="margin-bottom:1.5rem;">
          <h2 style="font-size:1.125rem;margin-bottom:1rem;">إضافة تُحسب لصالحك</h2>
          <ul class="req-list">
            {niceToHave.map((r: string) => (
              <li>
                <span class="material-symbols-outlined" style="color:#d97706;font-size:18px;flex-shrink:0;">star</span>
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      {benefits.length > 0 && (
        <div class="card">
          <h2 style="font-size:1.125rem;margin-bottom:1rem;">ما ستحصل عليه</h2>
          <ul class="req-list">
            {benefits.map((b: string) => (
              <li>
                <span class="material-symbols-outlined" style="color:#006875;font-size:18px;flex-shrink:0;">favorite</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

    </div>

    <!-- Application Form -->
    <div class="job-form-wrap">
      <div class="card" id="application-form-card" style="position:sticky;top:1.5rem;">
        <h2 style="font-size:1.125rem;margin-bottom:1.5rem;">قدّم لهذا الدور</h2>

        <!-- Success state (hidden by default) -->
        <div id="apply-success" style="display:none;text-align:center;padding:2rem 1rem;">
          <div style="width:56px;height:56px;border-radius:50%;background:#dcfce7;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
            <span class="material-symbols-outlined" style="color:#16a34a;font-size:28px;">check_circle</span>
          </div>
          <h3 style="margin-bottom:.5rem;">تم إرسال طلبك!</h3>
          <p style="color:#42474e;font-size:.9375rem;">شكراً لتقديمك. سنراجع طلبك ونتواصل معك خلال 5 أيام عمل.</p>
        </div>

        <!-- Error message -->
        <div id="apply-error" style="display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:.875rem 1rem;margin-bottom:1rem;color:#dc2626;font-size:.875rem;"></div>

        <form id="apply-form">
          <input type="hidden" id="f-job-id"    value={job.id} />
          <input type="hidden" id="f-job-title" value={job.title} />

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="f-name">الاسم الكامل <span style="color:#dc2626;">*</span></label>
              <input class="form-input" id="f-name" type="text" placeholder="اسمك الكامل" required />
            </div>
            <div class="form-group">
              <label class="form-label" for="f-email">البريد الإلكتروني <span style="color:#dc2626;">*</span></label>
              <input class="form-input" id="f-email" type="email" placeholder="you@email.com" required />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="f-phone">الهاتف / واتساب</label>
              <input class="form-input" id="f-phone" type="tel" placeholder="+971 50 000 0000" />
            </div>
            <div class="form-group">
              <label class="form-label" for="f-linkedin">حساب لينكدإن</label>
              <input class="form-input" id="f-linkedin" type="url" placeholder="linkedin.com/in/yourname" />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="f-portfolio">موقع أو معرض أعمال</label>
            <input class="form-input" id="f-portfolio" type="url" placeholder="yoursite.com (اختياري)" />
          </div>

          <div class="form-group">
            <label class="form-label" for="f-cv">السيرة الذاتية <span style="color:#dc2626;">*</span></label>
            <div class="file-drop-zone" id="cv-drop-zone">
              <span class="material-symbols-outlined" style="font-size:32px;color:#c2c7ce;display:block;margin-bottom:.5rem;">upload_file</span>
              <p style="font-size:.875rem;color:#42474e;margin:0 0 .25rem;">اسحب وأفلت أو <label for="f-cv" style="color:#006875;cursor:pointer;font-weight:600;">تصفّح</label></p>
              <p style="font-size:.75rem;color:#72787e;margin:0;">PDF أو DOCX · بحد أقصى 5 ميجابايت</p>
              <p id="cv-filename" style="font-size:.8125rem;color:#006875;font-weight:600;margin:.5rem 0 0;display:none;"></p>
            </div>
            <input type="file" id="f-cv" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" style="display:none;" required />
            <div id="cv-upload-progress" style="display:none;margin-top:.5rem;">
              <div style="height:4px;background:#e2e8f0;border-radius:2px;overflow:hidden;">
                <div id="cv-progress-bar" style="height:100%;background:#00e3fd;width:0%;transition:width .3s;"></div>
              </div>
              <p style="font-size:.75rem;color:#72787e;margin:.25rem 0 0;">جاري الرفع…</p>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="f-cover">رسالة تعريفية <span style="color:#dc2626;">*</span></label>
            <textarea class="form-input" id="f-cover" rows="5" placeholder="أخبرنا لماذا أنت مناسب لهذا الدور وما الذي يحمّسك للعمل في Aegis AI…" required style="resize:vertical;"></textarea>
          </div>

          <div class="form-group">
            <label class="form-label" for="f-heard">كيف سمعت عنا؟</label>
            <select class="form-select" id="f-heard" style="width:100%;">
              <option value="">اختر (اختياري)</option>
              <option>لينكدإن</option>
              <option>ترشيح من صديق أو زميل</option>
              <option>موقع Aegis AI</option>
              <option>لوحة وظائف (بيت، إنديد، إلخ)</option>
              <option>وسائل التواصل الاجتماعي</option>
              <option>أخرى</option>
            </select>
          </div>

          <button type="submit" id="apply-submit" class="btn-primary" style="width:100%;justify-content:center;display:flex;align-items:center;gap:.5rem;margin-top:.5rem;">
            <span class="material-symbols-outlined" style="font-size:18px;">send</span>
            إرسال الطلب
          </button>

          <p style="font-size:.75rem;color:#72787e;margin:.75rem 0 0;text-align:center;">بتقديمك للطلب فإنك توافق على <a href="/ar/privacy" style="color:#006875;">سياسة الخصوصية</a></p>
        </form>
      </div>
    </div>

  </div>
</div>

<!-- APPLICATION FAQ -->
<section class="section" style="padding-top:0;background:#f0f3ff;">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:2rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:#00253b;">أسئلة شائعة حول التقديم</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم تستغرق عملية التوظيف عادة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نراجع كل طلب خلال 5 أيام عمل. إذا كان ملفك مناسباً للدور، نتواصل معك لجدولة مقابلة أولى، وعادة ما تكتمل عملية التوظيف بالكامل خلال 2 إلى 3 أسابيع من تاريخ التقديم.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن التقديم إذا كنت خارج دبي أو الإمارات؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، نرحب بطلبات من خارج الدولة. بعض الأدوار تتطلب الانتقال إلى دبي، وأدوار أخرى تسمح بالعمل عن بعد جزئياً أو كلياً. راجع تفاصيل الموقع أعلى هذه الصفحة، أو اسأل الفريق مباشرة في مقابلتك الأولى.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما المستندات التي أحتاجها للتقديم؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">سيرتك الذاتية بصيغة PDF أو DOCX ورسالة تعريفية قصيرة كافيتان للبدء. رابط لينكدإن أو معرض أعمالك اختياري لكنه يساعدنا على فهم خبراتك بشكل أفضل.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          متى سأسمع رداً بعد التقديم؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">سنرسل لك رداً، سواء بالقبول للمرحلة التالية أو باعتذار، خلال 5 أيام عمل من استلام طلبك. إذا لم تسمع منا خلال هذه المدة، لا تتردد في التواصل معنا على hello@lenooai.com.</div>
      </div>

    </div>
  </div>
</section>

</ArBaseLayout>

<script>
  // CV file drag-and-drop
  const dropZone   = document.getElementById('cv-drop-zone')!;
  const fileInput  = document.getElementById('f-cv') as HTMLInputElement;
  const fileLabel  = document.getElementById('cv-filename')!;

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const file = e.dataTransfer?.files[0];
    if (file) setFile(file);
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) setFile(fileInput.files[0]);
  });

  function setFile(file: File) {
    // Transfer to input
    const dt = new DataTransfer();
    dt.items.add(file);
    fileInput.files = dt.files;
    fileLabel.textContent = file.name;
    fileLabel.style.display = 'block';
  }

  // Form submission
  const form       = document.getElementById('apply-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('apply-submit') as HTMLButtonElement;
  const successDiv = document.getElementById('apply-success')!;
  const errorDiv   = document.getElementById('apply-error')!;
  const progressWrap = document.getElementById('cv-upload-progress')!;
  const progressBar  = document.getElementById('cv-progress-bar')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.style.display = 'none';

    const name       = (document.getElementById('f-name')      as HTMLInputElement).value.trim();
    const email      = (document.getElementById('f-email')     as HTMLInputElement).value.trim();
    const phone      = (document.getElementById('f-phone')     as HTMLInputElement).value.trim();
    const linkedin   = (document.getElementById('f-linkedin')  as HTMLInputElement).value.trim();
    const portfolio  = (document.getElementById('f-portfolio') as HTMLInputElement).value.trim();
    const cover      = (document.getElementById('f-cover')     as HTMLTextAreaElement).value.trim();
    const heard      = (document.getElementById('f-heard')     as HTMLSelectElement).value;
    const jobId      = (document.getElementById('f-job-id')    as HTMLInputElement).value;
    const jobTitle   = (document.getElementById('f-job-title') as HTMLInputElement).value;
    const file       = fileInput.files?.[0];

    if (!name || !email || !cover) {
      showError('يرجى تعبئة جميع الحقول المطلوبة.');
      return;
    }
    if (!file) {
      showError('يرجى إرفاق سيرتك الذاتية.');
      return;
    }
    if (file.size > 5 * 1024 * 1024) {
      showError('يجب ألا يتجاوز حجم ملف السيرة الذاتية 5 ميجابايت.');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'جاري رفع السيرة الذاتية…';

    // Upload CV to Supabase Storage
    let cvUrl = '';
    try {
      const { PUBLIC_SUPABASE_URL, PUBLIC_SUPABASE_ANON_KEY } = (import.meta as unknown as Record<string, Record<string, string>>).env;
      if (!PUBLIC_SUPABASE_URL || !PUBLIC_SUPABASE_ANON_KEY) throw new Error('Storage not configured');

      progressWrap.style.display = 'block';
      progressBar.style.width = '30%';

      const ext      = file.name.split('.').pop() ?? 'pdf';
      const fileName = `${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`;
      const uploadUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/cvs/${fileName}`;

      const uploadRes = await fetch(uploadUrl, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${PUBLIC_SUPABASE_ANON_KEY}`,
          'Content-Type': file.type || 'application/octet-stream',
          'x-upsert': 'false',
        },
        body: file,
      });

      progressBar.style.width = '80%';
      if (!uploadRes.ok) throw new Error('CV upload failed');

      cvUrl = `${PUBLIC_SUPABASE_URL}/storage/v1/object/public/cvs/${fileName}`;
      progressBar.style.width = '100%';
    } catch (err) {
      progressWrap.style.display = 'none';
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:18px;">send</span> إرسال الطلب';
      showError('فشل رفع السيرة الذاتية. يرجى المحاولة مرة أخرى أو التواصل معنا مباشرة.');
      return;
    }

    submitBtn.textContent = 'جاري الإرسال…';

    try {
      const res = await fetch('/api/apply', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ job_id: jobId, job_title: jobTitle, full_name: name, email, phone, linkedin_url: linkedin, portfolio_url: portfolio, cv_url: cvUrl, cover_letter: cover, how_heard: heard }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Submission failed');

      form.style.display = 'none';
      successDiv.style.display = 'block';
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:18px;">send</span> إرسال الطلب';
      showError(err instanceof Error ? err.message : 'حدث خطأ ما. يرجى المحاولة مرة أخرى.');
    }
  });

  function showError(msg: string) {
    errorDiv.textContent = msg;
    errorDiv.style.display = 'block';
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  Object.assign(window, { setFile, showError });
</script>

<style>
  .job-layout {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 2rem;
    align-items: start;
  }
  .req-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .625rem;
  }
  .req-list li {
    display: flex;
    align-items: flex-start;
    gap: .625rem;
    font-size: .9375rem;
    color: #42474e;
    line-height: 1.5;
  }
  .file-drop-zone {
    border: 2px dashed #c2c7ce;
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .file-drop-zone:hover,
  .file-drop-zone.drag-over {
    border-color: #00e3fd;
    background: rgba(0,227,253,0.04);
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group { margin-bottom: 1rem; }
  .form-label { display: block; font-size: .875rem; font-weight: 600; color: #00253b; margin-bottom: .375rem; }
  @media (max-width: 900px) {
    .job-layout { grid-template-columns: 1fr; }
    .job-form-wrap .card { position: static !important; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
