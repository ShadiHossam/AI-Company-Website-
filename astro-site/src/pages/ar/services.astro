---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "خدمات الذكاء الاصطناعي للشركات في الإمارات | Lenoo AI",
    "url": "https://lenooai.com/ar/services",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://lenooai.com/ar/services" }
    ]
  }
];

const services = [
  {
    slug: "custom-ai-development",
    icon: "monitor_heart",
    title: "تطوير ذكاء اصطناعي مخصص",
    desc: "بصفتنا وكالة ذكاء اصطناعي في دبي، نبني أنظمة مصممة خصيصاً لعملياتك: روبوتات محادثة، أتمتة سير العمل، لوحات تحليلية، وأدوات تنبؤية مدمجة مع أنظمتك الحالية.",
    badge: "الأكثر طلباً",
    cat: "build"
  },
  {
    slug: "ai-agents",
    icon: "smart_toy",
    title: "وكلاء الذكاء الاصطناعي",
    desc: "ذكاء اصطناعي لا يجيب فحسب، بل يتصرف. نبني وكلاء مستقلين يُفكرون في المهام متعددة الخطوات ويُنفذونها دون إشراف مستمر.",
    badge: "",
    cat: "automate"
  },
  {
    slug: "ai-automation",
    icon: "autorenew",
    title: "أتمتة بالذكاء الاصطناعي",
    desc: "نُحوّل العمليات اليدوية المتكررة إلى سير عمل آلية ذكية، من المراسلات البريدية إلى تحديث البيانات والتقارير الدورية.",
    badge: "",
    cat: "automate"
  },
  {
    slug: "ai-training",
    icon: "school",
    title: "تدريب على الذكاء الاصطناعي",
    desc: "ورش عمل عملية بالعربي والإنجليزي تُمكّن فريقك من استخدام الذكاء الاصطناعي بثقة في عمله اليومي.",
    badge: "",
    cat: "consult"
  },
  {
    slug: "ai-strategy",
    icon: "bar_chart",
    title: "استشارات استراتيجية للذكاء الاصطناعي",
    desc: "خارطة طريق واضحة: نحدد الفرص الأعلى عائداً في شركتك ونضع خطة تنفيذ عملية لـ ١٢ شهراً.",
    badge: "",
    cat: "consult"
  },
  {
    slug: "ai-integration",
    icon: "integration_instructions",
    title: "دمج الذكاء الاصطناعي في عملياتك",
    desc: "نربط أدوات الذكاء الاصطناعي الموجودة بأنظمتك الحالية (CRM، ERP، أدوات التواصل) دون إعادة بناء كل شيء من الصفر.",
    badge: "",
    cat: "automate"
  },
  {
    slug: "internal-ai-tools",
    icon: "build",
    title: "أدوات ذكاء اصطناعي داخلية",
    desc: "نبني أدوات مخصصة لفريقك الداخلي: مساعدات معرفة، قواعد بيانات ذكية، وأتمتة خاصة بعملياتك الداخلية.",
    badge: "",
    cat: "build"
  },
  {
    slug: "custom-gpt-development",
    icon: "psychology",
    title: "تطوير نماذج لغوية مخصصة",
    desc: "نبني نماذج لغوية مُضبّطة على بيانات شركتك ومُدمجة في أنظمتك، للرد على عملائك أو دعم فريقك.",
    badge: "",
    cat: "build"
  },
  {
    slug: "vibe-coding",
    icon: "code",
    title: "فايب كودينج",
    desc: "نبني تطبيقات ويب وأدوات داخلية كاملة بالذكاء الاصطناعي، بسرعة أعلى وتكلفة أقل من التطوير التقليدي.",
    badge: "",
    cat: "build"
  },
  {
    slug: "claude-agent-builds",
    icon: "psychology",
    title: "بناء وكلاء ذكاء اصطناعي جاهزين للإنتاج",
    desc: "أذكى الوكلاء المستقلين، مبنيون للاعتمادية: اتباع دقيق للتعليمات، وتفكير بسياق طويل، واستخدام دقيق للأدوات، مصممون خصيصاً لسير عمل الأعمال المعقد.",
    badge: "",
    cat: "build"
  },
  {
    slug: "prompt-engineering",
    icon: "tune",
    title: "هندسة وتحسين الأوامر",
    desc: "ذكاؤك الاصطناعي بجودة الأوامر التي خلفه فقط. ندقق ونهندس ونحسّن الأوامر لأي نموذج ذكاء اصطناعي، لخفض وقت التعديل وتكاليف الاستخدام بشكل ملموس.",
    badge: "",
    cat: "consult"
  },
  {
    slug: "ai-model-finetuning",
    icon: "model_training",
    title: "تدريب نماذج الذكاء الاصطناعي المخصص",
    desc: "توقف عن استخدام ذكاء اصطناعي عام. ندرّب النماذج الأساسية على بيانات شركتك الخاصة، ليعرف ذكاؤك الاصطناعي عملك ويقدّم نتائج ثابتة على أي نطاق.",
    badge: "",
    cat: "build"
  }
];
---

<ArBaseLayout
  title="خدمات الذكاء الاصطناعي في الإمارات: بناء وأتمتة وتدريب واستشارات | Lenoo AI"
  description="Lenoo AI وكالة ذكاء اصطناعي في دبي، تقدّم 12 خدمة للشركات في الإمارات: تطوير مخصص، أتمتة، وكلاء ذكاء اصطناعي، أدوات داخلية، تدريب الفرق، واستشارات استراتيجية."
  canonicalPath="/ar/services"
  enPath="/services"
  ldJson={ldJson}
>

<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>الخدمات</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">electric_bolt</span>
      خدماتنا
    </div>
    <h1>خدمات الذكاء الاصطناعي<br><span class="gradient-text">للشركات في دبي</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:600px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      من بناء الأنظمة إلى تدريب الفرق، نحن شريكك الكامل في رحلة الذكاء الاصطناعي. ضمان استرداد ١٠٠٪ على جميع خدماتنا.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_services_hero" class="btn-primary">احجز استشارة مجانية</button>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:240px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=1400&q=80&auto=format&fit=crop" alt="خدمات الذكاء الاصطناعي للشركات في دبي" loading="eager" fetchpriority="high" width="1400" height="240" style="width:100%; height:100%; object-fit:cover; object-position:center;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
</div>

<section class="section">
  <div class="container">
    <div class="svc-tabs" id="svc-tabs" role="tablist" aria-label="تصفية الخدمات حسب النوع">
      <button class="svc-tab active" data-cat="all" type="button">كل الخدمات</button>
      <button class="svc-tab" data-cat="build" type="button">بناء الأنظمة</button>
      <button class="svc-tab" data-cat="automate" type="button">الوكلاء والأتمتة</button>
      <button class="svc-tab" data-cat="consult" type="button">التدريب والاستشارات</button>
    </div>
    <div class="svc-grid" id="svc-grid">
      {services.map(svc => (
        <a href={`/ar/services/${svc.slug}`} class="svc-card" data-cat={svc.cat}>
          <div class="svc-card-icon">
            <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">{svc.icon}</span>
          </div>
          {svc.badge && <div class="svc-badge">{svc.badge}</div>}
          <h3>{svc.title}</h3>
          <p>{svc.desc}</p>
          <div class="svc-link">
            تعرف على التفاصيل
            <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;transform:scaleX(-1);" aria-hidden="true">arrow_forward</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Featured services: build vs agents -->
<section class="section" style="background:#f0f3ff;">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أكثر خدمتين تبدأ بهما الشركات</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">إن لم تكن متأكداً من أين تبدأ، هاتان الخدمتان تغطيان أغلب احتياجات الشركات في الإمارات.</p>
    </div>
    <div class="svc-split">
      <div class="svc-split-img">
        <img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&q=80&auto=format&fit=crop" alt="واجهة روبوت محادثة وأتمتة ذكاء اصطناعي مخصصة لشركة في دبي" loading="lazy" width="800" height="480" />
      </div>
      <div>
        <div class="badge badge-cyan" style="margin-bottom:1rem;">الأكثر طلباً</div>
        <h3 style="margin-bottom:0.75rem;">تطوير ذكاء اصطناعي مخصص</h3>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">لا حل جاهز يناسب كل شركة. نبني نظاماً يعرف عملك تحديداً: روبوت محادثة، لوحة تحليلية، أو أداة تنبؤية، مربوطة بأنظمتك الحالية من اليوم الأول.</p>
        <a href="/ar/services/custom-ai-development" class="btn-outline-sky">اقرأ التفاصيل</a>
      </div>
    </div>
    <div class="svc-split svc-split-reverse">
      <div class="svc-split-img" style="order:2;">
        <img src="https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=800&q=80&auto=format&fit=crop" alt="فريق يبني وكلاء ذكاء اصطناعي مستقلين في مكتب بدبي" loading="lazy" width="800" height="480" />
      </div>
      <div style="order:1;">
        <div class="badge badge-cyan" style="margin-bottom:1rem;">وكلاء مستقلون</div>
        <h3 style="margin-bottom:0.75rem;">وكلاء الذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.8;margin-bottom:1.25rem;">وكيل يُنجز، لا يجيب فقط. يقرأ البريد، يحدّث CRM، يرد على واتساب، ويُصعّد للفريق فقط عندما يحتاج الأمر قراراً بشرياً.</p>
        <a href="/ar/services/ai-agents" class="btn-outline-sky">اقرأ التفاصيل</a>
      </div>
    </div>
  </div>
</section>

<!-- Guarantee CTA -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل: الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">جميع خدماتنا مشمولة بضمان الاسترداد ١٠٠٪</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">إذا لم تكن راضياً عما نبنيه، نردّ كل درهم دون أسئلة ودون تأخير. نحن نتحمل المخاطرة كاملة.</p>
    <button onclick="openModal(this)" data-source="ar_services_cta" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

</ArBaseLayout>

<script define:vars={{ pageId: 'ar-services' }}>
  (function () {
    const wrap = document.getElementById('svc-tabs');
    const grid = document.getElementById('svc-grid');
    if (!wrap || !grid) return;
    const buttons = wrap.querySelectorAll('.svc-tab');
    const cards = grid.querySelectorAll('.svc-card[data-cat]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-cat');
        cards.forEach((card) => {
          card.style.display = cat === 'all' || card.getAttribute('data-cat') === cat ? '' : 'none';
        });
      });
    });
  })();
</script>

<style>
  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .svc-card {
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    position: relative;
  }
  .svc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0,59,92,0.10);
    border-color: rgba(0,104,117,0.3);
  }
  .svc-card-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(0,227,253,0.12); display: flex;
    align-items: center; justify-content: center; color: #006875;
  }
  .svc-badge {
    position: absolute; top: 1.25rem; left: 1.25rem;
    background: rgba(0,104,117,0.12); color: #004f58;
    font-size: 0.7rem; font-weight: 700; padding: 3px 10px;
    border-radius: 100px; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .svc-card h3 { font-size: 1.0625rem; font-weight: 700; color: #00253b; margin: 0; }
  .svc-card p { font-size: 0.875rem; color: #42474e; line-height: 1.7; margin: 0; flex: 1; }
  .svc-link {
    display: flex; align-items: center; gap: 4px;
    font-size: 0.875rem; font-weight: 600; color: #006875; margin-top: 0.5rem;
  }
  .svc-tabs { display: flex; flex-wrap: wrap; gap: 0.625rem; justify-content: center; margin-bottom: 2.5rem; }
  .svc-tab {
    font-size: 0.875rem; font-weight: 600; padding: 0.5rem 1.25rem;
    border-radius: 100px; border: 1px solid rgba(0,37,59,0.14);
    background: #fff; color: #42474e; cursor: pointer;
    transition: all .2s var(--ease); font-family: inherit;
  }
  .svc-tab:hover { border-color: rgba(0,104,117,0.4); color: #006875; }
  .svc-tab.active { background: #00253b; border-color: #00253b; color: #fff; }

  .svc-split { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; margin-bottom: 4rem; }
  .svc-split:last-child { margin-bottom: 0; }
  .svc-split-img { border-radius: 20px; overflow: hidden; height: 320px; }
  .svc-split-img img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 900px) { .svc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) {
    .svc-split { grid-template-columns: 1fr; gap: 1.5rem; }
    .svc-split-img { height: 220px; order: -1 !important; }
  }
  @media (max-width: 580px)  { .svc-grid { grid-template-columns: 1fr; } }
</style>
