---
export const prerender = false;
import ArBaseLayout from '../../layouts/ArBaseLayout.astro';

const servicesFaqs = [
  { question: "أي خدمة نبدأ بها؟", answer: "لمعظم الشركات، جلسة استراتيجية سريعة للذكاء الاصطناعي. تُحلل سير عملك، وتُرتب الفرص حسب العائد على الاستثمار، وتخبرك بالضبط من أين تبدأ. إن كنت تعرف بالفعل ما تحتاجه، فمكالمة استكشافية كافية لنحدد النطاق مباشرة." },
  { question: "هل يمكن دمج عدة خدمات في مشروع واحد؟", answer: "نعم، معظم المشاريع كذلك. المشروع النموذجي قد يشمل جلسة استراتيجية، وبناء نظام مخصص، وتدريب الفريق ليُستخدم النظام فعلياً. نحدد نطاق المشاريع المدمجة كحزمة واحدة بجدول زمني واحد." },
  { question: "هل تعملون مع شركات خارج الإمارات؟", answer: "نعم. نحن مقيمون في دبي ونخدم شركات الإمارات أولاً، لكننا نقدّم الاستراتيجية والبناء والتدريب عن بُعد لعملاء في الشرق الأوسط وأوروبا وخارجها." },
  { question: "كيف يتم تحديد الأسعار عبر الخدمات؟", answer: "كل خدمة يُحدد نطاقها بشكل فردي حسب التعقيد والحجم. الجلسات الاستراتيجية وبرامج التدريب لها تسعير أكثر ثباتاً؛ أما الأنظمة والأتمتة والتكاملات فيُحدد سعرها بعد مكالمة استكشافية بمجرد فهم احتياجك." },
  { question: "ماذا يغطي ضمان الاسترداد ١٠٠٪ فعلياً؟", answer: "إذا لم تكن راضياً تماماً عما نُسلّمه، لا تدفع شيئاً. بلا شروط وبلا نزاعات. ينطبق على كل خدمة في هذه الصفحة." },
];

const servicesFaqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: servicesFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const ldJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'خدمات الذكاء الاصطناعي من Lenoo AI',
    url: 'https://lenooai.com/ar/services',
    description: 'تطوير ذكاء اصطناعي مخصص، أتمتة، وكلاء ذكاء اصطناعي، أدوات داخلية، تدريب الفرق، واستشارات استراتيجية لشركات الإمارات وخارجها.',
    inLanguage: 'ar',
    publisher: { '@type': 'Organization', name: 'Lenoo AI', url: 'https://lenooai.com' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'الرئيسية', item: 'https://lenooai.com/ar' },
      { '@type': 'ListItem', position: 2, name: 'الخدمات', item: 'https://lenooai.com/ar/services' },
    ],
  },
  servicesFaqLdJson,
];
---

<ArBaseLayout
  title="خدمات الذكاء الاصطناعي في الإمارات: بناء وأتمتة وتدريب واستشارات | Lenoo AI"
  description="Lenoo AI وكالة ذكاء اصطناعي في دبي، تقدّم 12 خدمة للشركات في الإمارات: تطوير مخصص، أتمتة، وكلاء ذكاء اصطناعي، أدوات داخلية، تدريب الفرق، واستشارات استراتيجية."
  canonicalPath="/ar/services"
  enPath="/services"
  ogImage="/assets/og-services.jpg"
  ldJson={ldJson}
>

<header class="hero-section page-hero" style="text-align:center;">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span>الخدمات</div>
    <h1>ثماني خدمات. رسالة واحدة.</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:600px; margin:1.5rem auto 0;">
      لا نبني أدوات ذكاء اصطناعي فقط. نجعل شركتك جاهزة للذكاء الاصطناعي فعلياً. من الاستراتيجية إلى البناء إلى تمكين الفريق، نغطي الرحلة كاملة.
    </p>
    <div class="trust-chips" style="justify-content:center; margin:1.75rem 0 2rem;">
      <span class="tchip">مقيمون في الإمارات، نعمل مع عملاء حول العالم</span>
      <span class="tchip">استراتيجية وبناء وتمكين الفريق</span>
      <span class="tchip">ضمان رضا على كل مشروع</span>
    </div>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_services_hero" class="btn-primary">احجز استشارة مجانية</button>
    </div>
  </div>
</header>

<!-- THREE PILLARS -->
<section id="services-list" class="section">
  <div class="container">
    <div class="section-header">
      <h2>رحلة تبني الذكاء الاصطناعي كاملة، في مكان واحد</h2>
      <p>كل ما نفعله يقع ضمن ثلاثة محاور: بناء الأنظمة الصحيحة، تدريب فريقك، والتخطيط للمسار قبل أن تصرف أي شيء.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">code</span></div>
        <h3 style="font-size:1.125rem; font-weight:700; margin-bottom:0.75rem;">ذكاء اصطناعي مبني حول سير عملك، لا العكس</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.8; margin:0;">الذكاء الاصطناعي الجاهز لا يناسب شركتك. نبني أنظمة تفعل بالضبط ما يحتاجه فريقك: روبوتات محادثة، خطوط أتمتة، لوحات تحكم، وأدوات تنبؤية، مدمجة مع برامجك الحالية.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">group</span></div>
        <h3 style="font-size:1.125rem; font-weight:700; margin-bottom:0.75rem;">فريقك يحتاج لاستخدام الذكاء الاصطناعي. نتأكد من أنه يفعل.</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.8; margin:0;">بناء الذكاء الاصطناعي نصف المعركة فقط. ندرّب موظفيك على استخدامه بثقة، بورش عمل عملية مصممة لقطاعك وسير عمل فريقك.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">bar_chart</span></div>
        <h3 style="font-size:1.125rem; font-weight:700; margin-bottom:0.75rem;">اعرف بالضبط أي ذكاء اصطناعي تبني قبل أن تصرف درهماً</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.8; margin:0;">نُحلل سير عملك، نُحدد فرص الذكاء الاصطناعي الأعلى عائداً، ونُسلّمك خطة تنفيذ واضحة. بلا تخمين. بلا هدر في الميزانية.</p>
      </div>
    </div>
  </div>
</section>

<!-- ALL SERVICES — one uniform grid, matching EN's structure -->
<section class="section hp-ind-bg">
  <div class="container">
    <div class="section-header">
      <h2>المزيد من الطرق التي نساعدك بها على الفوز بالذكاء الاصطناعي</h2>
      <p>من الوكلاء المستقلين إلى فايب كودينج إلى التكاملات العميقة، نغطي كل طبقة من رحلتك مع الذكاء الاصطناعي.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">smart_toy</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">وكلاء وأنظمة ذكاء اصطناعي مستقلة</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">ذكاء اصطناعي يعمل جنباً إلى جنب مع فريقك. نبني وكلاء مستقلين يتولون المهام المتكررة عالية الحجم، ليتفرّغ فريقك للقرارات التي تحتاج حكماً بشرياً.</p>
        <a href="/ar/services/ai-agents" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">settings_suggest</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">أتمتة بالذكاء الاصطناعي</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">توقف عن الأداء اليدوي. نبني خطوط أتمتة ذكية تُزيل العمل المتكرر في المبيعات والعمليات والإدارة، دون تغيير أدواتك الحالية.</p>
        <a href="/ar/services/ai-automation" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">code</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">تطوير ذكاء اصطناعي مخصص</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">حلول ذكاء اصطناعي مخصصة بالكامل مبنية حول سير عملك ومتطلباتك. مدمجة مع الأدوات التي تستخدمها بالفعل، ومبنية لتدوم.</p>
        <a href="/ar/services/custom-ai-development" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">group</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">تدريب الفريق على الذكاء الاصطناعي</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">بناء الذكاء الاصطناعي نصف المعركة فقط. ندرّب موظفيك على استخدامه بثقة، بورش عمل عملية مصممة لقطاعك وسير عمل فريقك.</p>
        <a href="/ar/services/ai-training" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">bar_chart</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">استراتيجية الذكاء الاصطناعي</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">نُحلل سير عملك، نُحدد فرص الذكاء الاصطناعي الأعلى عائداً، ونُسلّمك خطة تنفيذ واضحة لـ ١٢ شهراً. بلا تخمين. بلا هدر في الميزانية.</p>
        <a href="/ar/services/ai-strategy" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">hub</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">دمج الذكاء الاصطناعي</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">لست بحاجة لاستبدال برامجك الحالية. أنت بحاجة لجعلها أذكى. نُضيف طبقة ذكاء اصطناعي إلى CRM وERP وأدواتك ليعملوا بجهد أكبر بنفس الفريق.</p>
        <a href="/ar/services/ai-integration" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">dashboard</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">أدوات ذكاء اصطناعي داخلية</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">أدوات الذكاء الاصطناعي العامة لا تعرف شركتك. نبني مساعدين داخليين، وقواعد معرفة، ولوحات تحكم مدرّبة على بياناتك وإجراءاتك وسير عملك.</p>
        <a href="/ar/services/internal-ai-tools" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">chat</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">تطوير نماذج لغوية مخصصة</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">نماذج لغوية مخصصة مُدرّبة على منتجاتك ووثائقك وسير عملك، ليحصل فريقك على مساعد يعرف شركتك فعلياً.</p>
        <a href="/ar/services/custom-gpt-development" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">terminal</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">فايب كودينج</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">اشحن برمجياتك أسرع بتطوير مُسرّع بالذكاء الاصطناعي. نبني منتجك بممارسات برمجة تعتمد على الذكاء الاصطناعي أولاً دون المساس بالجودة.</p>
        <a href="/ar/services/vibe-coding" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">model_training</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">تدريب نماذج الذكاء الاصطناعي المخصص</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">توقف عن استخدام ذكاء اصطناعي عام. ندرّب النماذج الأساسية على بيانات شركتك الخاصة، ليعرف ذكاؤك الاصطناعي عملك ويقدّم نتائج ثابتة على أي نطاق.</p>
        <a href="/ar/services/ai-model-finetuning" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">psychology</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">بناء وكلاء Claude</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">أذكى الوكلاء المستقلين، مبنيون للاعتمادية: اتباع دقيق للتعليمات، وتفكير بسياق طويل، واستخدام دقيق للأدوات، مصممون خصيصاً لسير عمل الأعمال المعقد.</p>
        <a href="/ar/services/claude-agent-builds" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">tune</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.625rem;">هندسة الأوامر</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7; margin:0 0 1rem;">ذكاؤك الاصطناعي بجودة الأوامر التي خلفه فقط. ندقق ونهندس ونحسّن الأوامر لأي نموذج ذكاء اصطناعي، لخفض وقت التعديل وتكاليف الاستخدام بشكل ملموس.</p>
        <a href="/ar/services/prompt-engineering" class="learn-link">اعرف المزيد <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;direction:ltr;transform:scaleX(-1);">arrow_forward</span></a>
      </div>
    </div>
  </div>
</section>

<!-- STILL NOT SURE — text + photo -->
<section class="section">
  <div class="container">
    <div class="split-grid">
      <div>
        <h2 style="margin-bottom:1.25rem;">لا تزال غير متأكد من الخدمة المناسبة؟</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.75rem;">معظم عملائنا لا يصلون وهم يعرفون بالضبط ما يحتاجونه، وهذا طبيعي. احجز مكالمة مجانية وسنخبرك مباشرة، بلا عرض مبيعات، مجرد إجابة صريحة عمّا سيُحرّك شركتك فعلياً إلى الأمام.</p>
        <button onclick="openModal(this)" data-source="ar_services_deciding" class="btn-primary">احجز استشارة مجانية</button>
      </div>
      <div class="split-media">
        <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=900&q=80&auto=format&fit=crop" alt="ناطحات سحاب في دبي ترتفع فوق الغيوم" loading="lazy" width="900" height="620" />
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" style="background:var(--bg-soft);" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">الأسئلة الشائعة</h2>
    </div>
    <div class="faq-preview-list">
      {servicesFaqs.map((f) => (
        <details class="faq-item">
          <summary class="faq-question">{f.question}</summary>
          <p class="faq-answer">{f.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="section">
  <div class="container">
    <div class="cta-band">
      <h2>كل خدمة مشمولة بضمان الاسترداد ١٠٠٪</h2>
