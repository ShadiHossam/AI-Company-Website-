---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "تطوير ذكاء اصطناعي مخصص في دبي والخليج | Aegis AI",
    "url": "https://aegisai.ae/ar/services/custom-ai-development",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "تطوير ذكاء اصطناعي مخصص", "item": "https://aegisai.ae/ar/services/custom-ai-development" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "تطوير ذكاء اصطناعي مخصص",
    "description": "بناء أنظمة ذكاء اصطناعي مصممة لعمليات شركتك في الإمارات والسعودية والكويت وقطر: روبوتات محادثة، أتمتة، لوحات تحليلية مدمجة مع أدواتك.",
    "areaServed": [
      {"@type": "Country", "name": "United Arab Emirates"},
      {"@type": "Country", "name": "Saudi Arabia"},
      {"@type": "Country", "name": "Kuwait"},
      {"@type": "Country", "name": "Qatar"}
    ],
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "كم يستغرق تطوير نظام ذكاء اصطناعي مخصص؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يعتمد على تعقيد المشروع. المشاريع البسيطة تنجز بسرعة. الأنظمة الأكثر تعقيداً التي تشمل تكاملات متعددة تأخذ وقتاً أطول. نحدد الجدول الزمني بالضبط في جلسة التشخيص الأولى." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل النظام مع الأنظمة التي نستخدمها حالياً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نبني الأنظمة لتعمل مع ما لديك، سواء CRM أو ERP أو واتساب أو البريد الإلكتروني أو قواعد بيانات مخصصة. لا نطلب منك تغيير بنيتك الحالية." }
      },
      {
        "@type": "Question",
        "name": "هل يدعم النظام اللغة العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالطبع. جميع أنظمتنا تدعم العربية والإنجليزية بشكل كامل، بما في ذلك اللهجات الخليجية في روبوتات المحادثة." }
      },
      {
        "@type": "Question",
        "name": "ماذا يحدث إذا احتجت تعديلات بعد التسليم؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نوفر فترة دعم بعد التسليم لضمان عمل كل شيء كما هو متوقع. أي تعديلات ضمن نطاق المشروع الأصلي مشمولة. بعد ذلك تتوفر خطط صيانة بأسعار شفافة." }
      },
      {
        "@type": "Question",
        "name": "ما الفرق بين تطوير ذكاء اصطناعي مخصص وشراء أداة جاهزة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الأدوات الجاهزة تحل مشاكل عامة. النظام المخصص يُبنى على بياناتك وعملياتك وأهدافك تحديداً، مما يعطيك دقة أعلى وتكامل حقيقي مع عملك." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="تطوير ذكاء اصطناعي مخصص في دبي والخليج | Aegis AI"
  description="Aegis AI تبني أنظمة ذكاء اصطناعي مصممة لعمليات شركتك في الإمارات والسعودية والكويت وقطر: روبوتات محادثة، أتمتة، لوحات تحليلية. مدمجة مع أدواتك. ضمان استرداد 100%."
  canonicalPath="/ar/services/custom-ai-development"
  enPath="/services/custom-ai-development"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a><span class="sep">/</span><a href="/ar/services">الخدمات</a><span class="sep">/</span><strong class="current">تطوير ذكاء اصطناعي مخصص</strong>
    </nav>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">monitor_heart</span>
      الأكثر طلباً
    </div>
    <h1>تطوير ذكاء اصطناعي مخصص<br><span class="gradient-text">لشركتك في دبي</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      لا حلول جاهزة. نبني أنظمة ذكاء اصطناعي مصممة من الصفر على عمليات شركتك، مدمجة مع أدواتك الحالية، تعمل باللغتين، وتحل مشاكل حقيقية تواجهها اليوم.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_custom-ai-development_hero" class="btn-primary">احجز استشارة مجانية</button>
      <a href="/ar/services" class="btn-outline">جميع الخدمات</a>
    </div>
  </div>
</header>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">سريع</div>
        <div class="stat-label">وقت التسليم حسب المشروع</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان الاسترداد</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">+٤٧٪</div>
        <div class="stat-label">متوسط تحسين التحويل</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">عربي + إنجليزي</div>
        <div class="stat-label">ثنائي اللغة دائماً</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What We Build -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>ماذا نبني لشركتك</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">أمثلة شائعة، لا قائمة حصرية. من روبوتات المحادثة إلى لوحات التحليل، كل ما نبنيه مدمج في عملياتك اليومية. إذا كانت فكرتك مختلفة، أخبرنا بما تحتاجه.</p>
    </div>
    <div class="feature-grid">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">smart_toy</span>
        <h3>روبوتات واتساب وتيليغرام</h3>
        <p>بوتات محادثة تردّ على العملاء فوراً، تؤهّل العملاء المحتملين، وترسل عروض أسعار على مدار الساعة.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">manage_accounts</span>
        <h3>أتمتة CRM</h3>
        <p>تحديث تلقائي للسجلات، تصنيف العملاء المحتملين، وإرسال متابعات مخصصة دون تدخل يدوي.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">bar_chart</span>
        <h3>لوحات تحليلية تنبؤية</h3>
        <p>بيانات شركتك تتحول إلى رؤى قابلة للتنفيذ: مبيعات، مخزون، أداء الفرق. كل شيء في مكان واحد.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">description</span>
        <h3>معالجة المستندات</h3>
        <p>استخراج بيانات من الفواتير والعقود والنماذج تلقائياً، وتحويلها إلى بيانات منظمة في ثوانٍ.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">build</span>
        <h3>أدوات ذكاء اصطناعي داخلية</h3>
        <p>مساعد معرفة للموظفين، أداة توليد تقارير، أو أي أداة تحتاجها، مبنية خصيصاً لفريقك.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">account_tree</span>
        <h3>أتمتة سير العمل</h3>
        <p>نربط أنظمتك المختلفة ونُعيد تصميم العمليات المتكررة لتعمل وحدها، بدقة وبدون أخطاء.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Results Card -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:860px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2>نتيجة حقيقية من دبي</h2>
    </div>
    <div class="card results-card">
      <div class="results-badge">
        <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">apartment</span>
        شركة عقارات، دبي
      </div>
      <div class="results-row">
        <div class="results-col">
          <div class="results-label">المشكلة</div>
          <p>فريق المبيعات يرد على استفسارات واتساب يدوياً، أحياناً بعد ٤ ساعات من الاستلام. كثير من العملاء المحتملين يتحولون للمنافسين قبل الرد.</p>
        </div>
        <div class="results-divider" aria-hidden="true">←</div>
        <div class="results-col">
          <div class="results-label">الحل</div>
          <p>روبوت واتساب مخصص يرد فوراً، يؤهّل العملاء بأسئلة ذكية، ويحوّل الجاهزين للشراء مباشرة إلى المبيع المناسب.</p>
        </div>
      </div>
      <div class="results-metrics">
        <div class="metric">
          <div class="metric-number">+٤٧٪</div>
          <div class="metric-label">زيادة في تحويل العملاء المحتملين</div>
        </div>
        <div class="metric">
          <div class="metric-number">أقل من ٢ دقيقة</div>
          <div class="metric-label">متوسط وقت الرد (كان ٤ ساعات)</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>كيف يسير العمل</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>جلسة تشخيص مجانية</h3>
          <p>نجلس معك ٤٥ دقيقة لفهم عملياتك وتحديد أعلى نقطة تأثير للذكاء الاصطناعي في شركتك. تخرج بخارطة طريق واضحة حتى لو لم تستمر معنا.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>بناء وتكامل</h3>
          <p>نبني النظام بشكل تكراري ونريك نتائج كل أسبوع. تُدمج في أنظمتك الحالية دون توقف العمل. فريقك يُجرّب مع كل مرحلة.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٣</div>
        <div class="step-content">
          <h3>تسليم وضمان</h3>
          <p>تحصل على النظام كاملاً مع توثيق ودعم. إذا لم تكن راضياً تماماً خلال ٣٠ يوماً، نردّ ١٠٠٪. بدون أسئلة.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_custom-ai-development_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أسئلة شائعة</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق تطوير نظام ذكاء اصطناعي مخصص؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يعتمد على تعقيد المشروع. المشاريع البسيطة تنجز بسرعة. الأنظمة الأكثر تعقيداً التي تشمل تكاملات متعددة تأخذ وقتاً أطول. نحدد الجدول الزمني بالضبط في جلسة التشخيص الأولى.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يعمل النظام مع الأنظمة التي نستخدمها حالياً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. نبني الأنظمة لتعمل مع ما لديك، سواء CRM أو ERP أو واتساب أو البريد الإلكتروني أو قواعد بيانات مخصصة. لا نطلب منك تغيير بنيتك الحالية.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يدعم النظام اللغة العربية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">بالطبع. جميع أنظمتنا تدعم العربية والإنجليزية بشكل كامل، بما في ذلك اللهجات الخليجية في روبوتات المحادثة.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا يحدث إذا احتجت تعديلات بعد التسليم؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نوفر فترة دعم بعد التسليم لضمان عمل كل شيء كما هو متوقع. أي تعديلات ضمن نطاق المشروع الأصلي مشمولة. بعد ذلك تتوفر خطط صيانة بأسعار شفافة.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الفرق بين تطوير ذكاء اصطناعي مخصص وشراء أداة جاهزة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الأدوات الجاهزة تحل مشاكل عامة. النظام المخصص يُبنى على بياناتك وعملياتك وأهدافك تحديداً، مما يعطيك دقة أعلى وتكامل حقيقي مع عملك.</div>
      </div>

    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز لبناء نظامك الأول؟</h2>
    <p style="opacity:0.85;max-width:500px;margin:0 auto 2rem;line-height:1.8;">احجز جلسة تشخيص مجانية، نخرج منها بخارطة طريق واضحة لما يمكن أتمتته في شركتك.</p>
    <button onclick="openModal(this)" data-source="ar_custom-ai-development_cta" class="btn-primary">احجز جلستك المجانية</button>
  </div>
</section>

</ArBaseLayout>

<style>
  .stats-strip {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .stat-item { min-width: 120px; }
  .stat-number { font-size: 2rem; font-weight: 800; color: #00253b; line-height: 1.1; }
  .stat-label { font-size: 0.8125rem; color: #5f6b7a; margin-top: 0.375rem; }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .feature-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .feature-icon { font-size: 2rem; color: #006875; }
  .feature-card h3 { font-size: 1rem; font-weight: 700; color: #00253b; margin: 0; }
  .feature-card p { font-size: 0.875rem; color: #42474e; line-height: 1.7; margin: 0; }

  .results-card { padding: 2.5rem; }
  .results-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(0,104,117,0.1); color: #004f58;
    font-size: 0.8125rem; font-weight: 700; padding: 5px 14px;
    border-radius: 100px; margin-bottom: 2rem;
  }
  .results-row { display: flex; gap: 2rem; align-items: flex-start; margin-bottom: 2rem; }
  .results-col { flex: 1; }
  .results-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #006875; margin-bottom: 0.5rem; }
  .results-col p { font-size: 0.9375rem; color: #42474e; line-height: 1.75; margin: 0; }
  .results-divider { font-size: 1.5rem; color: #c4cbd4; padding-top: 1.5rem; flex-shrink: 0; }
  .results-metrics { display: flex; gap: 2rem; padding-top: 1.5rem; border-top: 1px solid #e2e8f0; }
  .metric { flex: 1; text-align: center; }
  .metric-number { font-size: 2rem; font-weight: 800; color: #006875; line-height: 1.1; }
  .metric-label { font-size: 0.8125rem; color: #5f6b7a; margin-top: 0.375rem; }

  .process-steps { display: flex; flex-direction: column; gap: 2rem; }
  .process-step { display: flex; gap: 1.5rem; align-items: flex-start; }
  .step-number {
    width: 44px; height: 44px; border-radius: 50%;
    background: #00253b; color: #fff;
    font-size: 1.125rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
