---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "دمج الذكاء الاصطناعي في عمليات شركتك | Aegis AI",
    "url": "https://lenooai.com/ar/services/ai-integration",
    "inLanguage": "ar",
    "description": "Aegis AI تدمج أدوات الذكاء الاصطناعي مع CRM وERP وأنظمة شركتك في الإمارات، دون إعادة البناء من الصفر.",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://lenooai.com/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "تكامل الذكاء الاصطناعي", "item": "https://lenooai.com/ar/services/ai-integration" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "دمج الذكاء الاصطناعي في عمليات شركتك",
    "url": "https://lenooai.com/ar/services/ai-integration",
    "inLanguage": "ar",
    "description": "ندمج أدوات الذكاء الاصطناعي مع أنظمتك الحالية: CRM وERP والبريد الإلكتروني وأكثر، دون إعادة البناء من الصفر.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://lenooai.com" },
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "serviceType": "AI System Integration"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "هل يمكنكم دمج الذكاء الاصطناعي مع نظام CRM الذي نستخدمه حالياً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، هذا بالضبط ما نفعله. ندمج الذكاء الاصطناعي مع أي نظام CRM تستخدمه دون الحاجة لتغيير النظام. فريقك يواصل العمل بنفس الطريقة، لكن النظام يصبح أذكى." }
      },
      {
        "@type": "Question",
        "name": "ما الأنظمة التي تدعمون دمجها مع الذكاء الاصطناعي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "أي نظام يملك API. الأكثر شيوعاً: أنظمة CRM وERP وأدوات التواصل الداخلي وإدارة المستندات ومنصات المراسلة، وأكثر من 50 نظاماً آخر." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق مشروع التكامل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الجدول الزمني يعتمد على عدد الأنظمة وتعقيد التكاملات. نعطيك جدولاً زمنياً دقيقاً بعد جلسة التحليل الأولى." }
      },
      {
        "@type": "Question",
        "name": "هل ستتأثر عملياتنا أثناء التكامل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "لا. نبني التكامل في بيئة اختبار منفصلة ولا نلمس أنظمتك الحية حتى يكتمل الاختبار بالكامل. لديك دائماً خيار التراجع كشبكة أمان." }
      },
      {
        "@type": "Question",
        "name": "ماذا يحدث بعد الإطلاق؟",
        "acceptedAnswer": { "@type": "Answer", "text": "جميع مشاريع التكامل تشمل دعماً لمدة 90 يوماً بعد الإطلاق. نراقب الأنظمة ونصلح أي مشكلة ونجري التحديثات اللازمة مع تطور عملياتك." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="خدمات دمج الذكاء الاصطناعي للشركات في الإمارات | Aegis AI"
  description="Aegis AI وكالة ذكاء اصطناعي في دبي تدمج أدوات الذكاء الاصطناعي مع CRM وERP وأنظمة شركتك في الإمارات، دون إعادة البناء من الصفر. تكامل سريع."
  canonicalPath="/ar/services/ai-integration"
  enPath="/services/ai-integration"
  ldJson={ldJson}
>

<!-- 1. HERO -->
<header class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>تكامل الأنظمة</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">hub</span>
      تكامل الأنظمة
    </div>
    <h1>اربط الذكاء الاصطناعي بأنظمتك الحالية <span class="gradient-text">بدون بناء من الصفر</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.9;">
      لا تحتاج إلى استبدال CRM أو ERP أو أي أداة أخرى. نضيف طبقة ذكاء اصطناعي دقيقة فوق ما تستخدمه حالياً، فيحصل فريقك على نتائج أفضل بكثير دون تغيير طريقة عمله.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_ai_integration_hero" class="btn-primary">ابدأ بربط أنظمتك بالذكاء الاصطناعي</button>
      <a href="#what-we-build" class="btn-outline">اكتشف ما نبنيه ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?w=1400&q=80&auto=format&fit=crop" alt="دمج الذكاء الاصطناعي مع الأنظمة الحالية وواجهات البرمجة" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.25),rgba(0,37,59,0.40));"></div>
</div>

<!-- 2. STATS -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-val">سريع</div>
        <div class="stat-desc">تكامل يبدأ من أول يوم</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">دون توقف</div>
        <div class="stat-desc">عملياتك لا تتوقف لحظة واحدة أثناء التكامل</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">+٥٠ نظام</div>
        <div class="stat-desc">دعم أكثر من ٥٠ نظاماً وأداة مختلفة</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">١٠٠٪</div>
        <div class="stat-desc">ضمان استرداد كامل إذا لم تكن راضياً</div>
      </div>
    </div>
  </div>
</div>

<!-- 3. WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="builds-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">ما الذي نبنيه</div>
      <h2 id="builds-heading">تكاملات الذكاء الاصطناعي التي نبنيها</h2>
      <p style="color:#42474e;font-size:1rem;max-width:560px;margin:0.75rem auto 0;line-height:1.8;">أمثلة شائعة، لا قائمة حصرية. بصفتنا وكالة الذكاء الاصطناعي في دبي، نُصمم كل تكامل لأنظمتك بالتحديد، نختبره على بياناتك الحقيقية، وندعمه بعد الإطلاق. إذا كان نظامك أو حالتك غير مذكورة هنا، نقوم بها على الأرجح. أخبرنا بما تعمل عليه.</p>
    </div>
    <div style="border-radius:20px;overflow:hidden;margin-bottom:2.5rem;box-shadow:0 20px 48px rgba(0,59,92,0.08);">
      <img src="https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=1100&q=80&auto=format&fit=crop" alt="شيفرة تكامل ذكاء اصطناعي على شاشة مطور في دبي" loading="lazy" width="1100" height="300" style="width:100%;height:clamp(180px,26vw,300px);object-fit:cover;display:block;" />
    </div>
    <div class="feature-ledger">
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">contacts</span>
        </div>
        <h3>تكامل CRM مع الذكاء الاصطناعي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نضيف الذكاء الاصطناعي لنظام CRM الذي تستخدمه. يُسجّل الصفقات تلقائياً، يتوقع صحة الفرص، ويحدد الخطوة التالية لكل مندوب دون مغادرة النظام.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">inventory_2</span>
        </div>
        <h3>مزامنة ERP مع الذكاء الاصطناعي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نحوّل بيانات ERP الخام إلى تحليلات تنبؤية: توقع الطلب، تحسين المخزون، الكشف عن الشذوذات قبل أن تتحول إلى مشاكل.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">whatsapp</span>
        </div>
        <h3>تكامل منصة المراسلة مع الذكاء الاصطناعي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نربط منصة المراسلة التي تستخدمها بأنظمتك الداخلية. رد تلقائي على الاستفسارات، تحديث الطلبات، وتوجيه المحادثات للشخص المناسب دون تدخل يدوي.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">mail</span>
        </div>
        <h3>منصة البريد الإلكتروني مع الذكاء الاصطناعي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">ذكاء اصطناعي مدمج في بريدك الإلكتروني. يلخص المحادثات الطويلة، يستخرج بنود الإجراءات، ويصيغ الردود، ويوجه الرسائل للشخص الصحيح تلقائياً.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">description</span>
        </div>
        <h3>إدارة المستندات واستخراج البيانات</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نربط نظام إدارة مستنداتك بالذكاء الاصطناعي لاستخراج البيانات من الفواتير والعقود والنماذج تلقائياً، وإدخالها مباشرة في أنظمتك.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">webhook</span>
        </div>
        <h3>جسور API مخصصة</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نبني وسيطاً ذكياً يصل أنظمتك الخاصة ببعضها، حتى تتدفق البيانات بذكاء بين أدوات لم تُصمَّم أصلاً للتحدث مع بعضها.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. RESULTS CARD -->
<section class="section" style="background:#e7eeff;padding:4rem 0;" aria-labelledby="results-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">نتيجة حقيقية</div>
      <h2 id="results-heading">من يعاني يومياً من إدخال البيانات يدوياً</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?w=1200&q=80&auto=format&fit=crop" alt="مهندس يربط أنظمة الذكاء الاصطناعي عبر شاشات متعددة" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card" style="max-width:800px;margin:0 auto;">
      <div class="results-grid">
        <div class="result-col">
          <div class="result-label">المشكلة</div>
          <p style="color:#42474e;line-height:1.8;">شركة لوجستيات كبرى في دبي: نظام ERP لا يتحدث مع بوابة العملاء. كل تحديث للطلبات كان يتم يدوياً بواسطة موظف يقضي ساعتين يومياً في نسخ البيانات بين النظامين.</p>
        </div>
        <div class="result-col">
          <div class="result-label">الحل</div>
          <p style="color:#42474e;line-height:1.8;">بنينا جسر ذكاء اصطناعي يزامن الطلبات لحظياً ويُحدّث العملاء تلقائياً، دون أي تدخل يدوي.</p>
        </div>
      </div>
      <div class="metrics-row">
        <div class="metric-item">
          <div class="metric-val">٠ تحديث</div>
          <div class="metric-desc">يدوي يومياً (كانت ٢ ساعة/يوم)</div>
        </div>
        <div class="metric-item">
          <div class="metric-val">٩٠٪-</div>
          <div class="metric-desc">تراجع في أخطاء إدخال البيانات</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. HOW IT WORKS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">كيف نعمل</div>
      <h2 id="process-heading">ثلاث خطوات لدمج الذكاء الاصطناعي في أنظمتك</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="process-num">١</div>
        <h3>تحليل أنظمتك الحالية</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">ندرس أنظمتك وتدفق البيانات وواجهات API المتاحة، ثم نحدد بالضبط أين يُحدث الذكاء الاصطناعي أعلى قيمة.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٢</div>
        <h3>بناء جسور التكامل</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نصمم طبقة الذكاء الاصطناعي ونبني الاتصالات الآمنة ونطور التكاملات في بيئة اختبار منفصلة تماماً عن أنظمتك الحية.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٣</div>
        <h3>اختبار ونشر وتدريب</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نتحقق من التكامل على بياناتك الحقيقية، ننشره دون تأثير على عملياتك، ثم ندرّب فريقك على الاستخدام، مع دعم ٩٠ يوماً بعد الإطلاق.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. GUARANTEE -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_ai_integration_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 id="faq-heading">أسئلة شائعة</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكنكم دمج الذكاء الاصطناعي مع أنظمة CRM الشائعة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، هذا بالضبط ما نفعله. ندمج الذكاء الاصطناعي مع أي نظام CRM تستخدمه دون الحاجة لتغيير النظام. فريقك يواصل العمل بنفس الطريقة، لكن النظام يصبح أذكى وأكثر كفاءة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الأنظمة التي تدعمون دمجها مع الذكاء الاصطناعي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">أي نظام يملك API. الأكثر شيوعاً: أنظمة CRM وERP وأدوات التواصل الداخلي والبريد الإلكتروني ومنصات المراسلة وإدارة المستندات، وأكثر من ٥٠ نظاماً آخر.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق مشروع التكامل عادةً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الجدول الزمني يعتمد على عدد الأنظمة وتعقيد التكاملات. نعطيك جدولاً زمنياً دقيقاً بعد جلسة التحليل الأولى.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل ستتأثر عملياتنا اليومية أثناء التكامل؟
