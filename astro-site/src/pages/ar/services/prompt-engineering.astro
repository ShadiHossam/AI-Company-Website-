---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const faqItems = [
  { question: "كيف يبدو مشروع هندسة الأوامر فعلياً؟", answer: "يعتمد على نقطة انطلاقك. للفرق التي تستخدم الذكاء الاصطناعي بكثافة، نبدأ بمراجعة شاملة للأوامر الحالية: نستعرض ما تستخدمه فعلاً، نحدّد أين يكون المخرج غير ثابت، ونعيد كتابة الأسوأ أداءً. للفرق التي تبني ميزات أو سير عمل جديداً بالذكاء الاصطناعي، ننضم لعملية التصميم مبكراً ونكتب أوامر النظام من الصفر. في الحالتين، تخرج بمكتبة أوامر موثّقة يسهل صيانتها وتحديثها." },
  { question: "مع أي نماذج ذكاء اصطناعي تعملون؟", answer: "نهندس الأوامر لجميع النماذج الرئيسية، المملوكة ومفتوحة المصدر على حد سواء. لكل نموذج نقاط قوة وسلوكيات وأنماط هندسة مثلى مختلفة. نعرفها جميعاً ونهندس بناءً عليها، فتحصل على أفضل أداء من أي نموذج تستخدمه." },
  { question: "كم يُكلّف فعلياً الأوامر السيئة؟", answer: "أكثر مما تتصوره معظم الفرق. الأوامر السيئة تُنتج مخرجات غير ثابتة تحتاج تعديلاً يدوياً، مما يُبطل الغرض من استخدام الذكاء الاصطناعي أساساً. كما تجعل النماذج تستهلك رموزاً أكثر من اللازم، فترفع تكلفة الواجهة البرمجية. وتخلق سلوكاً غير متوقّع يُضعف ثقة فريقك بأدوات الذكاء الاصطناعي. مكتبة أوامر مُهندسة جيداً تُقلّص وقت التعديل عادة بنسبة ٦٠ إلى ٨٠٪ وتُخفّض استهلاك الرموز بنسبة ٢٠ إلى ٤٠٪." },
  { question: "هل يمكنكم كتابة أوامر لقطاعنا أو مجالنا تحديداً؟", answer: "نعم، وهنا تكون هندسة الأوامر المتخصصة بمجال محدد أعلى قيمة. الأوامر العامة تُنتج مخرجات عامة. نبحث في مصطلحات قطاعك، معايير نبرتك، قيود الامتثال، ومتطلبات صيغة المخرج، ثم نهندس أوامر تراعي كل ذلك. القانوني، الصحي، المالي، العقاري، التجارة الإلكترونية: عملنا في كل هذه القطاعات." },
  { question: "هل تقدّمون تحسيناً مستمراً؟", answer: "نعم. نماذج الذكاء الاصطناعي تتحدّث باستمرار، وقد يحتاج الأمر الذي يعمل بشكل ممتاز اليوم لتعديل بعد تحديث النموذج. نقدّم عقود اشتراك شهرية تغطي اختباراً مستمراً، تحسيناً مع تطور النماذج، ودعماً ذا أولوية عند حدوث خلل. معظم عملائنا يجدونها قيّمة بمجرد أن يروا التحسّن في مخرجات أوامرهم." },
  { question: "كم يستغرق مشروع هندسة الأوامر؟", answer: "مراجعة الأوامر مع إعادة الكتابة لنظام قائم تستغرق عادة أسبوعاً إلى أسبوعين. بناء مكتبة أوامر كاملة من الصفر لمنتج أو سير عمل جديد بالذكاء الاصطناعي يستغرق أسبوعين إلى أربعة أسابيع حسب النطاق. معظم العملاء يلاحظون تحسناً واضحاً في جودة المخرج خلال أول أسبوع من العمل بأوامر مُحسَّنة. ترتيبات الاشتراك المستمر شهرية، دون حد أدنى للمدة." },
  { question: "نستخدم أداة أو أداتين فقط من أدوات الذكاء الاصطناعي. هل يستحق الأمر رغم ذلك؟", answer: "غالباً نعم، خصوصاً إذا كانت هاتان الأداتان مواجهتين للعميل أو تُنتجان محتوى يُعدّله فريقك يدوياً بكثرة. العائد من هندسة الأوامر يتناسب طردياً مع الوقت الذي يقضيه فريقك في تصحيح مخرجات الذكاء الاصطناعي. إذا كنت تقضي أكثر من بضع ساعات أسبوعياً في تعديل محتوى مُولَّد بالذكاء الاصطناعي، يُعوّض الاستثمار نفسه بسرعة. أمر نظام واحد مُهندَس جيداً لحالة استخدام مواجهة للعميل قد يُلغي ساعات من التصحيحات الأسبوعية." },
  { question: "هل يمكنكم مساعدتنا في بناء إرشادات داخلية ليكتب فريقنا أوامر أفضل بنفسه؟", answer: "نعم، وهذا جزء من كل مشروع نُنجزه. نُسلّم مجموعة إرشادات موثّقة خاصة بفريقك وأدواتك، تغطي البنية، تحديد السياق، تعليمات الصيغة، وأشيع أنماط الفشل التي يجب تجنبها. كما نُقدّم جلسة تدريبية نستعرض فيها المبادئ مع فريقك. الهدف أن يصبح فريقك، بعد العمل معنا، أفضل بشكل ملموس في كتابة الأوامر وتحسينها بنفسه." },
];

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "هندسة وتحسين الأوامر (Prompt Engineering) في دبي والإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/services/prompt-engineering",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "هندسة وتحسين الأوامر", "item": "https://aegisai.ae/ar/services/prompt-engineering" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "هندسة وتحسين الأوامر",
    "description": "نُراجع ونهندس ونحسّن أوامر الذكاء الاصطناعي لأي نموذج، فيحصل فريقك على مخرجات ثابتة وعالية الجودة، بتكلفة أقل ووقت تعديل أقل.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  faqLdJson
];
---

<ArBaseLayout
  title="هندسة وتحسين الأوامر (Prompt Engineering) للشركات في الإمارات | Aegis AI"
  description="Aegis AI، وكالة الذكاء الاصطناعي في دبي، تُراجع وتهندس وتُحسّن أوامر الذكاء الاصطناعي لأي نموذج، للشركات في الإمارات. مخرجات ثابتة، وقت تعديل أقل، وتكلفة واجهة برمجية أقل."
  canonicalPath="/ar/services/prompt-engineering"
  enPath="/services/prompt-engineering"
  ogImage="/assets/og-services.jpg"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>هندسة وتحسين الأوامر</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">tune</span>
      هندسة الأوامر
    </div>
    <h1>ذكاؤك الاصطناعي بجودة<br><span class="gradient-text">الأوامر التي خلفه فقط.</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      معظم الفرق التي تستخدم الذكاء الاصطناعي تترك أداءً كبيراً على الطاولة. المخرجات غير ثابتة، التعديل لا يتوقف، ولا أحد يعرف لماذا ينجح أحياناً ويفشل أحياناً أخرى. هذه مشكلة هندسة أوامر، ونحن نحلّها.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_prompt_eng_hero" class="btn-primary">احصل على مراجعة أوامر</button>
      <a href="#what-we-do" class="btn-outline">شاهد ما نقدّمه ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?w=1400&q=80&auto=format&fit=crop" alt="هندسة الأوامر وتحسين الذكاء الاصطناعي" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 25%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">٦٠–٨٠٪</div>
        <div class="stat-label">انخفاض في وقت التعديل اليدوي بعد التحسين</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">٢٠–٤٠٪</div>
        <div class="stat-label">انخفاض في استهلاك رموز الواجهة البرمجية بأوامر أدق وأخف</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">جميع النماذج</div>
        <div class="stat-label">كل النماذج الرئيسية. نعرف خصائصها ونهندس بناءً عليها</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What Is Prompt Engineering -->
<section class="section" aria-labelledby="explain-heading">
  <div class="container">
    <div style="max-width:800px;margin:0 auto;">
      <h2 id="explain-heading" style="margin-bottom:1.5rem;">ما هي هندسة الأوامر؟</h2>
      <p style="color:#42474e;font-size:1.0625rem;line-height:1.85;margin-bottom:1.25rem;">
        هندسة الأوامر هي ممارسة تصميم واختبار وتحسين التعليمات التي تُعطيها لنموذج ذكاء اصطناعي، بحيث يُنتج باستمرار المخرج الذي تحتاجه فعلاً. طريقة بناء الأمر، السياق الذي يقدّمه، الصيغة التي يطلبها، والأمثلة التي يتضمّنها، جميعها لها أثر قابل للقياس على جودة واتساق وكفاءة تكلفة مخرجات الذكاء الاصطناعي.
      </p>
      <p style="color:#42474e;font-size:1.0625rem;line-height:1.85;margin-bottom:1.25rem;">
        معظم الشركات التي تستخدم الذكاء الاصطناعي تعمل بأوامر كُتبت بسرعة، لم تُختبر بشكل صحيح، ولم تُوثَّق أبداً. النتيجة مخرجات غير ثابتة تحتاج تعديلاً يدوياً مستمراً، استهلاك رموز مرتفع بسبب أوامر مطوّلة تُثقل السياق دون داعٍ، وسلوك ذكاء اصطناعي غير متوقّع: ممتاز أحياناً، خاطئ أحياناً أخرى، دون فهم واضح للسبب.
      </p>
      <p style="color:#42474e;font-size:1.0625rem;line-height:1.85;">
        هندسة الأوامر الاحترافية تتعامل مع الأوامر كأدوات دقيقة، لا مسودات عابرة. الأمر المُهندَس جيداً يُحدّد دور النموذج، يضبط السياق بكفاءة، يُقيّد صيغة المخرج، يتعامل مع الحالات الاستثنائية بوضوح، وقد اختُبِر على مدخلات حقيقية للتحقق من أدائه. الفرق في جودة المخرج بين أمر كُتب بشكل عابر وآخر مُهندَس غالباً ما يكون كبيراً، وتوفير التكلفة من الأوامر الأدق حقيقي وقابل للقياس على نطاق واسع.
      </p>
    </div>
  </div>
</section>

<!-- 4. What We Do -->
<section id="what-we-do" class="section" style="background:#f8fafc;" aria-labelledby="services-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 id="services-heading">ماذا نفعل في مشروع هندسة الأوامر</h2>
      <p style="color:#42474e;max-width:600px;margin:1rem auto 0;line-height:1.8;">لا نُعيد كتابة الأوامر فقط. نبني نظاماً يستطيع فريقك صيانته وتطويره بنفسه.</p>
    </div>
    <div class="feature-ledger">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">search</span>
        <h3>مراجعة الأوامر</h3>
        <p>نستعرض كل أمر يستخدمه فريقك حالياً، نُقيّمه من حيث الجودة والاتساق، ونحدّد نقاط الفشل التي تُكلّفك وقتاً ومالاً تحديداً.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">edit</span>
        <h3>تصميم أوامر النظام</h3>
        <p>لمنتجات ووكلاء الذكاء الاصطناعي، أمر النظام هو الأساس. نكتب ونختبر أوامر نظام تُحدّد السلوك، تفرض النبرة، وتمنع المخرجات غير المرغوبة.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">library_books</span>
        <h3>بناء مكتبة أوامر</h3>
        <p>مكتبة أوامر موثّقة ومنظّمة لكل حالة استخدام لدى فريقك. مكتوبة، مُصنّفة بإصدارات، وجاهزة للاستخدام. لا مزيد من المعرفة المحصورة في رأس شخص واحد.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">science</span>
        <h3>اختبار A/B وتقييم</h3>
        <p>نُجري اختبارات مُنظَّمة تُقارن بين نسخ الأوامر عبر سيناريوهات حقيقية، نقيس جودة المخرج بشكل منهجي، ونختار الفائز بناءً على بيانات لا انطباعات.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">school</span>
        <h3>تدريب الفريق</h3>
        <p>يتعلّم فريقك كيف يكتب ويختبر ويُطوّر الأوامر بنفسه. ننقل المعرفة لتتوقف عن الاعتماد علينا في كل مرة يحتاج فيها شيء إلى تحديث.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">refresh</span>
        <h3>تحسين مستمر</h3>
        <p>النماذج تتحدّث. احتياجات العمل تتغيّر. نقدّم عقود اشتراك تُبقي مكتبة أوامرك محدّثة، مُختبرة، ومُحسَّنة مع تطور مشهد الذكاء الاصطناعي.</p>
      </div>
    </div>
  </div>
</section>

<!-- 5. Where It Matters Most -->
<section class="section" aria-labelledby="usecases-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 id="usecases-heading">أين تُحدث هندسة الأوامر أكبر فرق</h2>
      <p style="color:#42474e;max-width:600px;margin:1rem auto 0;line-height:1.8;">هذه أعلى نقاط البداية تأثيراً، لا قائمة كاملة بما يمكننا تحسينه. إذا لم تكن حالة استخدامك هنا، تواصل معنا.</p>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1200&q=80&auto=format&fit=crop" alt="كتابة وتحسين الأوامر على حاسوب محمول" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="feature-grid feature-grid-3">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">support_agent</span>
        <h3>ذكاء اصطناعي لدعم العملاء</h3>
        <p>وكلاء دعم يُعطون إجابات مختلفة لنفس السؤال يُدمّرون ثقة العميل. نهندس أوامر تُنتج ردوداً ثابتة ومتماشية مع علامتك في كل مرة.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">draw</span>
        <h3>توليد المحتوى</h3>
        <p>إذا كان محتواك المكتوب بالذكاء الاصطناعي يبدو دائماً كأنه مكتوب بالذكاء الاصطناعي، فأوامرك لا تؤدي عملها. نهندس أوامر تُنتج نصوصاً تبدو إنسانية فعلاً وتطابق صوت علامتك.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">description</span>
        <h3>تحليل المستندات</h3>
        <p>استخراج البيانات الصحيحة من العقود والتقارير ورسائل البريد يتطلب صياغة دقيقة. نهندس أوامر استخراج تجلب بالضبط ما تحتاجه، بالصيغة التي تحتاجها.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. Process -->
<section class="section" style="background:#f8fafc;" aria-labelledby="process-heading">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 id="process-heading">كيف يسير مشروع هندسة الأوامر</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>المراجعة</h3>
          <p>نستعرض أوامرك الحالية، سير عملك، ومخرجاتك، ونُقيّم بدقة ما هو معطّل ولماذا.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>الهندسة</h3>
