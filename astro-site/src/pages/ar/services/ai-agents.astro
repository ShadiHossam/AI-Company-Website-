<script define:vars={{ pageId: 'ai-agents' }}>
  (function () {
    const wrap = document.getElementById('agent-tabs');
    if (!wrap) return;
    const buttons = wrap.querySelectorAll('.agent-tab');
    const cards = document.querySelectorAll('.feature-ledger .card[data-cat]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        const cat = btn.getAttribute('data-cat');
        cards.forEach((card) => {
          card.style.display = cat === 'all' || card.getAttribute('data-cat') === cat ? '' : 'none';
        });
      });
    });
  })();
</script>

