---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "وكلاء الذكاء الاصطناعي في دبي والإمارات | Lenoo AI",
    "url": "https://lenooai.com/ar/services/ai-agents",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://lenooai.com/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "وكلاء الذكاء الاصطناعي", "item": "https://lenooai.com/ar/services/ai-agents" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "وكلاء الذكاء الاصطناعي",
    "description": "بناء وكلاء ذكاء اصطناعي مستقلين يُكملون مهام متعددة الخطوات، يتخذون قرارات، ويعملون 24/7 بالعربي والإنجليزي.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Lenoo AI", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الفرق بين وكيل الذكاء الاصطناعي وروبوت المحادثة العادي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "روبوت المحادثة يجيب على أسئلة. الوكيل يُفكر ويتصرف: يكمل مهام متعددة الخطوات بشكل مستقل، مثل البحث عن معلومة ثم إرسال بريد إلكتروني ثم تحديث السجل في CRM، مما يُحرّر فريقك للتركيز على القرارات التي تحتاج حكماً بشرياً حقيقياً." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن للوكيل التعامل مع العربية والإنجليزية معاً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. جميع وكلاءنا ثنائيو اللغة بشكل كامل، يفهمون السياق ويردون بنفس لغة المستخدم، ويتعاملون مع التبديل بين اللغتين في نفس المحادثة." }
      },
      {
        "@type": "Question",
        "name": "ما الأنظمة التي يمكن للوكيل الوصول إليها؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني الوكلاء ليصلوا إلى ما تحتاجه: بريد إلكتروني، CRM، تقاويم، قواعد بيانات، تطبيقات المراسلة، وغيرها. نحدد الصلاحيات بدقة لضمان الأمان الكامل." }
      },
      {
        "@type": "Question",
        "name": "كيف نضمن أن الوكيل لن يتخذ قرارات خاطئة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نصمم الوكلاء بحدود واضحة. يعرف الوكيل متى يتصرف ومتى يصعّد للإنسان. تحدد أنت مستوى الاستقلالية، ونبني نظام مراجعة داخلي لأي إجراء حساس." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن للوكيل أن يتعلم ويتحسن مع الوقت؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نصمم الوكلاء ليجمعوا تغذية راجعة من نتائجهم ويحسّنوا أداءهم. بعض الوكلاء يُحدَّثون يدوياً بشكل دوري، وبعضها يمكن أن يتكيف تلقائياً بناء على الأنماط." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="وكلاء الذكاء الاصطناعي وأنظمة الوكلاء للشركات في الإمارات | Lenoo AI"
  description="Lenoo AI وكالة ذكاء اصطناعي في دبي تبني وكلاء ذكاء اصطناعي مستقلين للشركات في الإمارات، يُكملون مهام متعددة الخطوات ويتخذون قرارات على مدار الساعة."
  canonicalPath="/ar/services/ai-agents"
  enPath="/services/ai-agents"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>وكلاء الذكاء الاصطناعي</div>
    <div class="badge badge-amber" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">smart_toy</span>
      وكلاء مستقلون
    </div>
    <h1>وكلاء ذكاء اصطناعي<br><span class="gradient-text">يُفكرون ويتصرفون دون انتظار</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      ليس مجرد ردود آلية. وكلاء حقيقيون يُكملون مهام متعددة الخطوات بشكل مستقل: يبحثون، يقررون، يُرسلون، يُحدّثون. كل ذلك دون أن تتدخل.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_ai-agents_hero" class="btn-primary">احجز استشارة مجانية</button>
      <a href="/ar/services" class="btn-outline">جميع الخدمات</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1535378917042-10a22c95931a?w=1400&q=80&auto=format&fit=crop" alt="وكلاء الذكاء الاصطناعي واتخاذ القرار المستقل" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
</div>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">٢٤/٧</div>
        <div class="stat-label">يعمل بلا توقف</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">٨٠٪</div>
        <div class="stat-label">متوسط تشغيل الطلبات تلقائياً</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان الاسترداد</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">ع + إنجليزي</div>
        <div class="stat-label">ثنائي اللغة دائماً</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What We Build -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أنواع الوكلاء التي نبنيها</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">أمثلة شائعة، لا قائمة نهائية. بصفتنا وكالة الذكاء الاصطناعي في دبي التي يثق بها عملاء من كل الإمارات، نُصمم كل وكيل لمهمة محددة، نُدرّبه على سياقك، وندمجه في أدواتك. إذا كانت فكرتك لا تنطبق على أي مما هنا، أخبرنا بها.</p>
    </div>
    <div class="agent-tabs" id="agent-tabs" role="tablist" aria-label="تصفية أنواع الوكلاء">
      <button class="agent-tab active" data-cat="all" type="button">الكل</button>
      <button class="agent-tab" data-cat="customer" type="button">خدمة العملاء</button>
      <button class="agent-tab" data-cat="sales" type="button">المبيعات والتسويق</button>
      <button class="agent-tab" data-cat="ops" type="button">العمليات الداخلية</button>
    </div>
    <div class="feature-ledger">
      <div class="card feature-card" data-cat="ops">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">mail</span>
        <h3>وكلاء البريد الإلكتروني</h3>
        <p>يقرأون البريد الوارد، يُصنّفون الأولويات، يُعدّون ردوداً مقترحة، وينهون المهام المرتبطة بكل رسالة تلقائياً.</p>
      </div>
      <div class="card feature-card" data-cat="ops">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">search</span>
        <h3>وكلاء البحث والتحليل</h3>
        <p>يبحثون عبر مصادر متعددة، يلخّصون المعلومات، ويُعدّون تقارير جاهزة للقرار. خلال دقائق لا ساعات.</p>
      </div>
      <div class="card feature-card" data-cat="sales">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">manage_accounts</span>
        <h3>وكلاء تحديث CRM</h3>
        <p>يتابعون العملاء المحتملين، يُحدّثون السجلات، وينبّهون الفريق بالوقت المناسب، دون لمسة يدوية.</p>
      </div>
      <div class="card feature-card" data-cat="sales">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">filter_alt</span>
        <h3>وكلاء تأهيل العملاء</h3>
        <p>يتحدثون مع العملاء المحتملين، يطرحون الأسئلة الصحيحة، ويحوّلون الجاهزين فقط إلى فريق المبيعات.</p>
      </div>
      <div class="card feature-card" data-cat="customer">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">support_agent</span>
        <h3>وكلاء خدمة العملاء</h3>
        <p>يُجيبون على استفسارات العملاء بدقة واتساق، يصلون إلى قواعد المعرفة، ويُصعّدون ما يحتاج إنساناً.</p>
      </div>
      <div class="card feature-card" data-cat="ops">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">calendar_month</span>
        <h3>وكلاء الجدولة والتنسيق</h3>
        <p>يُنسّقون المواعيد، يُرسلون التذكيرات، ويديرون التقاويم، مع الأخذ بالحسبان تفضيلاتك ومتاحيّتك.</p>
      </div>
    </div>

    <!-- Live example -->
    <div class="live-example">
      <div class="live-example-img">
        <img src="https://images.unsplash.com/photo-1611746869696-d09bce200020?w=800&q=80&auto=format&fit=crop" alt="وكيل ذكاء اصطناعي يرد على استفسارات العملاء عبر واتساب" loading="lazy" width="800" height="520" />
      </div>
      <div class="live-example-text">
        <div class="badge badge-cyan" style="margin-bottom:1rem;">مثال حي</div>
        <h3 style="margin-bottom:0.75rem;">وكيل واتساب يتابع كل استفسار خلال ثوانٍ</h3>
        <p style="color:#42474e;line-height:1.8;">عميل يسأل عن توفر غرفة أو موعد، الوكيل يرد فوراً، يتحقق من التوفر، ويحجز أو يُصعّد للفريق إذا احتاج الأمر قراراً بشرياً. لا انتظار، ولا رسالة تضيع.</p>
      </div>
    </div>
  </div>
</section>

<!-- Agent vs Chatbot comparison -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:2rem;">
      <h2>وكيل ذكاء اصطناعي أم روبوت محادثة عادي؟</h2>
    </div>
    <div class="compare-wrap" style="overflow-x:auto;background:#fff;border:1px solid #e2e8f0;border-radius:16px;">
      <table class="compare-table" style="width:100%;border-collapse:collapse;">
        <thead>
          <tr><th></th><th>روبوت محادثة عادي</th><th>وكيل Lenoo AI</th></tr>
        </thead>
        <tbody>
          <tr><td>ينفّذ مهام متعددة الخطوات</td><td class="check-no">✕</td><td class="check-yes">✓</td></tr>
          <tr><td>يتخذ قرارات بناء على السياق</td><td class="check-rarely">أحياناً</td><td class="check-yes">✓</td></tr>
          <tr><td>يتصل بأنظمتك (CRM، بريد، واتساب)</td><td class="check-no">✕</td><td class="check-yes">✓</td></tr>
          <tr><td>يعمل بالعربي والإنجليزي معاً</td><td class="check-rarely">أحياناً</td><td class="check-yes">✓</td></tr>
          <tr><td>يُصعّد للإنسان عند الحاجة</td><td class="check-no">✕</td><td class="check-yes">✓</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- 4. Results Card -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:860px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2>نتيجة حقيقية من دبي</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=1200&q=80&auto=format&fit=crop" alt="فريق عمليات يراجع مهام وكيل الذكاء الاصطناعي" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card results-card">
      <div class="results-badge">
        <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">hotel</span>
        مجموعة ضيافة فندقية، دبي
      </div>
      <div class="results-row">
        <div class="results-col">
          <div class="results-label">المشكلة</div>
          <p>طلبات النزلاء تأتي عبر قنوات متعددة، واتساب والبريد الإلكتروني والهاتف، والفريق يرد يدوياً على كل شيء، مما يُبطئ الاستجابة ويرفع التكاليف التشغيلية.</p>
        </div>
        <div class="results-divider" aria-hidden="true">←</div>
        <div class="results-col">
          <div class="results-label">الحل</div>
          <p>وكيل كونسيرج يفهم طلبات النزلاء، ينفّذ ما يستطيع تلقائياً، ويُصعّد ما يحتاج قراراً بشرياً. يعمل بالعربية والإنجليزية على مدار الساعة.</p>
        </div>
      </div>
      <div class="results-metrics">
        <div class="metric">
          <div class="metric-number">٨٠٪</div>
          <div class="metric-label">من الطلبات تُعالَج تلقائياً</div>
        </div>
        <div class="metric">
          <div class="metric-number">٢٤/٧</div>
          <div class="metric-label">خدمة بلا انقطاع بالعربي والإنجليزي</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>كيف يسير العمل</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>تحديد المهام والصلاحيات</h3>
          <p>نجلس معك لتحديد ما يُنفّذه الوكيل وحده، وما يُصعّده للفريق. تُحدّد أنت حدود الاستقلالية، ونبني على هذا الأساس.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>بناء وربط الأنظمة</h3>
          <p>نبني الوكيل ونربطه بالأنظمة التي تحتاجها: CRM، بريد إلكتروني، واتساب، وغيرها. نختبره على حالات حقيقية قبل الإطلاق.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٣</div>
        <div class="step-content">
          <h3>إطلاق ومراقبة</h3>
          <p>يعمل الوكيل ونتابع أداءه في المرحلة الأولى معاً. لوحة مراقبة تعرض كل إجراء اتخذه، شفافية كاملة.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_ai-agents_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أسئلة شائعة</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الفرق بين وكيل الذكاء الاصطناعي وروبوت المحادثة العادي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">روبوت المحادثة يجيب على أسئلة. الوكيل يُفكر ويتصرف: يكمل مهام متعددة الخطوات بشكل مستقل، مثل البحث عن معلومة ثم إرسال بريد إلكتروني ثم تحديث سجل العميل، مما يُحرّر فريقك للتركيز على القرارات التي تحتاج حكماً بشرياً حقيقياً.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن للوكيل التعامل مع العربية والإنجليزية معاً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. جميع وكلاءنا ثنائيو اللغة بشكل كامل. يفهمون السياق ويردون بنفس لغة المستخدم، ويتعاملون مع التبديل بين اللغتين في نفس المحادثة.</div>
      </div>

      <div class="faq-item">
