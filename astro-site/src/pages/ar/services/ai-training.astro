---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "تدريب الفرق على الذكاء الاصطناعي في الإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/services/ai-training",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "تدريب على الذكاء الاصطناعي", "item": "https://aegisai.ae/ar/services/ai-training" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "تدريب الفرق على الذكاء الاصطناعي",
    "description": "ورش عمل عملية بالعربي والإنجليزي تُمكّن فرق العمل في الإمارات من استخدام الذكاء الاصطناعي بثقة في عملهم اليومي.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "هل التدريب مناسب لموظفين غير تقنيين؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، وهذا بالضبط ما نتخصص فيه. ورشنا مُصمَّمة للمحاسبين، المسوّقين، الموارد البشرية، المبيعات. أي شخص يريد استخدام الذكاء الاصطناعي في عمله اليومي بلا خلفية تقنية." }
      },
      {
        "@type": "Question",
        "name": "كم عدد المشاركين المثالي في كل ورشة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نُفضّل 8-16 مشاركاً للحصول على تفاعل عالي وتطبيق عملي مناسب. يمكننا تشغيل جلسات أكبر للمجموعات الكبيرة، لكنها تكون أقل تفاعلية." }
      },
      {
        "@type": "Question",
        "name": "هل التدريب بالعربية أم الإنجليزية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "كلاهما. نُقدّم الورشة بالعربية أو الإنجليزية حسب تفضيل فريقك، أو بشكل مزدوج إذا كانت المجموعة متنوعة. المواد متوفرة بالغتين." }
      },
      {
        "@type": "Question",
        "name": "ما الأدوات التي يتعلم عليها المشاركون؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نُخصّص الأدوات بناء على احتياج فريقك، سواء كانت نماذج الذكاء الاصطناعي العامة أو أدوات متخصصة حسب القطاع. إذا كان لديكم أدوات معينة تريدون التدريب عليها، نبني الورشة حولها." }
      },
      {
        "@type": "Question",
        "name": "هل يحصل المشاركون على شهادة حضور؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. كل مشارك يحصل على شهادة حضور من Aegis AI، إضافة إلى حزمة مواد تشمل الأدلة والقوالب والموارد التي يمكن استخدامها فوراً بعد الورشة." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="تدريب الفرق على الذكاء الاصطناعي للشركات في الإمارات | Aegis AI"
  description="Aegis AI، وكالة الذكاء الاصطناعي في دبي، تُدرّب فرق العمل في الإمارات على استخدام الذكاء الاصطناعي بثقة. ورش عمل عملية بالعربي والإنجليزي، مُصمَّمة لقطاعك وأدواتك الفعلية."
  canonicalPath="/ar/services/ai-training"
  enPath="/services/ai-training"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>تدريب على الذكاء الاصطناعي</div>
    <div class="badge badge-amber" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">school</span>
      ورش عملية
    </div>
    <h1>تدريب فريقك على الذكاء الاصطناعي<br><span class="gradient-text">بالعربي والإنجليزي</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      لا محاضرات نظرية. ورش عمل عملية يخرج منها فريقك قادراً على استخدام الذكاء الاصطناعي في عمله اليومي من اليوم الأول، بالعربية أو الإنجليزية، مُصمَّمة لقطاعك.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_ai-training_hero" class="btn-primary">احجز ورشة لفريقك</button>
      <a href="/ar/services" class="btn-outline">جميع الخدمات</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=1400&q=80&auto=format&fit=crop" alt="ورشة تدريب على الذكاء الاصطناعي لفرق العمل" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">-٤٠٪</div>
        <div class="stat-label">وقت المهام الروتينية</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">٣ أشهر</div>
        <div class="stat-label">لرؤية نتائج قابلة للقياس</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان الاسترداد</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">عربي + إنجليزي</div>
        <div class="stat-label">الورش بكلتا اللغتين</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What We Build -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>برامج التدريب التي نُقدّمها</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">هذه البرامج الأكثر طلباً، لا الحد الأقصى لما نُقدّمه. كل ورشة مُصمَّمة لمستوى ومجال مختلف. إذا كانت احتياجاتك مختلفة، يمكننا تصميم ورشة خصيصاً لك.</p>
    </div>
    <div class="feature-grid">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">lightbulb</span>
        <h3>أسس الذكاء الاصطناعي</h3>
        <p>ورشة تمهيدية لمن يبدأ من الصفر: ما هو الذكاء الاصطناعي، كيف يعمل، وما يمكن توقّعه منه واقعياً.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">chat</span>
        <h3>نماذج الذكاء الاصطناعي للأعمال</h3>
        <p>كيف تُوظّف نماذج الذكاء الاصطناعي في مهامك اليومية: كتابة، تحليل، تلخيص، إعداد عروض، والمزيد.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">category</span>
        <h3>تدريب قطاعي متخصص</h3>
        <p>ورشة مُصمَّمة لقطاعك: عقارات، ضيافة، رعاية صحية، تجزئة، خدمات مالية. بأمثلة وحالات حقيقية من مجالك.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">terminal</span>
        <h3>هندسة الأوامر</h3>
        <p>كيف تكتب أوامر تُعطيك نتائج دقيقة وقابلة للاستخدام الفوري. تقنيات وأنماط عملية لكل قسم.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">supervisor_account</span>
        <h3>الذكاء الاصطناعي للمديرين</h3>
        <p>كيف تُقيّم فرص الذكاء الاصطناعي في فريقك، تُحدّد ما يُؤتمَت، وتقيس العائد على الاستثمار.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">tune</span>
        <h3>تدريب على أدواتك الخاصة</h3>
        <p>إذا طوّرنا لك نظاماً أو اشتريت أداة معينة، نُدرّب فريقك عليها حتى يستخدمها بكفاءة كاملة.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Results Card -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:860px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2>نتيجة حقيقية من الإمارات</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=1200&q=80&auto=format&fit=crop" alt="جلسة تدريب عملية على الذكاء الاصطناعي" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card results-card">
      <div class="results-badge">
        <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">business</span>
        شركة خدمات، ٥٠ موظف
      </div>
      <div class="results-row">
        <div class="results-col">
          <div class="results-label">المشكلة</div>
          <p>الفريق يسمع عن الذكاء الاصطناعي كثيراً لكنه لا يعرف كيف يُطبّقه في عمله الفعلي. محاولات فردية بلا توجيه تُنتج نتائج متذبذبة وغير موثوقة.</p>
        </div>
        <div class="results-divider" aria-hidden="true">←</div>
        <div class="results-col">
          <div class="results-label">الحل</div>
          <p>ورشة عمل مخصصة لمدة يومين لـ ٥٠ موظفاً، بالعربية والإنجليزية، مع تطبيق عملي على مهامهم الفعلية وقوالب جاهزة للاستخدام الفوري.</p>
        </div>
      </div>
      <div class="results-metrics">
        <div class="metric">
          <div class="metric-number">-٤٠٪</div>
          <div class="metric-label">وقت المهام الروتينية خلال ٣ أشهر</div>
        </div>
        <div class="metric">
          <div class="metric-number">٥٠ موظف</div>
          <div class="metric-label">يستخدمون الذكاء الاصطناعي يومياً</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>كيف يسير العمل</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>تشخيص احتياجات الفريق</h3>
          <p>نفهم قطاعك، مهام فريقك اليومية، ومستوى معرفتهم الحالية بالذكاء الاصطناعي. نُصمّم الورشة بناء على هذا، لا نستخدم قوالب جاهزة.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>ورشة تطبيقية</h3>
          <p>يوم أو يومان من التدريب العملي المكثّف. المشاركون يُطبّقون على أمثلة من عملهم الفعلي، ويخرجون بقوالب يستخدمونها من اليوم التالي مباشرة.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٣</div>
        <div class="step-content">
          <h3>متابعة وقياس الأثر</h3>
          <p>بعد ٤ أسابيع نتابع مع الفريق، نُجيب على أسئلتهم، ونُعدّل إذا لزم. بعد ٣ أشهر نُقيس التحسن الفعلي في الإنتاجية.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_ai-training_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أسئلة شائعة</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل التدريب مناسب لموظفين غير تقنيين؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، وهذا بالضبط ما نتخصص فيه. ورشنا مُصمَّمة للمحاسبين، المسوّقين، الموارد البشرية، المبيعات. أي شخص يريد استخدام الذكاء الاصطناعي في عمله اليومي بلا خلفية تقنية.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم عدد المشاركين المثالي في كل ورشة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نُفضّل ٨-١٦ مشاركاً للحصول على تفاعل عالي وتطبيق عملي مناسب. يمكننا تشغيل جلسات أكبر للمجموعات الكبيرة، لكنها تكون أقل تفاعلية.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل التدريب بالعربية أم الإنجليزية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">كلاهما. نُقدّم الورشة بالعربية أو الإنجليزية حسب تفضيل فريقك، أو بشكل مزدوج إذا كانت المجموعة متنوعة. المواد متوفرة بالغتين.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الأدوات التي يتعلم عليها المشاركون؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نُخصّص الأدوات بناء على احتياج فريقك، سواء كانت نماذج الذكاء الاصطناعي العامة أو أدوات متخصصة حسب القطاع. إذا كان لديكم أدوات معينة تريدون التدريب عليها، نبني الورشة حولها.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يحصل المشاركون على شهادة حضور؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. كل مشارك يحصل على شهادة حضور من Aegis AI، إضافة إلى حزمة مواد تشمل الأدلة والقوالب والموارد التي يمكن استخدامها فوراً بعد الورشة.</div>
      </div>

    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">فريقك يستحق أن يعمل بذكاء أكبر</h2>
    <p style="opacity:0.85;max-width:500px;margin:0 auto 2rem;line-height:1.8;">احجز ورشة لفريقك، نُصمّمها بناء على عملكم الفعلي، ويخرج الجميع بأدوات يطبّقونها من اليوم التالي.</p>
    <button onclick="openModal(this)" data-source="ar_ai-training_cta" class="btn-primary">احجز ورشة لفريقك</button>
  </div>
</section>

</ArBaseLayout>

<style>
  .stats-strip {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .stat-item { min-width: 120px; }
  .stat-number { font-size: 2rem; font-weight: 800; color: #00253b; line-height: 1.1; }
  .stat-label { font-size: 0.8125rem; color: #5f6b7a; margin-top: 0.375rem; }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .feature-card { display: flex; flex-direction: column; gap: 0.75rem; }
