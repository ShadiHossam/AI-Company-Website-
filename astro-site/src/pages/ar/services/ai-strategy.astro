---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "استشارات استراتيجية للذكاء الاصطناعي في دبي والإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/services/ai-strategy",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "استراتيجية الذكاء الاصطناعي", "item": "https://aegisai.ae/ar/services/ai-strategy" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "استشارات استراتيجية للذكاء الاصطناعي",
    "description": "وضع استراتيجية الذكاء الاصطناعي لشركتك في الإمارات: تحديد الفرص، حساب العائد على الاستثمار، وخطة تنفيذ لـ 12 شهراً.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الذي يُخرج به المدير من جلسة الاستراتيجية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "تقرير واضح يتضمن: قائمة بأعلى فرص الذكاء الاصطناعي في شركتك، تقدير العائد المتوقع لكل فرصة، خارطة طريق تنفيذية لـ 12 شهراً، وتوصيات الأدوات والموردين المناسبين. كل شيء قابل للتنفيذ الفوري." }
      },
      {
        "@type": "Question",
        "name": "هل نحتاج استشارة استراتيجية قبل بدء أي مشروع ذكاء اصطناعي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "ليس شرطاً، لكنه يوفّر عليك وقتاً ومالاً كبيرين. كثير من الشركات تبدأ بأداة أو مشروع دون خطة واضحة، ثم تكتشف لاحقاً أن الفرصة الحقيقية كانت في مكان آخر. الاستراتيجية تُرشّد الاستثمار من البداية." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق إعداد الاستراتيجية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعمل على مرحلتين: التشخيص وجمع المعلومات من فريقك، ثم التحليل وإعداد الوثيقة النهائية. بعدها نعقد جلسة عرض مع القيادة لمناقشة النتائج والتوصيات." }
      },
      {
        "@type": "Question",
        "name": "هل تُساعدوننا في تنفيذ الاستراتيجية بعد إعدادها؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. يمكنك الاختيار: تأخذ الاستراتيجية وتُنفّذها بنفسك أو مع فريقك، أو تستمر معنا لتنفيذ المبادرات المحددة. كثير من عملاءنا يختارون الخيارين بحسب كل مشروع." }
      },
      {
        "@type": "Question",
        "name": "هل تناسب الاستشارة الشركات الصغيرة والمتوسطة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، وكثير من أفضل نتائجنا كانت مع شركات صغيرة ومتوسطة. الذكاء الاصطناعي لا يحتاج ميزانية ضخمة، بل يحتاج تحديداً دقيقاً للمشكلة الصحيحة. وهذا بالضبط ما تُحقّقه الاستشارة الاستراتيجية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="استشارات استراتيجية للذكاء الاصطناعي للشركات في الإمارات | Aegis AI"
  description="Aegis AI تضع استراتيجية الذكاء الاصطناعي لشركتك في الإمارات: تحديد الفرص، حساب العائد على الاستثمار، وخطة تنفيذ لـ 12 شهراً. ضمان استرداد 100%."
  canonicalPath="/ar/services/ai-strategy"
  enPath="/services/ai-strategy"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>استراتيجية الذكاء الاصطناعي</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">bar_chart</span>
      استشارات استراتيجية
    </div>
    <h1>استراتيجية الذكاء الاصطناعي لشركتك<br><span class="gradient-text">خارطة طريق واضحة</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      قبل أن تستثمر درهماً في الذكاء الاصطناعي، اعرف أين يكمن أعلى عائد في شركتك. نُحدّد الفرص، نحسب العائد، ونضع خطة تنفيذ لـ 12 شهراً تبدأ من أول شهر.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_ai-strategy_hero" class="btn-primary">احجز جلسة استراتيجية</button>
      <a href="/ar/services" class="btn-outline">جميع الخدمات</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1400&q=80&auto=format&fit=crop" alt="جلسة استشارية لاستراتيجية الذكاء الاصطناعي مع قادة الأعمال" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 35%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">وفر ملموس</div>
        <div class="stat-label">متوسط الوفر السنوي المُكتشَف لكل شركة</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">٣ فرص</div>
        <div class="stat-label">متوسط ما نُحدّده لكل شركة</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٢ شهراً</div>
        <div class="stat-label">خارطة طريق تنفيذية</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان الاسترداد</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What We Build -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>ما تشمله الاستشارة الاستراتيجية</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">وثيقة استراتيجية شاملة تُمكّن قيادتك من اتخاذ قرارات الذكاء الاصطناعي بثقة.</p>
    </div>
    <div class="feature-grid">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">search_insights</span>
        <h3>تدقيق فرص الذكاء الاصطناعي</h3>
        <p>مراجعة شاملة لعمليات شركتك لاكتشاف أين يُحقّق الذكاء الاصطناعي أعلى تأثير وأسرع عائد.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">calculate</span>
        <h3>حساب العائد على الاستثمار</h3>
        <p>أرقام واضحة لكل فرصة: التكلفة المتوقعة للتنفيذ، الوفر أو العائد المتوقع، وفترة استرداد الاستثمار.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">map</span>
        <h3>خارطة طريق ١٢ شهراً</h3>
        <p>خطة تنفيذية بأولويات واضحة: ما يُنفَّذ في الشهر الأول، وما يأتي لاحقاً، مرتّبة حسب التأثير والجدوى.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">storefront</span>
        <h3>اختيار الموردين والأدوات</h3>
        <p>توصيات موضوعية بالأدوات والموردين الأنسب لاحتياجاتك، بناء على تحليل السوق لا العلاقات التجارية.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">group</span>
        <h3>تقييم جاهزية الفريق</h3>
        <p>تقييم قدرات فريقك الحالية وما يحتاجه من تدريب أو توظيف لتنفيذ الاستراتيجية بنجاح.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">priority_high</span>
        <h3>تحديد أولويات التنفيذ</h3>
        <p>ترتيب المبادرات حسب معادلة واضحة: تأثير عالٍ + تعقيد منخفض = أولوية قصوى. لا تخمين ولا هدر.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Results Card -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:860px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2>نتيجة حقيقية من الإمارات</h2>
    </div>
    <div class="card results-card">
      <div class="results-badge">
        <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">local_shipping</span>
        شركة لوجستيات، الإمارات
      </div>
      <div class="results-row">
        <div class="results-col">
          <div class="results-label">المشكلة</div>
          <p>الإدارة تعرف أن الذكاء الاصطناعي يمكن أن يُحسّن العمليات، لكن لا توجد صورة واضحة: من أين نبدأ، كم يكلف، وما العائد الفعلي المتوقع؟</p>
        </div>
        <div class="results-divider" aria-hidden="true">←</div>
        <div class="results-col">
          <div class="results-label">الحل</div>
          <p>جلسة استراتيجية شاملة أسفرت عن تحديد ٣ فرص أتمتة واضحة بأرقام دقيقة لكل منها وخطة تنفيذ انطلقت فيها الشركة فوراً.</p>
        </div>
      </div>
      <div class="results-metrics">
        <div class="metric">
          <div class="metric-number">٣ فرص</div>
          <div class="metric-label">أتمتة مُحددة بأرقام دقيقة</div>
        </div>
        <div class="metric">
          <div class="metric-number">خطة واضحة</div>
          <div class="metric-label">من الاستشارة إلى التنفيذ</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>كيف يسير العمل</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>تشخيص وجمع معلومات</h3>
          <p>نجري مقابلات مع القيادة والفرق المعنية، ونستعرض العمليات الحالية والأنظمة المستخدمة. هذا الأسبوع يبني الفهم العميق الذي تنبثق منه التوصيات.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>تحليل وبناء الاستراتيجية</h3>
          <p>نُحلّل المعلومات، نُقيّم الفرص، نحسب العوائد، ونُعدّ وثيقة الاستراتيجية الكاملة مع خارطة الطريق التنفيذية.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٣</div>
        <div class="step-content">
          <h3>عرض النتائج والقرار</h3>
          <p>نعرض الاستراتيجية على القيادة، نُجيب على كل الأسئلة، ونُساعد في تحديد أولى المبادرات للتنفيذ. تخرج الجلسة بقرارات واضحة وخطوات محددة.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_ai-strategy_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أسئلة شائعة</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الذي يُخرج به المدير من جلسة الاستراتيجية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">تقرير واضح يتضمن: قائمة بأعلى فرص الذكاء الاصطناعي في شركتك، تقدير العائد المتوقع لكل فرصة، خارطة طريق تنفيذية لـ ١٢ شهراً، وتوصيات الأدوات والموردين المناسبين. كل شيء قابل للتنفيذ الفوري.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل نحتاج استشارة استراتيجية قبل بدء أي مشروع ذكاء اصطناعي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">ليس شرطاً، لكنه يوفّر عليك وقتاً ومالاً كبيرين. كثير من الشركات تبدأ بأداة أو مشروع دون خطة واضحة، ثم تكتشف لاحقاً أن الفرصة الحقيقية كانت في مكان آخر. الاستراتيجية تُرشّد الاستثمار من البداية.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق إعداد الاستراتيجية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعمل على مرحلتين: التشخيص وجمع المعلومات من فريقك، ثم التحليل وإعداد الوثيقة النهائية. بعدها نعقد جلسة عرض مع القيادة لمناقشة النتائج والتوصيات.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل تُساعدوننا في تنفيذ الاستراتيجية بعد إعدادها؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. يمكنك الاختيار: تأخذ الاستراتيجية وتُنفّذها بنفسك أو مع فريقك، أو تستمر معنا لتنفيذ المبادرات المحددة. كثير من عملاءنا يختارون الخيارين بحسب كل مشروع.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل تناسب الاستشارة الشركات الصغيرة والمتوسطة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، وكثير من أفضل نتائجنا كانت مع شركات صغيرة ومتوسطة. الذكاء الاصطناعي لا يحتاج ميزانية ضخمة، بل يحتاج تحديداً دقيقاً للمشكلة الصحيحة. وهذا بالضبط ما تُحقّقه الاستشارة الاستراتيجية.</div>
      </div>

    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">ابدأ باستراتيجية، لا بتجربة عشوائية</h2>
    <p style="opacity:0.85;max-width:500px;margin:0 auto 2rem;line-height:1.8;">احجز جلسة تشخيص مجانية. نُحدّد معاً أين يكمن أعلى عائد للذكاء الاصطناعي في شركتك.</p>
    <button onclick="openModal(this)" data-source="ar_ai-strategy_cta" class="btn-primary">احجز جلسة استراتيجية</button>
  </div>
</section>

</ArBaseLayout>

<style>
  .stats-strip {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .stat-item { min-width: 120px; }
  .stat-number { font-size: 2rem; font-weight: 800; color: #00253b; line-height: 1.1; }
  .stat-label { font-size: 0.8125rem; color: #5f6b7a; margin-top: 0.375rem; }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .feature-card { display: flex; flex-direction: column; gap: 0.75rem; }
