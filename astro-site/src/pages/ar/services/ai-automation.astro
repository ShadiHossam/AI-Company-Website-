---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "أتمتة الأعمال بالذكاء الاصطناعي في الإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/services/ai-automation",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "أتمتة الأعمال بالذكاء الاصطناعي", "item": "https://aegisai.ae/ar/services/ai-automation" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "أتمتة الأعمال بالذكاء الاصطناعي",
    "description": "تحويل العمليات اليدوية المتكررة في الشركات إلى أتمتة ذكية: تقارير، مراسلات، تحديث بيانات، ومتابعة عملاء.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما العمليات التي يمكن أتمتتها في شركتي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "أي عملية متكررة يؤديها موظفك بنفس الطريقة كل مرة هي مرشحة للأتمتة. التقارير الدورية، متابعة العملاء، تحديث البيانات بين أنظمة مختلفة، معالجة الفواتير، إرسال إشعارات، كلها أمثلة شائعة. نحدد الأفضل معاً في جلسة التشخيص." }
      },
      {
        "@type": "Question",
        "name": "هل الأتمتة ستُلغي وظائف موظفينا؟",
        "acceptedAnswer": { "@type": "Answer", "text": "لا. الأتمتة تُحرّر فريقك من المهام المتكررة لكي يركّزوا على ما يحتاج حكماً وإبداعاً وعلاقات بشرية. معظم عملاءنا لا يُقلّصون فريقهم، بل يُوظّفون طاقته في مكان أعلى قيمة." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء أتمتة وإطلاقها؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبدأ دائماً بأعلى نقطة تأثير لترى نتيجة سريعة. الجدول الزمني يعتمد على تعقيد العمليات وعددها، ونحدده معك بدقة في جلسة التشخيص." }
      },
      {
        "@type": "Question",
        "name": "ماذا لو تغيّرت عمليات الشركة لاحقاً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني الأتمتة بمرونة وقابلية للتعديل. تغيير خطوة أو إضافة شرط جديد لا يحتاج إعادة بناء من الصفر، وتوفر لك وثائق واضحة لإدارة التعديلات البسيطة بنفسك." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن الأتمتة مع الأنظمة التي نستخدمها حالياً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نعمل مع معظم الأنظمة الشائعة. حتى الأنظمة القديمة التي لا تحتوي على API يمكن في الغالب دمجها بطرق بديلة." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="خدمات أتمتة الأعمال بالذكاء الاصطناعي للشركات في الإمارات | Aegis AI"
  description="Aegis AI هي وكالة الذكاء الاصطناعي في دبي التي تحوّل العمليات اليدوية المتكررة في شركتك إلى أتمتة ذكية: تقارير، مراسلات، تحديث بيانات، ومتابعة عملاء. لشركات المبيعات والعمليات والإدارة في الإمارات."
  canonicalPath="/ar/services/ai-automation"
  enPath="/services/ai-automation"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>أتمتة الأعمال بالذكاء الاصطناعي</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">autorenew</span>
      أتمتة ذكية
    </div>
    <h1>أتمتة الأعمال بالذكاء الاصطناعي<br><span class="gradient-text">وفّر ساعات يومياً</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:620px;margin:1.5rem auto 2.5rem;line-height:1.8;">
      كل مهمة متكررة يؤديها موظفك يدوياً هي وقت ومال يُهدَران. نُحوّل هذه العمليات إلى أتمتة ذكية، تعمل وحدها، بدقة أعلى، وبلا تعب.
    </p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_ai-automation_hero" class="btn-primary">احجز استشارة مجانية</button>
      <a href="/ar/services" class="btn-outline">جميع الخدمات</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1400&q=80&auto=format&fit=crop" alt="أتمتة سير العمل بالذكاء الاصطناعي وتحسين العمليات" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 30%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.25),rgba(0,37,59,0.40));"></div>
</div>

<!-- 2. Stats Strip -->
<section style="background:#f8fafc;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;padding:2.5rem 0;">
  <div class="container">
    <div class="stats-strip">
      <div class="stat-item">
        <div class="stat-number">٣+ ساعات</div>
        <div class="stat-label">متوسط الوفر اليومي</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">-٣٠٪</div>
        <div class="stat-label">تكاليف تشغيلية</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">١٠٠٪</div>
        <div class="stat-label">ضمان الاسترداد</div>
      </div>
      <div class="stat-item">
        <div class="stat-number">سريع</div>
        <div class="stat-label">وقت التنفيذ حسب المشروع</div>
      </div>
    </div>
  </div>
</section>

<!-- 3. What We Build -->
<section class="section">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>ما نؤتمته في شركتك</h2>
      <p style="color:#42474e;max-width:560px;margin:1rem auto 0;line-height:1.8;">بصفتنا وكالة الذكاء الاصطناعي في دبي، نُغطي كل عملية متكررة في شركتك: من التقارير إلى متابعة العملاء.</p>
    </div>
    <div class="feature-grid">
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">summarize</span>
        <h3>أتمتة التقارير</h3>
        <p>تقارير المبيعات والأداء والمخزون تُنشأ وتُرسل تلقائياً في الوقت المحدد، دون أن يلمسها أحد.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">forward_to_inbox</span>
        <h3>أتمتة المراسلات</h3>
        <p>ردود ومتابعات ورسائل تذكير مُرسَلة بالتوقيت الصحيح ولكل عميل بحسب وضعه، دون تدخل يدوي.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">sync_alt</span>
        <h3>مزامنة البيانات</h3>
        <p>بيانات شركتك متزامنة تلقائياً بين CRM وERP وجداول البيانات، لا إدخال مزدوج ولا أخطاء يدوية.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">person_search</span>
        <h3>متابعة العملاء</h3>
        <p>كل عميل محتمل يحصل على متابعة في الوقت المناسب تلقائياً، لا أحد يسقط من الشبكة.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">receipt_long</span>
        <h3>معالجة الفواتير</h3>
        <p>استلام الفواتير، مطابقتها، وتحديثها في النظام تلقائياً. توفير ساعات من العمل الورقي أسبوعياً.</p>
      </div>
      <div class="card feature-card">
        <span class="material-symbols-outlined feature-icon" style="direction:ltr;" aria-hidden="true">inventory_2</span>
        <h3>تحديث المخزون</h3>
        <p>مستويات المخزون تُحدَّث في الوقت الحقيقي، وتنبيهات إعادة الطلب تُرسَل تلقائياً عند الوصول للحد الأدنى.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Results Card -->
<section class="section" style="background:#f8fafc;">
  <div class="container" style="max-width:860px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2>نتيجة حقيقية من الإمارات</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=1200&q=80&auto=format&fit=crop" alt="فريق عمل أثناء تشغيل الأتمتة الذكية" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card results-card">
      <div class="results-badge">
        <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">store</span>
        سلسلة متاجر تجزئة، ١٢ فرع
      </div>
      <div class="results-row">
        <div class="results-col">
          <div class="results-label">المشكلة</div>
          <p>تحديث مخزون ١٢ فرع يدوياً عبر جداول البيانات. موظف كامل يقضي ٣ ساعات يومياً في الإدخال، مع أخطاء متكررة تؤدي لإفراط أو نقص في المخزون.</p>
        </div>
        <div class="results-divider" aria-hidden="true">←</div>
        <div class="results-col">
          <div class="results-label">الحل</div>
          <p>لوحة تحكم في الوقت الحقيقي مع أتمتة كاملة لتحديث المخزون عبر جميع الفروع، وتنبيهات تلقائية لإعادة الطلب قبل النفاد.</p>
        </div>
      </div>
      <div class="results-metrics">
        <div class="metric">
          <div class="metric-number">٣ ساعات</div>
          <div class="metric-label">وُفّرت يومياً من العمل اليدوي</div>
        </div>
        <div class="metric">
          <div class="metric-number">-٣٠٪</div>
          <div class="metric-label">تكاليف الإفراط في المخزون</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>كيف يسير العمل</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="step-number">١</div>
        <div class="step-content">
          <h3>رسم خريطة العمليات</h3>
          <p>نجلس مع فريقك لتوثيق العمليات المتكررة وحساب الوقت المهدر في كل منها. نُرتّب الأولويات بناء على العائد الأعلى والتعقيد الأدنى.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٢</div>
        <div class="step-content">
          <h3>بناء وتكامل</h3>
          <p>نبني الأتمتة ونربطها بأنظمتك الحالية. نبدأ بالعملية الأعلى تأثيراً لتشعر بالنتيجة سريعاً، ثم نوسّع تدريجياً.</p>
        </div>
      </div>
      <div class="process-step">
        <div class="step-number">٣</div>
        <div class="step-content">
          <h3>تشغيل وقياس</h3>
          <p>الأتمتة تعمل، أنت تتابع النتائج. نُوفّر لوحة بيانات تُظهر كم ساعة وُفّرت وكم خطأ تجنّبته، حتى تُقيس العائد بالضبط.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_ai-automation_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2>أسئلة شائعة</h2>
    </div>
    <div class="faq-list">

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما العمليات التي يمكن أتمتتها في شركتي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">أي عملية متكررة يؤديها موظفك بنفس الطريقة كل مرة هي مرشحة للأتمتة. التقارير الدورية، متابعة العملاء، تحديث البيانات بين أنظمة مختلفة، معالجة الفواتير، إرسال إشعارات، كلها أمثلة شائعة. نحدد الأفضل معاً في جلسة التشخيص.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل الأتمتة ستُلغي وظائف موظفينا؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">لا. الأتمتة تُحرّر فريقك من المهام المتكررة لكي يركّزوا على ما يحتاج حكماً وإبداعاً وعلاقات بشرية. معظم عملاءنا لا يُقلّصون فريقهم، بل يُوظّفون طاقته في مكان أعلى قيمة.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق بناء أتمتة وإطلاقها؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نبدأ دائماً بأعلى نقطة تأثير لترى نتيجة سريعة. الجدول الزمني يعتمد على تعقيد العمليات وعددها، ونحدده معك بدقة في جلسة التشخيص.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا لو تغيّرت عمليات الشركة لاحقاً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نبني الأتمتة بمرونة وقابلية للتعديل. تغيير خطوة أو إضافة شرط جديد لا يحتاج إعادة بناء من الصفر، وتوفر لك وثائق واضحة لإدارة التعديلات البسيطة بنفسك.</div>
      </div>

      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن الأتمتة مع الأنظمة التي نستخدمها حالياً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. نعمل مع معظم الأنظمة الشائعة. حتى الأنظمة القديمة التي لا تحتوي على API يمكن في الغالب دمجها بطرق بديلة.</div>
      </div>

    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">ابدأ بتحديد أول ساعة يمكن توفيرها</h2>
    <p style="opacity:0.85;max-width:500px;margin:0 auto 2rem;line-height:1.8;">احجز جلسة تشخيص مجانية ونخرج منها بقائمة واضحة لأعلى ٣ عمليات تستحق الأتمتة في شركتك.</p>
    <button onclick="openModal(this)" data-source="ar_ai-automation_cta" class="btn-primary">احجز جلستك المجانية</button>
  </div>
</section>

</ArBaseLayout>

<style>
  .stats-strip {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .stat-item { min-width: 120px; }
  .stat-number { font-size: 2rem; font-weight: 800; color: #00253b; line-height: 1.1; }
  .stat-label { font-size: 0.8125rem; color: #5f6b7a; margin-top: 0.375rem; }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .feature-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .feature-icon { font-size: 2rem; color: #006875; }
  .feature-card h3 { font-size: 1rem; font-weight: 700; color: #00253b; margin: 0; }
  .feature-card p { font-size: 0.875rem; color: #42474e; line-height: 1.7; margin: 0; }

