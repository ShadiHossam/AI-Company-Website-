---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "تطوير نماذج ذكاء اصطناعي مخصصة لشركتك | Aegis AI، الإمارات",
    "url": "https://aegisai.ae/ar/services/custom-gpt-development",
    "inLanguage": "ar",
    "description": "Aegis AI تطور نماذج ذكاء اصطناعي مخصصة لشركتك في الإمارات، مُدرَّبة على بياناتك، مدمجة في أنظمتك، تجيب بالعربي والإنجليزي.",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "نماذج ذكاء اصطناعي مخصصة", "item": "https://aegisai.ae/ar/services/custom-gpt-development" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "تطوير نماذج ذكاء اصطناعي مخصصة",
    "url": "https://aegisai.ae/ar/services/custom-gpt-development",
    "inLanguage": "ar",
    "description": "نطور نماذج ذكاء اصطناعي مخصصة مُدرَّبة على بيانات شركتك، تجيب بالعربي والإنجليزي وتُدمج في أنظمتك الحالية.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "serviceType": "Custom AI Model Development"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الفرق بين نموذج ذكاء اصطناعي مخصص ونموذج عام؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نماذج الذكاء الاصطناعي العامة مُدرَّبة على بيانات الإنترنت. لا تعرف منتجاتك ولا أسعارك ولا سياساتك. النموذج المخصص الذي نبنيه مُدرَّب على بيانات شركتك تحديداً، فيجيب بدقة عالية وبلغة شركتك." }
      },
      {
        "@type": "Question",
        "name": "هل يدعم النموذج اللهجات العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نبني النماذج بحيث تفهم العربية الفصحى واللهجة الإماراتية، وتجيب بالمستوى اللغوي المناسب لعملاء شركتك." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق تطوير نموذج ذكاء اصطناعي مخصص؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يعتمد على نهج التدريب وحجم البيانات. النماذج المبنية على RAG أسرع تسليماً من النماذج المُضبَّطة (fine-tuned) التي تتطلب تدريباً كاملاً. نحدد الجدول الزمني بعد تحليل متطلباتك." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن دمج النموذج مع واتساب أو الموقع الإلكتروني؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نبني النماذج مع واجهات API قياسية تتيح دمجها مع منصات المراسلة وموقعك الإلكتروني وتطبيقك والأنظمة الداخلية، على أي منصة تشاء." }
      },
      {
        "@type": "Question",
        "name": "ماذا يحدث عندما تتغير بيانات شركتنا؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني آلية تحديث منتظمة بحيث يتلقى النموذج بيانات شركتك الجديدة دورياً، سواء منتجات جديدة أو سياسات محدثة أو أسئلة إضافية، دون الحاجة لإعادة بناء كامل." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="تطوير مساعدات ذكاء اصطناعي مخصصة للشركات في الإمارات | Aegis AI"
  description="Aegis AI تطور نماذج ذكاء اصطناعي مخصصة لشركتك في الإمارات، مُدرَّبة على بياناتك، مدمجة في أنظمتك، تجيب بالعربي والإنجليزي. ضمان استرداد 100%."
  canonicalPath="/ar/services/custom-gpt-development"
  enPath="/services/custom-gpt-development"
  ldJson={ldJson}
>

<!-- 1. HERO -->
<header class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>نماذج ذكاء اصطناعي مخصصة</div>
    <div class="badge badge-amber" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">psychology</span>
      نماذج ذكاء اصطناعي مخصصة
    </div>
    <h1>نماذج ذكاء اصطناعي مُضبّطة على بيانات شركتك، <span class="gradient-text">لا على بيانات الإنترنت</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.9;">
      نماذج الذكاء الاصطناعي العامة لا تعرف منتجاتك ولا سياساتك. نبني نماذج مُدرَّبة على بيانات شركتك بالتحديد، تجيب بدقة عالية بالعربي والإنجليزي، وتُدمج أينما تريد.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_custom_gpt_development_hero" class="btn-primary">ابن نموذجاً خاصاً بشركتك</button>
      <a href="#what-we-build" class="btn-outline">اكتشف ما نبنيه ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1516110833967-0b5716ca1387?w=1400&q=80&auto=format&fit=crop" alt="تطوير GPT مخصص ومساعدات ذكاء اصطناعي" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 30%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- 2. STATS -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-val">بياناتك</div>
        <div class="stat-desc">نموذج مُدرَّب على منتجاتك وسياساتك تحديداً</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">بطلاقة</div>
        <div class="stat-desc">يجيب بالعربي بمستوى احترافي كامل</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">دقة أعلى</div>
        <div class="stat-desc">من نماذج الذكاء الاصطناعي العامة على أسئلة شركتك</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">١٠٠٪</div>
        <div class="stat-desc">ضمان استرداد كامل إذا لم تكن راضياً</div>
      </div>
    </div>
  </div>
</div>

<!-- 3. WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="builds-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">ما الذي نبنيه</div>
      <h2 id="builds-heading">نماذج الذكاء الاصطناعي المخصصة التي نبنيها</h2>
      <p style="color:#42474e;font-size:1rem;max-width:560px;margin:0.75rem auto 0;line-height:1.8;">أمثلة شائعة، لا قائمة شاملة. كل نموذج مُدرَّب على بيانات شركتك ومُدمج في أنظمتك. إذا كانت فكرتك مختلفة، نريد سماعها.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">smart_toy</span>
        </div>
        <h3>بوت محادثة للعملاء</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نموذج مُدرَّب على منتجاتك وأسئلتك الشائعة وأسعارك، يجيب عملاءك بدقة على مدار الساعة بالعربي والإنجليزي، ويُحرّر فريقك للتركيز على الاستفسارات التي تحتاج لمس بشري حقيقي.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">menu_book</span>
        </div>
        <h3>نموذج قاعدة المعرفة الداخلية</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نموذج مُدرَّب على سياساتك وإجراءاتك التشغيلية وأدلة الموظفين, يجيب الفريق الداخلي بدقة عالية دون الحاجة للبحث يدوياً في الوثائق.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">handshake</span>
        </div>
        <h3>مساعد المبيعات الذكي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يُعدّ ردوداً على اعتراضات العملاء، يقترح عروضاً مناسبة لكل فرصة، ويصيغ مقترحات مخصصة. كمدير مبيعات خبير متاح على مدار الساعة.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">translate</span>
        </div>
        <h3>نماذج ذكاء اصطناعي أولى بالعربية</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نماذج مُصمَّمة خصيصاً لسوق الإمارات، تفهم اللهجة الإماراتية، وتجيب بالمستوى اللغوي المناسب لجمهور شركتك.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">account_tree</span>
        </div>
        <h3>خط أنابيب متعدد النماذج</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">نبني خطوط عمل تجمع نماذج اللغة مع نماذج الرؤية لتحليل الصور ونماذج الصوت. حل متكامل يعالج أنواع المحتوى المختلفة في سير عمل واحد.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. RESULTS CARD -->
<section class="section" style="background:#e7eeff;padding:4rem 0;" aria-labelledby="results-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">نتيجة حقيقية</div>
      <h2 id="results-heading">فريق مبيعات يضيع وقته في الرد على نفس أسئلة المراسلة</h2>
    </div>
    <div class="card" style="max-width:800px;margin:0 auto;">
      <div class="results-grid">
        <div class="result-col">
          <div class="result-label">المشكلة</div>
          <p style="color:#42474e;line-height:1.8;">مطور عقاري في دبي: فريق المبيعات يُمضي ساعات يومياً في الإجابة على نفس الأسئلة عبر منصات المراسلة، الأسعار والموقع والمساحات وشروط الدفع. أسئلة متكررة تسرق وقت أصحاب أعلى راتب في الفريق.</p>
        </div>
        <div class="result-col">
          <div class="result-label">الحل</div>
          <p style="color:#42474e;line-height:1.8;">بنينا نموذج ذكاء اصطناعي مُدرَّب على أكثر من ٥٠٠ سؤال شائع لمشاريع العميل، مع تفاصيل كل وحدة وخطط الدفع والمواعيد. النموذج مُدمج مع منصة المراسلة ويرد بالعربي والإنجليزي.</p>
        </div>
      </div>
      <div class="metrics-row">
        <div class="metric-item">
          <div class="metric-val">٧٨٪</div>
          <div class="metric-desc">من استفسارات واتساب تُعالَج تلقائياً</div>
        </div>
        <div class="metric-item">
          <div class="metric-val">فريق المبيعات</div>
          <div class="metric-desc">تفرّغ للفرص العالية القيمة فقط</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. HOW IT WORKS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">كيف نعمل</div>
      <h2 id="process-heading">ثلاث خطوات لبناء نموذج ذكاء اصطناعي مخصص</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="process-num">١</div>
        <h3>تجميع وتنظيف بيانات شركتك</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجمّع منتجاتك وأسئلتك الشائعة وسياساتك ومحادثاتك السابقة، ننظفها ونهيئها لعملية التدريب بصورة تضمن دقة الإجابات وملاءمتها لسياق شركتك.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٢</div>
        <h3>ضبط وتدريب النموذج</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نختار أفضل نهج (RAG أو fine-tuning أو مزيج منهما) ونُدرّب النموذج ونختبر دقته على مئات الأسئلة الحقيقية من عملياتك قبل أي إطلاق.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٣</div>
        <h3>دمج واختبار ونشر</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">ندمج النموذج في منصتك المفضلة، سواء منصات المراسلة أو موقعك أو تطبيقك أو أنظمتك الداخلية، نختبر في بيئة حقيقية ثم ننشر مع دعم ٩٠ يوماً بعد الإطلاق.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. GUARANTEE -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_custom_gpt_development_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 id="faq-heading">أسئلة شائعة</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الفرق بين نموذج ذكاء اصطناعي مخصص ونموذج عام؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نماذج الذكاء الاصطناعي العامة مُدرَّبة على بيانات الإنترنت. لا تعرف منتجاتك ولا أسعارك ولا سياساتك. النموذج المخصص الذي نبنيه مُدرَّب على بيانات شركتك تحديداً، فيجيب بدقة عالية وبلغة شركتك ولا يخترع معلومات غير موجودة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يدعم النموذج اللهجات العربية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. نبني النماذج بحيث تفهم العربية الفصحى واللهجة الإماراتية، وتجيب بالمستوى اللغوي المناسب لعملاء شركتك ومنطقة تواجدك الجغرافي.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق تطوير نموذج ذكاء اصطناعي مخصص؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يعتمد على نهج التدريب وحجم البيانات. النماذج المبنية على RAG أسرع تسليماً من النماذج المُضبَّطة (fine-tuned) التي تتطلب تدريباً كاملاً. نحدد الجدول الزمني بعد تحليل متطلباتك.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن دمج النموذج مع منصات المراسلة والموقع الإلكتروني؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
