<script>
  (function () {
    const btn = document.querySelector('[data-more-toggle="internal-tools-more"]');
    if (!btn) return;
    const items = document.querySelectorAll('[data-more-group="internal-tools-more"]');
    const label = btn.querySelector('[data-more-label]');
    const icon = btn.querySelector('[data-more-icon]');
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      items.forEach((el) => { (el as HTMLElement).hidden = expanded; });
      btn.setAttribute('aria-expanded', String(!expanded));
      if (label) label.textContent = expanded ? 'عرض المزيد من الأدوات' : 'عرض أقل';
      if (icon) icon.textContent = expanded ? 'expand_more' : 'expand_less';
    });
  })();
</script>

