---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "أدوات ذكاء اصطناعي داخلية لفريقك | Aegis AI، الخليج",
    "url": "https://aegisai.ae/ar/services/internal-ai-tools",
    "inLanguage": "ar",
    "description": "Aegis AI تبني أدوات ذكاء اصطناعي داخلية لفريقك في الإمارات والسعودية والكويت وقطر: مساعدات معرفة، قواعد بيانات ذكية، وأتمتة خاصة بعملياتك.",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "أدوات داخلية", "item": "https://aegisai.ae/ar/services/internal-ai-tools" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "أدوات ذكاء اصطناعي داخلية لفريقك",
    "url": "https://aegisai.ae/ar/services/internal-ai-tools",
    "inLanguage": "ar",
    "description": "نبني أدوات ذكاء اصطناعي داخلية مخصصة لفريقك، تعمل بطريقتك، على بياناتك، وبالعربي والإنجليزي.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
    "areaServed": [
      {"@type": "Country", "name": "United Arab Emirates"},
      {"@type": "Country", "name": "Saudi Arabia"},
      {"@type": "Country", "name": "Kuwait"},
      {"@type": "Country", "name": "Qatar"}
    ],
    "serviceType": "Internal AI Tools Development"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الفرق بين أداة AI داخلية وبين نموذج الذكاء الاصطناعي العام؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نماذج الذكاء الاصطناعي العامة لا تعرف شيئاً عن شركتك. الأداة الداخلية التي نبنيها مُدرَّبة على سياساتك الخاصة ومستنداتك وعملياتك، فتجيب بدقة عالية على أسئلة خاصة بشركتك لا يمكن لأي نموذج عام الإجابة عنها." }
      },
      {
        "@type": "Question",
        "name": "هل بيانات شركتنا آمنة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نحن نبني الأدوات لتعمل على بنيتك التحتية الخاصة أو في بيئة مُعزَّزة لا يُشارك فيها أي بيانات مع نماذج عامة. بياناتك تظل داخل نطاق تحكمك الكامل." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء أداة AI داخلية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يعتمد على نوع الأداة وتعقيد التكاملات المطلوبة. الأدوات البسيطة تُسلَّم بسرعة، والأدوات الأكثر تعقيداً تأخذ وقتاً أطول. نعطيك جدولاً دقيقاً بعد تحليل احتياجاتك." }
      },
      {
        "@type": "Question",
        "name": "هل تدعم الأداة اللغة العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. جميع الأدوات التي نبنيها تدعم العربية والإنجليزي بشكل كامل. يمكن للموظف أن يسأل بالعربية ويحصل على رد بالعربية أو الإنجليزية حسب تفضيله." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن تحديث الأداة عند تغيير السياسات أو الإجراءات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالتأكيد. نبني الأدوات بحيث يمكنك تحديث قاعدة المعرفة بسهولة كلما تغيرت السياسات أو أُضيفت وثائق جديدة، دون الحاجة لإعادة البناء من الصفر." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="أدوات ذكاء اصطناعي داخلية لفريقك | Aegis AI، الخليج"
  description="Aegis AI تبني أدوات ذكاء اصطناعي داخلية لفريقك في الإمارات والسعودية والكويت وقطر: مساعدات معرفة، قواعد بيانات ذكية، وأتمتة خاصة بعملياتك. دعم عربي وإنجليزي."
  canonicalPath="/ar/services/internal-ai-tools"
  enPath="/services/internal-ai-tools"
  ldJson={ldJson}
>

<!-- 1. HERO -->
<header class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a>
      <span class="sep">/</span>
      <a href="/ar/services">الخدمات</a>
      <span class="sep">/</span>
      <span class="current">أدوات داخلية</span>
    </nav>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">build</span>
      أدوات داخلية
    </div>
    <h1>أدوات ذكاء اصطناعي مخصصة لفريقك، <span class="gradient-text">تعمل بالطريقة التي تعمل بها</span></h1>
    <p style="color:#42474e;font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.9;">
      لا أدوات عامة لا تعرف شركتك. نبني أدوات ذكاء اصطناعي مُدرَّبة على سياساتك ومستنداتك وعملياتك بالتحديد، تجيب بدقة، تعمل بالعربي والإنجليزي، وتوفر على فريقك ساعات يومياً.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_internal_ai_tools_hero" class="btn-primary">ابن أداة ذكاء اصطناعي لفريقك</button>
      <a href="#what-we-build" class="btn-outline">اكتشف ما نبنيه ↓</a>
    </div>
  </div>
</header>

<!-- 2. STATS -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-val">2+ ساعة</div>
        <div class="stat-desc">يوفرها كل موظف يومياً</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">كاملة</div>
        <div class="stat-desc">معرفة شركتك: سياسات، عمليات، مستندات</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">ثنائي اللغة</div>
        <div class="stat-desc">عربي وإنجليزي بشكل كامل</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">100%</div>
        <div class="stat-desc">ضمان استرداد كامل إذا لم تكن راضياً</div>
      </div>
    </div>
  </div>
</div>

<!-- 3. WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="builds-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">ما الذي نبنيه</div>
      <h2 id="builds-heading">خمسة أدوات داخلية نبنيها للشركات</h2>
      <p style="color:#42474e;font-size:1rem;max-width:560px;margin:0.75rem auto 0;line-height:1.8;">كل أداة مُصمَّمة خصيصاً لعمليات شركتك. لا حلول جاهزة، لا قوالب عامة.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">forum</span>
        </div>
        <h3>مساعد قاعدة المعرفة</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">بوت يجيب على أسئلة الموظفين من وثائق شركتك مباشرة: أدلة تشغيل، سياسات، إجراءات. لا بحث يدوي، لا انتظار للردود.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">people</span>
        </div>
        <h3>مساعد HR الذكي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يجيب الموظفين على أسئلة السياسات والإجازات والتأهيل الوظيفي تلقائياً، ويريح فريق HR للتركيز على العمل الاستراتيجي.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">trending_up</span>
        </div>
        <h3>أداة ذكاء المبيعات</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يعطي مندوب المبيعات ملخصاً كاملاً للحساب والفرصة والخطوات التالية المقترحة، دون ساعات من البحث والتحليل.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">summarize</span>
        </div>
        <h3>تلخيص الاجتماعات وبنود الإجراءات</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يلخص الاجتماعات تلقائياً ويستخرج بنود الإجراءات والمسؤوليات والمواعيد، ويرسلها للمعنيين فور انتهاء الاجتماع.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">bar_chart</span>
        </div>
        <h3>لوحة تقارير داخلية بتحليلات ذكية</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">لوحة تقارير تسأل بيانات شركتك بالعربي أو الإنجليزي وتحصل على إجابات فورية، دون الحاجة لمحلل بيانات أو معرفة بـ SQL.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. RESULTS CARD -->
<section class="section" style="background:#e7eeff;padding:4rem 0;" aria-labelledby="results-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">نتيجة حقيقية</div>
      <h2 id="results-heading">فريق HR يضيع 3 ساعات يومياً في أسئلة متكررة</h2>
    </div>
    <div class="card" style="max-width:800px;margin:0 auto;">
      <div class="results-grid">
        <div class="result-col">
          <div class="result-label">المشكلة</div>
          <p style="color:#42474e;line-height:1.8;">شركة تضم 200 موظف في دبي: فريق HR يُمضي 3 ساعات يومياً في الإجابة على نفس الأسئلة، سياسات الإجازة وإجراءات التأهيل والتعويضات. وقت ثمين يُهدر في أسئلة كان يمكن تجنبها.</p>
        </div>
        <div class="result-col">
          <div class="result-label">الحل</div>
          <p style="color:#42474e;line-height:1.8;">بنينا مساعد HR ذكي مُدرَّب على جميع سياسات الشركة وأدلة الموظفين. يجيب بالعربي والإنجليزي في ثوانٍ، ويُحيل الحالات المعقدة لفريق HR فقط عند الضرورة.</p>
        </div>
      </div>
      <div class="metrics-row">
        <div class="metric-item">
          <div class="metric-val">80%-</div>
          <div class="metric-desc">تراجع في الاستفسارات المتكررة لـ HR</div>
        </div>
        <div class="metric-item">
          <div class="metric-val">3 ساعات</div>
          <div class="metric-desc">يومياً تحررت لفريق HR للعمل الاستراتيجي</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. HOW IT WORKS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">كيف نعمل</div>
      <h2 id="process-heading">ثلاث خطوات لبناء أداة الذكاء الاصطناعي الداخلية</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="process-num">1</div>
        <h3>تحديد أكثر الاحتياجات أثراً</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجلس مع فريقك ونحدد أين يُهدر الوقت أكثر: الأسئلة المتكررة، البحث في الوثائق، التقارير اليدوية. نبدأ بالأداة التي تُحدث أكبر تأثير فوري.</p>
      </div>
      <div class="process-step">
        <div class="process-num">2</div>
        <h3>بناء وتدريب الأداة على بيانات شركتك</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجمّع مستنداتك وسياساتك وإجراءاتك، ندرّب عليها الأداة، ونختبر دقة الإجابات على سيناريوهات حقيقية من عملياتك اليومية.</p>
      </div>
      <div class="process-step">
        <div class="process-num">3</div>
        <h3>نشر وتدريب الفريق</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">ننشر الأداة في بيئتك، سواء كموقع داخلي أو تكامل مع أدوات التواصل الداخلي أو واجهة مستقلة، ونُدرّب فريقك على الاستخدام الأمثل مع دعم 90 يوماً بعد الإطلاق.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. GUARANTEE -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ 100% خلال 30 يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_internal_ai_tools_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 id="faq-heading">أسئلة شائعة</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الفرق بين أداة AI داخلية وبين نموذج الذكاء الاصطناعي العام؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نماذج الذكاء الاصطناعي العامة لا تعرف شيئاً عن شركتك. الأداة الداخلية التي نبنيها مُدرَّبة على سياساتك الخاصة ومستنداتك وعملياتك، فتجيب بدقة عالية على أسئلة خاصة بشركتك لا يمكن لأي نموذج عام الإجابة عنها.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل بيانات شركتنا آمنة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. نبني الأدوات لتعمل على بنيتك التحتية الخاصة أو في بيئة مُعزَّزة لا يُشارك فيها أي بيانات مع نماذج عامة. بياناتك تظل داخل نطاق تحكمك الكامل في جميع الأوقات.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق بناء أداة AI داخلية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يعتمد على نوع الأداة وتعقيد التكاملات المطلوبة. الأدوات البسيطة تُسلَّم بسرعة، والأدوات الأكثر تعقيداً تأخذ وقتاً أطول. نعطيك جدولاً زمنياً دقيقاً بعد تحليل احتياجاتك في جلسة مجانية.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل تدعم الأداة اللغة العربية؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. جميع الأدوات التي نبنيها تدعم العربية والإنجليزي بشكل كامل. يمكن للموظف أن يسأل بالعربية ويحصل على رد بالعربية أو الإنجليزية حسب تفضيله، دون أي فقدان في الدقة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يمكن تحديث الأداة عند تغيير السياسات أو الإجراءات؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">بالتأكيد. نبني الأدوات بحيث يمكنك تحديث قاعدة المعرفة بسهولة كلما تغيرت السياسات أو أُضيفت وثائق جديدة، دون الحاجة لإعادة البناء من الصفر أو الحاجة لمهارات تقنية متقدمة.</div>
      </div>
    </div>
  </div>
</section>

<!-- 8. FINAL CTA -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div style="position:relative;z-index:1;text-align:center;">
    <h2 style="color:#fff;font-size:clamp(1.75rem,3vw,2.5rem);margin-bottom:1rem;">ابن أداة ذكاء اصطناعي لفريقك</h2>
