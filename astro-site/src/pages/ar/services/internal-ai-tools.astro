---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "أدوات ذكاء اصطناعي داخلية لفريقك | Aegis AI، الإمارات",
    "url": "https://lenooai.com/ar/services/internal-ai-tools",
    "inLanguage": "ar",
    "description": "Aegis AI تبني أدوات ذكاء اصطناعي داخلية لفريقك في الإمارات: مساعدات معرفة، قواعد بيانات ذكية، وأتمتة خاصة بعملياتك.",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://lenooai.com/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "أدوات داخلية", "item": "https://lenooai.com/ar/services/internal-ai-tools" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "أدوات ذكاء اصطناعي داخلية لفريقك",
    "url": "https://lenooai.com/ar/services/internal-ai-tools",
    "inLanguage": "ar",
    "description": "نبني أدوات ذكاء اصطناعي داخلية مخصصة لفريقك، تعمل بطريقتك، على بياناتك، وبالعربي والإنجليزي.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://lenooai.com" },
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "serviceType": "Internal AI Tools Development"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الفرق بين أداة AI داخلية وبين نموذج الذكاء الاصطناعي العام؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نماذج الذكاء الاصطناعي العامة لا تعرف شيئاً عن شركتك. الأداة الداخلية التي نبنيها مُدرَّبة على سياساتك الخاصة ومستنداتك وعملياتك، فتجيب بدقة عالية على أسئلة خاصة بشركتك لا يمكن لأي نموذج عام الإجابة عنها." }
      },
      {
        "@type": "Question",
        "name": "هل بيانات شركتنا آمنة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نحن نبني الأدوات لتعمل على بنيتك التحتية الخاصة أو في بيئة مُعزَّزة لا يُشارك فيها أي بيانات مع نماذج عامة. بياناتك تظل داخل نطاق تحكمك الكامل." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء أداة AI داخلية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يعتمد على نوع الأداة وتعقيد التكاملات المطلوبة. الأدوات البسيطة تُسلَّم بسرعة، والأدوات الأكثر تعقيداً تأخذ وقتاً أطول. نعطيك جدولاً دقيقاً بعد تحليل احتياجاتك." }
      },
      {
        "@type": "Question",
        "name": "هل تدعم الأداة اللغة العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. جميع الأدوات التي نبنيها تدعم العربية والإنجليزي بشكل كامل. يمكن للموظف أن يسأل بالعربية ويحصل على رد بالعربية أو الإنجليزية حسب تفضيله." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن تحديث الأداة عند تغيير السياسات أو الإجراءات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالتأكيد. نبني الأدوات بحيث يمكنك تحديث قاعدة المعرفة بسهولة كلما تغيرت السياسات أو أُضيفت وثائق جديدة، دون الحاجة لإعادة البناء من الصفر." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="أدوات ذكاء اصطناعي داخلية للشركات في الإمارات | Aegis AI"
  description="Aegis AI، وكالة الذكاء الاصطناعي في دبي، تبني أدوات ذكاء اصطناعي داخلية لفريقك في الإمارات: مساعدات معرفة، قواعد بيانات ذكية، وأتمتة لعملياتك."
  canonicalPath="/ar/services/internal-ai-tools"
  enPath="/services/internal-ai-tools"
  ldJson={ldJson}
>

<!-- 1. HERO -->
<header class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>أدوات داخلية</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">build</span>
      أدوات داخلية
    </div>
    <h1>أدوات ذكاء اصطناعي مخصصة لفريقك، <span class="gradient-text">تعمل بالطريقة التي تعمل بها</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.9;">
      لا أدوات عامة لا تعرف شركتك. نبني أدوات ذكاء اصطناعي مُدرَّبة على سياساتك ومستنداتك وعملياتك بالتحديد، تجيب بدقة، تعمل بالعربي والإنجليزي، وتوفر على فريقك ساعات يومياً.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_internal_ai_tools_hero" class="btn-primary">ابن أداة ذكاء اصطناعي لفريقك</button>
      <a href="#what-we-build" class="btn-outline">اكتشف ما نبنيه ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=1400&q=80&auto=format&fit=crop" alt="أدوات ذكاء اصطناعي داخلية ولوحات ذكاء الأعمال" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
</div>

<!-- 2. STATS -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-val">٢+ ساعة</div>
        <div class="stat-desc">يوفرها كل موظف يومياً</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">كاملة</div>
        <div class="stat-desc">معرفة شركتك: سياسات، عمليات، مستندات</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">ثنائي اللغة</div>
        <div class="stat-desc">عربي وإنجليزي بشكل كامل</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">١٠٠٪</div>
        <div class="stat-desc">ضمان استرداد كامل إذا لم تكن راضياً</div>
      </div>
    </div>
  </div>
</div>

<!-- 3. WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="builds-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">ما الذي نبنيه</div>
      <h2 id="builds-heading">أدوات الذكاء الاصطناعي الداخلية التي نبنيها</h2>
      <p style="color:#42474e;font-size:1rem;max-width:560px;margin:0.75rem auto 0;line-height:1.8;">أمثلة شائعة، لا حد لما يمكن بناؤه. كل أداة مُصمَّمة خصيصاً لعمليات شركتك. إذا كان لديك أداة محددة في ذهنك غير مذكورة هنا، أخبرنا بها.</p>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1200&q=80&auto=format&fit=crop" alt="فريق عمل في مكتب بدبي يستخدم أداة ذكاء اصطناعي داخلية على الحاسوب" loading="lazy" width="1200" height="340" style="width:100%; height:clamp(200px, 26vw, 340px); object-fit:cover; display:block;" />
    </div>
    <div class="feature-ledger">
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">forum</span>
        </div>
        <h3>مساعد قاعدة المعرفة</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">بوت يجيب على أسئلة الموظفين من وثائق شركتك مباشرة: أدلة تشغيل، سياسات، إجراءات. لا بحث يدوي، لا انتظار للردود.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">people</span>
        </div>
        <h3>مساعد HR الذكي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يجيب الموظفين على أسئلة السياسات والإجازات والتأهيل الوظيفي تلقائياً، ويريح فريق HR للتركيز على العمل الاستراتيجي.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">trending_up</span>
        </div>
        <h3>أداة ذكاء المبيعات</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يعطي مندوب المبيعات ملخصاً كاملاً للحساب والفرصة والخطوات التالية المقترحة، دون ساعات من البحث والتحليل.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">summarize</span>
        </div>
        <h3>تلخيص الاجتماعات وبنود الإجراءات</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يلخص الاجتماعات تلقائياً ويستخرج بنود الإجراءات والمسؤوليات والمواعيد، ويرسلها للمعنيين فور انتهاء الاجتماع.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">bar_chart</span>
        </div>
        <h3>لوحة تقارير داخلية بتحليلات ذكية</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">لوحة تقارير تسأل بيانات شركتك بالعربي أو الإنجليزي وتحصل على إجابات فورية، دون الحاجة لمحلل بيانات أو معرفة بـ SQL.</p>
      </div>
      <div class="card" data-more-group="internal-tools-more" hidden>
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">gavel</span>
        </div>
        <h3>مساعد قانوني وعقود داخلي</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يراجع العقود القياسية، يُشير إلى البنود غير المعتادة أو الناقصة، ويُسرّع موافقات الفريق القانوني قبل التوقيع.</p>
      </div>
      <div class="card" data-more-group="internal-tools-more" hidden>
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">school</span>
        </div>
        <h3>أداة تأهيل وتدريب الموظفين</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يجيب الموظف الجديد عن أي سؤال متعلق بالتأهيل الوظيفي، ويقترح له خطوة التدريب التالية تلقائياً دون انتظار مسؤول HR.</p>
      </div>
      <div class="card" data-more-group="internal-tools-more" hidden>
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">shopping_cart</span>
        </div>
        <h3>مساعد المشتريات والموردين</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">يقارن عروض الموردين، يتتبع طلبات الشراء، وينبّه الفريق تلقائياً عند اقتراب أي طلب من تجاوز الميزانية المحددة.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:2rem;">
      <button type="button" class="btn-outline-sky" data-more-toggle="internal-tools-more" aria-expanded="false">
        <span data-more-label>عرض المزيد من الأدوات</span>
        <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true" data-more-icon>expand_more</span>
      </button>
    </div>
  </div>
</section>

<!-- 4. RESULTS CARD -->
<section class="section" style="background:#e7eeff;padding:4rem 0;" aria-labelledby="results-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">نتيجة حقيقية</div>
      <h2 id="results-heading">فريق HR يضيع ٣ ساعات يومياً في أسئلة متكررة</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?w=1200&q=80&auto=format&fit=crop" alt="فريق يستخدم لوحات معلومات داخلية في المكتب" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card" style="max-width:800px;margin:0 auto;">
      <div class="results-grid">
        <div class="result-col">
          <div class="result-label">المشكلة</div>
          <p style="color:#42474e;line-height:1.8;">شركة تضم ٢٠٠ موظف في دبي: فريق HR يُمضي ٣ ساعات يومياً في الإجابة على نفس الأسئلة، سياسات الإجازة وإجراءات التأهيل والتعويضات. وقت ثمين يُهدر في أسئلة كان يمكن تجنبها.</p>
        </div>
        <div class="result-col">
          <div class="result-label">الحل</div>
          <p style="color:#42474e;line-height:1.8;">بنينا مساعد HR ذكي مُدرَّب على جميع سياسات الشركة وأدلة الموظفين. يجيب بالعربي والإنجليزي في ثوانٍ، ويُحيل الحالات المعقدة لفريق HR فقط عند الضرورة.</p>
        </div>
      </div>
      <div class="metrics-row">
        <div class="metric-item">
          <div class="metric-val">٨٠٪-</div>
          <div class="metric-desc">تراجع في الاستفسارات المتكررة لـ HR</div>
        </div>
        <div class="metric-item">
          <div class="metric-val">٣ ساعات</div>
          <div class="metric-desc">يومياً تحررت لفريق HR للعمل الاستراتيجي</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. HOW IT WORKS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">كيف نعمل</div>
      <h2 id="process-heading">ثلاث خطوات لبناء أداة الذكاء الاصطناعي الداخلية</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="process-num">١</div>
        <h3>تحديد أكثر الاحتياجات أثراً</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجلس مع فريقك ونحدد أين يُهدر الوقت أكثر: الأسئلة المتكررة، البحث في الوثائق، التقارير اليدوية. نبدأ بالأداة التي تُحدث أكبر تأثير فوري.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٢</div>
        <h3>بناء وتدريب الأداة على بيانات شركتك</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجمّع مستنداتك وسياساتك وإجراءاتك، ندرّب عليها الأداة، ونختبر دقة الإجابات على سيناريوهات حقيقية من عملياتك اليومية.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٣</div>
        <h3>نشر وتدريب الفريق</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">ننشر الأداة في بيئتك، سواء كموقع داخلي أو تكامل مع أدوات التواصل الداخلي أو واجهة مستقلة، ونُدرّب فريقك على الاستخدام الأمثل مع دعم ٩٠ يوماً بعد الإطلاق.</p>
      </div>
    </div>
  </div>
</section>

<!-- 5b. Comparison -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="compare-heading">
  <div class="container" style="max-width:820px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 id="compare-heading">أداة داخلية مخصصة أم ChatGPT عام؟</h2>
      <p style="color:#42474e;max-width:580px;margin:1rem auto 0;line-height:1.8;">أدوات الذكاء الاصطناعي العامة مفيدة، لكنها لا تعرف شيئاً عن سياساتك أو بياناتك. الفرق يظهر في اليوم الأول من الاستخدام.</p>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=1200&q=80&auto=format&fit=crop" alt="فريق موظفين يتعاون حول شاشة أداة ذكاء اصطناعي داخلية في مكتب بدبي" loading="lazy" width="1200" height="340" style="width:100%; height:clamp(200px, 26vw, 340px); object-fit:cover; display:block;" />
    </div>
    <div class="compare-wrap" style="border-radius:var(--radius-md);overflow-x:auto;box-shadow:var(--shadow-card);">
      <table class="compare-table" style="width:100%;border-collapse:collapse;">
        <thead>
          <tr><th style="text-align:start;">المعيار</th><th>ChatGPT عام</th><th>أداة داخلية مخصصة</th></tr>
        </thead>
        <tbody>
