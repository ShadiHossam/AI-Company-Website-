---
export const prerender = false;
import ArBaseLayout from "../../../layouts/ArBaseLayout.astro";

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "بناء تطبيقات ويب بالذكاء الاصطناعي، Vibe Coding | Aegis AI",
    "url": "https://aegisai.ae/ar/services/vibe-coding",
    "inLanguage": "ar",
    "description": "Aegis AI تبني تطبيقات ويب وأدوات داخلية كاملة باستخدام Vibe Coding، بسرعة 5× أعلى وتكلفة أقل. للشركات في الإمارات.",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "الخدمات", "item": "https://aegisai.ae/ar/services" },
      { "@type": "ListItem", "position": 3, "name": "Vibe Coding", "item": "https://aegisai.ae/ar/services/vibe-coding" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "بناء تطبيقات ويب بالذكاء الاصطناعي، Vibe Coding",
    "url": "https://aegisai.ae/ar/services/vibe-coding",
    "inLanguage": "ar",
    "description": "نبني تطبيقات ويب وأدوات داخلية بسرعة 5 أضعاف التطوير التقليدي وتكلفة أقل بـ 60% باستخدام منهجية Vibe Coding.",
    "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "serviceType": "AI-Assisted Web Application Development"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما هو Vibe Coding؟",
        "acceptedAnswer": { "@type": "Answer", "text": "Vibe Coding هو منهجية تطوير تستخدم أدوات الذكاء الاصطناعي المتقدمة لكتابة الكود وبناء التطبيقات بسرعة تفوق التطوير التقليدي بـ 5 مرات، دون تقليص الجودة أو الموثوقية. المطور يوجّه ويراجع؛ الذكاء الاصطناعي يُنفذ." }
      },
      {
        "@type": "Question",
        "name": "هل جودة الكود مقبولة رغم السرعة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. نحن لا ندفع زر ونترك الذكاء الاصطناعي يعمل وحده. كل سطر كود يخضع لمراجعة مهندس متمرس. فايب كودينج يُسرّع الكتابة، لكن الجودة والاختبار والمراجعة لا تُختصر." }
      },
      {
        "@type": "Question",
        "name": "ما أنواع التطبيقات التي يمكنكم بناءها؟",
        "acceptedAnswer": { "@type": "Answer", "text": "أي تطبيق ويب: لوحات تحكم، بوابات عملاء، أدوات CRM مخصصة، أنظمة إدارة مخزون، أنظمة حجوزات، لوحات إدارة تقارير. إذا كان تطبيق ويب، يمكننا بناؤه." }
      },
      {
        "@type": "Question",
        "name": "ماذا يحدث بعد التسليم؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نقدم دعماً فنياً لمدة ٩٠ يوماً بعد التسليم: إصلاح أي عطل، تحديثات طارئة، وتوثيق كامل للكود. بعد ذلك تتوفر خطط صيانة وتطوير مستمر." }
      },
      {
        "@type": "Question",
        "name": "هل يمكن تطوير التطبيق بعد الإطلاق وإضافة ميزات جديدة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "بالتأكيد. نبني التطبيقات بهيكل قابل للتوسع من البداية. إضافة ميزات جديدة، دمج أنظمة إضافية، أو تكييف التطبيق مع نمو شركتك يكون أسرع وأقل تكلفة مقارنة بالتطوير التقليدي." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="بناء تطبيقات ويب بالذكاء الاصطناعي (Vibe Coding) للشركات في الإمارات | Aegis AI"
  description="Aegis AI تبني تطبيقات ويب وأدوات داخلية كاملة باستخدام Vibe Coding، بسرعة 5 أضعاف وتكلفة أقل. للشركات في الإمارات. ضمان استرداد 100%."
  canonicalPath="/ar/services/vibe-coding"
  enPath="/services/vibe-coding"
  ldJson={ldJson}
>

<!-- 1. HERO -->
<header class="page-hero">
  <div class="container" style="position:relative;z-index:1;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/services" style="color:inherit;text-decoration:none;opacity:0.65;">الخدمات</a><span style="opacity:0.4;padding:0 4px;"> / </span>فايب كودينج</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">code</span>
      فايب كودينج
    </div>
    <h1>بناء تطبيقات ويب بالذكاء الاصطناعي، <span class="gradient-text">أسرع وأرخص من التطوير التقليدي</span></h1>
    <p style="color:rgba(255,255,255,0.72);font-size:1.125rem;max-width:640px;margin:1.5rem auto 2.5rem;line-height:1.9;">
      لا داعي لدفع مئات الآلاف وانتظار أشهر. نبني تطبيقات ويب وأدوات داخلية كاملة بتكلفة أقل بـ ٦٠٪، باستخدام منهجية فايب كودينج التي تجمع سرعة الذكاء الاصطناعي مع إشراف مهندسين متمرسين.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_vibe_coding_hero" class="btn-primary">ابن تطبيقك بسرعة وبتكلفة أقل</button>
      <a href="#what-we-build" class="btn-outline">اكتشف ما نبنيه ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:260px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1400&q=80&auto=format&fit=crop" alt="فايب كودينج وتطوير برمجيات بمساعدة الذكاء الاصطناعي" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- 2. STATS -->
<div class="stats-strip">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-val">٥×</div>
        <div class="stat-desc">أسرع من التطوير التقليدي</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">٦٠٪</div>
        <div class="stat-desc">توفير في التكلفة مقارنة بالمنافسين</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">ملكية كاملة</div>
        <div class="stat-desc">للكود المصدري. تأخذ كل شيء. بدون قيود</div>
      </div>
      <div class="stat-div"></div>
      <div class="stat-item">
        <div class="stat-val">١٠٠٪</div>
        <div class="stat-desc">ضمان استرداد كامل إذا لم تكن راضياً</div>
      </div>
    </div>
  </div>
</div>

<!-- 3. WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="builds-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">ما الذي نبنيه</div>
      <h2 id="builds-heading">تطبيقات الويب التي نبنيها</h2>
      <p style="color:#42474e;font-size:1rem;max-width:560px;margin:0.75rem auto 0;line-height:1.8;">نقاط بداية شائعة، لا قائمة حصرية. من لوحة التحكم البسيطة إلى النظام المتكامل. إذا كان لديك شيء مختلف في ذهنك، نبنيه أيضاً.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">dashboard</span>
        </div>
        <h3>تطبيقات ويب داخلية</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">لوحات تحكم ومراقبة، بوابات تشغيلية، أدوات إدارة العمليات الداخلية، مخصصة لطريقة عمل فريقك بالضبط.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">public</span>
        </div>
        <h3>أدوات ويب للعملاء</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">بوابات خدمة ذاتية، منصات تتبع الطلبات، لوحات تقارير للعملاء. تُقلل الاتصال المتكرر وتزيد رضا العملاء.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">contacts</span>
        </div>
        <h3>تطبيقات CRM مخصصة</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">حين لا تناسبك أنظمة CRM الجاهزة، نبني نظام CRM مصمم لعمليات مبيعاتك بالتحديد، بالحقول والتقارير التي تحتاجها فعلاً.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">inventory</span>
        </div>
        <h3>أنظمة إدارة المخزون</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">تتبع المخزون في الوقت الحقيقي، تنبيهات إعادة الطلب التلقائية، تقارير الحركة. نظام مخصص لحجم ونوع عملياتك.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">calendar_month</span>
        </div>
        <h3>أنظمة الحجز والجدولة</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">حجز المواعيد، جدولة الموارد، إدارة التوافر. لعيادات، فنادق، مرافق رياضية، أو أي عمل يعتمد على الحجوزات.</p>
      </div>
      <div class="card">
        <div class="icon-box">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;direction:ltr;" aria-hidden="true">admin_panel_settings</span>
        </div>
        <h3>لوحات إدارة وتقارير</h3>
        <p style="color:#42474e;font-size:0.875rem;line-height:1.8;">لوحات إدارة المحتوى، تقارير الأداء، أدوات المراقبة الداخلية، مع تصورات بيانات واضحة وصلاحيات مخصصة لكل دور.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. RESULTS CARD -->
<section class="section" style="background:#e7eeff;padding:4rem 0;" aria-labelledby="results-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">نتيجة حقيقية</div>
      <h2 id="results-heading">٨٠٬٠٠٠ درهم مقابل ٢٤٬٠٠٠، لنفس التطبيق</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1200&q=80&auto=format&fit=crop" alt="مطور يبني ميزات المنتج في محطة عمل برمجية" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="card" style="max-width:800px;margin:0 auto;">
      <div class="results-grid">
        <div class="result-col">
          <div class="result-label">المشكلة</div>
          <p style="color:#42474e;line-height:1.8;">شركة ضيافة في دبي تحتاج أداة مخصصة لجدولة موظفيها: تتبع الورديات، الإجازات، التغطيات. الحل التقليدي: عرض سعر بـ ٨٠٬٠٠٠ درهم وجدول تنفيذ ٤ أشهر من شركة تطوير خارجية.</p>
        </div>
        <div class="result-col">
          <div class="result-label">الحل</div>
          <p style="color:#42474e;line-height:1.8;">بنينا نفس التطبيق بمنهجية فايب كودينج، بكل الميزات المطلوبة وتصميم عربي وإنجليزي وإشعارات تلقائية للموظفين. التكلفة الإجمالية: ٢٤٬٠٠٠ درهم.</p>
        </div>
      </div>
      <div class="metrics-row">
        <div class="metric-item">
          <div class="metric-val">أسرع بـ ٥×</div>
          <div class="metric-desc">من التطوير التقليدي للمشاريع المماثلة</div>
        </div>
        <div class="metric-item">
          <div class="metric-val">٢٤٬٠٠٠ د.إ</div>
          <div class="metric-desc">مقابل ٨٠٬٠٠٠ د.إ في العرض التقليدي</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. HOW IT WORKS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div style="font-size:0.75rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#006875;margin-bottom:0.75rem;">كيف نعمل</div>
      <h2 id="process-heading">ثلاث خطوات من الفكرة للتطبيق الحي</h2>
    </div>
    <div class="process-steps">
      <div class="process-step">
        <div class="process-num">١</div>
        <h3>تحديد متطلبات التطبيق بدقة</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">نجلس معك لتحديد الميزات والمستخدمين وتدفق العمل بالضبط، نكتب مواصفات واضحة قبل كتابة سطر كود واحد. الوضوح في البداية يمنع التغييرات المكلفة لاحقاً.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٢</div>
        <h3>بناء سريع بمساعدة الذكاء الاصطناعي</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">مهندسونا يستخدمون أحدث أدوات فايب كودينج لبناء التطبيق بسرعة ٥ أضعاف، مع مراجعة كل سطر كود للتأكد من الجودة والأمان قبل تسليمك نسخة للاختبار.</p>
      </div>
      <div class="process-step">
        <div class="process-num">٣</div>
        <h3>اختبار وتسليم ودعم</h3>
        <p style="color:#42474e;font-size:0.9rem;line-height:1.8;">اختبار شامل على سيناريوهات حقيقية، تسليم مع توثيق كامل، ودعم فني ٩٠ يوماً بعد الإطلاق. وإذا احتجت تحديثات أو ميزات جديدة، نكون معك.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. GUARANTEE -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_vibe_coding_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <h2 id="faq-heading">أسئلة شائعة</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما هو فايب كودينج؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">فايب كودينج هو منهجية تطوير تستخدم أدوات الذكاء الاصطناعي المتقدمة لكتابة الكود وبناء التطبيقات بسرعة تفوق التطوير التقليدي بـ ٥ مرات. المطور يوجّه ويراجع؛ الذكاء الاصطناعي يُنفذ. النتيجة: تطبيق مكتمل بتكلفة أقل بكثير وبوقت أسرع.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل جودة الكود مقبولة رغم السرعة؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. نحن لا ندفع زر ونترك الذكاء الاصطناعي يعمل وحده. كل سطر كود يخضع لمراجعة مهندس متمرس. فايب كودينج يُسرّع الكتابة، لكن الجودة والاختبار والأمان لا تُختصر في أي مرحلة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما أنواع التطبيقات التي يمكنكم بناءها؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">أي تطبيق ويب: لوحات تحكم، بوابات عملاء، أدوات CRM مخصصة، أنظمة إدارة مخزون، أنظمة حجوزات، لوحات إدارة وتقارير. إذا كان تطبيق ويب يحل مشكلة حقيقية في شركتك، يمكننا بناؤه.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا يحدث بعد التسليم؟
