  }
  .stat-item { padding: 0 .25rem; }
  .case-study-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }
  .case-label {
    display: inline-block;
    background: #e7eeff;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .case-section p {
    color: #42474e;
    line-height: 1.8;
    margin: 0;
  }
  .case-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e8eaed;
  }
  .result-metric {
    text-align: center;
  }
  .result-num {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: #1d4ed8;
  }
  .result-lbl {
    display: block;
    font-size: 0.875rem;
    color: #42474e;
    margin-top: 0.25rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .step-num {
    width: 52px;
    height: 52px;
    background: #1d4ed8;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .step-item h3 {
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }
  @media (max-width: 900px) {
    .retail-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  @media (max-width: 580px) {
    .retail-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .case-results { grid-template-columns: 1fr; }
  }
  .retail-tabs { max-width: 980px; margin: 0 auto; }
  .retail-tabs-nav {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .retail-tab-btn {
    background: #f0f3ff;
    border: 1px solid rgba(0,37,59,0.10);
    color: #42474e;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    cursor: pointer;
    transition: background .2s, color .2s, border-color .2s;
    font-family: inherit;
  }
  .retail-tab-btn:hover { background: #e7eeff; }
  .retail-tab-btn.active {
    background: #00253b;
    color: #fff;
    border-color: #00253b;
  }
  .retail-tab-btn:focus-visible { outline: 2px solid #006875; outline-offset: 2px; }
  .retail-tab-panel { display: none; }
  .retail-tab-panel.active {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .retail-tab-img { border-radius: 20px; overflow: hidden; box-shadow: 0 16px 40px rgba(0,59,92,0.10); }
  .retail-tab-img img { width: 100%; height: 320px; object-fit: cover; display: block; }
  .retail-tab-text h3 { margin-bottom: 0.75rem; }
  .retail-tab-text p { color: #42474e; line-height: 1.8; margin: 0; }
  @media (max-width: 760px) {
    .retail-tab-panel.active { grid-template-columns: 1fr; }
    .retail-tab-img img { height: 220px; }
  }
</style>

<script>
  (function () {
    const wrap = document.querySelector('[data-retail-tabs]');
    if (!wrap) return;
    const btns = wrap.querySelectorAll('.retail-tab-btn');
    const panels = wrap.querySelectorAll('.retail-tab-panel');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-retail-tab');
        btns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const targetPanel = wrap.querySelector('[data-retail-panel="' + target + '"]');
        if (targetPanel) targetPanel.classList.add('active');
      });
    });
  })();
</script>

</ArBaseLayout>
