---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي لقطاع التجزئة في الإمارات | Lenoo AI",
    "url": "https://lenooai.com/ar/industries/retail",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://lenooai.com/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "التجزئة", "item": "https://lenooai.com/ar/industries/retail" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي لقطاع التجزئة في الإمارات",
    "description": "حلول ذكاء اصطناعي لشركات التجزئة في الإمارات: إدارة مخزون ذكية، تنبؤ بالطلب، ومساعد مشتريات آلي.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Lenoo AI", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "كيف يساعد الذكاء الاصطناعي في إدارة المخزون؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الذكاء الاصطناعي يتابع مستويات المخزون في جميع الفروع لحظياً، يتنبأ بالطلب بناءً على البيانات التاريخية والمواسم، ويرسل تنبيهات إعادة الطلب قبل النفاد. كل هذا تلقائياً دون تدخل يدوي." }
      },
      {
        "@type": "Question",
        "name": "ما مدى دقة التنبؤ بالطلب؟",
        "acceptedAnswer": { "@type": "Answer", "text": "في معظم حالاتنا نصل لدقة 85% أو أعلى بعد فترة تعلّم من 4-8 أسابيع. الدقة تزيد كلما كانت البيانات التاريخية أشمل. النظام يتعلم باستمرار ويُحسّن تنبؤاته تلقائياً." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل النظام مع فروع متعددة؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، هذا أحد أقوى جوانبه. ترى صورة موحدة للمخزون عبر جميع الفروع لحظياً، وتستطيع تحريك المخزون بين الفروع بناءً على الطلب الفعلي لكل موقع." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء النظام وإطلاقه؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعمل على مرحلتين: مرحلة تحليل البيانات والتكامل مع أنظمتك الحالية، ثم مرحلة الاختبار وتدريب الفريق. تبدأ ترى البيانات لحظياً من يوم الإطلاق." }
      },
      {
        "@type": "Question",
        "name": "هل يتكامل مع نظام نقاط البيع الحالي لدينا؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نتكامل مع معظم أنظمة نقاط البيع الشائعة في الإمارات. حتى إذا كان نظامك قديماً أو مخصصاً، نملك طرقاً بديلة للتكامل. نفحص ذلك معاً في جلسة التشخيص المجانية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي لقطاع التجزئة في الإمارات | Lenoo AI"
  description="Lenoo AI، وكالة الذكاء الاصطناعي في دبي، تبني حلول ذكاء اصطناعي لشركات التجزئة في الإمارات: إدارة مخزون ذكية، تنبؤ بالطلب، ومساعد مشتريات آلي."
  canonicalPath="/ar/industries/retail"
  enPath="/industries/retail"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar#industries-heading" style="color:inherit;text-decoration:none;opacity:0.65;">القطاعات</a><span style="opacity:0.4;padding:0 4px;"> / </span>التجزئة</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">storefront</span>
      التجزئة
    </div>
    <h1>ذكاء اصطناعي للتجزئة في الإمارات<br><span class="gradient-text">تحكم كامل في مخزونك</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:rgba(255,255,255,0.72);">
      إدارة المخزون بالإكسل وعبر الهاتف بين الفروع تعني أخطاء، نقصاً، وإفراطاً في المخزون. كل هذا يكلّفك مالاً. نبني لك نظاماً ذكياً يرى مخزونك لحظياً عبر جميع الفروع ويتنبأ بالطلب قبل النفاد.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_retail_hero" class="btn-primary">احجز استشارة مجانية ←</button>
    </div>
  </div>
</header>

<!-- IMAGE BANNER + STATS -->
<div style="position:relative; overflow:hidden;">
  <img src="https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?w=1600&q=80&auto=format&fit=crop" alt="متجر تجزئة حديث مزوّد بتقنية الذكاء الاصطناعي" loading="eager" fetchpriority="high" width="1600" height="320" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.55) 0%,rgba(0,19,32,0.18) 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
  <div style="position:relative; padding:3rem 2rem;">
    <div class="glass-dark retail-stats-grid" style="max-width:920px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem;">
      <div class="stat-item">
        <p class="stat-num">-٣٠٪</p>
        <p class="stat-lbl">تكاليف الإفراط في المخزون</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">٨٥٪+</p>
        <p class="stat-lbl">دقة التنبؤ بالطلب</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">متعدد</p>
        <p class="stat-lbl">إدارة جميع الفروع من مكان واحد</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</div>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في التجزئة</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">خمسة تطبيقات عملية تُحوّل إدارة المخزون والمبيعات من عمل يدوي إلى نظام ذكي تلقائي.</p>
    <div class="feature-ledger">
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">inventory_2</span>
        <h3>إدارة مخزون ذكية في الوقت الفعلي</h3>
        <p style="color:#42474e;line-height:1.7;">ترى مستوى كل منتج في كل فرع لحظياً. لا تتصل، لا تكتب في إكسل، لا تنتظر تقرير نهاية اليوم.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">insights</span>
        <h3>تنبؤ بالطلب بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">يحلل البيانات التاريخية والمواسم والاتجاهات ليتنبأ بما تحتاجه كل فرع قبل أسابيع. تطلب بذكاء وليس بتخمين.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">psychology</span>
        <h3>تحليل سلوك العملاء</h3>
        <p style="color:#42474e;line-height:1.7;">يكشف ما يشتريه العملاء معاً، متى يتسوقون، وما المنتجات التي تجذبهم. قرارات التسعير والعروض مبنية على بيانات.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">autorenew</span>
        <h3>نظام إعادة طلب تلقائي</h3>
        <p style="color:#42474e;line-height:1.7;">عندما يصل مخزون منتج لحدٍّ معين، يُرسل طلب شراء للمورد تلقائياً. لا تنفد أبداً ولا تُفرط في الشراء.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">bar_chart</span>
        <h3>لوحة أداء المبيعات</h3>
        <p style="color:#42474e;line-height:1.7;">تقارير لحظية على أداء كل فرع ومنتج وموظف. تعرف أين تكسب وأين تخسر في الوقت الفعلي.</p>
      </div>
    </div>
  </div>
</section>

<!-- UAE RETAIL PHOTO GRID -->
<section class="section" aria-labelledby="retail-photo-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="retail-photo-heading">التجزئة والتجارة الإلكترونية، عبر الإمارات</h2>
      <p>واجهات المتاجر، المتسوقون، وغرف المخزون: العمل اليومي الذي بُنيت أنظمتنا لتعمل بجانبه.</p>
    </div>
    <div class="retail-photo-grid">
      <div class="retail-photo">
        <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=700&q=80&auto=format&fit=crop" alt="واجهة متجر بوتيك في مجمع تجاري بدبي" loading="lazy" width="700" height="500" />
        <p>واجهة المتجر</p>
      </div>
      <div class="retail-photo">
        <img src="https://images.unsplash.com/photo-1556740758-90de374c12ad?w=700&q=80&auto=format&fit=crop" alt="متسوق يحمل أكياساً بعد الشراء من متجر في الإمارات" loading="lazy" width="700" height="500" />
        <p>تجربة التسوق</p>
      </div>
      <div class="retail-photo">
        <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=700&q=80&auto=format&fit=crop" alt="رفوف مستودع مخزون تجزئة" loading="lazy" width="700" height="500" />
        <p>المخزون وغرفة التخزين</p>
      </div>
    </div>
  </div>
</section>

<!-- 3b. Inventory Lifecycle Tabs (interactive) -->
<section class="section" style="padding-top:0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">أين يتدخل الذكاء الاصطناعي في دورة المخزون</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:2.5rem;max-width:560px;margin-inline:auto;">اختر مرحلة من دورة المخزون لترى كيف يعمل النظام فيها.</p>
    <div class="retail-tabs" data-retail-tabs>
      <div class="retail-tabs-nav" role="tablist" aria-label="مراحل دورة المخزون">
        <button type="button" class="retail-tab-btn active" data-retail-tab="floor" role="tab" aria-selected="true">أرضية المتجر</button>
        <button type="button" class="retail-tab-btn" data-retail-tab="shelf" role="tab" aria-selected="false">تتبع الرفوف</button>
        <button type="button" class="retail-tab-btn" data-retail-tab="reorder" role="tab" aria-selected="false">إعادة الطلب</button>
      </div>
      <div class="retail-tabs-body">
        <div class="retail-tab-panel active" data-retail-panel="floor">
          <div class="retail-tab-img">
            <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=800&q=80&auto=format&fit=crop" alt="واجهة متجر تجزئة في مجمع تجاري بدبي" loading="lazy" width="800" height="500" />
          </div>
          <div class="retail-tab-text">
            <h3>صورة موحدة لكل فرع</h3>
            <p>كل فرع يظهر على لوحة واحدة: المبيعات، المخزون، وحركة العملاء، لحظياً، دون انتظار تقرير نهاية اليوم.</p>
          </div>
        </div>
        <div class="retail-tab-panel" data-retail-panel="shelf">
          <div class="retail-tab-img">
            <img src="https://images.unsplash.com/photo-1555529669-e69e7aa0ba9a?w=800&q=80&auto=format&fit=crop" alt="رفوف متجر تجزئة مرتبة بمنتجات متنوعة" loading="lazy" width="800" height="500" />
          </div>
          <div class="retail-tab-text">
            <h3>تتبع كل منتج على الرف</h3>
            <p>يعرف النظام كمية كل منتج في كل رف وفرع، ويكشف الفجوات بين المخزون المسجَّل والمخزون الفعلي قبل أن تصبح مشكلة.</p>
          </div>
        </div>
        <div class="retail-tab-panel" data-retail-panel="reorder">
          <div class="retail-tab-img">
            <img src="https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=800&q=80&auto=format&fit=crop" alt="رف ملابس في متجر جاهز لإعادة التزويد بالمخزون" loading="lazy" width="800" height="500" />
          </div>
          <div class="retail-tab-text">
            <h3>طلب شراء تلقائي عند الحاجة</h3>
            <p>عندما يقترب منتج من النفاد، يُرسل النظام طلب إعادة تزويد للمورد المناسب مباشرة، دون انتظار أحد يلاحظ النقص.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 4. Case Study -->
<section class="section" style="background:#f0f4ff;padding:4rem 0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:2.5rem;">قصة نجاح حقيقية</h2>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80&auto=format&fit=crop" alt="موظف تجزئة يساعد عميلاً في إتمام عملية الدفع عند الكاشير" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="case-study-card">
      <div class="case-section">
        <span class="case-label">المشكلة</span>
        <p>سلسلة تجزئة بـ ١٢ فرعاً كانت تدير مخزونها يدوياً عبر الإكسل. كل فرع يُرسل تقريره بنهاية اليوم، وكثيراً ما يُكتشف النفاد بعد فوات الأوان، أو العثور على مخزون زائد في فرع ونقص في آخر.</p>
      </div>
      <div class="case-section">
        <span class="case-label">ما بنيناه</span>
        <p>لوحة تتبع مخزون لحظية ذكية تجمع بيانات جميع الفروع الـ ١٢ آلياً، مع نظام تنبيه مبكر وتنبؤ أسبوعي بالطلب لكل فرع ومنتج.</p>
      </div>
      <div class="case-results">
        <div class="result-metric">
          <span class="result-num">-٣٠٪</span>
          <span class="result-lbl">تكاليف الإفراط في المخزون</span>
        </div>
        <div class="result-metric">
          <span class="result-num">٣ ساعات/يوم</span>
          <span class="result-lbl">توفير في وقت التتبع اليدوي</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MANUAL VS. AI -->
<section class="section" style="background:#f0f3ff;" aria-labelledby="roi-heading">
  <div class="container" style="max-width:940px;">
    <div class="section-header">
      <h2 id="roi-heading">ما الذي يتغيّر عندما يتولى الذكاء الاصطناعي العمل اليومي</h2>
      <p>يوم نموذجي لتاجر تجزئة إماراتي، قبل وبعد نشر أنظمة Lenoo AI.</p>
    </div>
    <div class="bento-grid bento-grid-2">
      <div class="card">
        <p class="roi-panel-label">العمليات اليدوية</p>
        <div class="roi-row"><span class="roi-metric">٤-٦ ساعات/أسبوع</span><span class="roi-desc">تُصرف في مطابقة المخزون يدوياً بين الفروع</span></div>
        <div class="roi-row"><span class="roi-metric">٢-٤٨ ساعة</span><span class="roi-desc">متوسط زمن الرد على رسالة عميل روتينية</span></div>
        <div class="roi-row"><span class="roi-metric">تخمين</span><span class="roi-desc">كميات إعادة الطلب بناءً على الحدس وأرقام العام الماضي</span></div>
        <div class="roi-row"><span class="roi-metric">عرض واحد</span><span class="roi-desc">يظهر لكل عميل، بغض النظر عن تاريخ مشترياته</span></div>
      </div>
      <div class="card">
        <p class="roi-panel-label" style="color:#006875;">مع Lenoo AI</p>
        <div class="roi-row"><span class="roi-metric roi-metric-good">تلقائي</span><span class="roi-desc">مزامنة المخزون بين نقاط البيع والمستودع والمتجر الإلكتروني لحظياً</span></div>
        <div class="roi-row"><span class="roi-metric roi-metric-good">أقل من دقيقة</span><span class="roi-desc">متوسط زمن رد روبوت المحادثة، على مدار الساعة، بالعربي والإنجليزي</span></div>
        <div class="roi-row"><span class="roi-metric roi-metric-good">مبني على بيانات</span><span class="roi-desc">كميات إعادة الطلب من نموذج مدرّب على مواسمك ودورات رمضان</span></div>
        <div class="roi-row"><span class="roi-metric roi-metric-good">مخصص</span><span class="roi-desc">منتج وعرض يظهران لكل متسوق بناءً على سلوكه الخاص</span></div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">كيف نعمل معك</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;">من تحليل بياناتك إلى نظام يعمل عبر جميع فروعك.</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-num">١</div>
        <h3>تحليل بيانات المخزون الحالية</h3>
        <p style="color:#42474e;line-height:1.7;">نفهم كيف تدير مخزونك الآن، ما الفجوات، وما البيانات المتاحة. نبني على ما لديك دون بداية من صفر.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٢</div>
        <h3>بناء نظام تتبع وتنبؤ ذكي</h3>
        <p style="color:#42474e;line-height:1.7;">نبني لوحة التتبع الموحدة مع خوارزمية التنبؤ بالطلب، مدرّبة على بيانات مبيعاتك التاريخية.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٣</div>
        <h3>ربط بجميع الفروع</h3>
        <p style="color:#42474e;line-height:1.7;">نتكامل مع أنظمة نقاط البيع في جميع فروعك. كل البيانات في مكان واحد، لحظياً، دون تدخل يدوي.</p>
      </div>
    </div>
  </div>
</section>

<!-- EVALUATION CRITERIA -->
<section class="section" aria-labelledby="eval-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="eval-heading">ما الذي يميّز الذكاء الاصطناعي الفعّال للتجزئة عن التجارب المكلفة</h2>
    </div>
    <div class="eval-grid">
      <div class="card" style="text-align:center;">
        <div class="num-circle">1</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">جودة البيانات أولاً</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">دقة التنبؤ بالذكاء الاصطناعي لا تتجاوز جودة البيانات المُغذّية له. أنظمة نقاط بيع متفرقة، تسمية منتجات غير متسقة، وسجلات معاملات ناقصة تُنتج تنبؤات خاطئة مهما كان النموذج متطوراً. البيانات النظيفة والموحدة شرط أساسي، لا إضافة لاحقة.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">2</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">تدريب مخصص للسوق المحلي</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">النماذج العامة تُقصّر. نموذج تنبؤ لا يفهم موسمية المنطقة (منحنيات الطلب في رمضان، ذروات المهرجانات المحلية، والذروات السياحية) سيُنتج توصيات خاطئة بشكل منهجي لسياق التجزئة في الشرق الأوسط.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">3</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">تصميم يُبقي الإنسان في الحلقة</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">أفضل ذكاء اصطناعي للتجزئة يعزز حكم الإنسان بدلاً من استبداله. التنبؤ بالطلب يجب أن يمنح المشترين توصيات يمكنهم مراجعتها وتجاوزها، لا أن يُصدر طلبات شراء تلقائياً بلا رقابة. الثقة تُبنى بالشفافية، لا بأتمتة مغلقة.</p>
      </div>
      <div class="card" style="text-align:center;">
        <div class="num-circle">4</div>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:0.5rem;">مقاييس العمل، لا مقاييس النموذج</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">مشاريع الذكاء الاصطناعي تفشل عندما يُعرَّف النجاح بالدقة التقنية بدلاً من نتائج العمل. السؤال ليس "ما مدى دقة النموذج؟" بل "هل انخفضت تكاليف الفائض؟". حدّد مقياس العمل قبل التنفيذ، لا بعده.</p>
      </div>
    </div>
  </div>
</section>

<!-- INDUSTRY RESEARCH -->
<section class="section" style="background:#e7eeff;" aria-labelledby="research-heading">
  <div class="container" style="max-width:860px;">
    <div class="section-header">
      <h2 id="research-heading">ما تُظهره البيانات حول الذكاء الاصطناعي في التجزئة</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=1200&q=80&auto=format&fit=crop" alt="موظف تجزئة يساعد عميلاً في إتمام عملية الدفع" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="ind-stats-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; margin-bottom:2rem;">
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">٣٥٪</p>
        <p style="color:#42474e; font-size:0.875rem;">من إيرادات كبرى منصات التجارة الإلكترونية تُعزى إلى محركات التوصية (McKinsey)</p>
      </div>
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">٢٠-٥٠٪</p>
        <p style="color:#42474e; font-size:0.875rem;">انخفاض في تكاليف حمل المخزون بفضل التنبؤ بالذكاء الاصطناعي (Gartner)</p>
      </div>
      <div class="card" style="text-align:center;">
        <p class="stat-number" style="font-size:2.25rem; margin-bottom:4px;">١.٢ تريليون دولار</p>
        <p style="color:#42474e; font-size:0.875rem;">القيمة المتوقع أن يضيفها الذكاء الاصطناعي لقطاع التجزئة العالمي بحلول ٢٠٣٠ (Capgemini)</p>
      </div>
    </div>
    <div class="research-panel">
      <div class="ind-text-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:2rem; font-size:0.875rem;">
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">تحسين المخزون</p>
          <p style="color:#42474e; line-height:1.7;">وجدت دراسة McKinsey (٢٠٢٣) أن تجار التجزئة الذين يستخدمون التنبؤ بالطلب بالذكاء الاصطناعي خفّضوا تكاليف المخزون بنسبة ٢٠-٥٠٪ مع تقليل تكرار نفاد المخزون في الوقت نفسه، وهو تحسّن مزدوج نادر تُحققه الأساليب التقليدية عادةً على حساب أحدهما للآخر.</p>
        </div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">تجربة العميل</p>
          <p style="color:#42474e; line-height:1.7;">وجد تقرير Salesforce لحالة التجارة (٢٠٢٤) أن ٧٤٪ من المستهلكين يتوقعون من العلامات التجارية فهم احتياجاتهم الفردية. تجار التجزئة الذين يستخدمون التخصيص بالذكاء الاصطناعي يرون معدلات فتح بريد أعلى بـ ١٠-٣٠٪، وتحويلاً أعلى بـ ٥-١٠٪.</p>
        </div>
        <div>
          <p style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">كفاءة سلسلة التوريد</p>
          <p style="color:#42474e; line-height:1.7;">تُظهر أبحاث BCG أن إدارة سلسلة التوريد بالذكاء الاصطناعي تُخفّض تكاليف اللوجستيات بنسبة ١٥٪، وتُحسّن توفر المنتج على الرف بنسبة ٣٥٪، وتُقلل المبيعات الضائعة بسبب نفاد المخزون بنسبة تصل إلى ٦٥٪.</p>
        </div>
      </div>
    </div>
  </div>
</section>

