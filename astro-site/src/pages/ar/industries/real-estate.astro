---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي للعقارات في الإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/industries/real-estate",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://aegisai.ae/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "العقارات", "item": "https://aegisai.ae/ar/industries/real-estate" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي للعقارات في الإمارات",
    "description": "حلول ذكاء اصطناعي لشركات العقارات في الإمارات: روبوت واتساب للردود الفورية، تأهيل عملاء آلي، ومطابقة العقارات مع الطلبات.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ماذا يستطيع الذكاء الاصطناعي أن يفعل لشركتي العقارية في دبي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يستطيع الذكاء الاصطناعي الرد على استفسارات العملاء فور وصولها على واتساب والموقع، تأهيل العملاء وتصنيفهم تلقائياً، مطابقة كل استفسار مع العقارات المناسبة، وإرسال متابعات آلية للعملاء غير المستجيبين. كل هذا بدون تدخل يدوي." }
      },
      {
        "@type": "Question",
        "name": "كيف يعمل روبوت واتساب للعقارات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الروبوت يستقبل رسائل العملاء على واتساب، يفهم الطلب بالعربي أو الإنجليزي، يجيب بمعلومات العقارات المناسبة، يسأل أسئلة التأهيل، ويحوّل العملاء الجاهزين للوكيل المناسب، فوراً وعلى مدار الساعة." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل الروبوت باللغة العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، بشكل كامل. ندرّب الروبوت على العربية والإنجليزي ويتعامل مع كلا اللغتين في نفس المحادثة. مناسب لسوق دبي المتعدد اللغات." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء الحل وإطلاقه؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعمل على مراحل متسلسلة: تحليل مسار البيع وجمع البيانات، ثم البناء والاختبار، ثم الإطلاق والتدريب مع مراقبة الأداء." }
      },
      {
        "@type": "Question",
        "name": "ما العائد المتوقع على الاستثمار؟",
        "acceptedAnswer": { "@type": "Answer", "text": "عملاؤنا في العقارات يرون في الغالب زيادة 30-50% في معدل تحويل العملاء الأولي، وتوفير ساعات عمل يومية للفريق. العائد الفعلي يعتمد على حجم استفساراتك الشهرية وقيمة الصفقة لديك." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي للعقارات في الإمارات | Aegis AI"
  description="Aegis AI، وكالة الذكاء الاصطناعي في دبي، تبني حلول ذكاء اصطناعي لشركات العقارات في الإمارات: روبوت واتساب للردود الفورية، تأهيل عملاء آلي، وتقارير مبيعات ذكية. ضمان استرداد 100%."
  canonicalPath="/ar/industries/real-estate"
  enPath="/industries/real-estate"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar#industries-heading" style="color:inherit;text-decoration:none;opacity:0.65;">القطاعات</a><span style="opacity:0.4;padding:0 4px;"> / </span>العقارات</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">apartment</span>
      العقارات
    </div>
    <h1>ذكاء اصطناعي للعقارات في دبي<br><span class="gradient-text">أسرع في الرد، أعلى في التحويل</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:rgba(255,255,255,0.72);">
      كل دقيقة تأخير في الرد تعني عميلاً محتملاً يتصل بالمنافس. نبني لك روبوت واتساب يرد فوراً بالعربي والإنجليزي، يؤهّل العملاء تلقائياً، ويطابق كل استفسار مع العقار المناسب، على مدار الساعة.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_real-estate_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/ar/results" class="btn-outline">شاهد النتائج</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER + STATS -->
<div style="position:relative; overflow:hidden;">
  <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1600&q=80&auto=format&fit=crop" alt="منظر جوي لقطاع العقارات وتطوير الممتلكات في دبي" loading="eager" fetchpriority="high" width="1600" height="320" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 60%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.55) 0%,rgba(0,19,32,0.18) 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
  <div style="position:relative; padding:3rem 2rem;">
    <div class="glass-dark re-stats-grid" style="max-width:920px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem;">
      <div class="stat-item">
        <p class="stat-num">٢٤/٧</p>
        <p class="stat-lbl">ردّ فوري بدون توقف</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">+٤٠٪</p>
        <p class="stat-lbl">متوسط زيادة معدل التحويل</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">عربي + إنجليزي</p>
        <p class="stat-lbl">دعم عربي وإنجليزي كامل</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</div>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في العقارات</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">ستة تطبيقات عملية تحوّل كيف تتعامل شركتك مع العملاء والمخزون والأداء.</p>
    <div class="feature-ledger">
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">chat</span>
        <h3>روبوت واتساب للردود الفورية</h3>
        <p style="color:#42474e;line-height:1.7;">يرد على كل استفسار في ثوانٍ، ليلاً ونهاراً، بالعربي والإنجليزي. لا يترك عميلاً ينتظر.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">leaderboard</span>
        <h3>تأهيل العملاء وتصنيفهم</h3>
        <p style="color:#42474e;line-height:1.7;">يسأل الروبوت أسئلة التأهيل تلقائياً ويصنّف العملاء حسب الجاهزية، فريقك يركّز على الصفقات الحقيقية.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">home_work</span>
        <h3>مطابقة العقارات بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">يحلّل الروبوت طلب العميل ويقترح العقارات المناسبة من قاعدة بياناتك فوراً. تجربة شخصية دون جهد يدوي.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">schedule_send</span>
        <h3>متابعة آلية للعملاء</h3>
        <p style="color:#42474e;line-height:1.7;">تسلسلات متابعة تلقائية للعملاء الذين لم يردوا، تذكيرات، عروض جديدة، وتحديثات السوق بدون تدخل يدوي.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">bar_chart</span>
        <h3>لوحة أداء المبيعات</h3>
        <p style="color:#42474e;line-height:1.7;">تقارير لحظية على أداء الوكلاء، معدلات التحويل، ومصادر العملاء. قرارات مبنية على بيانات وليس حدساً.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">translate</span>
        <h3>ذكاء اصطناعي متعدد اللغات</h3>
        <p style="color:#42474e;line-height:1.7;">يتواصل مع عملائك بالعربي والإنجليزي في نفس المحادثة، مثالي لسوق دبي المتنوع.</p>
      </div>
    </div>
  </div>
</section>

<!-- 3b. Buyer Journey Tabs (interactive) -->
<section class="section" style="padding-top:0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">أين يتدخل الذكاء الاصطناعي في رحلة العميل</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:2.5rem;max-width:560px;margin-inline:auto;">اختر مرحلة من رحلة العميل لترى كيف يعمل الروبوت فيها.</p>
    <div class="re-tabs" data-re-tabs>
      <div class="re-tabs-nav" role="tablist" aria-label="مراحل رحلة العميل">
        <button type="button" class="re-tab-btn active" data-re-tab="inquiry" role="tab" aria-selected="true">أول استفسار</button>
        <button type="button" class="re-tab-btn" data-re-tab="match" role="tab" aria-selected="false">مطابقة العقار</button>
        <button type="button" class="re-tab-btn" data-re-tab="viewing" role="tab" aria-selected="false">حجز المعاينة</button>
      </div>
      <div class="re-tabs-body">
        <div class="re-tab-panel active" data-re-panel="inquiry">
          <div class="re-tab-img">
            <img src="https://images.unsplash.com/photo-1560184897-ae75f418493e?w=800&q=80&auto=format&fit=crop" alt="عميل يستلم مفاتيح شقته الجديدة من الوكيل العقاري" loading="lazy" width="800" height="500" />
          </div>
          <div class="re-tab-text">
            <h3>ردّ فوري على أول رسالة</h3>
            <p>الروبوت يرد خلال ثوانٍ على أي استفسار يصل عبر واتساب أو الموقع، يفهم الميزانية والموقع المطلوب، ولا يترك العميل ينتظر.</p>
          </div>
        </div>
        <div class="re-tab-panel" data-re-panel="match">
          <div class="re-tab-img">
            <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=800&q=80&auto=format&fit=crop" alt="فيلا حديثة في دبي معروضة على منصة عقارية" loading="lazy" width="800" height="500" />
          </div>
          <div class="re-tab-text">
            <h3>اقتراح العقارات المناسبة</h3>
            <p>يطابق الروبوت طلب العميل مع مخزون العقارات المتاح، ويرسل خيارات مناسبة فعلاً، لا قائمة عشوائية من كل ما هو معروض.</p>
          </div>
        </div>
        <div class="re-tab-panel" data-re-panel="viewing">
          <div class="re-tab-img">
            <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=800&q=80&auto=format&fit=crop" alt="صالة معيشة عصرية في شقة معروضة للمعاينة" loading="lazy" width="800" height="500" />
          </div>
          <div class="re-tab-text">
            <h3>حجز موعد المعاينة تلقائياً</h3>
            <p>عند جاهزية العميل، يحجز الروبوت موعد المعاينة مباشرة في تقويم الوكيل المناسب، ويرسل تذكيراً للطرفين قبل الموعد.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 4. Case Study -->
<section class="section" style="background:#f0f4ff;padding:4rem 0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:2.5rem;">قصة نجاح حقيقية</h2>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1526948531399-320e7e40f0ca?w=1200&q=80&auto=format&fit=crop" alt="وكيل عقاري يراجع تفاصيل عقار مع عميل في شقة عصرية" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="case-study-card">
      <div class="case-section">
        <span class="case-label">المشكلة</span>
        <p>وكالة عقارية في دبي كانت تخسر عملاء محتملين لأن وكلاءها لم يتمكنوا من الرد بسرعة كافية. متوسط وقت الرد كان ٤ ساعات، وكثير من العملاء كانوا يتحولون للمنافسين في هذه الفترة.</p>
      </div>
      <div class="case-section">
        <span class="case-label">ما بنيناه</span>
        <p>روبوت واتساب مُدرَّب على مخزون العقارات والأسعار، يرد فوراً بالعربي والإنجليزي، يأخذ بيانات العميل ومتطلباته، ويحوّل الجاهزين مباشرة للوكيل المناسب.</p>
      </div>
      <div class="case-results">
        <div class="result-metric">
          <span class="result-num">دقيقتان</span>
          <span class="result-lbl">متوسط وقت الرد (من ٤ ساعات)</span>
        </div>
        <div class="result-metric">
          <span class="result-num">+٤٧٪</span>
          <span class="result-lbl">زيادة في معدل تحويل العملاء</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">كيف نعمل معك</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;">من أول جلسة إلى الإطلاق الكامل في أسرع وقت ممكن.</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-num">١</div>
        <h3>نحلل مسار البيع الحالي</h3>
        <p style="color:#42474e;line-height:1.7;">نفهم كيف يصل العملاء إليك، أين يتأخر الرد، وما العقارات الأكثر طلباً. نبني على ما لديك.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٢</div>
        <h3>نبني روبوت واتساب مُدرَّب على عقاراتك</h3>
        <p style="color:#42474e;line-height:1.7;">ندرّب الروبوت على مخزونك وأسعارك وأسلوب تواصل فريقك، يبدو وكأنه أحد وكلائك.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٣</div>
        <h3>إطلاق ومتابعة</h3>
        <p style="color:#42474e;line-height:1.7;">إطلاق مع تدريب الفريق ومراقبة الأداء في المرحلة الأولى. لا تترك وحدك بعد التسليم.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_real-estate_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة شائعة</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا يستطيع الذكاء الاصطناعي أن يفعل لشركتي العقارية في دبي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يستطيع الذكاء الاصطناعي الرد على استفسارات العملاء فور وصولها على واتساب والموقع، تأهيل العملاء وتصنيفهم تلقائياً، مطابقة كل استفسار مع العقارات المناسبة، وإرسال متابعات آلية للعملاء غير المستجيبين. كل هذا بدون تدخل يدوي.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يعمل روبوت واتساب للعقارات تحديداً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الروبوت يستقبل رسائل العملاء على واتساب، يفهم الطلب بالعربي أو الإنجليزي، يجيب بمعلومات العقارات المناسبة، يسأل أسئلة التأهيل، ويحوّل العملاء الجاهزين للوكيل المناسب. فوري ومتاح على مدار الساعة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يعمل الروبوت باللغة العربية بشكل صحيح؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، بشكل كامل. ندرّب الروبوت على العربية والإنجليزي ويتعامل مع كلا اللغتين في نفس المحادثة، حتى الدارجة العربية الشائعة في دبي. مناسب تماماً لسوق دبي المتعدد اللغات.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق بناء الحل وإطلاقه؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعمل على مراحل متسلسلة: تحليل مسار البيع وجمع بيانات العقارات، ثم البناء والاختبار المكثّف، ثم الإطلاق والتدريب ومراقبة الأداء.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما العائد المتوقع على الاستثمار؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">عملاؤنا في العقارات يرون في الغالب زيادة ٣٠-٥٠٪ في معدل تحويل العملاء الأولي، وتوفير ساعات عمل يومية للفريق. العائد الفعلي يعتمد على حجم استفساراتك الشهرية وقيمة الصفقة لديك. نحسبها معاً في جلسة التشخيص المجانية.</div>
      </div>
    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
