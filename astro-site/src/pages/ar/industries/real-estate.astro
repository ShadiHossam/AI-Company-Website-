  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .step-num {
    width: 52px;
    height: 52px;
    background: #1d4ed8;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .step-item h3 {
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }
  @media (max-width: 900px) {
    .re-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .steps-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
  @media (max-width: 580px) {
    .re-stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    .case-results { grid-template-columns: 1fr; }
  }
  .re-tabs { max-width: 980px; margin: 0 auto; }
  .re-tabs-nav {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .re-tab-btn {
    background: #f0f3ff;
    border: 1px solid rgba(0,37,59,0.10);
    color: #42474e;
    font-weight: 700;
    font-size: 0.9375rem;
    padding: 0.7rem 1.5rem;
    border-radius: 100px;
    cursor: pointer;
    transition: background .2s, color .2s, border-color .2s;
    font-family: inherit;
  }
  .re-tab-btn:hover { background: #e7eeff; }
  .re-tab-btn.active {
    background: #00253b;
    color: #fff;
    border-color: #00253b;
  }
  .re-tab-btn:focus-visible { outline: 2px solid #006875; outline-offset: 2px; }
  .re-tab-panel { display: none; }
  .re-tab-panel.active {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .re-tab-img { border-radius: 20px; overflow: hidden; box-shadow: 0 16px 40px rgba(0,59,92,0.10); }
  .re-tab-img img { width: 100%; height: 320px; object-fit: cover; display: block; }
  .re-tab-text h3 { margin-bottom: 0.75rem; }
  .re-tab-text p { color: #42474e; line-height: 1.8; margin: 0; }
  @media (max-width: 760px) {
    .re-tab-panel.active { grid-template-columns: 1fr; }
    .re-tab-img img { height: 220px; }
  }
</style>

<script>
  (function () {
    const wrap = document.querySelector('[data-re-tabs]');
    if (!wrap) return;
    const btns = wrap.querySelectorAll('.re-tab-btn');
    const panels = wrap.querySelectorAll('.re-tab-panel');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-re-tab');
        btns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const targetPanel = wrap.querySelector('[data-re-panel="' + target + '"]');
        if (targetPanel) targetPanel.classList.add('active');
      });
    });
  })();
</script>

