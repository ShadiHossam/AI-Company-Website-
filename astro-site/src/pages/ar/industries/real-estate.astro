  .research-panel { background:#fff; border:1px solid rgba(0,37,59,0.10); border-radius:20px; padding:2rem; margin-top:2rem; }
  .eval-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.5rem; }
  @media(max-width:900px) { .eval-grid { grid-template-columns:1fr 1fr; } .ind-stats-grid, .ind-text-grid { grid-template-columns:1fr 1fr !important; } }
  @media(max-width:600px) { .eval-grid { grid-template-columns:1fr; } .ind-stats-grid, .ind-text-grid { grid-template-columns:1fr !important; } }
</style>

<script>
  (function () {
    const wrap = document.querySelector('[data-re-tabs]');
    if (!wrap) return;
    const btns = wrap.querySelectorAll('.re-tab-btn');
    const panels = wrap.querySelectorAll('.re-tab-panel');
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-re-tab');
        btns.forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
        panels.forEach((p) => p.classList.remove('active'));
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        const targetPanel = wrap.querySelector('[data-re-panel="' + target + '"]');
        if (targetPanel) targetPanel.classList.add('active');
      });
    });
  })();
</script>

</ArBaseLayout>
