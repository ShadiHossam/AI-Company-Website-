---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي للعقارات في دبي | Aegis AI",
    "url": "https://aegisai.ae/ar/industries/real-estate",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://aegisai.ae/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "العقارات", "item": "https://aegisai.ae/ar/industries/real-estate" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي للعقارات في دبي",
    "description": "حلول ذكاء اصطناعي لشركات العقارات في دبي — روبوت واتساب للردود الفورية، تأهيل عملاء آلي، ومطابقة العقارات مع الطلبات.",
    "areaServed": "Dubai",
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ماذا يستطيع الذكاء الاصطناعي أن يفعل لشركتي العقارية في دبي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يستطيع الذكاء الاصطناعي الرد على استفسارات العملاء فور وصولها على واتساب والموقع، تأهيل العملاء وتصنيفهم تلقائياً، مطابقة كل استفسار مع العقارات المناسبة، وإرسال متابعات آلية للعملاء غير المستجيبين — كل هذا بدون تدخل يدوي." }
      },
      {
        "@type": "Question",
        "name": "كيف يعمل روبوت واتساب للعقارات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الروبوت يستقبل رسائل العملاء على واتساب، يفهم الطلب بالعربي أو الإنجليزي، يجيب بمعلومات العقارات المناسبة، يسأل أسئلة التأهيل، ويحوّل العملاء الجاهزين للوكيل المناسب — فوراً وعلى مدار الساعة." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل الروبوت باللغة العربية؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم، بشكل كامل. ندرّب الروبوت على العربية والإنجليزي ويتعامل مع كلا اللغتين في نفس المحادثة. مناسب لسوق دبي المتعدد اللغات." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء الحل وإطلاقه؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نطلق في 3 أسابيع من بدء العمل. الأسبوع الأول لتحليل مسار البيع وجمع البيانات، الثاني للبناء والاختبار، الثالث للإطلاق والتدريب." }
      },
      {
        "@type": "Question",
        "name": "ما العائد المتوقع على الاستثمار؟",
        "acceptedAnswer": { "@type": "Answer", "text": "عملاؤنا في العقارات يرون في الغالب زيادة 30-50% في معدل تحويل العملاء الأولي، وتوفير ساعات عمل يومية للفريق. العائد الفعلي يعتمد على حجم استفساراتك الشهرية وقيمة الصفقة لديك." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي للعقارات في دبي | Aegis AI"
  description="Aegis AI تبني حلول ذكاء اصطناعي لشركات العقارات في دبي — روبوت واتساب للردود الفورية، تأهيل عملاء آلي، وتقارير مبيعات ذكية. ضمان استرداد 100%."
  canonicalPath="/ar/industries/real-estate"
  enPath="/industries/real-estate"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <nav class="page-breadcrumb" style="justify-content:center;margin-bottom:1.5rem;" aria-label="مسار التنقل">
      <a href="/ar">الرئيسية</a><span class="sep">/</span><a href="/ar/industries">القطاعات</a><span class="sep">/</span><strong class="current">العقارات</strong>
    </nav>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">apartment</span>
      العقارات
    </div>
    <h1>ذكاء اصطناعي للعقارات في دبي<br><span class="gradient-text">أسرع في الرد، أعلى في التحويل</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:#42474e;">
      كل دقيقة تأخير في الرد تعني عميلاً محتملاً يتصل بالمنافس. نبني لك روبوت واتساب يرد فوراً بالعربي والإنجليزي، يؤهّل العملاء تلقائياً، ويطابق كل استفسار مع العقار المناسب — على مدار الساعة.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_real-estate_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/ar/results" class="btn-outline">شاهد النتائج</a>
    </div>
  </div>
</header>

<!-- 2. Stats Strip -->
<section style="background:#f8f9fa;padding:2.5rem 0;border-top:1px solid #e8eaed;border-bottom:1px solid #e8eaed;">
  <div class="container">
    <div class="re-stats-grid">
      <div class="stat-item">
        <p class="stat-num">24/7</p>
        <p class="stat-lbl">ردّ فوري بدون توقف</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">+40%</p>
        <p class="stat-lbl">متوسط زيادة معدل التحويل</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">ع + EN</p>
        <p class="stat-lbl">دعم عربي وإنجليزي كامل</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">100%</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</section>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في العقارات</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">ستة تطبيقات عملية تحوّل كيف تتعامل شركتك مع العملاء والمخزون والأداء.</p>
    <div class="use-cases-grid">
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">chat</span>
        <h3 style="margin:1rem 0 0.5rem;">روبوت واتساب للردود الفورية</h3>
        <p style="color:#42474e;line-height:1.7;">يرد على كل استفسار في ثوانٍ — ليلاً ونهاراً، بالعربي والإنجليزي. لا يترك عميلاً ينتظر.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">leaderboard</span>
        <h3 style="margin:1rem 0 0.5rem;">تأهيل العملاء وتصنيفهم</h3>
        <p style="color:#42474e;line-height:1.7;">يسأل الروبوت أسئلة التأهيل تلقائياً ويصنّف العملاء حسب الجاهزية — فريقك يركّز على الصفقات الحقيقية.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">home_work</span>
        <h3 style="margin:1rem 0 0.5rem;">مطابقة العقارات بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">يحلّل الروبوت طلب العميل ويقترح العقارات المناسبة من قاعدة بياناتك فوراً — تجربة شخصية دون جهد يدوي.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">schedule_send</span>
        <h3 style="margin:1rem 0 0.5rem;">متابعة آلية للعملاء</h3>
        <p style="color:#42474e;line-height:1.7;">تسلسلات متابعة تلقائية للعملاء الذين لم يردوا — تذكيرات، عروض جديدة، وتحديثات السوق بدون تدخل يدوي.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">bar_chart</span>
        <h3 style="margin:1rem 0 0.5rem;">لوحة أداء المبيعات</h3>
        <p style="color:#42474e;line-height:1.7;">تقارير لحظية على أداء الوكلاء، معدلات التحويل، ومصادر العملاء — قرارات مبنية على بيانات وليس حدساً.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">translate</span>
        <h3 style="margin:1rem 0 0.5rem;">ذكاء اصطناعي متعدد اللغات</h3>
        <p style="color:#42474e;line-height:1.7;">يتواصل مع عملائك بالعربي والإنجليزي في نفس المحادثة — مثالي لسوق دبي المتنوع.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Case Study -->
<section class="section" style="background:#f0f4ff;padding:4rem 0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:2.5rem;">قصة نجاح حقيقية</h2>
    <div class="case-study-card">
      <div class="case-section">
        <span class="case-label">المشكلة</span>
        <p>وكالة عقارية في دبي كانت تخسر عملاء محتملين لأن وكلاءها لم يتمكنوا من الرد بسرعة كافية — متوسط وقت الرد كان 4 ساعات، وكثير من العملاء كانوا يتحولون للمنافسين في هذه الفترة.</p>
      </div>
      <div class="case-section">
        <span class="case-label">ما بنيناه</span>
        <p>روبوت واتساب مُدرَّب على مخزون العقارات والأسعار، يرد فوراً بالعربي والإنجليزي، يأخذ بيانات العميل ومتطلباته، ويحوّل الجاهزين مباشرة للوكيل المناسب.</p>
      </div>
      <div class="case-results">
        <div class="result-metric">
          <span class="result-num">دقيقتان</span>
          <span class="result-lbl">متوسط وقت الرد (من 4 ساعات)</span>
        </div>
        <div class="result-metric">
          <span class="result-num">+47%</span>
          <span class="result-lbl">زيادة في معدل تحويل العملاء</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">كيف نعمل معك</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;">من أول جلسة إلى الإطلاق في 3 أسابيع.</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-num">١</div>
        <h3>نحلل مسار البيع الحالي</h3>
        <p style="color:#42474e;line-height:1.7;">نفهم كيف يصل العملاء إليك، أين يتأخر الرد، وما العقارات الأكثر طلباً — نبني على ما لديك.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٢</div>
        <h3>نبني روبوت واتساب مُدرَّب على عقاراتك</h3>
        <p style="color:#42474e;line-height:1.7;">ندرّب الروبوت على مخزونك وأسعارك وأسلوب تواصل فريقك — يبدو وكأنه أحد وكلائك.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٣</div>
        <h3>نطلق خلال 3 أسابيع</h3>
        <p style="color:#42474e;line-height:1.7;">إطلاق مع تدريب الفريق ومراقبة الأداء في الأسابيع الأولى — لا تترك وحدك بعد التسليم.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل — الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً — لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ 100% خلال 30 يوماً من التسليم — دون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_real-estate_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة شائعة</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ماذا يستطيع الذكاء الاصطناعي أن يفعل لشركتي العقارية في دبي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يستطيع الذكاء الاصطناعي الرد على استفسارات العملاء فور وصولها على واتساب والموقع، تأهيل العملاء وتصنيفهم تلقائياً، مطابقة كل استفسار مع العقارات المناسبة، وإرسال متابعات آلية للعملاء غير المستجيبين — كل هذا بدون تدخل يدوي.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يعمل روبوت واتساب للعقارات تحديداً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الروبوت يستقبل رسائل العملاء على واتساب، يفهم الطلب بالعربي أو الإنجليزي، يجيب بمعلومات العقارات المناسبة، يسأل أسئلة التأهيل، ويحوّل العملاء الجاهزين للوكيل المناسب — فوراً وعلى مدار الساعة.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يعمل الروبوت باللغة العربية بشكل صحيح؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم، بشكل كامل. ندرّب الروبوت على العربية والإنجليزي ويتعامل مع كلا اللغتين في نفس المحادثة — حتى الدارجة العربية الشائعة في دبي. مناسب تماماً لسوق دبي المتعدد اللغات.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق بناء الحل وإطلاقه؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نطلق في 3 أسابيع من بدء العمل. الأسبوع الأول لتحليل مسار البيع وجمع بيانات العقارات، الثاني للبناء والاختبار المكثّف، الثالث للإطلاق والتدريب ومراقبة الأداء.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما العائد المتوقع على الاستثمار؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">عملاؤنا في العقارات يرون في الغالب زيادة 30-50% في معدل تحويل العملاء الأولي، وتوفير ساعات عمل يومية للفريق. العائد الفعلي يعتمد على حجم استفساراتك الشهرية وقيمة الصفقة لديك — نحسبها معاً في جلسة التشخيص المجانية.</div>
      </div>
    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز لتحويل مبيعات عقاراتك؟</h2>
    <p style="margin-bottom:2rem;opacity:0.9;max-width:500px;margin-inline:auto;line-height:1.7;">احجز جلسة تشخيص مجانية — نحلل مسار البيع لديك ونقترح الحل الأنسب. بدون التزام.</p>
    <button onclick="openModal(this)" data-source="ar_real-estate_cta" class="btn-primary" style="background:#fff;color:#1d4ed8;">ابدأ الآن ←</button>
  </div>
</section>

<style>
  .re-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: #1d4ed8;
    margin: 0 0 0.25rem;
  }
  .stat-lbl {
    color: #42474e;
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }
  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .case-study-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }
  .case-label {
    display: inline-block;
    background: #e7eeff;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .case-section p {
    color: #42474e;
    line-height: 1.8;
    margin: 0;
  }
  .case-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e8eaed;
  }
  .result-metric {
    text-align: center;
  }
  .result-num {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: #1d4ed8;
  }
  .result-lbl {
    display: block;
    font-size: 0.875rem;
    color: #42474e;
    margin-top: 0.25rem;
  }
  .steps-grid {
    display: grid;
