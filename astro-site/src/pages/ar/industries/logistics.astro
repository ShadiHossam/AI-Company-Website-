---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي للخدمات اللوجستية في الإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/industries/logistics",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://aegisai.ae/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "اللوجستيات", "item": "https://aegisai.ae/ar/industries/logistics" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي للخدمات اللوجستية في الإمارات",
    "description": "حلول ذكاء اصطناعي لشركات الشحن واللوجستيات في الإمارات: تتبع آلي، تحسين المسارات، وتواصل مع العملاء بدون جهد يدوي.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "كيف يُحسّن الذكاء الاصطناعي مسارات التوصيل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يحلل النظام مسارات التوصيل الحالية وبيانات حركة المرور وأوقات التسليم وكثافة الطلبات في كل منطقة، ثم يقترح المسار الأمثل لكل سائق يومياً. النتيجة: أقل وقود، أسرع توصيل، وأقل إجهاداً على الأسطول." }
      },
      {
        "@type": "Question",
        "name": "هل تُرسَل إشعارات التوصيل للعملاء تلقائياً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. عندما يخرج الشحن من المستودع، وعندما يقترب من الوجهة، وعند التسليم، كل هذا يُرسَل تلقائياً للعميل عبر واتساب أو رسالة نصية. لا مكالمات يدوية، لا أسئلة متكررة." }
      },
      {
        "@type": "Question",
        "name": "ما حجم الشركة المناسب لهذا الحل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الحل مناسب من 5 مركبات فأكثر. الشركات الصغيرة تستفيد من تحسين المسارات وإشعارات العملاء، والشركات الكبيرة تضيف تتبع الأسطول الكامل وتحليلات الأداء المتقدمة." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل النظام بدون GPS في المركبات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يفضّل وجود GPS لتتبع الأسطول لحظياً. إذا لم يكن لديك أجهزة GPS، نساعدك في اختيار حلول منخفضة التكلفة تتكامل مع النظام. بعض الميزات مثل تحسين المسارات وإشعارات العملاء تعمل بدون GPS." }
      },
      {
        "@type": "Question",
        "name": "كيف يساعد الذكاء الاصطناعي في معالجة مستندات الشحن؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني نظاماً يقرأ بوالص الشحن وفواتير الجمارك ووثائق التخليص تلقائياً، يستخرج البيانات، ويُدخلها في نظامك. ساعات عمل يدوي تتحول لثوانٍ معالجة آلية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي للخدمات اللوجستية في الإمارات | Aegis AI"
  description="Aegis AI تبني حلول ذكاء اصطناعي لشركات الشحن واللوجستيات في الإمارات: تتبع آلي، تحسين المسارات، وتواصل مع العملاء بالعربي والإنجليزي. ضمان 100%."
  canonicalPath="/ar/industries/logistics"
  enPath="/industries/logistics"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar/industries" style="color:inherit;text-decoration:none;opacity:0.65;">القطاعات</a><span style="opacity:0.4;padding:0 4px;"> / </span>اللوجستيات</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">local_shipping</span>
      اللوجستيات
    </div>
    <h1>ذكاء اصطناعي للخدمات اللوجستية<br><span class="gradient-text">توصيل أسرع، تكاليف أقل</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:#42474e;">
      تكاليف الوقود ترتفع، العملاء يتصلون يسألون عن شحناتهم، ومسارات التوصيل تُخطَّط يدوياً كل يوم. نبني لك نظاماً ذكياً يُحسّن المسارات تلقائياً ويُرسل إشعارات للعملاء دون أي تدخل يدوي.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_logistics_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/ar/results" class="btn-outline">شاهد النتائج</a>
    </div>
  </div>
</header>

<!-- 2. Stats Strip -->
<section style="background:#f8f9fa;padding:2.5rem 0;border-top:1px solid #e8eaed;border-bottom:1px solid #e8eaed;">
  <div class="container">
    <div class="logi-stats-grid">
      <div class="stat-item">
        <p class="stat-num">-٢٠٪</p>
        <p class="stat-lbl">تكاليف الوقود في المتوسط</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">لحظي</p>
        <p class="stat-lbl">تتبع الأسطول في الوقت الفعلي</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">آلي</p>
        <p class="stat-lbl">إشعارات التوصيل للعملاء</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</section>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في اللوجستيات</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">خمسة تطبيقات عملية تخفّض التكاليف وتُحسّن تجربة العملاء في الوقت ذاته.</p>
    <div class="use-cases-grid">
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">route</span>
        <h3 style="margin:1rem 0 0.5rem;">تحسين المسارات بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">يحلل الطلبات اليومية وحركة المرور ليُخطّط أقصر مسار لكل سائق. يوفّر الوقود ويوصّل أكثر بأقل تكلفة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">notifications_active</span>
        <h3 style="margin:1rem 0 0.5rem;">إشعارات توصيل آلية عبر واتساب</h3>
        <p style="color:#42474e;line-height:1.7;">يُرسل للعملاء تحديثات تلقائية: خروج الشحن، وقت الوصول المتوقع، تأكيد التسليم. بدون مكالمات يدوية.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">directions_car</span>
        <h3 style="margin:1rem 0 0.5rem;">لوحة تتبع الأسطول</h3>
        <p style="color:#42474e;line-height:1.7;">ترى جميع مركباتك على خريطة لحظية، مكانها وسرعتها وحالة التوصيلات، من شاشة واحدة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">warehouse</span>
        <h3 style="margin:1rem 0 0.5rem;">تنبؤ بالطلب للمستودع</h3>
        <p style="color:#42474e;line-height:1.7;">يتنبأ بكميات الشحن المتوقعة بناءً على البيانات التاريخية، تُخطّط الطاقة البشرية والمركبات مسبقاً.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="font-size:32px;color:#2563eb;direction:ltr;" aria-hidden="true">description</span>
        <h3 style="margin:1rem 0 0.5rem;">معالجة مستندات الشحن</h3>
        <p style="color:#42474e;line-height:1.7;">يقرأ بوالص الشحن ومستندات الجمارك تلقائياً ويُدخل البيانات في نظامك. ساعات عمل يدوي تتحول لثوانٍ.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Case Study -->
<section class="section" style="background:#f0f4ff;padding:4rem 0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:2.5rem;">قصة نجاح حقيقية</h2>
    <div class="case-study-card">
      <div class="case-section">
        <span class="case-label">المشكلة</span>
        <p>شركة لوجستيات في دبي كانت تنفق ١٨٠٬٠٠٠ درهم سنوياً على الوقود، وفريقها يُمضي ساعات يومياً في تخطيط المسارات يدوياً والرد على اتصالات العملاء يسألون عن شحناتهم.</p>
      </div>
      <div class="case-section">
        <span class="case-label">ما بنيناه</span>
        <p>نظام تحسين مسارات يومي يحلّل جميع الطلبات ويُوزّع أفضل مسار على كل سائق، مع إشعارات واتساب تلقائية للعملاء في كل مرحلة توصيل.</p>
      </div>
      <div class="case-results">
        <div class="result-metric">
          <span class="result-num">-٢٢٪</span>
          <span class="result-lbl">تكاليف الوقود سنوياً</span>
        </div>
        <div class="result-metric">
          <span class="result-num">صفر</span>
          <span class="result-lbl">مكالمات يدوية لتحديث العملاء يومياً</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">كيف نعمل معك</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;">من تحليل عملياتك إلى نظام يعمل من أول يوم.</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-num">١</div>
        <h3>تحليل مسارات ومستودعات الشركة</h3>
        <p style="color:#42474e;line-height:1.7;">نفهم مناطق التوصيل، حجم الأسطول، وأنماط الطلب الحالية. نبني النظام على بياناتك الفعلية.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٢</div>
        <h3>بناء نظام تتبع وتحسين ذكي</h3>
        <p style="color:#42474e;line-height:1.7;">نبني لوحة التتبع وخوارزمية تحسين المسارات ونظام الإشعارات، مُدمجة مع أنظمتك الحالية.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٣</div>
        <h3>إطلاق + تدريب الفريق</h3>
        <p style="color:#42474e;line-height:1.7;">إطلاق مع تدريب السائقين والمشرفين على النظام. يبدأ الفريق العمل باستقلالية كاملة بسرعة.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_logistics_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة شائعة</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يُحسّن الذكاء الاصطناعي مسارات التوصيل تحديداً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يحلل النظام مسارات التوصيل الحالية وبيانات حركة المرور وأوقات التسليم وكثافة الطلبات في كل منطقة، ثم يقترح المسار الأمثل لكل سائق يومياً. النتيجة: أقل وقود، أسرع توصيل، وأقل إجهاداً على الأسطول.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل تُرسَل إشعارات التوصيل للعملاء تلقائياً؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعم. عند خروج الشحن من المستودع، عند الاقتراب من الوجهة، وعند التسليم، كل هذا يُرسَل تلقائياً للعميل عبر واتساب أو رسالة نصية. لا مكالمات يدوية، لا أسئلة متكررة من العملاء.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما حجم الشركة المناسب لهذا الحل؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الحل مناسب من 5 مركبات فأكثر. الشركات الصغيرة تستفيد من تحسين المسارات وإشعارات العملاء، والشركات الكبيرة تضيف تتبع الأسطول الكامل وتحليلات الأداء المتقدمة وتنبؤ الطلب.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يعمل النظام بدون GPS في المركبات؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يفضّل وجود GPS لتتبع الأسطول لحظياً. إذا لم يكن لديك أجهزة GPS، نساعدك في اختيار حلول منخفضة التكلفة تتكامل مع النظام. ميزات تحسين المسارات وإشعارات العملاء تعمل حتى بدون GPS.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يساعد الذكاء الاصطناعي في معالجة مستندات الشحن؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نبني نظاماً يقرأ بوالص الشحن وفواتير الجمارك ووثائق التخليص تلقائياً، يستخرج البيانات، ويُدخلها في نظامك. ساعات عمل يدوي تتحول لثوانٍ معالجة آلية. يعمل مع المستندات العربية والإنجليزية.</div>
      </div>
    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز لخفض تكاليف التوصيل؟</h2>
    <p style="margin-bottom:2rem;max-width:500px;margin-inline:auto;line-height:1.7;">احجز جلسة تشخيص مجانية، نحلل مسارات أسطولك ونقترح أين يوفّر الذكاء الاصطناعي أكثر. بدون التزام.</p>
    <button onclick="openModal(this)" data-source="ar_logistics_cta" class="btn-primary">ابدأ الآن ←</button>
  </div>
</section>

<style>
  .logi-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: #1d4ed8;
    margin: 0 0 0.25rem;
  }
  .stat-lbl {
    color: #42474e;
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }
  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .case-study-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }
  .case-label {
    display: inline-block;
    background: #e7eeff;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .case-section p {
    color: #42474e;
    line-height: 1.8;
    margin: 0;
  }
  .case-results {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #e8eaed;
  }
  .result-metric {
    text-align: center;
  }
  .result-num {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: #1d4ed8;
  }
  .result-lbl {
    display: block;
    font-size: 0.875rem;
    color: #42474e;
    margin-top: 0.25rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .step-num {
    width: 52px;
    height: 52px;
    background: #1d4ed8;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
