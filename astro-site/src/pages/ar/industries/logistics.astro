---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي للخدمات اللوجستية في الإمارات | Lenoo AI",
    "url": "https://lenooai.com/ar/industries/logistics",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://lenooai.com/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://lenooai.com/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "اللوجستيات", "item": "https://lenooai.com/ar/industries/logistics" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي للخدمات اللوجستية في الإمارات",
    "description": "حلول ذكاء اصطناعي لشركات الشحن واللوجستيات في الإمارات: تتبع آلي، تحسين المسارات، وتواصل مع العملاء بدون جهد يدوي.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Lenoo AI", "url": "https://lenooai.com" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "كيف يُحسّن الذكاء الاصطناعي مسارات التوصيل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يحلل النظام مسارات التوصيل الحالية وبيانات حركة المرور وأوقات التسليم وكثافة الطلبات في كل منطقة، ثم يقترح المسار الأمثل لكل سائق يومياً. النتيجة: أقل وقود، أسرع توصيل، وأقل إجهاداً على الأسطول." }
      },
      {
        "@type": "Question",
        "name": "هل تُرسَل إشعارات التوصيل للعملاء تلقائياً؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نعم. عندما يخرج الشحن من المستودع، وعندما يقترب من الوجهة، وعند التسليم، كل هذا يُرسَل تلقائياً للعميل عبر واتساب أو رسالة نصية. لا مكالمات يدوية، لا أسئلة متكررة." }
      },
      {
        "@type": "Question",
        "name": "ما حجم الشركة المناسب لهذا الحل؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الحل مناسب من 5 مركبات فأكثر. الشركات الصغيرة تستفيد من تحسين المسارات وإشعارات العملاء، والشركات الكبيرة تضيف تتبع الأسطول الكامل وتحليلات الأداء المتقدمة." }
      },
      {
        "@type": "Question",
        "name": "هل يعمل النظام بدون GPS في المركبات؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يفضّل وجود GPS لتتبع الأسطول لحظياً. إذا لم يكن لديك أجهزة GPS، نساعدك في اختيار حلول منخفضة التكلفة تتكامل مع النظام. بعض الميزات مثل تحسين المسارات وإشعارات العملاء تعمل بدون GPS." }
      },
      {
        "@type": "Question",
        "name": "كيف يساعد الذكاء الاصطناعي في معالجة مستندات الشحن؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني نظاماً يقرأ بوالص الشحن وفواتير الجمارك ووثائق التخليص تلقائياً، يستخرج البيانات، ويُدخلها في نظامك. ساعات عمل يدوي تتحول لثوانٍ معالجة آلية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي للخدمات اللوجستية في الإمارات | Lenoo AI"
  description="Lenoo AI، وكالة الذكاء الاصطناعي في دبي، تبني حلول ذكاء اصطناعي لشركات الشحن واللوجستيات في الإمارات: تتبع آلي، تحسين المسارات، وتواصل آلي مع العملاء."
  canonicalPath="/ar/industries/logistics"
  enPath="/industries/logistics"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar#industries-heading" style="color:inherit;text-decoration:none;opacity:0.65;">القطاعات</a><span style="opacity:0.4;padding:0 4px;"> / </span>اللوجستيات</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">local_shipping</span>
      اللوجستيات
    </div>
    <h1>ذكاء اصطناعي للخدمات اللوجستية<br><span class="gradient-text">توصيل أسرع، تكاليف أقل</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:rgba(255,255,255,0.72);">
      تكاليف الوقود ترتفع، العملاء يتصلون يسألون عن شحناتهم، ومسارات التوصيل تُخطَّط يدوياً كل يوم. نبني لك نظاماً ذكياً يُحسّن المسارات تلقائياً ويُرسل إشعارات للعملاء دون أي تدخل يدوي.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_logistics_hero" class="btn-primary">احجز استشارة مجانية ←</button>
    </div>
  </div>
</header>

<!-- IMAGE BANNER + STATS -->
<div style="position:relative; overflow:hidden;">
  <img src="https://images.unsplash.com/photo-1494412574643-ff11b0a5c1c3?w=1600&q=80&auto=format&fit=crop" alt="الخدمات اللوجستية وإدارة سلسلة التوريد بالذكاء الاصطناعي في الإمارات" loading="eager" fetchpriority="high" width="1600" height="320" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.55) 0%,rgba(0,19,32,0.18) 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
  <div style="position:relative; padding:3rem 2rem;">
    <div class="glass-dark logi-stats-grid" style="max-width:920px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem;">
      <div class="stat-item">
        <p class="stat-num">-٢٠٪</p>
        <p class="stat-lbl">تكاليف الوقود في المتوسط</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">لحظي</p>
        <p class="stat-lbl">تتبع الأسطول في الوقت الفعلي</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">آلي</p>
        <p class="stat-lbl">إشعارات التوصيل للعملاء</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</div>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في اللوجستيات</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">خمسة تطبيقات عملية تخفّض التكاليف وتُحسّن تجربة العملاء في الوقت ذاته.</p>
    <div class="feature-ledger">
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">route</span>
        <h3>تحسين المسارات بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">يحلل الطلبات اليومية وحركة المرور ليُخطّط أقصر مسار لكل سائق. يوفّر الوقود ويوصّل أكثر بأقل تكلفة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">notifications_active</span>
        <h3>إشعارات توصيل آلية عبر واتساب</h3>
        <p style="color:#42474e;line-height:1.7;">يُرسل للعملاء تحديثات تلقائية: خروج الشحن، وقت الوصول المتوقع، تأكيد التسليم. بدون مكالمات يدوية.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">directions_car</span>
        <h3>لوحة تتبع الأسطول</h3>
        <p style="color:#42474e;line-height:1.7;">ترى جميع مركباتك على خريطة لحظية، مكانها وسرعتها وحالة التوصيلات، من شاشة واحدة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">warehouse</span>
        <h3>تنبؤ بالطلب للمستودع</h3>
        <p style="color:#42474e;line-height:1.7;">يتنبأ بكميات الشحن المتوقعة بناءً على البيانات التاريخية، تُخطّط الطاقة البشرية والمركبات مسبقاً.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">description</span>
        <h3>معالجة مستندات الشحن</h3>
        <p style="color:#42474e;line-height:1.7;">يقرأ بوالص الشحن ومستندات الجمارك تلقائياً ويُدخل البيانات في نظامك. ساعات عمل يدوي تتحول لثوانٍ.</p>
      </div>
    </div>
  </div>
</section>

<!-- CHALLENGES -->
<section id="challenges" class="section" style="background:#e7eeff;">
  <div class="container">
    <div class="section-header">
      <h2>ثلاثة أمور تُخبرنا بها شركات اللوجستيات في الإمارات دائماً</h2>
      <p>كل شركة لوجستيات مختلفة. لكن المشاكل التي تدفعها للتواصل معنا غالباً هي نفسها. ولكل واحدة حل.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="card" style="padding:2.5rem;">
        <div class="challenge-icon" style="background:rgba(186,26,26,0.08);">
          <span class="material-symbols-outlined" style="direction:ltr;color:#ba1a1a;" aria-hidden="true">schedule</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">"مُخططو المسارات لدينا يبدأون كل صباح ببناء المسارات يدوياً على إكسل."</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin-bottom:1rem;">أربعة أشخاص. ساعتان لكل واحد. كل يوم. هذا ٨ ساعات عمل على مهمة يُنجزها الذكاء الاصطناعي في ٤ دقائق، بينما ينتظر العملاء نوافذ التسليم ويجلس السائقون بلا عمل.</p>
        <p class="fix-lead">الحل: تحسين المسارات بالذكاء الاصطناعي يُخطط خلال دقائق، لا ساعات</p>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">يُعيد النظام حساب كل مسار كل صباح باستخدام حركة المرور اللحظية وتكاليف سالك ونوافذ التسليم. المُخططون يراجعون ويوافقون بدلاً من البناء من الصفر.</p>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div class="challenge-icon" style="background:rgba(245,158,11,0.10);">
          <span class="material-symbols-outlined" style="direction:ltr;color:#b45309;" aria-hidden="true">visibility_off</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">"لا رؤية لحظية لأسطولنا بين الاستلام والتسليم."</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin-bottom:1rem;">سائق يختفي عن الرد، توصيل متأخر، عميل يتصل. فريق العمليات بلا إجابة. فجوات الرؤية تُكلّفك ثقة العملاء ووقوداً إضافياً عندما يسلك السائقون مساراً غير مثالي لا يراه أحد.</p>
        <p class="fix-lead">الحل: إدارة الأسطول بالذكاء الاصطناعي تمنحك خريطة لحظية</p>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">كل مركبة تُبلّغ عن موقعها وحالتها ووقت وصولها المتوقع باستمرار. فريق العمليات يرى الاستثناءات لحظة حدوثها، لا من خلال عميل غاضب.</p>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div class="challenge-icon" style="background:rgba(0,37,59,0.08);">
          <span class="material-symbols-outlined" style="direction:ltr;color:#006875;" aria-hidden="true">chat</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">"فريق خدمة العملاء يجيب على 'أين شحنتي؟' ٦٠ مرة يومياً."</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin-bottom:1rem;">موظفان. نفس السؤال. طوال اليوم. بالعربي والإنجليزي. هذه ليست خدمة عملاء، بل وظيفة إبلاغ يستطيع الذكاء الاصطناعي تولّيها تلقائياً، ليتفرّغ فريقك للمحادثات التي تحتاج فعلاً إلى إنسان.</p>
        <p class="fix-lead">الحل: تواصل العملاء بالذكاء الاصطناعي يُجيب قبل أن يتصلوا</p>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">تحديثات آلية بالعربي والإنجليزي تصل عند الشحن، وأثناء الطريق، وعند التسليم. معظم العملاء لا يحتاجون للسؤال، لأن الإجابة وصلتهم مسبقاً.</p>
      </div>
    </div>
  </div>
</section>

<!-- KEY APPLICATIONS -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>أين يُحدث الذكاء الاصطناعي أكبر أثر</h2>
    </div>
    <div class="bento-grid bento-grid-4">
      <div class="card" style="padding:2rem;">
        <div class="key-app-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">route</span>
        </div>
        <h4 style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">تحسين المسارات الديناميكي</h4>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin-bottom:0.75rem;">نماذج الذكاء الاصطناعي تُراعي حركة المرور اللحظية، وتكاليف بوابات سالك، وازدحام الموانئ، وسعة المركبات، ونوافذ التسليم لإعادة حساب أكفأ المسارات فوراً. مبني لأنماط طرق الإمارات، لا نماذج عالمية عامة.</p>
        <span class="solution-tag">مثال: نظام UPS ORION يوفّر ٤٠٠ مليون دولار سنوياً في الوقود</span>
      </div>
      <div class="card" style="padding:2rem;">
        <div class="key-app-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">inventory_2</span>
        </div>
        <h4 style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">التنبؤ بالطلب</h4>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin-bottom:0.75rem;">التنبؤ بذروات الطلب الإقليمية لتموضع المخزون مسبقاً. يُقلّص الشراء الطارئ وأزمات السعة في اللحظة الأخيرة.</p>
        <span class="solution-tag">DHL تتنبأ بطلب الشحن الجوي قبل ٣٠ يوماً</span>
      </div>
      <div class="card" style="padding:2rem;">
        <div class="key-app-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">precision_manufacturing</span>
        </div>
        <h4 style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">صيانة تنبؤية</h4>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin-bottom:0.75rem;">حساسات إنترنت الأشياء والذكاء الاصطناعي تتنبأ بأعطال مركبات الأسطول قبل حدوثها، فتُلغي التوقف المفاجئ.</p>
        <span class="solution-tag">تُقلّص توقف الأسطول بنسبة تصل إلى ٥٠٪</span>
      </div>
      <div class="card" style="padding:2rem;">
        <div class="key-app-icon">
          <span class="material-symbols-outlined" style="direction:ltr;" aria-hidden="true">smart_toy</span>
        </div>
        <h4 style="font-weight:700; color:#00253b; margin-bottom:0.5rem;">أتمتة المستودعات</h4>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin-bottom:0.75rem;">تخزين ذكي يضع المنتجات المناسبة في المواقع المناسبة. تحسين مسار الالتقاط يُقلّص وقت التنقل. جرد آلي بدل العد اليدوي.</p>
        <span class="solution-tag">مستودعات الذكاء الاصطناعي تلتقط بسرعة ٣ أضعاف العمل اليدوي</span>
      </div>
    </div>
  </div>
</section>

<!-- 3b. Delivery Lifecycle Tabs (interactive) -->
<section class="section" style="padding-top:0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">أين يتدخل الذكاء الاصطناعي في رحلة الشحنة</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:2.5rem;max-width:560px;margin-inline:auto;">اختر مرحلة من مراحل الشحنة لترى كيف يعمل النظام فيها.</p>
    <div class="logi-tabs" data-logi-tabs>
      <div class="logi-tabs-nav" role="tablist" aria-label="مراحل الشحنة">
        <button type="button" class="logi-tab-btn active" data-logi-tab="load" role="tab" aria-selected="true">التحميل من المستودع</button>
        <button type="button" class="logi-tab-btn" data-logi-tab="transit" role="tab" aria-selected="false">في الطريق</button>
        <button type="button" class="logi-tab-btn" data-logi-tab="deliver" role="tab" aria-selected="false">التسليم</button>
      </div>
      <div class="logi-tabs-body">
        <div class="logi-tab-panel active" data-logi-panel="load">
          <div class="logi-tab-img">
            <img src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?w=800&q=80&auto=format&fit=crop" alt="عامل مستودع يفحص الشحنات بجهاز مسح الباركود قبل التحميل" loading="lazy" width="800" height="500" />
          </div>
          <div class="logi-tab-text">
            <h3>ترتيب الشحنات وتوزيع المسارات</h3>
            <p>يُوزّع النظام الطلبات على السائقين حسب أقصر مسار وأكبر سعة تحميل، قبل أن تغادر أول شاحنة المستودع.</p>
          </div>
        </div>
        <div class="logi-tab-panel" data-logi-panel="transit">
          <div class="logi-tab-img">
