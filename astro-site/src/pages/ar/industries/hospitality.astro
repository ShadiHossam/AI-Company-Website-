---
export const prerender = false;
import ArBaseLayout from '../../../layouts/ArBaseLayout.astro';

const ldJson = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "الذكاء الاصطناعي للفنادق والضيافة في الإمارات | Aegis AI",
    "url": "https://aegisai.ae/ar/industries/hospitality",
    "inLanguage": "ar",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://aegisai.ae/ar" },
      { "@type": "ListItem", "position": 2, "name": "القطاعات", "item": "https://aegisai.ae/ar/industries" },
      { "@type": "ListItem", "position": 3, "name": "الضيافة", "item": "https://aegisai.ae/ar/industries/hospitality" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "الذكاء الاصطناعي لقطاع الضيافة في الإمارات",
    "description": "كونسيرج ذكاء اصطناعي لفنادق الإمارات، يرد على الضيوف 24/7 بالعربي والإنجليزي والهندي، يستقبل الطلبات، ويوصي بالخدمات.",
    "areaServed": {"@type": "Country", "name": "United Arab Emirates"},
    "provider": { "name": "Aegis AI", "url": "https://aegisai.ae" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "ما الفرق بين الكونسيرج البشري والكونسيرج الذكي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "الكونسيرج الذكي يتولى الطلبات الروتينية المتكررة: طلب الغرف، ساعات المطعم، الخدمات، الاستفسارات الشائعة. يعمل بشكل فوري وعلى مدار الساعة. الكونسيرج البشري يتفرّغ للطلبات المعقدة التي تحتاج حكماً بشرياً وعلاقات شخصية." }
      },
      {
        "@type": "Question",
        "name": "هل يستطيع الكونسيرج الذكي التعامل مع شكاوى الضيوف؟",
        "acceptedAnswer": { "@type": "Answer", "text": "يستطيع التعامل مع الشكاوى البسيطة وتسجيلها وتوجيهها للفريق المناسب فوراً. الشكاوى الحساسة يحولها للكونسيرج البشري مع ملخص كامل للمحادثة. لا يضيع شيء." }
      },
      {
        "@type": "Question",
        "name": "ما اللغات التي يدعمها الكونسيرج الذكي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "ندرّبه على اللغات التي تحتاجها. معظم فنادق دبي نبني لها دعماً للعربية والإنجليزية والهندية. يمكن إضافة لغات أخرى حسب جنسيات ضيوفك." }
      },
      {
        "@type": "Question",
        "name": "كم يستغرق بناء الكونسيرج الذكي لفندقنا؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نطلق بشكل تدريجي بعد مرحلة تحليل أنواع طلبات الضيوف الشائعة وبناء قاعدة المعرفة، ثم مرحلة الاختبار والإطلاق التدريجي على الضيوف الفعليين." }
      },
      {
        "@type": "Question",
        "name": "كيف يتكامل الكونسيرج الذكي مع نظام إدارة الفندق الحالي؟",
        "acceptedAnswer": { "@type": "Answer", "text": "نبني التكامل مع الأنظمة الشائعة مثل Opera وMews وLighthouse. إذا كان فندقك يستخدم نظاماً مختلفاً، نفحص إمكانية التكامل في جلسة التشخيص المجانية." }
      }
    ]
  }
];
---

<ArBaseLayout
  title="الذكاء الاصطناعي للفنادق والضيافة في الإمارات | Aegis AI"
  description="Aegis AI، وكالة الذكاء الاصطناعي في دبي، تبني كونسيرج ذكاء اصطناعي للفنادق في الإمارات، يرد على الضيوف على مدار الساعة بالعربي والإنجليزي، يستقبل الطلبات، ويوصي بالخدمات. ضمان استرداد 100%."
  canonicalPath="/ar/industries/hospitality"
  enPath="/industries/hospitality"
  ldJson={ldJson}
>

<!-- 1. Page Hero -->
<header class="page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="مسار التنقل"><a href="/ar" style="color:inherit;text-decoration:none;opacity:0.65;">الرئيسية</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/ar#industries-heading" style="color:inherit;text-decoration:none;opacity:0.65;">القطاعات</a><span style="opacity:0.4;padding:0 4px;"> / </span>الضيافة</div>
    <div class="badge badge-cyan" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:16px;direction:ltr;" aria-hidden="true">hotel</span>
      الضيافة
    </div>
    <h1>ذكاء اصطناعي لقطاع الضيافة في دبي<br><span class="gradient-text">كونسيرج لا ينام أبداً</span></h1>
    <p style="max-width:640px;margin:1.5rem auto;line-height:1.8;color:rgba(255,255,255,0.72);">
      ضيوفك يحتاجون مساعدة في أي وقت، ليلاً، في عطلة نهاية الأسبوع، وبلغات مختلفة. نبني لك كونسيرج ذكي يرد فوراً بالعربي والإنجليزي والهندي، يعالج الطلبات تلقائياً، ويترك فريقك يركّز على ما يُحدث فرقاً حقيقياً.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="ar_hospitality_hero" class="btn-primary">احجز استشارة مجانية ←</button>
      <a href="/ar/results" class="btn-outline">شاهد النتائج</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER + STATS -->
<div style="position:relative; overflow:hidden;">
  <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1600&q=80&auto=format&fit=crop" alt="ردهة فندق فاخر تمثل الضيافة المدعومة بالذكاء الاصطناعي" loading="eager" fetchpriority="high" width="1600" height="320" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 30%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.55) 0%,rgba(0,19,32,0.18) 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.40));"></div>
  <div style="position:relative; padding:3rem 2rem;">
    <div class="glass-dark hosp-stats-grid" style="max-width:920px; margin:0 auto; border-radius:20px; padding:2rem 2.5rem;">
      <div class="stat-item">
        <p class="stat-num">٨٠٪</p>
        <p class="stat-lbl">طلبات معالجة آلياً</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">٢٤/٧</p>
        <p class="stat-lbl">خدمة بدون توقف</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">٣ لغات</p>
        <p class="stat-lbl">عربي، إنجليزي، هندي</p>
      </div>
      <div class="stat-item">
        <p class="stat-num">١٠٠٪</p>
        <p class="stat-lbl">ضمان استرداد إذا لم ترضَ</p>
      </div>
    </div>
  </div>
</div>

<!-- 3. AI Use Cases -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">ما يفعله الذكاء الاصطناعي في الضيافة</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;max-width:560px;margin-inline:auto;">خمسة تطبيقات عملية تحوّل تجربة الضيف وتُحرّر فريقك من المهام المتكررة.</p>
    <div class="feature-ledger">
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">support_agent</span>
        <h3>كونسيرج ذكي ٢٤/٧</h3>
        <p style="color:#42474e;line-height:1.7;">يرد على الضيوف عبر واتساب وشات الموقع في ثوانٍ، بغض النظر عن الوقت أو اللغة أو ازدحام الفريق.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">room_service</span>
        <h3>أتمتة طلبات الضيوف</h3>
        <p style="color:#42474e;line-height:1.7;">طلبات الغرف، الصيانة، الاستيقاظ المبكر. يسجّلها الكونسيرج الذكي ويحولها للفريق المناسب فوراً بدون أخطاء.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">reviews</span>
        <h3>تحليل آراء الضيوف</h3>
        <p style="color:#42474e;line-height:1.7;">يجمع آراء الضيوف ويحللها تلقائياً، يكشف الأنماط المتكررة قبل أن تتحول لمشكلة في التقييمات العامة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">trending_up</span>
        <h3>إدارة الإيرادات بالذكاء الاصطناعي</h3>
        <p style="color:#42474e;line-height:1.7;">تحليل بيانات الإشغال والمنافسين لاقتراح تسعير ديناميكي، تزيد الإيراد في أوقات الذروة وتُحسّن الإشغال في الهادئة.</p>
      </div>
      <div class="card">
        <span class="material-symbols-outlined" style="color:#2563eb;direction:ltr;" aria-hidden="true">language</span>
        <h3>تواصل متعدد اللغات</h3>
        <p style="color:#42474e;line-height:1.7;">يتواصل مع ضيوفك بلغتهم: عربي، إنجليزي، هندي، وإضافة أي لغة يحتاجها فندقك. كل ضيف يشعر أنه في المنزل.</p>
      </div>
    </div>
  </div>
</section>

<!-- 4. Case Study -->
<section class="section" style="background:#f0f4ff;padding:4rem 0;">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:2.5rem;">قصة نجاح حقيقية</h2>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:2.5rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1543325042-c67825847491?w=1200&q=80&auto=format&fit=crop" alt="مكتب استقبال فندقي حيث يتم استقبال الضيوف وتلبية طلباتهم" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="case-study-card">
      <div class="case-section">
        <span class="case-label">المشكلة</span>
        <p>مجموعة فنادق في دبي كان فريق الكونسيرج لديها يغرق في طلبات متكررة: ساعات المطعم، خدمة الغرف، الاستفسارات عن الخدمات. مما جعلهم أقل تركيزاً على الضيوف الذين يحتاجون مساعدة فعلية.</p>
      </div>
      <div class="case-section">
        <span class="case-label">ما بنيناه</span>
        <p>كونسيرج ذكي عبر واتساب وشات الموقع، مُدرَّب على كل خدمات الفندق وأسئلته الشائعة، يتعامل بالعربي والإنجليزي والهندي، ويحوّل الحالات المعقدة للفريق البشري مع ملخص المحادثة.</p>
      </div>
      <div class="case-results">
        <div class="result-metric">
          <span class="result-num">٨٠٪</span>
          <span class="result-lbl">من الطلبات الروتينية تُعالَج تلقائياً</span>
        </div>
        <div class="result-metric">
          <span class="result-num">تفرّغ كامل</span>
          <span class="result-lbl">الفريق يركّز على الطلبات المعقدة</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 5. How It Works -->
<section class="section">
  <div class="container">
    <h2 style="text-align:center;margin-bottom:0.75rem;">كيف نعمل معك</h2>
    <p style="text-align:center;color:#42474e;margin-bottom:3rem;">من جلسة التشخيص إلى إطلاق الكونسيرج بشكل تدريجي ومحكوم.</p>
    <div class="steps-grid">
      <div class="step-item">
        <div class="step-num">١</div>
        <h3>تحليل أنواع طلبات الضيوف</h3>
        <p style="color:#42474e;line-height:1.7;">نحلل أكثر الطلبات تكراراً لدى ضيوفك، واللغات التي يتواصلون بها، وأوقات الذروة. نبني الكونسيرج على هذه البيانات.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٢</div>
        <h3>بناء كونسيرج مُدرَّب على خدمات فندقك</h3>
        <p style="color:#42474e;line-height:1.7;">ندرّب الكونسيرج على كل خدماتك وأسعارك وقواعد فندقك، يردّ بصوت فندقك وليس كروبوت عام.</p>
      </div>
      <div class="step-item">
        <div class="step-num">٣</div>
        <h3>إطلاق تدريجي مع مراقبة</h3>
        <p style="color:#42474e;line-height:1.7;">إطلاق تدريجي مع مراقبة مستمرة في الأسابيع الأولى. نضبط الأداء بناءً على محادثات الضيوف الفعليين.</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. Guarantee -->
<section class="section" style="background:#e7eeff;padding:4rem 0;text-align:center;">
  <div class="container">
    <div class="guarantee-badge" style="margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;direction:ltr;" aria-hidden="true">shield</span>
      ضمان الاسترداد الكامل، الوحيد في الإمارات
    </div>
    <h2 style="margin-bottom:1rem;">إذا لم تكن راضياً، لا تدفع أي شيء.</h2>
    <p style="color:#42474e;max-width:560px;margin:0 auto 2rem;line-height:1.8;">نبني، تختبر، وإذا لم تكن راضياً تماماً نردّ ١٠٠٪ خلال ٣٠ يوماً من التسليم. بدون أسئلة.</p>
    <button onclick="openModal(this)" data-source="ar_hospitality_guarantee" class="btn-primary">ابدأ بدون مخاطرة</button>
  </div>
</section>

<!-- 7. FAQ -->
<section class="section">
  <div class="container" style="max-width:760px;">
    <h2 style="text-align:center;margin-bottom:2.5rem;">أسئلة شائعة</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما الفرق بين الكونسيرج البشري والكونسيرج الذكي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">الكونسيرج الذكي يتولى الطلبات الروتينية المتكررة: طلب الغرف، ساعات المطعم، الخدمات، الاستفسارات الشائعة. يعمل بشكل فوري وعلى مدار الساعة. الكونسيرج البشري يتفرّغ للطلبات المعقدة التي تحتاج حكماً بشرياً وعلاقات شخصية.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          هل يستطيع الكونسيرج الذكي التعامل مع شكاوى الضيوف؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">يستطيع التعامل مع الشكاوى البسيطة وتسجيلها وتوجيهها للفريق المناسب فوراً. الشكاوى الحساسة يحولها للكونسيرج البشري مع ملخص كامل للمحادثة. لا يضيع شيء ولا يشعر الضيف بالتجاهل.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          ما اللغات التي يدعمها الكونسيرج الذكي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">ندرّبه على اللغات التي تحتاجها. معظم فنادق دبي نبني لها دعماً للعربية والإنجليزية والهندية. يمكن إضافة لغات أخرى، روسية أو صينية أو فرنسية، حسب جنسيات ضيوفك.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كم يستغرق بناء الكونسيرج الذكي لفندقنا؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نعمل على مرحلتين: الأولى لتحليل طلبات الضيوف الشائعة وبناء قاعدة المعرفة، والثانية للاختبار والإطلاق التدريجي مع مراقبة الأداء.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          كيف يتكامل الكونسيرج الذكي مع نظام إدارة الفندق الحالي؟
          <span class="faq-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" width="12" height="12" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg></span>
        </button>
        <div class="faq-body">نبني التكامل مع الأنظمة الشائعة مثل Opera وMews وLighthouse. إذا كان فندقك يستخدم نظاماً مختلفاً، نفحص إمكانية التكامل في جلسة التشخيص المجانية. في معظم الحالات يمكن الدمج.</div>
      </div>
    </div>
  </div>
</section>

<!-- 8. Final CTA Band -->
<section class="cta-band" style="border-radius:24px;margin:2rem 2rem 4rem;">
  <div class="container" style="text-align:center;">
    <h2 style="margin-bottom:1rem;">جاهز لتحويل تجربة ضيوفك؟</h2>
    <p style="margin-bottom:2rem;max-width:500px;margin-inline:auto;line-height:1.7;">احجز جلسة تشخيص مجانية، نحلل طلبات ضيوفك الشائعة ونقترح الحل الأنسب. بدون التزام.</p>
    <button onclick="openModal(this)" data-source="ar_hospitality_cta" class="btn-primary">ابدأ الآن ←</button>
  </div>
</section>

<style>
  .hosp-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .stat-num {
    font-size: 2rem;
    font-weight: 800;
    color: #00e3fd;
    margin: 0 0 0.25rem;
  }
  .stat-lbl {
    color: rgba(255,255,255,0.72);
    font-size: 0.875rem;
    margin: 0;
    line-height: 1.5;
  }
  .stat-item { padding: 0 .25rem; }
  .case-study-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    gap: 1.5rem;
  }
  .case-label {
    display: inline-block;
    background: #e7eeff;
    color: #1d4ed8;
