---
import BaseLayout from "../layouts/BaseLayout.astro";

const homeLdJson = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "logo": "https://aegisai.ae/assets/og-home.jpg",
    "description": "Aegis AI builds custom AI systems and trains teams to use them — serving SMEs in Dubai across real estate, retail, hospitality and logistics.",
    "email": "hello@aegisai.ae",
    "telephone": "+97143218888",
    "areaServed": { "@type": "City", "name": "Dubai" },
    "sameAs": ["https://www.linkedin.com/company/aegis-ai-dubai"],
    "offers": [
      { "@type": "Offer", "name": "Custom AI Development", "url": "https://aegisai.ae/services/custom-ai-development" },
      { "@type": "Offer", "name": "AI Training & Workshops", "url": "https://aegisai.ae/services/ai-training" },
      { "@type": "Offer", "name": "AI Strategy Consulting", "url": "https://aegisai.ae/services/ai-strategy" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "image": "https://aegisai.ae/assets/og-home.jpg",
    "description": "Dubai-based AI company providing custom AI development, team training, and AI strategy consulting for SMEs.",
    "telephone": "+97143218888",
    "email": "hello@aegisai.ae",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Dubai",
      "addressCountry": "AE"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 25.2048, "longitude": 55.2708 },
    "priceRange": "AED 8,000 – AED 80,000",
    "currenciesAccepted": "AED",
    "openingHours": "Mo-Fr 09:00-18:00",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "AI Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom AI Development" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Training & Workshops" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Strategy Consulting" } }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://aegisai.ae/blog?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  }
];
---

<BaseLayout
  title="Custom AI Solutions & Training for Dubai SMEs | Aegis AI"
  description="Aegis AI builds custom AI systems and trains your team to use them — serving SMEs in Dubai across real estate, retail, hospitality and logistics. Book a free strategy call."
  canonicalPath="/"
  ldJson={homeLdJson}
>

<!-- HERO -->
<header class="hero-section">
  <div class="container">
    <div class="hero-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">

      <!-- Left: Copy -->
      <div>
        <div class="hero-eyebrow-pill">
          <span class="hero-pulse"></span>
          The only Dubai AI partner with a 100% refund guarantee
        </div>
        <h1>
          Custom AI Systems +<br>
          <span class="gradient-text">Team Training, in One Package.</span>
        </h1>
        <p style="color:#42474e; font-size:1.125rem; line-height:1.8; max-width:520px; margin:1.5rem 0 2.5rem;">
          We build AI that fits your workflows and train your people to use it — for Dubai SMEs in real estate, retail, hospitality, and logistics.
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-bottom:2.5rem;">
          <button onclick="openModal(this)" data-source="homepage_hero" class="btn-primary">
            Book Free Strategy Call
            <span class="material-symbols-outlined" style="font-size:20px;">arrow_forward</span>
          </button>
        </div>
        <!-- Stats bar -->
        <div style="display:inline-flex; flex-wrap:wrap; gap:1.5rem; background:#fff; border:1px solid rgba(0,37,59,0.10); border-radius:16px; padding:1.25rem 1.75rem; box-shadow:0 8px 32px rgba(0,59,92,0.06);">
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">100%</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">Refund Guarantee</p>
          </div>
          <div style="width:1px; background:rgba(0,37,59,0.10);"></div>
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">AR/EN</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">Bilingual</p>
          </div>
          <div style="width:1px; background:rgba(0,37,59,0.10);"></div>
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">90-Day</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">Support Included</p>
          </div>
        </div>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="hero-db">
        <div class="dashboard-card">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
            <div>
              <p style="color:#fff; font-weight:600; font-size:0.875rem; margin:0;">AI Operations Dashboard</p>
              <p style="color:#72787e; font-size:0.75rem; margin:0;">Sample interface — representative results</p>
            </div>
            <div style="display:flex; gap:6px;">
              <span style="width:10px;height:10px;border-radius:50%;background:#ef4444;display:inline-block;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#f59e0b;display:inline-block;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
            </div>
          </div>
          <!-- Metric cards -->
          <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:1.25rem;">
            <div class="db-metric" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.20);">
              <p style="color:#fff; font-weight:800; font-size:1.125rem; margin:0;">↑ 47%</p>
              <p style="color:#72787e; font-size:0.6875rem; margin:0;">Lead Conv.</p>
            </div>
            <div class="db-metric" style="background:rgba(0,104,117,0.15); border:1px solid rgba(0,104,117,0.25);">
              <p style="color:#fff; font-weight:800; font-size:1.125rem; margin:0;">3h</p>
              <p style="color:#72787e; font-size:0.6875rem; margin:0;">Saved/day</p>
            </div>
            <div class="db-metric" style="background:rgba(34,197,94,0.10); border:1px solid rgba(34,197,94,0.20);">
              <p style="color:#fff; font-weight:800; font-size:1.125rem; margin:0;">24/7</p>
              <p style="color:#72787e; font-size:0.6875rem; margin:0;">AI Active</p>
            </div>
          </div>
          <!-- Bar chart -->
          <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:1rem; margin-bottom:1rem;">
            <p style="color:#72787e; font-size:0.6875rem; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.75rem;">Weekly AI Tasks Automated</p>
            <div style="display:flex; align-items:flex-end; gap:8px; height:64px;">
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:45%;opacity:0.7;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:60%;opacity:0.8;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:50%;opacity:0.75;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:80%;opacity:0.9;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:70%;opacity:0.85;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:95%;"></div>
              <div style="flex:1;background:linear-gradient(to top,#006875,#00e3fd);border-radius:4px 4px 0 0;height:88%;"></div>
            </div>
            <div style="display:flex; justify-content:space-between; margin-top:6px;">
              <span style="color:#c2c7ce;font-size:0.625rem;">Mon</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Tue</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Wed</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Thu</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Fri</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Sat</span>
              <span style="color:#c2c7ce;font-size:0.625rem;">Sun</span>
            </div>
          </div>
          <!-- Activity feed -->
          <div style="display:flex; flex-direction:column; gap:10px;">
            <div style="display:flex; align-items:center; gap:12px;">
              <span style="width:28px;height:28px;border-radius:50%;background:rgba(0,227,253,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-symbols-outlined" style="font-size:14px;color:#00e3fd;">chat</span>
              </span>
              <div style="flex:1;">
                <p style="color:#fff;font-size:0.75rem;font-weight:500;margin:0;">WhatsApp AI replied to 12 leads</p>
                <p style="color:#72787e;font-size:0.625rem;margin:0;">2 min ago</p>
              </div>
              <span style="color:#22c55e;font-size:0.6875rem;font-weight:600;">✓</span>
            </div>
            <div style="display:flex; align-items:center; gap:12px;">
              <span style="width:28px;height:28px;border-radius:50%;background:rgba(0,104,117,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-symbols-outlined" style="font-size:14px;color:#00e3fd;">bar_chart</span>
              </span>
              <div style="flex:1;">
                <p style="color:#fff;font-size:0.75rem;font-weight:500;margin:0;">Sales report auto-generated</p>
                <p style="color:#72787e;font-size:0.625rem;margin:0;">18 min ago</p>
              </div>
              <span style="color:#22c55e;font-size:0.6875rem;font-weight:600;">✓</span>
            </div>
            <div style="display:flex; align-items:center; gap:12px;">
              <span style="width:28px;height:28px;border-radius:50%;background:rgba(245,158,11,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <span class="material-symbols-outlined" style="font-size:14px;color:#f59e0b;">person</span>
              </span>
              <div style="flex:1;">
                <p style="color:#fff;font-size:0.75rem;font-weight:500;margin:0;">3 new qualified leads routed</p>
                <p style="color:#72787e;font-size:0.625rem;margin:0;">35 min ago</p>
              </div>
              <span style="color:#22c55e;font-size:0.6875rem;font-weight:600;">✓</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Technology partners -->
    <div style="text-align:center; margin-top:4rem;">
      <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.10em; color:#72787e; font-weight:600; margin-bottom:1.25rem;">Technology Partners</p>
      <div style="display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:2rem; opacity:0.60;">
        <span style="font-weight:700; font-size:0.875rem; letter-spacing:0.03em; color:#42474e;">OpenAI</span>
        <span style="font-weight:700; font-size:0.875rem; letter-spacing:0.03em; color:#42474e;">Microsoft Azure</span>
        <span style="font-weight:700; font-size:0.875rem; letter-spacing:0.03em; color:#42474e;">Make.com</span>
        <span style="font-weight:700; font-size:0.875rem; letter-spacing:0.03em; color:#42474e;">n8n</span>
        <span style="font-weight:700; font-size:0.875rem; letter-spacing:0.03em; color:#42474e;">WhatsApp Business API</span>
      </div>
    </div>
  </div>
</header>

<!-- TRUST STRIP -->
<div class="trust-strip" aria-label="Trust signals">
  <div class="container">
    <div class="trust-strip-inner">
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#d97706; font-size:20px;">shield</span>
        Zero Cost If You're Not Happy
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875; font-size:20px;">location_on</span>
        Dubai-Based Team
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875; font-size:20px;">language</span>
        Arabic &amp; English Support
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875; font-size:20px;">schedule</span>
        90-Day Post-Launch Support
      </div>
    </div>
  </div>
</div>

<!-- AI IMPACT -->
<section class="section" aria-labelledby="ai-impact-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">Why AI Matters</div>
      <h2 id="ai-impact-heading">AI Doesn't Just Save Time —<br>It Transforms How You Compete.</h2>
      <p>Businesses that adopt AI aren't just more efficient — they're structurally ahead of those that don't.</p>
    </div>
    <div class="bento-grid bento-grid-3" style="margin-bottom:3rem;">
      <div class="card" style="padding:2.5rem;">
        <div style="width:48px;height:48px;border-radius:16px;background:rgba(0,104,117,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="color:#006875;">trending_down</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Lower Operational Costs</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">AI automates repetitive tasks — data entry, follow-ups, reporting — so your team focuses on revenue-generating work instead. Most clients recover their investment within the first quarter.</p>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div style="width:48px;height:48px;border-radius:16px;background:rgba(0,227,253,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="color:#006875;">speed</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Faster Response, Faster Decisions</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">AI processes data and surfaces insights in seconds — giving your team the clarity to move faster than competitors still relying on manual analysis and gut instinct.</p>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div style="width:48px;height:48px;border-radius:16px;background:rgba(34,197,94,0.10);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="color:#006875;">trending_up</span>
        </div>
        <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">More Revenue, Less Overhead</h3>
        <p style="color:#42474e; font-size:0.9375rem; line-height:1.7; margin:0;">AI handles the volume — qualifying leads, responding to customers, processing orders — so your business scales without scaling your payroll.</p>
      </div>
    </div>
    <p style="text-align:center; font-weight:700; font-size:1.125rem; color:#006875;">The question isn't whether to adopt AI. It's whether to do it right.</p>
  </div>
</section>

<!-- CASE STUDIES -->
<section class="section" aria-labelledby="results-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">Client Results</div>
      <h2 id="results-heading">What Aegis AI Has Built for UAE Businesses</h2>
      <p>Real projects, real outcomes — across Dubai's most active industries.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="card" style="padding:2.5rem;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,104,117,0.10);border-radius:8px;padding:6px 12px;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="font-size:16px;color:#006875;">home</span>
          <span style="font-size:0.75rem;font-weight:700;color:#006875;text-transform:uppercase;letter-spacing:0.05em;">Real Estate Agency · Dubai</span>
        </div>
        <p style="font-size:0.875rem;color:#42474e;line-height:1.7;margin-bottom:1.25rem;">A 30-person agency was losing leads to slow response times — average reply was 4+ hours. We built a WhatsApp AI that qualifies and responds to every lead in under 2 minutes, 24/7, in Arabic and English.</p>
        <div style="display:flex;gap:2rem;">
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">47%</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">lead-to-viewing conversion</p>
          </div>
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">&lt;2 min</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">avg. first response time</p>
          </div>
        </div>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,104,117,0.10);border-radius:8px;padding:6px 12px;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="font-size:16px;color:#006875;">shopping_bag</span>
          <span style="font-size:0.75rem;font-weight:700;color:#006875;text-transform:uppercase;letter-spacing:0.05em;">Retail Chain · UAE</span>
        </div>
        <p style="font-size:0.875rem;color:#42474e;line-height:1.7;margin-bottom:1.25rem;">A 12-location retail chain was managing inventory manually across Excel sheets, leading to frequent overstock and stockouts. We built an AI forecasting dashboard that syncs all locations in real time.</p>
        <div style="display:flex;gap:2rem;">
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">3h</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">saved daily on manual reporting</p>
          </div>
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">30%</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">reduction in overstock cost</p>
          </div>
        </div>
      </div>
      <div class="card" style="padding:2.5rem;">
        <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(0,104,117,0.10);border-radius:8px;padding:6px 12px;margin-bottom:1.25rem;">
          <span class="material-symbols-outlined" style="font-size:16px;color:#006875;">hotel</span>
          <span style="font-size:0.75rem;font-weight:700;color:#006875;text-transform:uppercase;letter-spacing:0.05em;">Hotel Group · Dubai</span>
        </div>
        <p style="font-size:0.875rem;color:#42474e;line-height:1.7;margin-bottom:1.25rem;">A boutique hotel group was handling all guest requests through a single WhatsApp line — one staff member, constant delays. We deployed a bilingual AI concierge that handles 80% of requests autonomously.</p>
        <div style="display:flex;gap:2rem;">
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">80%</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">guest queries handled by AI</p>
          </div>
          <div>
            <p style="font-size:1.375rem;font-weight:800;color:#006875;margin:0;">24/7</p>
            <p style="font-size:0.75rem;color:#72787e;margin:0;">bilingual guest support</p>
          </div>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem;">
      <a href="/results" style="display:inline-flex;align-items:center;gap:6px;font-weight:600;font-size:0.9375rem;color:#006875;text-decoration:none;">
        See all client results <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
      </a>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" class="section" style="background:#e7eeff;" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">What We Do</div>
      <h2 id="services-heading">AI That Works. Teams That Know How.</h2>
      <p>Three services, one mission: make your business genuinely AI-ready — not just AI-curious.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">monitor_heart</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Custom AI Development</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">We build AI systems tailored to your workflows — chatbots, automation, dashboards, and predictive tools. Integrated with what you already use.</p>
        <div style="display:inline-flex; align-items:center; gap:6px; background:rgba(245,158,11,0.10); border:1px solid rgba(245,158,11,0.25); border-radius:8px; padding:6px 12px; color:#d97706; font-size:0.75rem; font-weight:600; margin-bottom:1.5rem;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#d97706;">shield</span>
          Covered by our zero-cost guarantee
        </div>
        <a href="/services/custom-ai-development" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">group</span>
        </div>
