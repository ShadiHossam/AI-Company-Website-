---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPageContent, getVal } from "../lib/page-content";
import { getSupabaseAdmin } from "../lib/supabase";

export const prerender = false;

const pc = await loadPageContent('home');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

type Testimonial = {
  client_name: string;
  client_title: string | null;
  client_company: string | null;
  industry: string | null;
  client_image_url: string | null;
  quote: string;
};

const fallbackTestimonials: Testimonial[] = [
  {
    client_name: 'Ahmed Al Rashidi',
    client_title: 'CEO',
    client_company: 'Al Rashidi Properties',
    industry: 'Real Estate',
    quote: "Aegis AI built us a WhatsApp lead bot that responds to every inquiry in seconds. Our team saves hours every week and we are following up with more leads than ever before. Best investment we have made.",
    client_image_url: null,
  },
  {
    client_name: 'Sarah Mitchell',
    client_title: 'Operations Director',
    client_company: 'Bloom Retail Group',
    industry: 'Retail',
    quote: 'The AI inventory system they built solved our stockout problem entirely. We used to lose sales every weekend, now the system handles reordering automatically. It paid for itself faster than we expected.',
    client_image_url: null,
  },
  {
    client_name: 'Khalid Al Mansoori',
    client_title: 'General Manager',
    client_company: 'Noor Hospitality Group',
    industry: 'Hospitality',
    quote: 'Our AI concierge handles guest requests around the clock. Staff can now focus on high-value interactions instead of answering the same questions repeatedly. It has changed how we run the hotel.',
    client_image_url: null,
  },
];

const supabase = getSupabaseAdmin();
const { data: rawTestimonials } = await supabase
  .from('testimonials')
  .select('client_name, client_title, client_company, industry, client_image_url, quote')
  .eq('published', true)
  .is('deleted_at', null)
  .order('sort_order', { ascending: true })
  .limit(6);

const testimonials: Testimonial[] = (rawTestimonials && rawTestimonials.length > 0)
  ? rawTestimonials as Testimonial[]
  : fallbackTestimonials;

const homeLdJson = [
  {
    "@context": "https://schema.org",
    "@type": ["Organization", "ProfessionalService"],
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "logo": {
      "@type": "ImageObject",
      "url": "https://aegisai.ae/favicon-192.png",
      "width": 192,
      "height": 192
    },
    "description": "Aegis AI builds custom AI systems, agents, automation, and internal tools for businesses in Dubai and the UAE. We back every project with a 100% refund guarantee.",
    "email": "hello@aegisai.ae",
    "telephone": "+97143218888",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Business Bay",
      "addressLocality": "Dubai",
      "addressCountry": "AE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 25.1850,
      "longitude": 55.2592
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    "areaServed": [
      { "@type": "Country", "name": "United Arab Emirates" }
    ],
    "sameAs": ["https://www.linkedin.com/company/aegis-ai-dubai"],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "AI Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom AI Development", "url": "https://aegisai.ae/services/custom-ai-development" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Agents", "url": "https://aegisai.ae/services/ai-agents" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Automation", "url": "https://aegisai.ae/services/ai-automation" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Strategy Consulting", "url": "https://aegisai.ae/services/ai-strategy" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI Training", "url": "https://aegisai.ae/services/ai-training" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Internal AI Tools", "url": "https://aegisai.ae/services/internal-ai-tools" } }
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Aegis AI",
    "url": "https://aegisai.ae",
    "potentialAction": {
      "@type": "SearchAction",
      "target": { "@type": "EntryPoint", "urlTemplate": "https://aegisai.ae/blog?q={search_term_string}" },
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Custom AI Solutions, Agents and Automation | Aegis AI",
    "url": "https://aegisai.ae",
    "description": "Aegis AI builds custom AI systems, agents, workflow automation, and internal tools for businesses. 100% refund guarantee on every project. Book a free strategy call.",
    "isPartOf": { "@type": "WebSite", "url": "https://aegisai.ae" },
    "about": { "@type": "Organization", "name": "Aegis AI" },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".section-header h2"]
    }
  }
];
---

<BaseLayout
  title="AI Adoption for UAE Businesses: Build, Train & Get Results | Aegis AI"
  description="Aegis AI helps UAE businesses adopt AI and get real results from it. Custom development, team training, strategy, and automation for companies across Dubai and the UAE. Backed by a 100% refund guarantee."
  canonicalPath="/"
  ldJson={homeLdJson}
  arPath="/ar"
>

<!-- HERO -->
<header class="hero-section">
  <div class="container">
    <div class="hero-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">

      <!-- Left: Copy -->
      <div>

        <h1>
          {g('hero_h1_line1', 'We Build AI That Fits')}<br>
          <span class="gradient-text">{g('hero_h1_line2', "How Your Business Works.")}</span>
        </h1>
        <p style="color:#42474e; font-size:1.125rem; line-height:1.8; max-width:520px; margin:1.5rem 0 2.5rem;">
          {g('hero_subtext', "Custom AI systems, agents, and automation built around your workflows. Every project includes team training and a 100% refund guarantee.")}
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap; margin-bottom:2.5rem;">
          <button onclick="openModal(this)" data-source="homepage_hero" class="btn-primary">
            {g('hero_cta', 'Book Free Strategy Call')}
            <span class="material-symbols-outlined" style="font-size:20px;">arrow_forward</span>
          </button>
        </div>
        <!-- Stats bar -->
        <div style="display:inline-flex; flex-wrap:wrap; gap:1.5rem; background:#fff; border:1px solid rgba(0,37,59,0.10); border-radius:16px; padding:1.25rem 1.75rem; box-shadow:0 8px 32px rgba(0,59,92,0.06);">
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">{g('stat_1_value', '100%')}</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">{g('stat_1_label', 'Refund Guarantee')}</p>
          </div>
          <div style="width:1px; background:rgba(0,37,59,0.10);"></div>
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">{g('stat_2_value', 'Free')}</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">{g('stat_2_label', 'Strategy Call')}</p>
          </div>
          <div style="width:1px; background:rgba(0,37,59,0.10);"></div>
          <div style="text-align:center;">
            <p style="font-size:1.25rem; font-weight:800; color:#00253b; margin:0;">{g('stat_3_value', '90-Day')}</p>
            <p style="font-size:0.75rem; color:#72787e; margin:0;">{g('stat_3_label', 'Support Included')}</p>
          </div>
        </div>
      </div>

      <!-- Right: Service cards visual -->
      <div class="hero-db" style="position:relative; display:flex; align-items:center; justify-content:center; min-height:380px; border-radius:24px; overflow:hidden;">
        <!-- Background photo -->
        <img src="https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=900&q=80&auto=format&fit=crop" alt="AI technology workspace" loading="eager" fetchpriority="high" width="900" height="380" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
        <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,30,48,0.78),rgba(0,37,59,0.62));"></div>
        <!-- Center card -->
        <div style="background:rgba(0,37,59,0.92); border:1px solid rgba(0,227,253,0.28); border-radius:24px; padding:2rem; width:230px; position:relative; z-index:2; box-shadow:0 0 80px rgba(0,104,117,0.18), 0 32px 80px rgba(0,37,59,0.28);">
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.25rem; padding-bottom:1.25rem; border-bottom:1px solid rgba(255,255,255,0.08);">
            <div style="width:36px; height:36px; border-radius:10px; background:rgba(245,158,11,0.15); border:1px solid rgba(245,158,11,0.30); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span class="material-symbols-outlined" style="color:#d97706; font-size:18px;">shield</span>
            </div>
            <p style="font-size:0.8125rem; font-weight:700; color:#d97706; margin:0; line-height:1.4;">100% Refund<br><span style="color:#72787e; font-weight:400; font-size:0.75rem;">if not satisfied</span></p>
          </div>
          <p style="color:#72787e; font-size:0.6875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.875rem;">What We Build</p>
          <div style="display:flex; flex-direction:column; gap:10px;">
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined" style="font-size:15px; color:#00e3fd;">check_circle</span>
              <span style="color:#c2c7ce; font-size:0.8125rem;">AI Agents</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined" style="font-size:15px; color:#00e3fd;">check_circle</span>
              <span style="color:#c2c7ce; font-size:0.8125rem;">Workflow Automation</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined" style="font-size:15px; color:#00e3fd;">check_circle</span>
              <span style="color:#c2c7ce; font-size:0.8125rem;">WhatsApp Automation</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined" style="font-size:15px; color:#00e3fd;">check_circle</span>
              <span style="color:#c2c7ce; font-size:0.8125rem;">Internal Systems</span>
            </div>
            <div style="display:flex; align-items:center; gap:8px;">
              <span class="material-symbols-outlined" style="font-size:15px; color:#00e3fd;">check_circle</span>
              <span style="color:#c2c7ce; font-size:0.8125rem;">AI Strategy</span>
            </div>
          </div>
        </div>
        <!-- Floating pills -->
        <div class="hero-float-pill" style="top:6%; left:8%; animation-delay:0s;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#006875;">smart_toy</span>AI Agents
        </div>
        <div class="hero-float-pill" style="top:28%; right:4%; animation-delay:0.8s;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#006875;">bolt</span>Automation
        </div>
        <div class="hero-float-pill" style="bottom:28%; right:4%; animation-delay:1.6s;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#006875;">chat</span>WhatsApp AI
        </div>
        <div class="hero-float-pill" style="bottom:6%; left:8%; animation-delay:2.4s;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#006875;">dns</span>Internal Systems
        </div>
        <div class="hero-float-pill" style="top:28%; left:4%; animation-delay:3.2s;">
          <span class="material-symbols-outlined" style="font-size:14px; color:#006875;">insights</span>AI Strategy
        </div>
      </div>
    </div>
  </div>
</header>

<!-- TRUST STRIP -->
<div class="trust-strip" aria-label="Trust signals">
  <div class="container">
    <div class="trust-strip-inner">
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#d97706; font-size:20px;">shield</span>
        Zero Cost If You're Not Happy
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="material-symbols-outlined" style="color:#006875; font-size:20px;">schedule</span>
        90-Day Post-Launch Support
      </div>
    </div>
  </div>
</div>


<!-- WHO THIS IS FOR -->
<section class="section" style="background:#fff;" aria-labelledby="who-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="who-heading">Built for Businesses That Are Ready to Move</h2>
      <p>If any of these sound familiar, you're in the right place.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="pain-card">
        <div class="pain-icon">
          <span class="material-symbols-outlined">timer</span>
        </div>
        <h3 style="font-size:1.125rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Your team can't keep up with the volume.</h3>
        <p style="color:#42474e; line-height:1.8; margin:0;">Leads go cold. Enquiries pile up. Your people are stretched. The problem isn't effort, it's volume. AI handles the repetitive workload so your team can focus on what actually needs a human.</p>
      </div>
      <div class="pain-card">
        <div class="pain-icon">
          <span class="material-symbols-outlined">tune</span>
        </div>
        <h3 style="font-size:1.125rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">You've tried AI tools. None of them fit.</h3>
        <p style="color:#42474e; line-height:1.8; margin:0;">ChatGPT doesn't know your products. Zapier templates don't match your process. Off-the-shelf tools give generic results. You need something built around how your business actually works.</p>
      </div>
      <div class="pain-card">
        <div class="pain-icon">
          <span class="material-symbols-outlined">explore</span>
        </div>
        <h3 style="font-size:1.125rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">You know AI could help. You don't know where to start.</h3>
        <p style="color:#42474e; line-height:1.8; margin:0;">Every vendor promises transformation. Few give you a plan. We start with your biggest operational problem, figure out what's realistic, and tell you straight whether AI is the right move before you spend anything.</p>
      </div>
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="services" class="section" style="background:#e7eeff;" aria-labelledby="services-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="services-heading">The Full AI Adoption Journey, in One Place</h2>
      <p>We cover everything your business needs to adopt AI well: from knowing where to start, to building the right systems, to making sure your team actually uses them.</p>
    </div>
    <div class="bento-grid bento-grid-3" style="margin-bottom:2.5rem;">
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">smart_toy</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">AI Agents</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Custom AI agents that handle specific tasks in your business automatically, from customer interactions to data processing and decision-making.</p>
        <a href="/services" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">group</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">AI Team Training</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Most AI investments fail because teams don't adopt them. We train your people to use AI confidently in their daily work, role-specific, hands-on, and tailored to your industry.</p>
        <a href="/services/ai-training" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">bolt</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Workflow Automation</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Connect your tools and automate repetitive processes so your team stops doing things manually. We map your workflow and build the automation around it.</p>
        <a href="/services" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">dns</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Internal Systems</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Custom dashboards, portals, and internal tools built for how your team works. Not generic software that needs workarounds, but something built specifically for your process.</p>
        <a href="/services" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">monitor_heart</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Custom AI Development</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Fully bespoke AI solutions built around your specific workflows and requirements. Integrated with the tools you already use, built to last.</p>
        <a href="/services/custom-ai-development" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
      <div class="service-card">
        <div class="service-icon">
          <span class="material-symbols-outlined">bar_chart</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">AI Strategy</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">We map where AI makes the most sense in your business and give you a clear plan before you spend anything. Know exactly what you are getting into before we start.</p>
        <a href="/services/ai-strategy" style="display:inline-flex; align-items:center; gap:4px; font-weight:600; font-size:0.875rem; color:#006875; text-decoration:none;">
          Learn More <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
        </a>
      </div>
    </div>
    <div style="text-align:center;">
      <a href="/services" style="display:inline-flex; align-items:center; gap:8px; font-weight:700; font-size:0.9375rem; color:#006875; background:#fff; border:1.5px solid rgba(0,104,117,0.30); border-radius:12px; padding:0.875rem 2rem; text-decoration:none; transition:border-color .2s, box-shadow .2s;">
        View All Services <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span>
      </a>
    </div>
  </div>
</section>




<!-- INDUSTRIES -->
<section class="section" style="background:#fff;" aria-labelledby="industries-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="industries-heading">Industries We Serve</h2>
      <p>We focus on a few industries and go deep. That means fewer surprises, faster builds, and AI that fits your context from day one.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <a href="/industries/real-estate" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined">apartment</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Real Estate</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">WhatsApp lead bots, CRM automation, and AI that qualifies buyers and books viewings around the clock, in Arabic and English.</p>
        <span class="industry-link">Explore Real Estate AI <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span></span>
      </a>
      <a href="/industries/retail" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined">shopping_bag</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Retail</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">Demand forecasting, inventory automation, and customer support that scales across stores without adding headcount.</p>
        <span class="industry-link">Explore Retail AI <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span></span>
      </a>
      <a href="/industries/hospitality" class="industry-card">
        <div class="industry-icon">
          <span class="material-symbols-outlined">hotel</span>
        </div>
        <h3 style="font-size:1.25rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Hospitality</h3>
        <p style="color:#42474e; line-height:1.8; margin-bottom:1.5rem;">AI concierges that handle guest enquiries 24/7, freeing your team for the interactions that need a human touch.</p>
        <span class="industry-link">Explore Hospitality AI <span class="material-symbols-outlined" style="font-size:18px;">arrow_forward</span></span>
      </a>
    </div>
  </div>
</section>

<!-- COMPARISON TABLE -->
<section class="section" style="background:#e7eeff;" aria-labelledby="compare-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="compare-heading">The AI Partner That Builds, Supports, and Guarantees Results.</h2>
    </div>
    <div class="compare-wrap" style="overflow-x:auto;">
      <table class="compare-table">
        <thead>
          <tr>
            <th style="width:40%; text-align:left; border-radius:0;">Feature</th>
