---
export const prerender = false;
import { getSupabaseAdmin } from '../../lib/supabase';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { marked } from 'marked';
import { sanitizeRichText } from '../../lib/sanitize';

const { slug } = Astro.params;

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

interface KeyPoint {
  heading: string;
  body: string;
}

interface RelatedPost {
  title: string;
  slug: string;
  category: string;
}

interface DbPost {
  id: string;
  title: string;
  slug: string;
  description: string;
  body_markdown: string;
  category: string;
  pub_date: string;
  updated_date?: string | null;
  author_name?: string | null;
  cover_image?: string | null;
  og_image?: string | null;
  key_points?: KeyPoint[] | null;
  meta_title?: string | null;
  meta_description?: string | null;
  ar_title?: string | null;
}

let dbPost: DbPost | null = null;
let bodyHtml = '';
let pubDate = new Date();
let updatedDate: Date | undefined;
let relatedPosts: RelatedPost[] = [];

// 1. Try Supabase first
try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('blog_posts')
    .select('*')
    .eq('slug', slug!)
    .eq('status', 'published')
    .is('deleted_at', null)
    .single();

  if (!error && data) {
    dbPost = data as DbPost;
    bodyHtml = sanitizeRichText(await marked(dbPost.body_markdown ?? ''));
    pubDate = dbPost.pub_date ? new Date(dbPost.pub_date) : new Date();
    updatedDate = dbPost.updated_date ? new Date(dbPost.updated_date) : undefined;

    // Fetch related posts (same category, different slug, max 3)
    const { data: related } = await supabase
      .from('blog_posts')
      .select('title, slug, category')
      .eq('status', 'published')
      .is('deleted_at', null)
      .eq('category', dbPost.category)
      .neq('slug', slug!)
      .limit(3);

    relatedPosts = (related ?? []) as RelatedPost[];
  }
} catch {
  // fall through to content collection
}

// 2. Fall back to content collection
let collectionTitle = '';
let collectionDescription = '';
let collectionCategory = '';
let collectionPubDate = new Date();
let collectionUpdatedDate: Date | undefined;
let collectionOgImage: string | undefined;
let collectionCoverImage: string | undefined;
let collectionAuthorName: string | undefined;
let collectionKeyPoints: KeyPoint[] = [];
let CollectionContent: any = null;

if (!dbPost) {
  try {
    const { getCollection, render } = await import('astro:content');
    const posts = await getCollection('blog');
    const found = posts.find(p => p.id === slug);
    if (found) {
      collectionTitle = found.data.title;
      collectionDescription = found.data.description;
      collectionCategory = found.data.category;
      collectionPubDate = found.data.pubDate;
      collectionUpdatedDate = found.data.updatedDate;
      collectionOgImage = found.data.ogImage;
      collectionCoverImage = found.data.coverImage;
      collectionAuthorName = found.data.authorName;
      collectionKeyPoints = found.data.keyPoints ?? [];

      const rendered = await render(found);
      CollectionContent = rendered.Content;

      // Related posts from content collection (same category)
      relatedPosts = posts
        .filter(p => p.id !== slug && p.data.category === collectionCategory)
        .slice(0, 3)
        .map(p => ({ title: p.data.title, slug: p.id, category: p.data.category }));
    } else {
      return Astro.redirect('/blog');
    }
  } catch {
    return Astro.redirect('/blog');
  }
}
---

{dbPost ? (
  <ArticleLayout
    title={dbPost.meta_title ?? dbPost.title}
    description={dbPost.meta_description ?? dbPost.description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    category={dbPost.category}
    slug={dbPost.slug}
    ogImage={dbPost.og_image ?? '/assets/og-blog.jpg'}
    coverImage={dbPost.cover_image ?? undefined}
    authorName={dbPost.author_name ?? undefined}
    keyPoints={dbPost.key_points ?? []}
    relatedPosts={relatedPosts}
    arPath={dbPost.ar_title ? `/ar/blog/${dbPost.slug}` : undefined}
  >
    <Fragment set:html={bodyHtml} />
    <div class="native-share-widget" id="native-share-widget">
      <div class="nsw-text">
        <strong>Found this useful?</strong>
        <span>Share it with your team.</span>
      </div>
      <button type="button" class="nsw-btn" id="native-share-btn">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:18px;">ios_share</span>
        <span id="native-share-btn-label">Share this article</span>
      </button>
    </div>
  </ArticleLayout>
) : (
  <ArticleLayout
    title={collectionTitle}
    description={collectionDescription}
    pubDate={collectionPubDate}
    updatedDate={collectionUpdatedDate}
    category={collectionCategory}
    slug={slug!}
    ogImage={collectionOgImage}
    coverImage={collectionCoverImage}
    authorName={collectionAuthorName}
    keyPoints={collectionKeyPoints}
    relatedPosts={relatedPosts}
  >
    {CollectionContent && <CollectionContent />}
    <div class="native-share-widget" id="native-share-widget">
      <div class="nsw-text">
        <strong>Found this useful?</strong>
        <span>Share it with your team.</span>
      </div>
      <button type="button" class="nsw-btn" id="native-share-btn">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:18px;">ios_share</span>
        <span id="native-share-btn-label">Share this article</span>
      </button>
    </div>
  </ArticleLayout>
)}

<style>
  .native-share-widget {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
    background: linear-gradient(135deg, rgba(0,227,253,0.06), rgba(0,104,117,0.03));
    border: 1px solid rgba(0,104,117,0.14); border-radius: 16px;
    padding: 1.25rem 1.5rem; margin: 2.5rem 0 0;
  }
  .nsw-text { display: flex; flex-direction: column; gap: 2px; }
  .nsw-text strong { color: #00253b; font-size: 0.9375rem; }
  .nsw-text span { color: #42474e; font-size: 0.8125rem; }
  .nsw-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: #00253b; color: #fff; font-weight: 700; font-size: 0.875rem;
    padding: 11px 20px; border-radius: 9px; border: none; cursor: pointer;
    font-family: inherit; transition: background 0.2s, transform 0.15s;
    flex-shrink: 0;
  }
  .nsw-btn:hover { background: #003a57; transform: translateY(-1px); }
  .nsw-btn:focus-visible { outline: 3px solid #006875; outline-offset: 3px; }
</style>

<script>
  const shareBtn = document.getElementById('native-share-btn');
  const shareLabel = document.getElementById('native-share-btn-label');

  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = { title: document.title, url: window.location.href };

      if (navigator.share) {
        try {
          await navigator.share(shareData);
          return;
        } catch {
          // user cancelled the native share sheet, fall through to clipboard
        }
      }

      try {
        await navigator.clipboard.writeText(window.location.href);
        if (shareLabel) {
          const original = shareLabel.textContent;
          shareLabel.textContent = 'Link copied!';
          setTimeout(() => {
            if (shareLabel) shareLabel.textContent = original;
          }, 2000);
        }
      } catch {
        // clipboard access unavailable, nothing more we can do silently
      }
    });
  }
</script>
