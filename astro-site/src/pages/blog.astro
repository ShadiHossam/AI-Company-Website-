---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

// Set caching headers
Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

interface DbPost {
  id: string;
  title: string;
  slug: string;
  description: string;
  category: string;
  pub_date: string;
  author_name: string;
  og_image: string;
}

let dbPosts: DbPost[] = [];
let dbError = false;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('blog_posts')
    .select('id, title, slug, description, category, pub_date, author_name, og_image')
    .eq('status', 'published')
    .order('pub_date', { ascending: false });

  if (!error && data) {
    dbPosts = data as DbPost[];
  } else {
    dbError = true;
  }
} catch {
  dbError = true;
}

// Fall back to content collection if DB fails or has no posts
let collectionPosts: Array<{ slug: string; data: { title: string; description: string; category: string; pubDate: Date; ogImage?: string } }> = [];
if (dbError || dbPosts.length === 0) {
  try {
    const { getCollection } = await import('astro:content');
    const allPosts = await getCollection('blog');
    collectionPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  } catch {
    // No content collection — show placeholder cards below
  }
}

const useDb = !dbError && dbPosts.length > 0;

// Collect unique categories for filter
const allCategories = useDb
  ? [...new Set(dbPosts.map(p => p.category).filter(Boolean))]
  : [...new Set(collectionPosts.map(p => p.data.category).filter(Boolean))];
---

<BaseLayout
  title="AI Blog Dubai — Insights for UAE Businesses | Aegis AI"
  description="Expert AI insights, guides, and case studies for Dubai SMEs. Learn how to implement AI, calculate ROI, and transform your business with practical advice from Aegis AI."
  canonicalPath="/blog"
  ogImage="/assets/og-blog.jpg"
  arPath="/ar/blog"
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <strong>Blog</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span style="width:8px;height:8px;border-radius:50%;background:#00e3fd;display:inline-block;"></span>
      AI Insights for Dubai Businesses
    </div>
    <h1>AI Blog — <span class="gradient-text">UAE Edition</span></h1>
    <p style="color:#42474e; font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      Practical guides, case studies, and AI strategy insights — built for Dubai's SMEs, written in plain English (and Arabic).
    </p>
  </div>
</header>

<!-- ALL POSTS -->
<section class="section" style="padding-top:3rem;">
  <div class="container">

    <!-- CATEGORY FILTER -->
    {allCategories.length > 1 && (
      <div id="filter-bar" style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:2rem;">
        <button class="filter-btn active" data-filter="all">All</button>
        {allCategories.map(cat => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>
    )}

    {useDb ? (
      <div>
        <div id="posts-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
          {dbPosts.map(post => (
            <article class="blog-card" data-category={post.category}>
              {post.og_image ? (
                <img src={post.og_image} alt={post.title} class="blog-card-img" loading="lazy" />
              ) : (
                <div class="blog-card-placeholder">
                  <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
                </div>
              )}
              <div class="blog-card-body">
                <div style="margin-bottom:0.875rem; display:flex; align-items:center; gap:8px; justify-content:space-between;">
                  <span class="tag tag-teal">{post.category}</span>
                  {post.pub_date && (
                    <span style="font-size:0.75rem; color:#72787e;">
                      {new Date(post.pub_date).toLocaleDateString('en-AE', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                  )}
                </div>
                <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">
                  <a href={`/blog/${post.slug}`} style="color:inherit; text-decoration:none;">{post.title}</a>
                </h3>
                <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0 0 1rem;">{post.description}</p>
                <a href={`/blog/${post.slug}`} style="font-size:0.8125rem; font-weight:600; color:#006875; text-decoration:none; margin-top:auto;">
                  Read more →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    ) : collectionPosts.length > 0 ? (
      <div id="posts-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
        {collectionPosts.map(post => (
          <article class="blog-card" data-category={post.data.category}>
            {post.data.ogImage ? (
              <img src={post.data.ogImage} alt={post.data.title} class="blog-card-img" loading="lazy" />
            ) : (
              <div class="blog-card-placeholder">
                <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
              </div>
            )}
            <div class="blog-card-body">
              <div style="margin-bottom:0.875rem; display:flex; align-items:center; gap:8px; justify-content:space-between;">
                <span class="tag tag-teal">{post.data.category}</span>
                <span style="font-size:0.75rem; color:#72787e;">
                  {post.data.pubDate.toLocaleDateString('en-AE', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">
                <a href={`/blog/${post.slug}`} style="color:inherit; text-decoration:none;">{post.data.title}</a>
              </h3>
              <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0 0 1rem;">{post.data.description}</p>
              <a href={`/blog/${post.slug}`} style="font-size:0.8125rem; font-weight:600; color:#006875; text-decoration:none; margin-top:auto;">
                Read more →
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div>
        <div class="section-eyebrow" style="margin-bottom:2rem;">Coming Soon</div>
        <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div style="margin-bottom:0.875rem;"><span class="tag tag-coming">Coming Soon</span></div>
              <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">UAE AI Strategy 2031: What It Means for Your Business</h3>
              <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0;">A practical breakdown of the UAE National AI Strategy and how SMEs can align their AI investments with national priorities.</p>
            </div>
          </article>

          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div style="margin-bottom:0.875rem;"><span class="tag tag-coming">Coming Soon</span></div>
              <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">Arabic AI Chatbots: A Complete Guide for UAE Businesses</h3>
              <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0;">Everything you need to know about deploying Arabic-language AI — accuracy, dialect handling, and integration with UAE customer channels.</p>
            </div>
          </article>
        </div>
      </div>
    )}

  </div>
</section>

</BaseLayout>

<style>
.blog-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:24px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .blog-card:hover { transform:translateY(-4px); box-shadow:0 24px 56px rgba(0,59,92,0.10); }
    .blog-card-img { width:100%; height:200px; object-fit:cover; }
    .blog-card-placeholder { height:200px; background:#e7eeff; display:flex; align-items:center; justify-content:center; }
    .blog-card-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }
    .tag { display:inline-flex; align-items:center; padding:3px 12px; border-radius:100px; font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; }
    .tag-coming { background:rgba(245,158,11,0.12); color:#d97706; border:1px solid rgba(245,158,11,0.25); }
    .tag-teal { background:rgba(0,104,117,0.10); color:#004f58; border:1px solid rgba(0,104,117,0.20); }
    .filter-btn { padding:6px 18px; border-radius:100px; font-size:0.8125rem; font-weight:600; cursor:pointer; border:1px solid rgba(0,37,59,0.18); background:#fff; color:#42474e; transition:all .18s; }
    .filter-btn:hover { border-color:#006875; color:#006875; }
    .filter-btn.active { background:#006875; color:#fff; border-color:#006875; }
</style>

<script>
  const filterBar = document.getElementById('filter-bar');
  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
      if (!btn) return;
      const filter = btn.dataset.filter;
      filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const grid = document.getElementById('posts-grid');
      if (!grid) return;
      grid.querySelectorAll<HTMLElement>('.blog-card').forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  }
</script>
