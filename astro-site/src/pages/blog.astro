---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Blog Dubai — Insights for UAE Businesses | Aegis AI"
  description="Expert AI insights, guides, and case studies for Dubai SMEs. Learn how to implement AI, calculate ROI, and transform your business with practical advice from Aegis AI."
  canonicalPath="/blog"
  ogImage="/assets/og-blog.jpg"
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <strong>Blog</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span style="width:8px;height:8px;border-radius:50%;background:#00e3fd;display:inline-block;"></span>
      AI Insights for Dubai Businesses
    </div>
    <h1>AI Blog — <span class="gradient-text">UAE Edition</span></h1>
    <p style="color:#42474e; font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      Practical guides, case studies, and AI strategy insights — built for Dubai's SMEs, written in plain English (and Arabic).
    </p>
  </div>
</header>

<!-- ALL POSTS -->
<section class="section" style="padding-top:3rem;">
  <div class="container">
    <div class="section-eyebrow" style="margin-bottom:2rem;">Coming Soon</div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">

      <article class="blog-card" style="opacity:0.60;">
        <div class="blog-card-placeholder">
          <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
        </div>
        <div class="blog-card-body">
          <div style="margin-bottom:0.875rem;"><span class="tag tag-coming">Coming Soon</span></div>
          <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">UAE AI Strategy 2031: What It Means for Your Business</h3>
          <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0;">A practical breakdown of the UAE National AI Strategy and how SMEs can align their AI investments with national priorities.</p>
        </div>
      </article>

      <article class="blog-card" style="opacity:0.60;">
        <div class="blog-card-placeholder">
          <span class="material-symbols-outlined" style="font-size:40px; color:#c2c7ce;">edit_note</span>
        </div>
        <div class="blog-card-body">
          <div style="margin-bottom:0.875rem;"><span class="tag tag-coming">Coming Soon</span></div>
          <h3 style="font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.4;">Arabic AI Chatbots: A Complete Guide for UAE Businesses</h3>
          <p style="color:#72787e; font-size:0.875rem; line-height:1.6; margin:0;">Everything you need to know about deploying Arabic-language AI — accuracy, dialect handling, and integration with UAE customer channels.</p>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- NEWSLETTER CTA -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div style="max-width:580px; margin:0 auto; text-align:center; background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:24px; padding:3rem; box-shadow:0 20px 40px rgba(0,59,92,0.04);">
      <div style="width:56px;height:56px;border-radius:16px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.25);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <span class="material-symbols-outlined" style="color:#006875; font-size:24px;">mail</span>
      </div>
      <h2 style="font-size:1.5rem; font-weight:700; color:#00253b; margin-bottom:0.75rem;">Get New AI Insights — Monthly</h2>
      <p style="color:#42474e; margin-bottom:2rem;">One email per month. Practical AI guides, UAE market data, and case studies — no fluff.</p>
      <form id="newsletter-form" style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;" onsubmit="handleNewsletterSubmit(event)">
        <input id="newsletter-email" type="email" name="EMAIL" required placeholder="your@email.com" style="flex:1; min-width:200px; height:48px; padding:0 1rem; border:1px solid rgba(0,37,59,0.18); border-radius:8px; font-size:0.9375rem; font-family:inherit; color:#111c2d; outline:none;" />
        <button type="submit" class="btn-primary" style="height:48px; padding:0 1.5rem; white-space:nowrap;">Subscribe</button>
      </form>
      <div id="newsletter-success" style="display:none; color:#22c55e; font-weight:600; margin-top:0.75rem;">&#10003; You're subscribed!</div>
      <p style="font-size:0.75rem; color:#72787e; margin-top:0.875rem;">No spam. Unsubscribe any time.</p>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.blog-card { background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:24px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 20px 40px rgba(0,59,92,0.04); transition:transform .25s, box-shadow .25s; }
    .blog-card:hover { transform:translateY(-4px); box-shadow:0 24px 56px rgba(0,59,92,0.10); }
    .blog-card-img { width:100%; height:200px; object-fit:cover; }
    .blog-card-placeholder { height:200px; background:#e7eeff; display:flex; align-items:center; justify-content:center; }
    .blog-card-body { padding:1.5rem; flex:1; display:flex; flex-direction:column; }
    .tag { display:inline-flex; align-items:center; padding:3px 12px; border-radius:100px; font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; }
    .tag-coming { background:rgba(245,158,11,0.12); color:#d97706; border:1px solid rgba(245,158,11,0.25); }
    .tag-teal { background:rgba(0,104,117,0.10); color:#004f58; border:1px solid rgba(0,104,117,0.20); }
</style>