---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

// Set caching headers
Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

interface DbPost {
  id: string;
  title: string;
  slug: string;
  description: string;
  category: string;
  pub_date: string;
  author_name: string;
  og_image: string;
}

let dbPosts: DbPost[] = [];
let dbError = false;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('blog_posts')
    .select('id, title, slug, description, category, pub_date, author_name, og_image')
    .eq('status', 'published')
    .is('deleted_at', null)
    .order('pub_date', { ascending: false });

  if (!error && data) {
    dbPosts = data as DbPost[];
  } else {
    dbError = true;
  }
} catch {
  dbError = true;
}

// Fall back to content collection if DB fails or has no posts
let collectionPosts: Array<{ id: string; data: { title: string; description: string; category: string; pubDate: Date; ogImage?: string } }> = [];
if (dbError || dbPosts.length === 0) {
  try {
    const { getCollection } = await import('astro:content');
    const allPosts = await getCollection('blog');
    collectionPosts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
  } catch {
    // No content collection — show placeholder cards below
  }
}

const useDb = !dbError && dbPosts.length > 0;

// Collect unique categories for filter
const allCategories = useDb
  ? [...new Set(dbPosts.map(p => p.category).filter(Boolean))]
  : [...new Set(collectionPosts.map(p => p.data.category).filter(Boolean))];

const blogLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'Blog',
    name: 'Aegis AI Blog',
    url: 'https://lenooai.com/blog',
    description: 'Expert AI insights, guides, and case studies for Dubai and UAE businesses.',
    publisher: { '@type': 'Organization', name: 'Aegis AI', url: 'https://lenooai.com' },
    inLanguage: 'en-AE',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lenooai.com/' },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://lenooai.com/blog' },
    ],
  },
];
---

<BaseLayout
  title="AI Blog Dubai: Insights for UAE Businesses | Aegis AI"
  description="AI insights, guides, and case studies from Aegis AI, a Dubai AI agency, for UAE SMEs. Learn how to implement AI, calculate ROI, and grow your business."
  canonicalPath="/blog"
  ogImage="/assets/og-blog.jpg"
  arPath="/ar/blog"
  ldJson={blogLdJson}
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Blog</div>
    <h1>AI Blog: <span class="gradient-text">UAE Edition</span></h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      Practical guides, case studies, and AI strategy insights, built for Dubai's SMEs, written in plain English (and Arabic).
    </p>
  </div>
</header>

<!-- BANNER IMAGE -->
<div style="position:relative; overflow:hidden; height:220px;">
  <img src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1400&q=80&auto=format&fit=crop" alt="Writing and researching an AI strategy article at a laptop" loading="lazy" width="1400" height="220" style="width:100%;height:100%;object-fit:cover;object-position:center 35%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.55) 0%,rgba(249,249,255,0) 45%),linear-gradient(to top,rgba(0,19,32,0.25) 0%,transparent 55%);"></div>
</div>

<!-- ALL POSTS -->
<section class="section" style="padding-top:3rem;">
  <div class="container">

    <!-- SEARCH -->
    <div style="max-width:420px; margin:0 auto 2rem;">
      <div class="search-box">
        <span class="material-symbols-outlined search-icon" aria-hidden="true">search</span>
        <input type="search" id="post-search" class="search-input" placeholder="Search articles..." aria-label="Search blog articles" />
      </div>
    </div>

    <!-- CATEGORY FILTER -->
    {allCategories.length > 1 && (
      <div id="filter-bar" style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:2rem;">
        <button class="filter-btn active" data-filter="all">All</button>
        {allCategories.map(cat => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>
    )}

    {useDb ? (
      <div>
        <div id="posts-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
          {dbPosts.map(post => (
            <article class="blog-card" data-category={post.category}>
              {post.og_image ? (
                <div class="blog-card-media">
                  <img src={post.og_image} alt={post.title} class="blog-card-img" loading="lazy" />
                </div>
              ) : (
                <div class="blog-card-placeholder">
                  <span class="material-symbols-outlined" aria-hidden="true" style="font-size:40px; color:#c2c7ce;">edit_note</span>
                </div>
              )}
              <div class="blog-card-body">
                <div class="blog-card-meta">
                  <span class="tag tag-teal">{post.category}</span>
                  {post.pub_date && (
                    <span class="blog-card-date">
                      {new Date(post.pub_date).toLocaleDateString('en-AE', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </span>
                  )}
                </div>
                <h3 class="blog-card-title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h3>
                <p class="blog-card-excerpt">{post.description}</p>
                <a href={`/blog/${post.slug}`} class="blog-card-link">
                  Read more →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    ) : collectionPosts.length > 0 ? (
      <div id="posts-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
        {collectionPosts.map(post => (
          <article class="blog-card" data-category={post.data.category}>
            {post.data.ogImage ? (
              <div class="blog-card-media">
                <img src={post.data.ogImage} alt={post.data.title} class="blog-card-img" loading="lazy" />
              </div>
            ) : (
              <div class="blog-card-placeholder">
                <span class="material-symbols-outlined" aria-hidden="true" style="font-size:40px; color:#c2c7ce;">edit_note</span>
              </div>
            )}
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="tag tag-teal">{post.data.category}</span>
                <span class="blog-card-date">
                  {post.data.pubDate.toLocaleDateString('en-AE', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
              </div>
              <h3 class="blog-card-title">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="blog-card-excerpt">{post.data.description}</p>
              <a href={`/blog/${post.id}`} class="blog-card-link">
                Read more →
              </a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:28px;">
          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" aria-hidden="true" style="font-size:40px; color:#c2c7ce;">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta"><span class="tag tag-coming">Coming Soon</span></div>
              <h3 class="blog-card-title">UAE AI Strategy 2031: What It Means for Your Business</h3>
              <p class="blog-card-excerpt" style="margin-bottom:0;">A practical breakdown of the UAE National AI Strategy and how SMEs can align their AI investments with national priorities.</p>
            </div>
          </article>

          <article class="blog-card" style="opacity:0.60;">
            <div class="blog-card-placeholder">
              <span class="material-symbols-outlined" aria-hidden="true" style="font-size:40px; color:#c2c7ce;">edit_note</span>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta"><span class="tag tag-coming">Coming Soon</span></div>
              <h3 class="blog-card-title">Arabic AI Chatbots: A Complete Guide for UAE Businesses</h3>
              <p class="blog-card-excerpt" style="margin-bottom:0;">Everything you need to know about deploying Arabic-language AI: accuracy, dialect handling, and integration with UAE customer channels.</p>
            </div>
          </article>
        </div>
      </div>
    )}

    <p id="no-results" class="no-results">No articles match your search. Try a different keyword or category.</p>

  </div>
</section>

</BaseLayout>

<style>
.blog-card {
  background:#fff; border:1px solid rgba(0,37,59,0.08); border-radius:var(--radius-lg);
  overflow:hidden; display:flex; flex-direction:column;
  box-shadow:var(--shadow-card);
  transition:transform .3s var(--ease), box-shadow .3s var(--ease), border-color .3s;
}
.blog-card:hover { transform:translateY(-5px); border-color:rgba(0,104,117,0.16); box-shadow:var(--shadow-card-hover); }
.blog-card-media { height:200px; overflow:hidden; position:relative; }
.blog-card-media::after {
  content:''; position:absolute; inset:0;
  background:linear-gradient(to top, rgba(0,37,59,0.10), transparent 40%);
  pointer-events:none;
}
.blog-card-img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .6s var(--ease); }
.blog-card:hover .blog-card-img { transform:scale(1.05); }
.blog-card-placeholder { height:200px; background:linear-gradient(135deg,#e7eeff,#f0f8ff); display:flex; align-items:center; justify-content:center; }
.blog-card-body { padding:1.625rem 1.625rem 1.5rem; flex:1; display:flex; flex-direction:column; }
.blog-card-meta { margin-bottom:0.875rem; display:flex; align-items:center; gap:8px; justify-content:space-between; }
.blog-card-date { font-size:0.75rem; color:#72787e; font-variant-numeric:tabular-nums; }
.blog-card-title { font-size:1.0625rem; font-weight:700; color:#00253b; margin-bottom:0.625rem; line-height:1.42; letter-spacing:-0.015em; }
.blog-card-title a { color:inherit; text-decoration:none; transition:color .2s; }
.blog-card-title a:hover { color:#006875; }
.blog-card-excerpt { color:#72787e; font-size:0.875rem; line-height:1.65; margin:0 0 1.125rem; }
.blog-card-link { font-size:0.8125rem; font-weight:700; color:#006875; text-decoration:none; margin-top:auto; align-self:flex-start; transition:transform .25s var(--ease), color .2s; }
.blog-card-link:hover { color:#004f58; transform:translateX(3px); }
.tag { display:inline-flex; align-items:center; padding:3px 12px; border-radius:100px; font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; }
.tag-coming { background:rgba(245,158,11,0.12); color:#d97706; border:1px solid rgba(245,158,11,0.25); }
.tag-teal { background:rgba(0,104,117,0.10); color:#004f58; border:1px solid rgba(0,104,117,0.20); }
.filter-btn {
  padding:7px 18px; border-radius:100px; font-size:0.8125rem; font-weight:600; cursor:pointer;
  border:1px solid rgba(0,37,59,0.16); background:#fff; color:#42474e;
  box-shadow:0 1px 2px rgba(0,37,59,0.04);
  transition:color .2s, border-color .2s, background .2s, transform .2s var(--ease), box-shadow .2s var(--ease);
}
.filter-btn:hover { border-color:#006875; color:#006875; transform:translateY(-1px); box-shadow:0 1px 2px rgba(0,37,59,0.05), 0 6px 14px rgba(0,59,92,0.08); }
.filter-btn.active { background:#006875; color:#fff; border-color:#006875; box-shadow:0 1px 2px rgba(0,37,59,0.10), 0 6px 16px rgba(0,104,117,0.26); }
.search-box {
  position: relative; display: flex; align-items: center;
}
.search-icon {
  position: absolute; left: 14px; font-size: 20px; color: #72787e; pointer-events: none;
}
.search-input {
  width: 100%; padding: .75rem 1rem .75rem 2.75rem;
  border: 1px solid #c2c7ce; border-radius: 100px; font-size: .9375rem; font-family: inherit;
  color: #111c2d; background: #ffffff;
  transition: border-color .2s, box-shadow .2s; outline: none;
}
.search-input::placeholder { color: #72787e; }
.search-input:focus { border-color: #006875; box-shadow: 0 0 0 3px rgba(0,104,117,0.12); }
.no-results { text-align: center; color: #72787e; padding: 3rem 1rem; display: none; }
.no-results.show { display: block; }
</style>

<script>
  const filterBar   = document.getElementById('filter-bar');
  const searchInput = document.getElementById('post-search') as HTMLInputElement | null;
  const noResults   = document.getElementById('no-results');
  let activeCategory = 'all';

  function applyFilters() {
    const grid = document.getElementById('posts-grid');
    if (!grid) return;
    const query = (searchInput?.value ?? '').trim().toLowerCase();
    let visibleCount = 0;

    grid.querySelectorAll<HTMLElement>('.blog-card').forEach(card => {
      const categoryMatch = activeCategory === 'all' || card.dataset.category === activeCategory;
      const text = (card.textContent ?? '').toLowerCase();
      const searchMatch = query === '' || text.includes(query);
      const match = categoryMatch && searchMatch;
      card.style.display = match ? '' : 'none';
      if (match) visibleCount++;
    });

    if (noResults) noResults.classList.toggle('show', visibleCount === 0);
  }

  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.filter-btn') as HTMLButtonElement | null;
      if (!btn) return;
      activeCategory = btn.dataset.filter ?? 'all';
      filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  }

  if (searchInput) {
    searchInput.addEventListener('input', () => applyFilters());
  }
</script>
