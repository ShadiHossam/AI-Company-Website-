---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

let jobs: { id: string; title: string; slug: string; department: string | null; location: string; job_type: string; salary_range: string | null }[] = [];
try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('jobs')
    .select('id, title, slug, department, location, job_type, salary_range')
    .eq('published', true)
    .order('sort_order', { ascending: true })
    .order('created_at', { ascending: false });
  jobs = data ?? [];
} catch {}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const careersSchema = jobs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Job Openings at Aegis AI',
  url: 'https://aegisai.ae/careers',
  itemListElement: jobs.map((j, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'JobPosting',
      title: j.title,
      url: `https://aegisai.ae/jobs/${j.slug}`,
      hiringOrganization: { '@type': 'Organization', name: 'Aegis AI', sameAs: 'https://aegisai.ae' },
      jobLocation: {
        '@type': 'Place',
        address: { '@type': 'PostalAddress', addressLocality: j.location ?? 'Dubai', addressCountry: 'AE' },
      },
      employmentType: 'FULL_TIME',
    },
  })),
} : undefined;
---

<BaseLayout
  title="Careers at Aegis AI — Join Our Dubai Team"
  description="Join Aegis AI and help SMEs across the UAE adopt AI. We're looking for builders, trainers, and problem-solvers based in Dubai."
  canonicalPath="/careers"
  ldJson={careersSchema}
>

<!-- HERO -->
<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><strong>Careers</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">work</span>
      We're Hiring
    </div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      Build AI That Changes<br>How Dubai <span class="gradient-text">Does Business.</span>
    </h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      We're a small, ambitious team helping SMEs across the UAE actually adopt AI — not just talk about it. If that sounds like work worth doing, we'd love to meet you.
    </p>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:280px;">
  <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&q=80&auto=format&fit=crop" alt="Team collaborating in a modern Dubai office" loading="eager" fetchpriority="high" width="1400" height="280" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0.05) 100%);"></div>
</div>

<!-- WHY JOIN US -->
<section class="section" style="padding:5rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <div class="section-eyebrow">Why Aegis AI</div>
      <h2>Where Your Work Has a <span class="gradient-text">Real Impact</span></h2>
      <p style="color:#42474e; max-width:560px; margin:1rem auto 0;">We're not building demos. Every system we ship is live in a real business, used by real people every day.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;">
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">rocket_launch</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Real Ownership</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">Small team means you own entire features end-to-end — no six-month tickets waiting in a backlog.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">diversity_3</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Diverse, Bilingual Team</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">We work in Arabic and English with clients across industries. Cultural fluency is a real edge here.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">school</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Keep Learning</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">Annual learning budget, access to the latest AI tools, and a team that discusses research papers at lunch.</p>
      </div>
    </div>
  </div>
</section>

<!-- PERKS -->
<section class="section" style="background:#e7eeff; padding:4rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <div class="section-eyebrow">Perks & Benefits</div>
      <h2>Built for People Who <span class="gradient-text">Do Great Work</span></h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem;">
      {[
        { icon: 'payments', label: 'Competitive Salary', desc: 'Benchmarked to Dubai market rates, reviewed annually' },
        { icon: 'health_and_safety', label: 'Health Insurance', desc: 'Full medical cover for you and your dependents' },
        { icon: 'menu_book', label: 'Learning Budget', desc: 'AED 5,000/year for courses, conferences, and books' },
        { icon: 'wb_sunny', label: 'Flexible Hours', desc: 'Core hours with flexibility around school runs and prayer times' },
        { icon: 'laptop_mac', label: 'Latest Equipment', desc: 'MacBook Pro or Windows — your choice, fully specced' },
        { icon: 'groups', label: 'Team Events', desc: 'Quarterly offsites, monthly team lunches, Eid celebrations' },
        { icon: 'trending_up', label: 'Clear Growth Path', desc: 'Transparent career ladder with 6-month reviews' },
        { icon: 'volunteer_activism', label: '100% Guarantee Culture', desc: 'We stand behind everything we do — including how we treat our team' },
      ].map(p => (
        <div class="stat-pill" style="flex-direction:column;align-items:flex-start;gap:.5rem;padding:1.25rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:22px;">{p.icon}</span>
          <div>
            <div style="font-weight:700;font-size:.9375rem;color:#00253b;">{p.label}</div>
            <div style="font-size:.8125rem;color:#42474e;margin-top:.25rem;line-height:1.5;">{p.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- OPEN ROLES -->
{jobs.length > 0 ? (
  <section class="section" style="padding:5rem 0;" id="open-roles">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <div class="section-eyebrow">Open Positions</div>
        <h2>Find Your <span class="gradient-text">Next Role</span></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {jobs.map(job => (
          <a href={`/jobs/${job.slug}`} class="job-card">
            <div class="job-card-left">
              <h3 style="font-size:1.125rem;font-weight:700;color:#00253b;margin-bottom:.375rem;">{job.title}</h3>
              <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                {job.department && (
                  <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                    <span class="material-symbols-outlined" style="font-size:15px;">corporate_fare</span>
                    {job.department}
                  </span>
                )}
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                  <span class="material-symbols-outlined" style="font-size:15px;">location_on</span>
                  {job.location}
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                  <span class="material-symbols-outlined" style="font-size:15px;">schedule</span>
                  {job.job_type}
                </span>
                {job.salary_range && (
                  <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                    <span class="material-symbols-outlined" style="font-size:15px;">payments</span>
                    {job.salary_range}
                  </span>
                )}
              </div>
            </div>
            <div class="job-card-right">
              <span class="btn-outline" style="display:inline-flex;align-items:center;gap:.375rem;font-size:.875rem;padding:.5rem 1.25rem;">
                Apply Now
                <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND (only shown when there are open roles) -->
  <section class="section" style="background:#e7eeff; padding:3.5rem 0;">
    <div class="container">
      <div class="cta-band">
        <h2 style="margin-bottom:.75rem;">Don't See a Perfect Fit?</h2>
        <p style="margin-bottom:1.75rem; opacity:.85;">We hire for attitude and aptitude. If you believe in what we're building, reach out — we'd still love to hear from you.</p>
        <a href={`mailto:careers@aegisai.ae?subject=Speculative%20Application`} class="btn-primary" style="display:inline-flex;align-items:center;gap:.5rem;">
          <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
          careers@aegisai.ae
        </a>
      </div>
    </div>
  </section>
) : (
  <!-- COMBINED EMPTY STATE + CTA (single block when no roles) -->
  <section class="section" style="padding:5rem 0;" id="open-roles">
    <div class="container">
      <div class="cta-band" style="text-align:center;">
        <span class="material-symbols-outlined" style="font-size:48px;opacity:.6;display:block;margin-bottom:1.25rem;">work_history</span>
        <h2 style="margin-bottom:.75rem;">No Open Roles Right Now</h2>
        <p style="margin-bottom:1.75rem; opacity:.85; max-width:480px; margin-left:auto; margin-right:auto;">We're not actively hiring but we hire for attitude and aptitude. If you believe in what we're building, send us your CV — we'd love to hear from you.</p>
        <a href={`mailto:careers@aegisai.ae?subject=Speculative%20Application`} class="btn-primary" style="display:inline-flex;align-items:center;gap:.5rem;">
          <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
          careers@aegisai.ae
        </a>
      </div>
    </div>
  </section>
)}

</BaseLayout>

<style>
  .job-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 1.375rem 1.5rem;
    text-decoration: none;
    transition: box-shadow .2s, border-color .2s, transform .15s;
  }
  .job-card:hover {
    border-color: #00e3fd;
    box-shadow: 0 8px 24px rgba(0, 99, 117, 0.10);
    transform: translateY(-2px);
  }
  .job-card-left { flex: 1; min-width: 0; }
  .job-card-right { flex-shrink: 0; }
  @media (max-width: 600px) {
    .job-card { flex-direction: column; align-items: flex-start; }
    .job-card-right { width: 100%; }
    .job-card-right .btn-outline { width: 100%; justify-content: center; }
  }
</style>
