---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

let jobs: { id: string; title: string; slug: string; department: string | null; location: string; job_type: string; salary_range: string | null }[] = [];
try {
  const supabase = getSupabaseAdmin();
  const { data } = await supabase
    .from('jobs')
    .select('id, title, slug, department, location, job_type, salary_range')
    .eq('published', true)
    .is('deleted_at', null)
    .order('sort_order', { ascending: true })
    .order('created_at', { ascending: false });
  jobs = data ?? [];
} catch {}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const careersSchema = jobs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Job Openings at Aegis AI',
  url: 'https://aegisai.ae/careers',
  itemListElement: jobs.map((j, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'JobPosting',
      title: j.title,
      url: `https://aegisai.ae/jobs/${j.slug}`,
      hiringOrganization: { '@type': 'Organization', name: 'Aegis AI', sameAs: 'https://aegisai.ae' },
      jobLocation: {
        '@type': 'Place',
        address: j.location ? { '@type': 'PostalAddress', addressLocality: j.location } : undefined,
      },
      employmentType: 'FULL_TIME',
    },
  })),
} : undefined;
---

<BaseLayout
  title="Careers at Aegis AI: We Hire Drive, Not Degrees"
  description="Aegis AI is a global AI company. We hire creative, self-driven minds, no minimum age, no red tape. If you build, learn, and create, we want you."
  canonicalPath="/careers"
  arPath="/ar/careers"
  ldJson={careersSchema}
>

<!-- HERO -->
<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Careers</div>
    <h1 style="max-width:780px; margin-left:auto; margin-right:auto;">
      The Future Is Built by People<br>Who Can't Stop <span class="gradient-text">Creating.</span>
    </h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 0;">
      We're a global AI company that ships real products for real clients. We don't care where you're from or how old you are. We care what you build. If you're driven, curious, and hungry to make something, you belong here.
    </p>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:280px;">
  <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1400&q=80&auto=format&fit=crop" alt="Team collaborating on AI products" loading="eager" fetchpriority="high" width="1400" height="280" style="width:100%;height:100%;object-fit:cover;object-position:center 40%;" />
  <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(249,249,255,0.50) 0%,rgba(249,249,255,0.05) 100%);"></div>
</div>

<!-- WHY JOIN US -->
<section class="section" style="padding:5rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2>Where Your Work Has a <span class="gradient-text">Real Impact</span></h2>
      <p style="color:#42474e; max-width:560px; margin:1rem auto 0;">We're not building demos. Every system we ship is live in a real business, used by real people every day.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem;">
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">rocket_launch</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Real Ownership</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">You don't shadow someone for six months. From day one, you own real work that ships to real users.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">globe</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Global Team, Global Clients</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">We work with clients across continents. No borders on ideas, no ceiling on where this takes you.</p>
      </div>
      <div class="value-card">
        <div style="width:48px;height:48px;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:24px;">school</span>
        </div>
        <h3 style="font-size:1.125rem;margin-bottom:.5rem;">Never Stop Learning</h3>
        <p style="color:#42474e;font-size:.9375rem;line-height:1.6;">AI moves fast. We give you the tools, the time, and the team to stay ahead, not just keep up.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHO WE'RE LOOKING FOR -->
<section class="section" style="padding:5rem 0; background:#f9f9ff;">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2>We Look for <span class="gradient-text">People, Not Profiles.</span></h2>
      <p style="color:#42474e; max-width:540px; margin:1rem auto 0;">No resume template. No minimum age. No corporate ladder to climb before you can do real work. Just four things we look for in everyone we hire.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:1.5rem; max-width:860px; margin:0 auto 3rem;">
      {[
        { icon: 'self_improvement', title: 'Self-Driven', desc: "You don't wait to be told what to do. You spot the problem, understand it, and fix it, because it needs fixing." },
        { icon: 'lightbulb', title: 'Love to Learn', desc: "Curiosity isn't a perk for you. It's how you're wired. You read, experiment, and get excited when something breaks." },
        { icon: 'payments', title: 'Want to Earn', desc: "We believe great work deserves great pay. No \"exposure\" here. Real money for real results, reviewed regularly." },
        { icon: 'draw', title: 'Create Your Own Ideas', desc: "Got a wild idea? Bring it. The best things we've built started as someone's side thought in a random conversation." },
      ].map(t => (
        <div class="value-card" style="display:flex; gap:1rem; align-items:flex-start;">
          <div style="width:44px;height:44px;flex-shrink:0;border-radius:12px;background:rgba(0,227,253,0.12);display:flex;align-items:center;justify-content:center;">
            <span class="material-symbols-outlined" style="color:#006875;font-size:22px;">{t.icon}</span>
          </div>
          <div>
            <h3 style="font-size:1.0625rem;margin-bottom:.375rem;">{t.title}</h3>
            <p style="color:#42474e;font-size:.9375rem;line-height:1.6;margin:0;">{t.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Quote block -->
    <div style="max-width:720px; margin:0 auto 2rem; border-left:4px solid #00e3fd; background:rgba(0,227,253,0.06); border-radius:0 12px 12px 0; padding:1.5rem 2rem;">
      <p style="font-size:1.25rem; font-style:italic; color:#00253b; line-height:1.7; margin:0 0 .75rem;">
        "The most dangerous person in any room isn't the most experienced. It's the one who hasn't been told what's impossible yet."
      </p>
      <span style="font-size:.875rem; font-weight:600; color:#006875;">— Aegis AI</span>
    </div>

    <!-- No-age callout -->
    <div style="text-align:center;">
      <span style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:8px 20px; color:#004f58; font-size:.9375rem; font-weight:600;">
        <span class="material-symbols-outlined" style="font-size:18px;">verified</span>
        No degree required. No minimum age. Just show us what you can do.
      </span>
    </div>
  </div>
</section>

<!-- PERKS -->
<section class="section" style="background:#e7eeff; padding:4rem 0;">
  <div class="container">
    <div style="text-align:center; margin-bottom:2.5rem;">
      <h2>Built for People Who <span class="gradient-text">Do Great Work</span></h2>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:1rem;">
      {[
        { icon: 'payments', label: 'Competitive Pay', desc: 'Real money benchmarked to what great work is worth, reviewed every year' },
        { icon: 'menu_book', label: 'Learning Budget', desc: 'Annual budget for courses, books, tools, and anything that makes you sharper' },
        { icon: 'wb_sunny', label: 'Flexible Hours', desc: 'Work when you do your best thinking. We care about output, not schedules' },
        { icon: 'laptop_mac', label: 'Latest Equipment', desc: 'Top-spec machine of your choice, set up the way you want it' },
        { icon: 'trending_up', label: 'Clear Growth Path', desc: 'Transparent ladder, honest feedback, and a team that wants you to level up' },
        { icon: 'lightbulb', label: 'Your Ideas Matter', desc: "Bring an idea. If it's good, we'll build it together and you'll own a piece of it" },
        { icon: 'public', label: 'Work from Anywhere', desc: 'Remote-friendly and globally distributed. Your timezone is not a barrier' },
        { icon: 'volunteer_activism', label: 'We Have Your Back', desc: 'We stand behind everything we ship, and everyone on the team' },
      ].map(p => (
        <div class="stat-pill" style="flex-direction:column;align-items:flex-start;gap:.5rem;padding:1.25rem;">
          <span class="material-symbols-outlined" style="color:#006875;font-size:22px;">{p.icon}</span>
          <div>
            <div style="font-weight:700;font-size:.9375rem;color:#00253b;">{p.label}</div>
            <div style="font-size:.8125rem;color:#42474e;margin-top:.25rem;line-height:1.5;">{p.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- OPEN ROLES -->
{jobs.length > 0 ? (
  <section class="section" style="padding:5rem 0;" id="open-roles">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <h2>Find Your <span class="gradient-text">Next Role</span></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {jobs.map(job => (
          <a href={`/jobs/${job.slug}`} class="job-card">
            <div class="job-card-left">
              <h3 style="font-size:1.125rem;font-weight:700;color:#00253b;margin-bottom:.375rem;">{job.title}</h3>
              <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
                {job.department && (
                  <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                    <span class="material-symbols-outlined" style="font-size:15px;">corporate_fare</span>
                    {job.department}
                  </span>
                )}
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                  <span class="material-symbols-outlined" style="font-size:15px;">location_on</span>
                  {job.location}
                </span>
                <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                  <span class="material-symbols-outlined" style="font-size:15px;">schedule</span>
                  {job.job_type}
                </span>
                {job.salary_range && (
                  <span style="display:inline-flex;align-items:center;gap:4px;font-size:.8125rem;color:#42474e;">
                    <span class="material-symbols-outlined" style="font-size:15px;">payments</span>
                    {job.salary_range}
                  </span>
                )}
              </div>
            </div>
            <div class="job-card-right">
              <span class="btn-outline" style="display:inline-flex;align-items:center;gap:.375rem;font-size:.875rem;padding:.5rem 1.25rem;">
                Apply Now
                <span class="material-symbols-outlined" style="font-size:16px;">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA (only shown when there are open roles) -->
  <section class="section" style="background:#e7eeff; padding:3.5rem 0;">
    <div class="container">
      <div class="cta-band">
        <div style="position:relative; z-index:1; text-align:center;">
          <p class="cta-eyebrow">Free Discovery Call</p>
          <h2 style="font-size:clamp(1.75rem,3vw,2.5rem); margin-bottom:1rem;">Don't See a Perfect Fit?</h2>
          <p style="font-size:1.125rem; max-width:36rem; margin:0 auto 2rem; line-height:1.7;">We hire for attitude and aptitude. If you believe in what we're building, reach out. We'd still love to hear from you.</p>
          <div class="cta-trust-badges">
            <span class="cta-trust-badge">✓ 100% free</span>
            <span class="cta-trust-badge">✓ No commitment</span>
            <span class="cta-trust-badge">✓ Refund guarantee</span>
          </div>
          <a href={`mailto:careers@aegisai.ae?subject=Speculative%20Application`} class="btn-primary" style="display:inline-flex;align-items:center;gap:.5rem;font-size:1.125rem;padding:1.125rem 2.75rem;">
            <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
            careers@aegisai.ae
          </a>
          <p style="font-size:.875rem; margin-top:1rem; color:#94a3b8;">30-min call · No sales pressure</p>
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="section" style="padding:5rem 0;" id="open-roles">
    <div class="container">
      <div class="cta-band" style="text-align:center;">
        <div style="position:relative; z-index:1; text-align:center;">
          <span class="material-symbols-outlined" style="font-size:48px;opacity:.6;display:block;margin-bottom:1.25rem;">work_history</span>
          <p class="cta-eyebrow">Free Discovery Call</p>
          <h2 style="font-size:clamp(1.75rem,3vw,2.5rem); margin-bottom:1rem;">No Open Roles Right Now</h2>
          <p style="font-size:1.125rem; max-width:36rem; margin:0 auto 2rem; line-height:1.7;">We're not actively hiring but we hire for attitude and aptitude. If you believe in what we're building, send us your CV. We'd love to hear from you.</p>
          <div class="cta-trust-badges">
            <span class="cta-trust-badge">✓ 100% free</span>
            <span class="cta-trust-badge">✓ No commitment</span>
            <span class="cta-trust-badge">✓ Refund guarantee</span>
          </div>
          <a href={`mailto:careers@aegisai.ae?subject=Speculative%20Application`} class="btn-primary" style="display:inline-flex;align-items:center;gap:.5rem;font-size:1.125rem;padding:1.125rem 2.75rem;">
            <span class="material-symbols-outlined" style="font-size:18px;">mail</span>
            careers@aegisai.ae
          </a>
          <p style="font-size:.875rem; margin-top:1rem; color:#94a3b8;">30-min call · No sales pressure</p>
        </div>
      </div>
    </div>
  </section>
)}

</BaseLayout>

<style>
  .job-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 1.375rem 1.5rem;
    text-decoration: none;
    transition: box-shadow .2s, border-color .2s, transform .15s;
  }
  .job-card:hover {
    border-color: #00e3fd;
    box-shadow: 0 8px 24px rgba(0, 99, 117, 0.10);
    transform: translateY(-2px);
  }
  .job-card-left { flex: 1; min-width: 0; }
  .job-card-right { flex-shrink: 0; }
  @media (max-width: 600px) {
    .job-card { flex-direction: column; align-items: flex-start; }
    .job-card-right { width: 100%; }
    .job-card-right .btn-outline { width: 100%; justify-content: center; }
  }
</style>
