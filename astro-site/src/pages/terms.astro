---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";

let dynamicSections: { heading: string; body: string }[] | null = null;
let dynamicLastUpdated: string | null = null;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('legal_pages')
    .select('sections, last_updated')
    .eq('slug', 'terms')
    .single();

  if (!error && data && Array.isArray(data.sections) && data.sections.length > 0) {
    dynamicSections = data.sections;
    dynamicLastUpdated = data.last_updated ?? null;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Terms & Conditions | Aegis AI"
  description="Terms and Conditions for Aegis AI — outlining the terms, conditions, and agreements for our custom AI development, consulting, and team training services in the UAE."
  canonicalPath="/terms"
  ogImage="/assets/og-terms.jpg"
  noindex={true}
>

<header class="hero-section" style="padding:8rem 0 5rem;">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <strong>Terms &amp; Conditions</strong>
    </nav>
    <h1>Terms &amp; <span class="gradient-text">Conditions</span></h1>
    <p style="color:#42474e; font-size:1.0625rem; max-width:560px; margin:1rem auto 0;">
      {dynamicLastUpdated ? `Last Updated: ${dynamicLastUpdated}.` : "Last Updated: June 11, 2026."} Please read these terms carefully before using our website or engaging our services.
    </p>
  </div>
</header>

<main class="section">
  <div class="container" style="max-width:760px;">
    <div class="prose">

      {dynamicSections ? (
        dynamicSections.map((section) => (
          <section>
            <h2 set:html={section.heading}></h2>
            <p set:html={section.body}></p>
          </section>
        ))
