    .guarantee-box ul { color: #42474e; font-size: 0.875rem; }
    .contact-box { background: #f0f3ff; border: 1px solid rgba(0,37,59,0.10); border-radius: 12px; padding: 1.25rem; margin-top: 1rem; }
    .contact-box p { margin: 0 0 0.375rem; color: #42474e; font-size: 0.9rem; }
</style>
