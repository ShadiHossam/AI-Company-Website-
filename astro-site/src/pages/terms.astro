    .prose ul { color: #42474e; padding-left: 1.5rem; line-height: 1.8; }
    .prose li { margin-bottom: 0.5rem; }
    .prose strong { color: #111c2d; }
    .prose section { margin-bottom: 2.5rem; }
    .prose a { color: #006875; text-decoration: underline; }
    .guarantee-box { background: rgba(0,104,117,0.06); border: 1px solid rgba(0,104,117,0.20); border-radius: 12px; padding: 1.25rem; margin: 1rem 0; }
