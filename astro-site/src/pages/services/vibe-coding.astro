---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";
import FaqAccordion from "../../components/FaqAccordion.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import StatStrip from "../../components/StatStrip.astro";

const fallbackFaqs = [
  { question: "What exactly is vibe coding?", answer: "Vibe coding is AI-accelerated software development. Instead of writing every line manually, developers work with AI as a pair programmer using the latest AI coding tools. The result is faster delivery without sacrificing quality." },
  { question: "Is the quality as good as traditional development?", answer: "Yes, often better. AI tools catch more bugs, suggest optimized patterns, and enforce consistency across large codebases. We pair AI-generated code with rigorous human review, automated testing, and QA cycles. You get speed and quality." },
  { question: "What kinds of projects are best suited for vibe coding?", answer: "Web applications, SaaS products, internal tools, APIs, dashboards, mobile apps, and scripts. It works especially well for MVPs where speed to market matters, and for modernizing legacy codebases that need to be rewritten efficiently." },
  { question: "Do you hand over the code and documentation?", answer: "Yes. You receive full ownership of all code, documentation, and infrastructure configuration. We don't lock you in. The handover includes a technical walkthrough so your team can maintain and extend the product independently." },
  { question: "Is the code maintainable by our in-house developers after handover?", answer: "Yes, that's a core requirement of how we build. We write clean, well-structured code with documentation. AI-assisted development doesn't mean messy code; it means faster production of the same clean code your developers would write themselves. We also hold a technical walkthrough session so your team understands the architecture before they take ownership." },
  { question: "How does the 10× speed claim actually work in practice?", answer: "AI coding tools dramatically accelerate the parts of development that are most time-consuming: writing boilerplate, generating tests, scaffolding components, and handling repetitive implementation patterns. Senior engineers focus on architecture, logic, and review. The combination produces output at a pace that would be impossible with manual development alone. Real projects vary, but a 3-5 week MVP that would traditionally take 3-5 months is a realistic expectation." },
  { question: "What tech stacks do you build with?", answer: "We work across major modern stacks: React, Next.js, Vue, Node.js, Python, TypeScript, PostgreSQL, Supabase, and others. We recommend the right stack for your specific requirements, factoring in your team's existing knowledge, deployment environment, and long-term maintenance needs." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'vibe_coding')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const processSteps = [
  { icon: "description", step: "Step 1", title: "Spec & Architecture", description: "We scope the product, define the tech stack, and create a detailed spec you approve before we write a line of code." },
  { icon: "code", step: "Step 2", title: "AI-Powered Build", description: "We build using AI tools at maximum velocity. Every line is reviewed by senior engineers for quality and security." },
  { icon: "bug_report", step: "Step 3", title: "Test & Review", description: "AI-generated tests + manual QA + your team's review. Nothing ships without passing every check." },
  { icon: "rocket_launch", step: "Step 4", title: "Deploy & Hand Over", description: "Product goes live. Full code handover with documentation and a technical walkthrough for your team, wherever you're based in Dubai or the wider UAE." },
];

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Vibe Coding for UAE Businesses: AI-Accelerated Development | Lenoo AI"
  description="Ship software faster with AI-accelerated development. Our Dubai AI agency builds products for UAE businesses without sacrificing quality."
  canonicalPath="/services/vibe-coding"
  arPath="/ar/services/vibe-coding"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/services" style="color:inherit;text-decoration:none;opacity:0.65;">Services</a><span style="opacity:0.4;padding:0 4px;"> / </span>Vibe Coding</div>
    <h1>Ship 10× Faster With <span class="gradient-text">AI-Powered Development.</span></h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:620px; margin:1.5rem auto 2.5rem; line-height:1.8;">
      Traditional software development is slow. Vibe coding changes that. We use the latest AI coding tools to build your product faster, without cutting corners on quality, security, or maintainability.
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="vibe_hero" class="btn-primary">Discuss Your Project</button>
      <a href="#what-we-build" class="btn-outline">See What We Build ↓</a>
    </div>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:260px;">
  <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1400&q=80&auto=format&fit=crop" alt="Vibe coding and AI-assisted software development" loading="eager" fetchpriority="high" width="1400" height="260" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.45));"></div>
</div>

<!-- STAT BANNER -->
<div style="background:linear-gradient(135deg,#00253b,#003b5c,#006875); padding:4rem 0;">
  <div class="container">
    <StatStrip stats={[
      { value: "10×", caption: "faster than traditional development on average, measured across our client projects" },
      { value: "Full code", caption: "ownership. You get everything: source code, docs, infra configs, and no lock-in" },
      { value: "100%", caption: "refund guarantee if you're not satisfied with what we deliver" },
    ]} />
  </div>
</div>

<!-- WHAT IS VIBE CODING -->
<section class="section" aria-labelledby="explain-heading">
  <div class="container">
    <div class="split-grid">
      <div>
        <h2 id="explain-heading" style="text-align:left; margin-bottom:1.5rem;">What Is Vibe Coding?</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.85; margin-bottom:1.25rem;">
          Vibe coding is a development approach where engineers use AI as an active pair programmer throughout the entire build process. Instead of writing every line from scratch, developers describe what they need, review and refine what AI generates, direct architecture decisions, and focus their energy on the parts that require genuine expertise: security, performance, data modeling, and integration logic.
        </p>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.85; margin-bottom:1.25rem;">
          The speed advantage is real and measurable. Tasks that consume 80% of traditional development time, things like scaffolding components, writing tests, generating boilerplate, and implementing standard patterns, happen in a fraction of the time with AI assistance. Senior engineers redirect that time to architecture and quality control, resulting in better code in less time.
        </p>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.85;">
          This is not AI writing your software unsupervised. Every line produced goes through human review by engineers who know what good code looks like. The output passes the same automated testing and QA standards as any traditionally developed product. What vibe coding changes is the ratio of time spent on creative problem-solving versus repetitive implementation, and that ratio shift is what produces dramatically faster delivery without the quality trade-off.
        </p>
      </div>
      <div class="split-media">
        <img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=900&q=80&auto=format&fit=crop" alt="AI-assisted program code on a developer's screen" loading="lazy" width="900" height="620" />
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="build-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="build-heading">What You Can Ship With Vibe Coding</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Common starting points. If you have something different in mind, we build that too. From MVPs to full products to legacy modernization. Built fast, built right either way.</p>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?w=1200&q=80&auto=format&fit=crop" alt="Lenoo AI engineer pairing with AI coding tools across multiple screens in Dubai" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">web</span></div>
        <h3>Web Applications &amp; SaaS Products</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Full-stack web apps built with modern frameworks, shipped faster than traditional development without cutting corners on quality.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">speed</span></div>
        <h3>Rapid Prototypes &amp; MVPs</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Got an idea? We'll build a working MVP fast enough to validate it with real users before you've spent a significant budget.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">dashboard</span></div>
        <h3>Internal Tools &amp; Admin Panels</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Custom dashboards, admin interfaces, and internal tools that do exactly what your team needs, without enterprise software bloat.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">api</span></div>
        <h3>APIs &amp; Backend Systems</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">RESTful and GraphQL APIs, microservices, and data pipelines built for scale, with documentation and testing built in from day one.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">transform</span></div>
        <h3>Legacy Code Modernization</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">We use AI to analyze, refactor, and modernize old codebases, eliminating tech debt and reducing maintenance costs without full rewrites.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" aria-hidden="true" style="color:#006875; font-size:24px;">verified</span></div>
        <h3>AI-Generated Test Suites</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Comprehensive unit, integration, and end-to-end tests generated by AI, so your codebase ships with confidence and stays stable as it grows.</p>
      </div>
    </div>
  </div>
</section>

<!-- IS IT RIGHT FOR YOU -->
<section class="section" style="background:#f0f3ff;" aria-labelledby="right-for-you-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="right-for-you-heading">Is Vibe Coding Right for Your Project?</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Vibe coding is the right approach for most software projects, but it's especially well-suited to certain situations.</p>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
      <div style="background:#fff; border:1px solid rgba(0,104,117,0.2); border-radius:16px; padding:1.75rem;">
        <p style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#006875; margin-bottom:1rem;">Great fit</p>
        <ul style="color:#42474e; font-size:0.9rem; line-height:1.9; padding-left:1.25rem; margin:0; list-style:none; padding:0;">
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#006875; flex-shrink:0;">✓</span> You need an MVP validated quickly before committing to a full build</li>
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#006875; flex-shrink:0;">✓</span> You have a defined scope and want it shipped on a tight timeline</li>
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#006875; flex-shrink:0;">✓</span> You have a legacy codebase that needs to be modernized without a full rewrite</li>
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#006875; flex-shrink:0;">✓</span> Budget matters and you want maximum output per dollar spent</li>
          <li style="padding:0.375rem 0; display:flex; gap:0.625rem;"><span style="color:#006875; flex-shrink:0;">✓</span> You want comprehensive test coverage built in from day one</li>
        </ul>
      </div>
      <div style="background:#fff; border:1px solid rgba(0,37,59,0.1); border-radius:16px; padding:1.75rem;">
        <p style="font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#42474e; margin-bottom:1rem;">Worth discussing first</p>
        <ul style="color:#42474e; font-size:0.9rem; line-height:1.9; padding-left:1.25rem; margin:0; list-style:none; padding:0;">
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#42474e; flex-shrink:0;">→</span> Requirements are still being defined and may change frequently</li>
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#42474e; flex-shrink:0;">→</span> The project requires highly specialized hardware or real-time systems</li>
          <li style="padding:0.375rem 0; border-bottom:1px solid rgba(0,37,59,0.07); display:flex; gap:0.625rem;"><span style="color:#42474e; flex-shrink:0;">→</span> Compliance requirements mandate a specific development methodology or audit trail</li>
          <li style="padding:0.375rem 0; display:flex; gap:0.625rem;"><span style="color:#42474e; flex-shrink:0;">→</span> You have strong preferences about specific technologies we haven't worked with</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- TIMELINE COMPARISON -->
<section class="section" style="background:#fff;" aria-labelledby="timeline-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="timeline-heading">The Timeline Difference</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Same MVP scope, two ways of building it.</p>
    </div>
    <div class="bento-grid bento-grid-2">
      <div class="value-card">
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:1rem;">Traditional Development</h3>
        <div class="vc-week-row"><span class="vc-week-tag">Weeks 1-3</span><span>Requirements, architecture, and design sign-off</span></div>
        <div class="vc-week-row"><span class="vc-week-tag">Weeks 4-12</span><span>Manual build of core features, one at a time</span></div>
        <div class="vc-week-row"><span class="vc-week-tag">Weeks 13-16</span><span>Testing, bug fixes, and stakeholder review cycles</span></div>
        <div class="vc-week-row"><span class="vc-week-tag">Weeks 17-20</span><span>Final QA, deployment, and handover</span></div>
      </div>
      <div class="value-card">
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:1rem;">Vibe Coding</h3>
        <div class="vc-week-row"><span class="vc-week-tag vc-week-tag-fast">Week 1</span><span>Spec, architecture, and tech stack approved</span></div>
        <div class="vc-week-row"><span class="vc-week-tag vc-week-tag-fast">Weeks 2-3</span><span>AI-accelerated build across the full feature set at once</span></div>
        <div class="vc-week-row"><span class="vc-week-tag vc-week-tag-fast">Weeks 3-4</span><span>AI-generated test suites plus senior engineer review</span></div>
        <div class="vc-week-row"><span class="vc-week-tag vc-week-tag-fast">Week 5</span><span>Deployment and full code handover</span></div>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <h2 id="process-heading">How We Ship Your Product Fast</h2>
    </div>
    <div style="border-radius:24px; overflow:hidden; margin-bottom:3rem; box-shadow:0 24px 56px rgba(0,59,92,0.10);">
      <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1200&q=80&auto=format&fit=crop" alt="Developer shipping product features at a coding workstation" loading="lazy" width="1200" height="380" style="width:100%; height:clamp(200px, 30vw, 380px); object-fit:cover; display:block;" />
    </div>
    <ProcessSteps steps={processSteps} />
  </div>
</section>

<!-- FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">Frequently Asked Questions</h2>
    </div>
    <FaqAccordion items={faqItems} />
  </div>
</section>

<!-- FINAL CTA -->
<div class="cta-band">
  <div style="position:relative; z-index:1; text-align:center;">
    <p class="cta-eyebrow">Free Discovery Call</p>
    <h2 style="font-size:clamp(1.75rem,3vw,2.5rem); margin-bottom:1rem;">Ready to Ship Your Product Faster?</h2>
    <p style="font-size:1.125rem; max-width:36rem; margin:0 auto 2rem; line-height:1.7;">Tell us what you want to build. We'll give you a timeline and cost estimate, free, with no commitment.</p>
    <div class="cta-trust-badges">
      <span class="cta-trust-badge">✓ 100% free</span>
      <span class="cta-trust-badge">✓ No commitment</span>
      <span class="cta-trust-badge">✓ Refund guarantee</span>
    </div>
    <button onclick="openModal(this)" data-source="vibe_cta" class="btn-primary" style="font-size:1.125rem; padding:1.125rem 2.75rem;">Discuss Your Project</button>
    <p style="font-size:.875rem; margin-top:1rem; color:#94a3b8;">30-min call · No sales pressure</p>
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Vibe Coding",
      "url": "https://lenooai.com/services/vibe-coding",
      "description": "AI-accelerated software development: web apps, SaaS products, APIs, and internal tools shipped 10× faster using the latest AI coding tools.",
      "provider": { "@type": "Organization", "name": "Lenoo AI", "url": "https://lenooai.com" },
      "areaServed": "United Arab Emirates",
      "serviceType": "Software Development"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lenooai.com/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://lenooai.com/services" },
        { "@type": "ListItem", "position": 3, "name": "Vibe Coding", "item": "https://lenooai.com/services/vibe-coding" }
      ]
    }
  ]
}
</script>

</BaseLayout>

<style>
.icon-box { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; }
.builds-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.tech-pill { display:inline-block; background:#fff; border:1px solid #dde3ea; border-radius:100px; padding:0.375rem 1rem; font-size:0.8125rem; font-weight:600; color:#00253b; }
.vc-week-row { display:flex; align-items:center; gap:1rem; padding:0.875rem 0; border-bottom:1px solid rgba(0,37,59,0.08); color:#42474e; font-size:0.9375rem; }
.vc-week-row:last-child { border-bottom:none; }
.vc-week-tag { flex-shrink:0; width:110px; font-weight:700; font-size:0.8125rem; color:#72787e; }
.vc-week-tag-fast { color:#006875; }
@media(max-width:900px) { .builds-grid { grid-template-columns:1fr 1fr; } .process-grid { grid-template-columns:1fr 1fr; } .process-connector { display:none; } }
@media(max-width:600px) { .builds-grid { grid-template-columns:1fr; } }
</style>
