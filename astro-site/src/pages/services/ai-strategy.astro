---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "What does the Strategy Sprint actually involve?", answer: "Phase 1: We conduct interviews with key stakeholders, review your current workflows, data, and tools. Phase 2: We analyze findings, build the roadmap document, and prepare the executive presentation. The engagement closes with a 60-minute session where we present the full roadmap." },
  { question: "Is the Strategy Sprint cost deductible from implementation?", answer: "Yes. If you proceed with any Custom AI Development package with us after the Strategy Sprint, the full sprint cost is deducted from your project cost. This makes the strategy session effectively free when combined with implementation." },
  { question: "Are we obligated to use your company for implementation?", answer: "No. The roadmap document belongs to you. You're free to use it to build with us, hire another team, or implement internally. We're confident our implementation quality will make the choice obvious." },
  { question: "How many people from our company need to be involved?", answer: "Ideally 2–4 stakeholders: the decision-maker (CEO/COO), an operations manager, and ideally one department head from the area you're most interested in improving. Interviews take 1–2 hours total from your team across the engagement." },
  { question: "We've already started using some AI tools. Does a strategy session still make sense?", answer: "Often more so. Starting without a strategy means you may have made some good decisions and some costly ones. A strategy session helps you assess what's working, what should be stopped or replaced, and how to build on what you have with a coherent plan. Many of our clients come in with a few tools already deployed and leave with a clear picture of how to make them work together." },
  { question: "What size business is this designed for?", answer: "We've run strategy sprints for companies ranging from 15-person teams to large enterprises. The format scales: a smaller business gets focused, prioritized recommendations; a larger organization gets a full multi-department roadmap. Either way, the output is a document you can actually act on, not a generic framework with your logo on it." },
  { question: "How current is the AI landscape knowledge you bring to the sprint?", answer: "Very current. AI capabilities change fast, and we stay actively involved in the ecosystem. We'll tell you what's newly possible that wasn't viable six months ago, what tools have emerged in your industry, and where the hype still exceeds the reality. The roadmap we deliver reflects the state of AI today, not last year." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'strategy')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
