---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";
import FaqAccordion from "../../components/FaqAccordion.astro";
import ProcessSteps from "../../components/ProcessSteps.astro";
import StatStrip from "../../components/StatStrip.astro";

const fallbackFaqs = [
  { question: "What's the difference between an AI agent and a chatbot?", answer: "A chatbot responds to questions. An AI agent takes actions. Agents can browse the web, write and send emails, update your CRM, book meetings, run searches, call APIs, and chain multiple steps together without waiting to be told what to do next. They're autonomous problem-solvers, not just answer machines." },
  { question: "How reliable are AI agents at making decisions?", answer: "We design agents with clear guardrails, approval checkpoints for high-stakes actions, and human-in-the-loop controls where needed. Agents handle the high-volume, low-risk decisions automatically; anything requiring human judgment routes to a person for approval. Reliability increases over time as agents learn from feedback." },
  { question: "Can agents work with our existing tools?", answer: "Yes. We build agents that connect to your existing systems via API: CRM, email, calendar, databases, team communication tools, and more. The agent acts as a smart layer on top of your current stack, not a replacement for it." },
  { question: "Is there a risk of agents doing something wrong?", answer: "We build comprehensive logging, rollback capabilities, and action limits into every agent. Every action the agent takes is recorded and reviewable. For mission-critical workflows, we add a human approval step before irreversible actions are executed." },
  { question: "What's the difference between a simple automation and an AI agent?", answer: "A traditional automation follows a fixed script: if X happens, do Y. It breaks the moment something unexpected occurs. An AI agent reasons through the situation, decides the best course of action, and adapts when things don't go as planned. Automations are great for predictable, repetitive tasks. Agents are for tasks that require judgment, unstructured input, or variable steps." },
  { question: "Can one agent handle multiple different tasks?", answer: "An agent can be given multiple capabilities and tools, but we generally design narrowly focused agents that do one job extremely well. For complex workflows that span multiple domains, we build multi-agent systems: a team of specialized agents coordinated by an orchestrator. This produces more reliable results than one overloaded generalist agent." },
  { question: "What does a typical AI agent project cost?", answer: "It depends on the complexity of the workflow, the number of tools the agent needs to use, and whether you need a custom UI or just an API. Simple single-workflow agents start in the low thousands. Multi-agent systems for complex operations are scoped individually. All projects include a free discovery call where we give you a clear estimate before you commit to anything." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'ai_agents')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const processSteps = [
  { icon: "target", step: "Step 1", title: "Define the Mission", description: "We scope exactly what your agent needs to do, what tools it needs access to, and where humans stay in the loop." },
  { icon: "extension", step: "Step 2", title: "Build & Connect", description: "We build the agent, connect it to your tools, train it on your context, and define guardrails for safe operation." },
  { icon: "science", step: "Step 3", title: "Test Rigorously", description: "We stress-test with edge cases, adversarial inputs, and real scenarios to ensure the agent behaves as expected before going live." },
  { icon: "monitoring", step: "Step 4", title: "Monitor & Improve", description: "Full audit logs, performance dashboards, and 90-day support ensure your agent keeps improving after launch." },
];

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="AI Agents & Agentic Systems for UAE Businesses | Lenoo AI"
  description="AI that doesn't just answer, it acts. As a Dubai AI agency, we build autonomous AI agents for UAE businesses that reason, decide, and execute."
  canonicalPath="/services/ai-agents"
  arPath="/ar/services/ai-agents"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/services" style="color:inherit;text-decoration:none;opacity:0.65;">Services</a><span style="opacity:0.4;padding:0 4px;"> / </span>AI Agents</div>
    <h1>AI That Thinks, Decides, and Acts <span class="gradient-text">Without Waiting for Instructions.</span></h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:640px; margin:1.5rem auto 0; line-height:1.8;">
      Most AI just responds. Agents take initiative. They reason through complex problems, use tools, make decisions, and complete multi-step tasks autonomously, at scale, 24/7.
    </p>
    <div class="trust-chips" style="justify-content:center; margin:1.75rem 0 2rem;">
      <span class="tchip">Runs around the clock, no breaks, no off days</span>
      <span class="tchip">Chains dozens of actions to finish complex tasks</span>
      <span class="tchip">Adjusts its approach based on what it finds</span>
    </div>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="agents_hero" class="btn-primary">Build Your First Agent</button>
      <a href="#agent-types" class="btn-outline">See Agent Types ↓</a>
    </div>
  </div>
</header>

<!-- IMAGE BANNER -->
<div style="width:100%; height:280px; overflow:hidden; position:relative;">
  <img src="https://images.unsplash.com/photo-1535378917042-10a22c95931a?w=1400&q=80&auto=format&fit=crop" alt="AI agents and autonomous decision-making systems" loading="eager" fetchpriority="high" width="1400" height="280" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center;" />
  <div style="width:100%; height:100%; background:rgba(0,25,42,0.78); display:flex; align-items:center; justify-content:center; position:relative;">
    <div style="position:absolute; inset:0; background-image:radial-gradient(circle, rgba(0,227,253,0.07) 1px, transparent 1px); background-size:24px 24px;"></div>
    <StatStrip stats={[
      { value: "24/7", caption: "Agents run around the clock, no breaks, no off days" },
      { value: "Multi-step", caption: "Agents chain dozens of actions to complete complex tasks" },
      { value: "Adaptive", caption: "Agents adjust their approach based on what they find" },
    ]} />
  </div>
  <div style="position:absolute; inset:0; background:linear-gradient(to top,#f9f9ff 0%,transparent 100%); pointer-events:none;"></div>
</div>

<!-- WHAT ARE AI AGENTS -->
<section class="section" aria-labelledby="explain-heading">
  <div class="container">
    <div class="explain-split">
      <div>
        <h2 id="explain-heading" style="margin-bottom:1.5rem;">What Exactly Is an AI Agent?</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.85; margin-bottom:1.25rem;">
          An AI agent is a software system that can perceive its environment, reason through a problem, and take actions to achieve a goal, without needing a human to guide each step. Unlike a chatbot that waits for questions and answers them one at a time, an agent is given a task and figures out how to complete it on its own: what information it needs, which tools to call, in what order, and how to handle what comes back.
        </p>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.85;">
          The practical difference is significant. Ask a chatbot to "find our top 20 leads, check LinkedIn for recent updates, and draft personalized outreach," and you'll get a to-do list in response. Give the same task to a well-built AI agent, and it searches for the leads, reads the LinkedIn data, drafts 20 personalized emails, and drops them into your CRM, ready to review. The agent handles the work; you handle the decisions that actually require your judgment.
        </p>
      </div>
      <div class="explain-img-wrap">
        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80&auto=format&fit=crop" alt="Dubai team reviewing an AI agent's task queue on a laptop" loading="lazy" width="800" height="600" />
      </div>
    </div>
    <p style="color:#42474e; font-size:1.0625rem; line-height:1.85; max-width:800px; margin:2rem auto 0;">
      For businesses, this capability gap is massive. Most companies have employees spending 20 to 40 percent of their time on tasks that are structured, repeatable, and tool-assisted: routing emails, updating records, pulling data from one system to put into another, scheduling, follow-ups, monitoring. These are exactly the tasks AI agents are designed for. Deploying agents on these workflows does not reduce headcount; it frees your team to focus on the judgment-heavy, relationship-driven work that actually requires a human.
    </p>
  </div>
</section>

