---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "What data do you train the internal AI on?", answer: "We train on whatever your team actually uses: company wikis, SOPs, policies, product docs, past projects, support tickets, internal documents, and more. The AI becomes a true company expert, not a generic one." },
  { question: "Is our company data safe?", answer: "Yes. Your data never leaves your control. We deploy internal AI tools in your own cloud environment or on-premise. Data is not used to train any external AI models. We configure access controls so employees only see what they're authorized to see." },
  { question: "Can employees without technical skills use these tools?", answer: "Yes, that's the point. Internal AI tools are designed for non-technical staff. Employees ask questions in plain language and get direct answers. No training required beyond a short onboarding session." },
  { question: "How do you keep the AI up to date when our docs change?", answer: "We set up automated sync pipelines that continuously update the AI with new or changed documents. The AI's knowledge stays current without any manual effort from your team." },
  { question: "What's the difference between an internal AI tool and just using SharePoint search?", answer: "SharePoint search finds documents that contain your keywords. An internal AI tool understands what you're asking and gives you the answer, with context, in plain language. It synthesizes across multiple documents, explains policies, compares options, and handles follow-up questions. It's the difference between being handed a stack of files and having a knowledgeable colleague explain exactly what you need to know." },
  { question: "Can we restrict which employees can access what information?", answer: "Yes, access controls are built in from the start. We configure the AI so that it only surfaces information the asking employee is authorized to see. HR can access HR data. Finance sees finance docs. An entry-level employee won't get executive compensation data just by asking. Permissions mirror your existing organizational structure." },
  { question: "How quickly can an internal AI tool be deployed?", answer: "A focused knowledge base AI for a single department can typically go from kickoff to live in two to four weeks. Larger enterprise deployments covering multiple departments, document types, and integrations take longer and are scoped individually. We stage the rollout to validate accuracy before full deployment." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'internal_ai_tools')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Internal AI Tools for UAE Businesses: Dashboards &amp; Assistants | Aegis AI"
  description="Give your UAE team an AI that actually knows your business. We build internal AI assistants, knowledge bases, and custom dashboards trained on your own data and workflows."
  canonicalPath="/services/internal-ai-tools"
  arPath="/ar/services/internal-ai-tools"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#004f58;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/services" style="color:inherit;text-decoration:none;opacity:0.65;">Services</a><span style="opacity:0.4;padding:0 4px;"> / </span>Internal AI Tools</div>
