---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "What data do you train the internal AI on?", answer: "We train on whatever your team actually uses — company wikis, SOPs, policies, product docs, past projects, support tickets, Notion/Confluence pages, Google Drive files, and more. The AI becomes a true company expert, not a generic one." },
  { question: "Is our company data safe?", answer: "Yes. Your data never leaves your control. We deploy internal AI tools in your own cloud environment (AWS, Azure, GCP) or on-premise. Data is not used to train any external AI models. We configure access controls so employees only see what they're authorized to see." },
  { question: "Can employees without technical skills use these tools?", answer: "Yes — that's the point. Internal AI tools are designed for non-technical staff. Employees ask questions in plain language and get direct answers. No training required beyond a short onboarding session." },
  { question: "How do you keep the AI up to date when our docs change?", answer: "We set up automated sync pipelines that continuously update the AI with new or changed documents. The AI's knowledge stays current without any manual effort from your team." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'internal_ai_tools')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Internal AI Tools — Custom Dashboards, Knowledge Bases & Assistants | Aegis AI"
  description="Give your team an AI that actually knows your business. We build internal AI assistants, knowledge bases, and custom dashboards trained on your own data and workflows."
  canonicalPath="/services/internal-ai-tools"
  arPath="/ar/services/internal-ai-tools"
  ogImage="/assets/og-internal-ai-tools.jpg"
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/services">Services</a><span>/</span>
      <strong>Internal AI Tools</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">dashboard</span>
      Internal AI Tools
    </div>
    <h1>Give Your Team an AI <span class="gradient-text">That Actually Knows Your Business.</span></h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 2.5rem; line-height:1.8;">
      ChatGPT doesn't know your policies, your products, or your processes. We build AI tools trained on your company's own data — so your team gets accurate, context-aware answers instantly.
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="internal_hero" class="btn-primary">Book a Free Discovery Call</button>
      <a href="#what-we-build" class="btn-outline">See What We Build ↓</a>
    </div>
  </div>
</header>

<!-- PROBLEM CARDS -->
<section class="section" aria-labelledby="problem-heading">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <h2 id="problem-heading">The Problem With Generic AI Tools</h2>
      <p style="color:#42474e; max-width:36rem; margin:1rem auto 0; line-height:1.7;">Your team deserves AI that knows your business — not AI that gives everyone else's answer.</p>
    </div>
    <div class="bento-grid bento-grid-3">
      <div class="card text-center">
        <div style="width:52px; height:52px; border-radius:50%; background:rgba(186,26,26,0.08); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="#ba1a1a" stroke-width="2"><path d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p style="color:#42474e; line-height:1.65;">"ChatGPT gives us generic answers — it doesn't know how we actually do things here."</p>
      </div>
      <div class="card text-center">
        <div style="width:52px; height:52px; border-radius:50%; background:rgba(245,158,11,0.10); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="#92400e" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <p style="color:#42474e; line-height:1.65;">"New employees take weeks to find answers that are buried in 200-page policy docs."</p>
      </div>
      <div class="card text-center">
        <div style="width:52px; height:52px; border-radius:50%; background:rgba(0,37,59,0.08); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
          <svg viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="#00253b" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
        </div>
        <p style="color:#42474e; line-height:1.65;">"Our senior people spend half their day answering the same internal questions over and over."</p>
      </div>
    </div>
  </div>
</section>

<!-- WHAT WE BUILD -->
<section id="what-we-build" class="section" style="background:#e7eeff;" aria-labelledby="build-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">What We Build</div>
      <h2 id="build-heading">Six Internal AI Tools We Deploy</h2>
      <p style="color:#42474e; font-size:1.0625rem;">All deployed in your environment, on your data, with your access controls.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">menu_book</span></div>
        <h3>Company Knowledge Base AI</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Ask any question and get a precise answer with source citations — trained on your SOPs, policies, product docs, and FAQs.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">support_agent</span></div>
        <h3>Internal Operations Assistant</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">A 24/7 AI colleague that handles HR questions, IT tickets, onboarding queries, and internal requests — instantly and accurately.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">monitoring</span></div>
        <h3>Custom Analytics Dashboards</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Real-time visibility into your business metrics — ask your dashboard questions in plain English and get charts, summaries, and forecasts.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">search</span></div>
        <h3>AI-Powered Document Search</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Find anything in your company's documents, emails, and files — not keyword search, but semantic understanding of what you're actually looking for.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">auto_awesome</span></div>
        <h3>AI Content &amp; Writing Tools</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">AI writing assistants trained on your brand voice — draft proposals, reports, emails, and presentations that sound like your company.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">school</span></div>
        <h3>Onboarding &amp; Training AI</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">New hire AI that walks employees through company processes, answers their questions, and surfaces the right information at the right time.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">How It Works</div>
      <h2 id="process-heading">From Your Data to a Working Tool</h2>
    </div>
    <div class="process-grid">
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">folder_open</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 1</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Data Audit</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We inventory your documents, wikis, and data sources — then identify what to include and how to structure it.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">settings</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Weeks 2–3</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Build &amp; Configure</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We ingest your data, configure the AI, set access permissions, and build the interface your team will actually use.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">fact_check</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 4</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Test &amp; Tune</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Your team tests real questions. We tune the responses, fix gaps, and ensure accuracy before launch.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">rocket_launch</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 5+</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Launch &amp; Update</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Tool goes live with continuous document sync. 90-day support included to expand and refine.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">Frequently Asked Questions</h2>
    </div>
    <div>
      {faqItems.map((item) => (
        <div class="faq-item">
          <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
            {item.question}
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-body">{item.answer}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="cta-band">
  <div style="position:relative; z-index:1; text-align:center;">
    <h2 style="color:#fff; font-size:clamp(1.75rem,3vw,2.5rem); margin-bottom:1rem;">Ready to Give Your Team AI That Actually Knows Your Business?</h2>
    <p style="color:rgba(255,255,255,0.55); font-size:1.125rem; max-width:36rem; margin:0 auto 2.5rem; line-height:1.7;">Book a free discovery call. We'll assess your documents, identify the highest-value use cases, and show you what's possible in 4–6 weeks.</p>
    <button onclick="openModal(this)" data-source="internal_cta" class="btn-primary" style="font-size:1.125rem; padding:1.125rem 2.75rem;">Book Free Discovery Call</button>
    <p style="color:rgba(255,255,255,0.30); font-size:.875rem; margin-top:1.25rem;">Free · No commitment · Your data stays private</p>
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Internal AI Tools",
      "url": "https://aegisai.ae/services/internal-ai-tools",
      "description": "Custom internal AI assistants, knowledge bases, and dashboards trained on your own company data — deployed in your environment with your access controls.",
      "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
      "areaServed": "Worldwide",
      "serviceType": "Internal AI Development"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aegisai.ae/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://aegisai.ae/services" },
        { "@type": "ListItem", "position": 3, "name": "Internal AI Tools", "item": "https://aegisai.ae/services/internal-ai-tools" }
      ]
    }
  ]
}
</script>

</BaseLayout>

<style>
.icon-box { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; }
.builds-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.process-step { display:flex; flex-direction:column; align-items:center; text-align:center; }
.process-circle { width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,#00253b,#006875); box-shadow:0 0 0 6px #fff, 0 0 0 8px rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; position:relative; z-index:1; }
.process-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; position:relative; }
.process-connector { position:absolute; top:27px; left:calc(12.5% + 28px); right:calc(12.5% + 28px); height:2px; background:linear-gradient(90deg,#00e3fd,rgba(0,37,59,0.20)); }
.faq-item { border-top:1px solid rgba(0,37,59,0.10); }
.faq-btn { display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:1.1rem 0; font-weight:600; color:#00253b; cursor:pointer; background:none; border:none; font-family:inherit; font-size:0.95rem; }
.faq-body { display:none; padding-bottom:1rem; color:#42474e; font-size:0.9rem; line-height:1.7; }
.faq-body.open { display:block; }
.faq-icon { transition:transform 0.25s; font-size:1.1rem; color:#006875; }
.faq-icon.open { transform:rotate(45deg); }
@media(max-width:900px) { .builds-grid { grid-template-columns:1fr 1fr; } .process-grid { grid-template-columns:1fr 1fr; } .process-connector { display:none; } }
@media(max-width:600px) { .builds-grid { grid-template-columns:1fr; } }
</style>
