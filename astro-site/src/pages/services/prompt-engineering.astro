---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "What does a prompt engineering engagement actually look like?", answer: "It depends on your starting point. For teams already using AI heavily, we start with a prompt audit: reviewing your existing prompts, identifying where output quality is inconsistent, and rewriting the worst offenders. For teams building AI features or workflows, we join the design process early and write the system prompts from scratch. Either way, you end up with a documented prompt library that's easy to maintain and update." },
  { question: "Which AI models do you work with?", answer: "We engineer prompts for all major AI models, both proprietary and open-source. Each model has different strengths, quirks, and optimal prompting patterns. We know them all and engineer accordingly, so you get the best performance out of whichever model you're using." },
  { question: "How much does bad prompting actually cost?", answer: "More than most teams realize. Bad prompts produce inconsistent outputs that require manual editing, which defeats the purpose of using AI in the first place. They also cause models to use more tokens than necessary, driving up API costs. And they create unpredictable behavior that erodes trust in AI tools across your team. A well-engineered prompt library typically cuts editing time by 60–80% and reduces API token usage by 20–40%." },
  { question: "Can you write prompts for our specific industry or domain?", answer: "Yes, and this is where domain-specific prompt engineering is most valuable. Generic prompts produce generic output. We research your industry terminology, your tone standards, your compliance constraints, and your output format requirements, then engineer prompts that account for all of them. Legal, healthcare, finance, real estate, e-commerce: we've worked across all of them." },
  { question: "Do you offer ongoing optimization?", answer: "Yes. AI models update frequently, and a prompt that works perfectly today may need adjustment after a model update. We offer monthly retainers that cover continuous testing, optimization as models evolve, and priority support when something breaks. Most clients find this valuable once they see the improvement in their prompt outputs." },
  { question: "How long does a prompt engineering engagement take?", answer: "A prompt audit with rewrites for an existing system typically takes 1-2 weeks. Building a full prompt library from scratch for a new AI product or workflow takes 2-4 weeks depending on scope. Most clients see measurable output quality improvement within the first week of working with optimized prompts. Ongoing retainer arrangements are monthly, with no minimum term." },
  { question: "We only use one or two AI tools. Is it still worth it?", answer: "Often yes, especially if those tools are customer-facing or produce content your team then edits heavily. The return on prompt engineering is directly proportional to how much time your team spends correcting AI output. If you're spending more than a few hours a week editing AI-generated content, the investment pays for itself quickly. A single well-engineered system prompt for a customer-facing use case can eliminate hours of weekly corrections." },
  { question: "Can you help us build internal prompt guidelines so our team writes better prompts themselves?", answer: "Yes, this is part of every engagement. We deliver a set of documented prompting guidelines specific to your team and tools, covering structure, context setting, format instructions, and common failure modes to avoid. We also run a training session walking your team through the principles. The goal is that after working with us, your team is meaningfully better at writing and improving prompts on their own." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'prompt_engineering')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

