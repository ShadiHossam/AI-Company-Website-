---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "We already have a CRM. Can you add AI to it without replacing it?", answer: "Yes, that's exactly what AI integration is for. We add an AI layer on top of your existing CRM or custom system. Your team keeps working in the same system they know; it just gets smarter: auto-enriching contacts, predicting deal health, surfacing the right follow-up actions." },
  { question: "What systems do you integrate AI with?", answer: "Any system with an API. We regularly work with CRMs, ERPs, communication platforms, project management tools, data warehouses, and e-commerce platforms. If your system has an API, we can add AI to it. We'll tell you upfront if something isn't feasible." },
  { question: "How long does an AI integration project take?", answer: "Each project is scoped individually. We give you a precise timeline after the discovery session, based on the number of systems involved, data complexity, and your existing API setup." },
  { question: "Will our existing workflows break during integration?", answer: "No. We build and test AI integrations in a staging environment first. Your production systems remain untouched until the integration has been fully validated. Rollbacks are built in as a safety net." },
  { question: "Our CRM is custom-built in-house. Can you still integrate AI with it?", answer: "Yes, as long as your system exposes an API or allows database access. We've integrated AI with many custom-built systems that have no off-the-shelf documentation. We review the API during the discovery session, confirm feasibility, and build a secure connection. If your system has no API at all, we can discuss options for creating one." },
  { question: "What happens to the AI layer if we switch our main software later?", answer: "The AI integration is built as a middleware layer, meaning it connects to your main system via API rather than being baked in. If you migrate to a new CRM or ERP, we update the API connections on the AI side to point to the new system. In most cases, the AI layer itself requires only minor changes during a migration." },
  { question: "How is AI integration different from just buying a software plugin?", answer: "A plugin adds a fixed set of features that the vendor designed for the average customer. AI integration is built around your specific data structure, your workflows, and your business logic. It understands the meaning of your data, not just its format. The result is a system that actually reflects how your business works, not how someone else's business works." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'ai_integration')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="AI Integration Services for UAE Businesses | Aegis AI"
  description="You don't need to replace your software. You need to make it smarter. As an AI agency in Dubai, we add an AI layer to your CRM, ERP, and existing tools, built for UAE businesses, so they work harder with the same team."
