---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "We already have a CRM. Can you add AI to it without replacing it?", answer: "Yes, that's exactly what AI integration is for. We add an AI layer on top of your existing CRM or custom system. Your team keeps working in the same system they know; it just gets smarter: auto-enriching contacts, predicting deal health, surfacing the right follow-up actions." },
  { question: "What systems do you integrate AI with?", answer: "Any system with an API. We regularly work with CRMs, ERPs, communication platforms, project management tools, data warehouses, and e-commerce platforms. If your system has an API, we can add AI to it. We'll tell you upfront if something isn't feasible." },
  { question: "How long does an AI integration project take?", answer: "Each project is scoped individually. We give you a precise timeline after the discovery session, based on the number of systems involved, data complexity, and your existing API setup." },
  { question: "Will our existing workflows break during integration?", answer: "No. We build and test AI integrations in a staging environment first. Your production systems remain untouched until the integration has been fully validated. Rollbacks are built in as a safety net." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'ai_integration')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="AI Integration Services — Add AI to Your Existing Software Stack | Aegis AI"
  description="You don't need to replace your software — you need to make it smarter. We add an AI layer to your CRM, ERP, and existing tools so they work harder with the same team."
  canonicalPath="/services/ai-integration"
  arPath="/ar/services/ai-integration"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/services">Services</a><span>/</span>
      <strong>AI Integration Services</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">hub</span>
      AI Integration Services
    </div>
    <h1>Your Existing Software, <span class="gradient-text">Supercharged With AI.</span></h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:620px; margin:1.5rem auto 2.5rem; line-height:1.8;">
      You don't need to rip out your CRM, ERP, or tools. You need to make them smarter. We add a precise AI layer on top of what you already use, so the same team gets dramatically better results.
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="integration_hero" class="btn-primary">Book a Free Discovery Call</button>
      <a href="#what-we-integrate" class="btn-outline">See What We Integrate ↓</a>
    </div>
  </div>
</header>

<!-- STAT BANNER -->
<div style="background:linear-gradient(135deg,#001e30,#00253b,#003b5c); padding:4rem 0;">
  <div class="container">
    <div class="stat-strip">
      <div class="stat-item">
        <div class="stat-num">No replace</div>
        <p class="stat-label">We enhance your existing tools. We never ask you to scrap what's working.</p>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-num">API-first</div>
        <p class="stat-label">Any system with an API can be enhanced — CRMs, ERPs, databases, and more</p>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-num">100%</div>
        <p class="stat-label">refund guarantee if you're not satisfied with what we deliver</p>
      </div>
    </div>
  </div>
</div>

<!-- WHAT WE INTEGRATE -->
<section id="what-we-integrate" class="section" aria-labelledby="integrate-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">What We Build</div>
      <h2 id="integrate-heading">Six Types of AI Integrations We Deliver</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Each integration is scoped to your exact system, tested against real data, and supported after launch.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">contacts</span></div>
        <h3>CRM AI Enrichment</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Add AI to your CRM to auto-enrich contacts, score leads, predict deal health, and surface the right next action for every rep, all without leaving your existing system.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">inventory_2</span></div>
        <h3>ERP AI Intelligence</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Transform raw ERP data into predictive insights: demand forecasting, inventory optimization, supplier risk scoring, and anomaly detection that acts before issues escalate.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">forum</span></div>
        <h3>Communication Platform AI</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">AI added to your communication tools to summarize long threads, surface action items, draft responses, and route messages to the right person automatically.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">shopping_cart</span></div>
        <h3>E-commerce AI Layer</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">AI recommendations, dynamic pricing, personalized search, and churn prediction layered on top of your e-commerce platform or custom storefront.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">storage</span></div>
        <h3>Data Warehouse AI</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Ask your data warehouse questions in plain English. AI translates to SQL, runs queries, and returns insights without your team needing to know SQL.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">webhook</span></div>
        <h3>Custom API AI Connections</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">We build bespoke AI middleware that connects your proprietary systems — so data flows intelligently between tools that were never designed to talk to each other.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">How It Works</div>
      <h2 id="process-heading">How We Add AI to Your Existing Stack</h2>
    </div>
    <div class="process-grid">
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">search</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Step 1</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Stack Audit</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We assess your existing systems, APIs, and data flows, then identify exactly where AI integration creates the most value.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">architecture</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Step 2</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Design &amp; Connect</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We design the AI layer, establish secure API connections, and build integrations in a staging environment.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">fact_check</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Step 3</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Test on Real Data</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We validate the integration against your actual data, edge cases, and load — with zero impact on your live systems.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">rocket_launch</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Step 4</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Deploy &amp; Monitor</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Integration goes live. 90-day monitoring and support included. We catch issues before they reach your team.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">Frequently Asked Questions</h2>
    </div>
    <div>
      {faqItems.map((item) => (
        <div class="faq-item">
          <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
            {item.question}
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-body">{item.answer}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="cta-band">
  <div style="position:relative; z-index:1; text-align:center;">
    <h2 style="color:#fff; font-size:clamp(1.75rem,3vw,2.5rem); margin-bottom:1rem;">Ready to Make Your Existing Tools Dramatically Smarter?</h2>
    <p style="color:rgba(255,255,255,0.55); font-size:1.125rem; max-width:36rem; margin:0 auto 2.5rem; line-height:1.7;">Tell us what systems you use. We'll show you exactly where AI integration creates the most value — free, no commitment.</p>
    <button onclick="openModal(this)" data-source="integration_cta" class="btn-primary" style="font-size:1.125rem; padding:1.125rem 2.75rem;">Book Free Discovery Call</button>
    <p style="color:rgba(255,255,255,0.30); font-size:.875rem; margin-top:1.25rem;">Free · No commitment · 100% refund guarantee</p>
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "AI Integration Services",
      "url": "https://aegisai.ae/services/ai-integration",
      "description": "We add an AI layer to your existing CRM, ERP, and software stack, making your current tools dramatically smarter without replacing them.",
      "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
      "areaServed": "Worldwide",
      "serviceType": "AI Integration"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aegisai.ae/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://aegisai.ae/services" },
        { "@type": "ListItem", "position": 3, "name": "AI Integration Services", "item": "https://aegisai.ae/services/ai-integration" }
      ]
    }
  ]
}
</script>

</BaseLayout>

<style>
.icon-box { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; }
.builds-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.process-step { display:flex; flex-direction:column; align-items:center; text-align:center; }
.process-circle { width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,#00253b,#006875); box-shadow:0 0 0 6px #fff, 0 0 0 8px rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; position:relative; z-index:1; }
.process-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; position:relative; }
.process-connector { position:absolute; top:27px; left:calc(12.5% + 28px); right:calc(12.5% + 28px); height:2px; background:linear-gradient(90deg,#00e3fd,rgba(0,37,59,0.20)); }
.stat-strip { display:grid; grid-template-columns:1fr auto 1fr auto 1fr; gap:2rem; align-items:center; }
.stat-divider { width:1px; height:80px; background:rgba(255,255,255,0.15); }
.stat-item { text-align:center; }
.stat-num { font-size:2.5rem; font-weight:800; color:#00e3fd; line-height:1; margin-bottom:0.5rem; }
.stat-label { color:rgba(255,255,255,0.55); font-size:0.875rem; line-height:1.6; }
.tech-pill { display:inline-block; background:#fff; border:1px solid #dde3ea; border-radius:100px; padding:0.375rem 1rem; font-size:0.8125rem; font-weight:600; color:#00253b; }
.faq-item { border-top:1px solid rgba(0,37,59,0.10); }
.faq-btn { display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:1.1rem 0; font-weight:600; color:#00253b; cursor:pointer; background:none; border:none; font-family:inherit; font-size:0.95rem; }
.faq-body { display:none; padding-bottom:1rem; color:#42474e; font-size:0.9rem; line-height:1.7; }
.faq-body.open { display:block; }
.faq-icon { transition:transform 0.25s; font-size:1.1rem; color:#006875; }
.faq-icon.open { transform:rotate(45deg); }
@media(max-width:900px) { .builds-grid { grid-template-columns:1fr 1fr; } .process-grid { grid-template-columns:1fr 1fr; } .process-connector { display:none; } .stat-strip { grid-template-columns:1fr; } .stat-divider { display:none; } }
@media(max-width:600px) { .builds-grid { grid-template-columns:1fr; } }
</style>
