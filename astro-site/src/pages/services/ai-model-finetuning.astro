---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "What's the difference between fine-tuning and using a prompt?", answer: "A prompt tells a general-purpose model how to behave in a specific situation. Fine-tuning trains the model on hundreds or thousands of examples so that behavior becomes the model's default — no prompt required. The result is faster responses, lower token costs (shorter or no system prompt needed), and significantly more consistent output. Fine-tuning is worth it when you have a high-volume use case and need the model to perform a specific task reliably, at scale." },
  { question: "Which models can you fine-tune?", answer: "We fine-tune both proprietary and open-source foundation models. Proprietary models offer convenience and low infrastructure overhead. Open-source models can be fine-tuned on your own infrastructure, keeping your data fully within your environment. We'll recommend the right option based on your use case, data sensitivity, and cost requirements." },
  { question: "How much data do I need to fine-tune a model?", answer: "It depends on the task. For most business use cases — classifying documents, generating responses in a specific format, or writing in a consistent brand tone — we can get strong results with 200–500 high-quality examples. More complex tasks benefit from more data, but quality matters far more than volume. We help you build and curate a training dataset as part of the engagement." },
  { question: "Is our data safe during the fine-tuning process?", answer: "Yes. Your training data is used solely to fine-tune your model and is not used to train any shared or public models. For organizations with strict data policies, we can fine-tune open-source models on your own cloud infrastructure so your data never leaves your environment. We discuss and document your data handling requirements before any data is shared." },
  { question: "What's included after the model is trained?", answer: "We deliver the fine-tuned model along with evaluation results showing exactly how it performs versus the base model, integration documentation for your developers, and 60-day support. For ongoing tasks, we can retrain on new data as your needs evolve — pricing for retraining is typically much lower than the initial engagement." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'ai_finetuning')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="AI Model Fine-Tuning — Train AI on Your Data, Not the Internet's | Aegis AI"
  description="We fine-tune foundation models on your proprietary data so your AI knows your business, speaks your language, and delivers consistent outputs at scale."
  canonicalPath="/services/ai-model-finetuning"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/services">Services</a><span>/</span>
      <strong>AI Model Fine-Tuning</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">model_training</span>
      AI Model Fine-Tuning
    </div>
