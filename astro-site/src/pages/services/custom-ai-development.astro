---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "How long does custom AI development take?", answer: "Most projects take 8–12 weeks from discovery to launch. Simple automations (one workflow) can go live in 4–6 weeks. We give you a precise timeline after the discovery session." },
  { question: "Do you work with our existing systems?", answer: "Yes. We integrate with most CRMs, ERPs, WhatsApp Business, HubSpot, Salesforce, Google Workspace, Microsoft 365, and hundreds of other apps via API or automation platforms (Make.com, n8n, Zapier)." },
  { question: "Where is our data hosted?", answer: "We offer flexible hosting options — cloud (AWS, Azure, GCP) or on-premise. For clients with data residency requirements, we configure deployments to meet your regional compliance needs. All options are discussed during discovery." },
  { question: "What if we need changes after launch?", answer: "All packages include 90-day post-launch support — bug fixes, small adjustments, and optimization. Beyond that, we offer ongoing support retainers — contact us for details." },
  { question: "What is the 100% refund guarantee?", answer: "If we deliver your custom AI system and you're not satisfied with the results, we refund 100% of your investment. No fine print, no conditions. It's our promise — and it's why we only take on projects we know we can deliver well." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'custom_ai')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

