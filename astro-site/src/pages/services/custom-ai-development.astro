---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "How long does custom AI development take?", answer: "Each project is scoped individually. We give you a precise timeline after the discovery session, based on your specific workflows, data, and integration requirements." },
  { question: "Do you work with our existing systems?", answer: "Yes. We integrate with most CRMs, ERPs, and hundreds of other business apps via API. You keep the tools your team already knows; we add an AI layer on top." },
  { question: "Where is our data hosted?", answer: "We offer flexible hosting: cloud or on-premise. For clients with data residency requirements, we configure deployments to meet your regional compliance needs. All options are discussed during discovery." },
  { question: "What if we need changes after launch?", answer: "All packages include 90-day post-launch support: bug fixes, small adjustments, and optimization. Beyond that, we offer ongoing support retainers. Contact us for details." },
  { question: "What is the 100% refund guarantee?", answer: "If we deliver your custom AI system and you're not satisfied with the results, we refund 100% of your investment. No fine print, no conditions. It's our promise, and it's why we only take on projects we know we can deliver well." },
  { question: "How is custom AI different from just using a general AI tool for our team?", answer: "Off-the-shelf AI tools are general-purpose and know nothing about your business. Custom AI development means building a system trained on your specific data, integrated with your specific workflows, and configured with your specific rules and guardrails. It knows your products, your tone, your policies, and your customers. It can take actions inside your systems, not just answer questions. The difference in practical output quality is significant." },
  { question: "What kind of business benefits most from custom AI development?", answer: "Businesses that have high-volume, repetitive work that requires domain-specific knowledge, businesses with complex customer interactions that need consistency, and businesses where manual processes are a real bottleneck to growth. If you're spending significant team time on tasks that follow a pattern but require judgment, custom AI development almost always pays back quickly." },
  { question: "Do we need to prepare our data before the project starts?", answer: "No. Data preparation is part of what we do. We assess your existing data during discovery, identify what's needed, help you collect or generate what's missing, and handle all cleaning and formatting before we start building. You don't need to show up with perfectly organized datasets." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'custom_ai')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
