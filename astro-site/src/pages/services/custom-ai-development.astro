    </div>
  </div>
</section>

<script is:inline>
(function () {
  var toggles = document.querySelectorAll('[data-cad-toggle]');
  var panels = document.querySelectorAll('[data-cad-panel]');
  toggles.forEach(function (btn) {
    btn.addEventListener('click', function () {
      toggles.forEach(function (t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(function (p) { p.hidden = true; });
      btn.classList.add('is-active');
      btn.setAttribute('aria-selected', 'true');
      var panel = document.querySelector('[data-cad-panel="' + btn.getAttribute('data-cad-toggle') + '"]');
      if (panel) panel.hidden = false;
    });
  });
})();
</script>

