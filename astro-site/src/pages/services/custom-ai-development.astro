---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Custom AI Development Dubai — Chatbots & Automation | Aegis AI"
  description="Custom AI development for Dubai SMEs — chatbots, automation pipelines, predictive dashboards. 8–12 week delivery. UAE-compliant. 100% satisfaction guarantee."
  canonicalPath="/services/custom-ai-development"
  ogImage="/assets/og-custom-ai.jpg"
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/services">Services</a><span>/</span>
      <strong>Custom AI Development</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">code</span>
      Custom AI Systems
    </div>
    <h1>AI Built for <span class="gradient-text">Your</span> Business. Not a Template.</h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:600px; margin:1.5rem auto 2.5rem; line-height:1.8;">
      Off-the-shelf AI tools don't fit your workflows. We build custom AI systems that do exactly what your team needs — and integrate with the tools you already use.
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal()" class="btn-primary">Get a Free Custom AI Quote</button>
      <a href="#what-we-build" class="btn-outline">See What We Build ↓</a>
    </div>
  </div>
</header>

<!-- HERO IMAGE -->
<div style="position:relative; overflow:hidden; height:240px;">
  <img src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=1400&q=80&auto=format&fit=crop" alt="Custom AI development and software engineering" loading="lazy" style="width:100%; height:100%; object-fit:cover; object-position:center 40%;" />
  <div style="position:absolute; inset:0; background:linear-gradient(135deg,rgba(0,104,117,0.15),rgba(0,37,59,0.25));"></div>
</div>

<!-- WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="build-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">Deliverables</div>
      <h2 id="build-heading">What We Build For You</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Six categories of AI systems, all built to your workflows and integrated with your existing tools.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">smart_toy</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Internal AI Assistants</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Trained on your company data, documents, and SOPs — answers your team's questions instantly in Arabic and English.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">support_agent</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Customer-Facing Chatbots</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Handles inquiries, bookings, and support 24/7 via your website, WhatsApp, and Instagram — in Arabic and English.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">bolt</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Workflow Automation</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Eliminates manual repetitive tasks across sales, operations, and admin. Connect your apps and let AI do the data entry.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">monitoring</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Predictive Analytics Dashboards</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Forecasting tools for sales, demand, pricing, and inventory — so you make decisions based on data, not guesswork.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">integration_instructions</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">CRM &amp; ERP AI Layers</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Add AI intelligence to your existing HubSpot, Salesforce, or custom systems — no replacement needed, just enhancement.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">description</span></div>
        <h3 style="font-weight:700; font-size:1.0625rem; color:#00253b; margin-bottom:0.5rem;">Document Processing AI</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Contracts, invoices, and reports processed automatically — extracts, classifies, and routes data in seconds.</p>
      </div>
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section class="section-sm" style="background:#e7eeff;" aria-label="Technology partners">
  <div class="container" style="text-align:center;">
    <p style="color:#72787e; font-size:0.8125rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:1.5rem;">Technologies We Use</p>
    <div style="display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:1.5rem 2.5rem;">
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">OpenAI GPT-4o</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Claude AI</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Microsoft Azure AI</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Google Gemini</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">LangChain</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Make.com</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">n8n</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Zapier</span>
      <span style="color:#c2c7ce;">·</span>
      <span style="color:#00253b; font-weight:600; font-size:0.9375rem;">Python / FastAPI</span>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section" aria-labelledby="process-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">How It Works</div>
      <h2 id="process-heading">From Discovery to Launch in 8–12 Weeks</h2>
    </div>
    <div class="process-grid">
      <div class="process-connector"></div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">search</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 1–2</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Discovery</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">We map your workflows and identify where AI creates the most value.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">edit</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 3–5</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Design</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Architecture planning, data requirements, and system design — you approve before we build.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">code</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 6–9</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Build &amp; Test</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">Development, integration, QA testing, and UAE compliance checks before go-live.</p>
      </div>
      <div class="process-step">
        <div class="process-circle">
          <span class="material-symbols-outlined" style="color:#00e3fd; font-size:22px;">rocket_launch</span>
        </div>
        <span style="color:#006875; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Week 10+</span>
        <h3 style="font-weight:700; font-size:0.9375rem; color:#00253b; margin-bottom:4px;">Launch &amp; Support</h3>
        <p style="color:#42474e; font-size:0.8125rem; line-height:1.6;">System goes live. 90-day support included. Team training included in most packages.</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="faq-heading">Frequently Asked Questions</h2>
    </div>
    <div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          How long does custom AI development take?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-body">Most projects take 8–12 weeks from discovery to launch. Simple automations (one workflow) can go live in 4–6 weeks. We give you a precise timeline after the discovery session.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          Do you work with our existing systems?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-body">Yes. We integrate with most CRMs, ERPs, WhatsApp Business, HubSpot, Salesforce, Google Workspace, Microsoft 365, and hundreds of other apps via API or automation platforms (Make.com, n8n, Zapier).</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          Is our data kept in the UAE?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-body">Yes. We offer UAE-hosted deployment options compliant with DESC (Dubai Electronic Security Center) and UAE Personal Data Protection Law. Data residency options available on all packages.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          What if we need changes after launch?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-body">All packages include 90-day post-launch support — bug fixes, small adjustments, and optimization. Beyond that, we offer ongoing support retainers — contact us for details.</div>
      </div>
      <div class="faq-item">
        <button class="faq-btn" onclick="toggleFaq(this)" aria-expanded="false">
          What is the 100% refund guarantee?
          <span class="faq-icon">+</span>
        </button>
        <div class="faq-body">If we deliver your custom AI system and you're not satisfied with the results, we refund 100% of your investment. No fine print, no conditions. It's our promise — and it's why we only take on projects we know we can deliver well.</div>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="cta-band">
  <h2>Ready to Build Your Custom AI System?</h2>
  <p>Book a free discovery call. We'll assess your needs and tell you exactly what AI can do for your business — and what it will cost.</p>
  <button onclick="openModal()" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Book Free Discovery Call</button>
  <p style="color:rgba(255,255,255,0.55); font-size:0.875rem; margin-top:1rem;">100% free · No commitment · Responds within 4 hours</p>
</div>


<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Custom AI Development",
      "url": "https://aegisai.ae/services/custom-ai-development.html",
      "description": "We build custom AI systems for Dubai SMEs — chatbots, automation pipelines, predictive dashboards, and CRM/ERP integrations. UAE-compliant, Arabic and English ready.",
      "provider": { "@type": "Organization", "name": "Aegis AI", "url": "https://aegisai.ae" },
      "areaServed": "Dubai",
      "offers": { "@type": "Offer", "description": "Custom AI development — pricing tailored to your project scope. Book a free discovery call for a quote." },
      "serviceType": "AI Development",
      "termsOfService": "100% satisfaction guarantee — full refund if not happy"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aegisai.ae/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://aegisai.ae/pages/services.html" },
        { "@type": "ListItem", "position": 3, "name": "Custom AI Development", "item": "https://aegisai.ae/services/custom-ai-development.html" }
      ]
    }
  ]
}
</script>

</BaseLayout>

<style>
.icon-box { width:48px; height:48px; border-radius:14px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; }
    .process-step { display:flex; flex-direction:column; align-items:center; text-align:center; }
    .process-circle { width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,#00253b,#006875); box-shadow:0 0 0 6px #fff, 0 0 0 8px rgba(0,227,253,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; position:relative; z-index:1; }
    .check-li { display:flex; gap:10px; align-items:flex-start; margin-bottom:8px; font-size:0.875rem; color:#42474e; }
    .faq-item { border-top:1px solid rgba(0,37,59,0.10); }
    .faq-btn { display:flex; justify-content:space-between; align-items:center; width:100%; text-align:left; padding:1.1rem 0; font-weight:600; color:#00253b; cursor:pointer; background:none; border:none; font-family:inherit; font-size:0.95rem; }
    .faq-body { display:none; padding-bottom:1rem; color:#42474e; font-size:0.9rem; line-height:1.7; }
    .faq-body.open { display:block; }
    .faq-icon { transition:transform 0.25s; font-size:1.1rem; color:#006875; }
    .faq-icon.open { transform:rotate(45deg); }
    .builds-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
    .process-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:2rem; position:relative; }
    .process-connector { position:absolute; top:27px; left:calc(12.5% + 28px); right:calc(12.5% + 28px); height:2px; background:linear-gradient(90deg,#00e3fd,rgba(0,37,59,0.20)); }
    @media(max-width:900px) { .builds-grid { grid-template-columns:1fr 1fr; } .process-grid { grid-template-columns:1fr 1fr; } .process-connector { display:none; } }
    @media(max-width:600px) { .builds-grid { grid-template-columns:1fr; } }
</style>