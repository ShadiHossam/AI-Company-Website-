---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import FaqAccordion from "../../components/FaqAccordion.astro";
import StatStrip from "../../components/StatStrip.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

// Hardcoded fallback FAQ items
const fallbackFaqs = [
  { question: "How many people can attend one workshop?", answer: "The AI Foundations workshop fits up to 20 participants. For larger teams, we run multiple sessions. The hands-on programs (AI Power User) are capped at 12 for quality. We'd schedule additional cohorts for larger teams." },
  { question: "Do participants need any prior AI knowledge?", answer: "No. AI Foundations is designed for complete beginners. We run a pre-training assessment so we always start at the right level for your team. You don't need to know anything about AI." },
  { question: "Can we get materials in our preferred language?", answer: "Yes. All materials are fully customizable by language. We support English as default and can accommodate other languages upon request. We'll confirm delivery language during your onboarding call." },
  { question: "Can training be combined with AI system development?", answer: "Yes, and this is our recommended approach. When we build you a custom AI system, team training is included in Core System and Transformation packages. This ensures adoption is high from day one." },
  { question: "How do you measure whether the training worked?", answer: "We run a post-training assessment to compare AI confidence and capability levels before and after. We also check in at 30 days to see how actively teams are using AI in their daily work. If adoption is lagging, we identify why and run targeted follow-up sessions. The goal is behavioral change, not just attendance." },
  { question: "What's the difference between your training and watching YouTube tutorials?", answer: "YouTube tutorials are generic. Our training is built around your team's specific roles, your company's tools and workflows, and real scenarios from your industry. Participants practice on tasks they'll actually do at work, not hypothetical examples. The exercises use your actual AI tools, your actual content, and produce outputs your team can use immediately." },
  { question: "We're based outside the UAE. Can you train our team remotely?", answer: "Yes. All programs are available fully remote via video call, with the same hands-on exercises and real-time Q&A as on-site delivery. We've run training for teams across the Middle East, Europe, and Asia. Materials are delivered digitally, and the 30-day follow-up support works the same way regardless of location." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'training')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="AI Training & Workshops for UAE Teams | Lenoo AI"
  description="Hands-on AI training workshops from a Dubai AI agency serving teams across the UAE. Role-specific programs, on-site or remote, 100% satisfaction guarantee."
  canonicalPath="/services/ai-training"
  arPath="/ar/services/ai-training"
  ogImage="/assets/og-ai-training.jpg"
  ldJson={[faqLdJson]}
>

<!-- ── HERO ── -->
<header class="hero-section" style="padding-top: 10rem; padding-bottom: 5rem; text-align: center;">
  <div class="container" style="position: relative; z-index: 1;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span><a href="/services" style="color:inherit;text-decoration:none;opacity:0.65;">Services</a><span style="opacity:0.4;padding:0 4px;"> / </span>AI Training & Workshops</div>
