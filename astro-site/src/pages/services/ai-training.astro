<script>
document.querySelectorAll('[data-role-tabs]').forEach((wrap) => {
  wrap.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      wrap.querySelectorAll('.tab-btn').forEach((b) => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      wrap.querySelectorAll('.tab-panel').forEach((p) => p.classList.add('hidden'));
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const target = (btn as HTMLElement).dataset.tab;
      wrap.querySelector(`[data-panel="${target}"]`)?.classList.remove('hidden');
    });
  });
});
</script>

