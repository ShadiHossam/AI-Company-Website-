---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";
import FaqAccordion from "../../components/FaqAccordion.astro";

const fallbackFaqs = [
  { question: "What exactly is a custom AI assistant?", answer: "A custom AI assistant is a language model configured specifically for your business. You define its purpose, provide knowledge files (your docs, SOPs, product info), and optionally connect it to external systems via API. It behaves according to your rules, knows your content, and can be shared with your team or customers, all without your team writing a single line of code." },
  { question: "Can our AI assistant connect to our systems?", answer: "Yes. We connect your AI assistant to external APIs: your CRM, your database, your website, your helpdesk, or any system with an API. This means it can look up real-time data, create records, send messages, and take action, not just answer questions." },
  { question: "Who can access it once it's built?", answer: "You choose. We can configure it for private access (only people you invite), share it across your internal team workspace, or open it to customers. Most business clients start with internal-only access and expand from there." },
  { question: "Does it stay up to date with new information?", answer: "We set up workflows to refresh your AI assistant's knowledge base automatically, so it always reflects your latest pricing, policies, and documentation. For real-time data, we connect it to pull live information from your systems at the time of each conversation." },
  { question: "What's the 100% guarantee?", answer: "If you're not satisfied with what we deliver, you pay nothing. That's not marketing. It's our standard terms. We only take on projects we know we can deliver, which is why we've never had to issue a refund." },
  { question: "How is this different from just using a general AI tool at work?", answer: "General AI tools are unconfigured and know nothing about your business. A custom AI assistant is trained on your products, your policies, your tone, and your context. It gives consistent answers aligned with your business rules, not the average answer it learned from the internet. It can also be restricted: it won't give advice outside its scope, won't discuss competitors, and won't say things that contradict your policies." },
  { question: "Which platforms can you deploy the assistant on?", answer: "We deploy on web interfaces, internal team platforms, messaging apps, website chat widgets, and custom applications. Your assistant can run in one channel or multiple simultaneously. We build the integration based on where your team or customers actually spend their time." },
  { question: "What if we want to expand what the assistant can do after launch?", answer: "That's very common. Most clients start with a focused assistant and expand its capabilities over time, adding more knowledge, new tools, or additional channels. The underlying architecture we build is modular, so adding capabilities after launch is typically straightforward and doesn't require rebuilding from scratch." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'custom_gpt')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Custom AI Assistant Development for UAE Businesses | Aegis AI"
  description="We build custom AI assistants for UAE businesses, trained on your products, knowledge base, and workflows. As a Dubai-based AI agency, we deploy your brand, your data, your AI exactly where your team or customers work."
  canonicalPath="/services/custom-gpt-development"
  arPath="/ar/services/custom-gpt-development"
