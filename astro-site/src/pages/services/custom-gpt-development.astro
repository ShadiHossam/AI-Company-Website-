    <div style="position:absolute; inset:0; background-image:radial-gradient(circle, rgba(0,227,253,0.07) 1px, transparent 1px); background-size:24px 24px;"></div>
    <div style="position:relative; z-index:1; display:grid; grid-template-columns:repeat(3,1fr); gap:3rem; text-align:center; max-width:800px; margin:0 auto;">
      <div>
        <p style="color:#00e3fd; font-size:2.25rem; font-weight:800; line-height:1;">No code</p>
        <p style="color:rgba(255,255,255,0.55); font-size:0.9rem; margin-top:0.375rem;">We handle everything. Your team just uses it.</p>
      </div>
      <div>
        <p style="color:#00e3fd; font-size:2.25rem; font-weight:800; line-height:1;">No code</p>
        <p style="color:rgba(255,255,255,0.55); font-size:0.9rem; margin-top:0.375rem;">Your team uses it — no technical training needed</p>
      </div>
      <div>
        <p style="color:#00e3fd; font-size:2.25rem; font-weight:800; line-height:1;">Any team</p>
        <p style="color:rgba(255,255,255,0.55); font-size:0.9rem; margin-top:0.375rem;">Sales, support, ops, HR — built for whoever needs it</p>
      </div>
    </div>
  </div>
  <div style="position:absolute; inset:0; background:linear-gradient(to top,#f9f9ff 0%,transparent 100%); pointer-events:none;"></div>
</div>

<!-- WHAT WE BUILD -->
<section id="what-we-build" class="section" aria-labelledby="build-heading">
  <div class="container">
    <div class="section-header">
      <div class="section-eyebrow">What We Build</div>
      <h2 id="build-heading">Six Types of Custom GPTs We Deploy</h2>
      <p style="color:#42474e; font-size:1.0625rem;">Each one is trained on your content, configured to your rules, and connected to your tools.</p>
    </div>
    <div class="builds-grid">
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">support_agent</span></div>
        <h3>Customer Support GPT</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Handles Tier 1 and Tier 2 questions using your actual documentation, FAQs, and return policies — without sending customers to a generic ChatGPT.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">trending_up</span></div>
        <h3>Sales Assistant GPT</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.7;">Knows your products, pricing, and objection-handling playbooks. Helps your sales team write proposals, prepare for calls, and respond to prospect questions in seconds.</p>
      </div>
      <div class="card">
        <div class="icon-box"><span class="material-symbols-outlined" style="color:#006875; font-size:24px;">school</span></div>
        <h3>Internal Knowledge GPT</h3>
