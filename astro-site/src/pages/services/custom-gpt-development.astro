---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../../lib/supabase";

const fallbackFaqs = [
  { question: "What exactly is a Custom GPT?", answer: "A Custom GPT is a version of ChatGPT configured specifically for your business. You give it a name, a set of instructions, knowledge files (your docs, SOPs, product info), and optionally connect it to external tools via API. It behaves according to your rules, knows your content, and can be shared with your team or customers — all without writing a single line of code." },
  { question: "Can our Custom GPT connect to our systems?", answer: "Yes. Through GPT Actions, we can connect your Custom GPT to external APIs — your CRM, your database, your website, your helpdesk, or any system with an API. This means your GPT can look up real-time data, create records, send messages, and take action — not just answer questions." },
  { question: "Who can access it once it's built?", answer: "You choose. We can publish it privately (only people you invite), share it with everyone in your ChatGPT Team or Enterprise workspace, or publish it publicly to the GPT Store for anyone to find. Most business clients start with internal-only access and expand from there." },
  { question: "Does it stay up to date with new information?", answer: "We can set up workflows to refresh your Custom GPT's knowledge files automatically — so it always reflects your latest pricing, policies, and documentation. For real-time data, we use GPT Actions to pull live information from your systems at the time of each conversation." },
  { question: "What's the 100% guarantee?", answer: "If you're not satisfied with what we deliver, you pay nothing. That's not marketing — it's our standard terms. We only take on projects we know we can deliver, which is why we've never had to issue a refund." },
];

let faqItems = fallbackFaqs;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('faq_items')
    .select('question, answer, sort_order')
    .eq('section', 'custom_gpt')
    .eq('published', true)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    faqItems = data;
  }
} catch (err) {}

const faqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');
---

<BaseLayout
  title="Custom GPT Development — Build a Branded AI Assistant for Your Business | Aegis AI"
  description="We build Custom GPTs trained on your products, knowledge base, and workflows. Your brand, your data, your AI — deployed inside ChatGPT for your team or customers."
  canonicalPath="/services/custom-gpt-development"
  arPath="/ar/services/custom-gpt-development"
  ogImage="/assets/og-services.jpg"
  ldJson={[faqLdJson]}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <a href="/services">Services</a><span>/</span>
      <strong>Custom GPT Development</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">chat</span>
      Custom GPT Development
    </div>
    <h1>Your Business. Your AI. <span class="gradient-text">Built Inside ChatGPT.</span></h1>
