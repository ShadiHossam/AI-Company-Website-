---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Products for Dubai SMEs — WhatsApp AI & Dashboard | Aegis AI"
  description="Pre-built AI products for Dubai SMEs — WhatsApp AI Agent, Operations Dashboard, and Team AI Trainer. Deploy in under 2 weeks. Arabic & English ready."
  canonicalPath="/products"
  ogImage="/assets/og-products.jpg"
>

<!-- ── HERO ── -->
<header class="hero-section" style="padding-top: 10rem; padding-bottom: 5rem; text-align: center;">
  <div class="container" style="position: relative; z-index: 1;">
    <nav class="page-breadcrumb mb-8 justify-center" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Products</span>
    </nav>
    <h1 style="max-width: 48rem; margin: 0 auto 1.5rem;">
      AI Products Built for the <span class="gradient-text">UAE</span>
    </h1>
    <p style="color: #42474e; font-size: 1.125rem; line-height: 1.75; max-width: 36rem; margin: 0 auto;">
      Pre-built AI modules for the industries we serve — ready to deploy in weeks, not months. Each product is customised to your brand and workflows.
    </p>
  </div>
</header>

<!-- ── PRODUCTS ── -->
<section class="section-sm">
  <div class="container">

    <!-- Product 1: WhatsApp AI Agent -->
    <div class="product-panel">
      <div class="product-glow"></div>
      <div class="product-inner" style="position: relative; z-index: 1;">
        <div>
          <div class="product-icon">
            <svg viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="#006875" stroke-width="1.8"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <div style="display: inline-flex; align-items: center; gap: .375rem; background: rgba(34,197,94,0.10); border: 1px solid rgba(34,197,94,0.30); border-radius: 100px; padding: .25rem .875rem; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: #22c55e;"></span>
            <span style="font-size: .75rem; font-weight: 700; color: #166534; font-family: 'Inter', sans-serif; letter-spacing: .04em; text-transform: uppercase;">Available Now</span>
          </div>
          <h2 style="margin-bottom: 1rem;">WhatsApp AI Agent</h2>
          <p style="color: #42474e; line-height: 1.75; margin-bottom: 1.75rem;">A 24/7 bilingual AI assistant that qualifies leads, books appointments, and handles FAQs — directly in WhatsApp. Works in Arabic and English with zero manual effort.</p>
          <div style="margin-bottom: 2rem;">
            <span class="feature-tag">Lead qualification</span>
            <span class="feature-tag">Appointment booking</span>
            <span class="feature-tag">FAQ automation</span>
            <span class="feature-tag">Arabic + English</span>
            <span class="feature-tag">CRM integration</span>
          </div>
          <button onclick="openModal()" class="btn-primary">Get Started →</button>
        </div>
        <div class="feature-list-panel">
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Deployed in your WhatsApp Business account in under 2 weeks</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Trained on your products, services, and pricing</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Hands off to a human agent when a question needs one</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Full analytics dashboard — conversations, conversion rates, drop-off points</span>
          </div>
          <div class="feature-list-item" style="margin-bottom: 0;">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Integrates with Salesforce, HubSpot, Zoho, and more</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Product 2: Operations Dashboard -->
    <div class="product-panel" style="--glow-color: rgba(0,104,117,0.12);">
      <div class="product-glow" style="background: rgba(0,104,117,0.12);"></div>
      <div class="product-inner" style="position: relative; z-index: 1;">
        <div class="feature-list-panel" style="order: 0;">
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Connects to 50+ tools including Excel, Google Sheets, ERPs, and POS systems</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">AI-generated daily summaries and anomaly alerts sent via WhatsApp or email</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Role-based views for management, operations, and frontline teams</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Automated approval workflows, task routing, and escalation rules</span>
          </div>
          <div class="feature-list-item" style="margin-bottom: 0;">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Mobile-first — works on any device, optimised for managers on the go</span>
          </div>
        </div>
        <div style="order: 1;">
          <div class="product-icon" style="background: rgba(0,104,117,0.10);">
            <svg viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="#006875" stroke-width="1.8"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <div style="display: inline-flex; align-items: center; gap: .375rem; background: rgba(34,197,94,0.10); border: 1px solid rgba(34,197,94,0.30); border-radius: 100px; padding: .25rem .875rem; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: #22c55e;"></span>
            <span style="font-size: .75rem; font-weight: 700; color: #166534; font-family: 'Inter', sans-serif; letter-spacing: .04em; text-transform: uppercase;">Available Now</span>
          </div>
          <h2 style="margin-bottom: 1rem;">Operations Dashboard</h2>
          <p style="color: #42474e; line-height: 1.75; margin-bottom: 1.75rem;">Real-time AI analytics and workflow automation dashboards — connected to your existing tools. Turn raw data into clear decisions without needing a data team.</p>
          <div style="margin-bottom: 2rem;">
            <span class="feature-tag">Real-time analytics</span>
            <span class="feature-tag">Workflow automation</span>
            <span class="feature-tag">Custom KPIs</span>
            <span class="feature-tag">Multi-source data</span>
            <span class="feature-tag">AI insights</span>
          </div>
          <button onclick="openModal()" class="btn-primary">Get Started →</button>
        </div>
      </div>
    </div>

    <!-- Product 3: Team AI Trainer -->
    <div class="product-panel">
      <div class="product-glow" style="background: rgba(0,37,59,0.10);"></div>
      <div class="product-inner" style="position: relative; z-index: 1;">
        <div>
          <div class="product-icon" style="background: #e7eeff;">
            <svg viewBox="0 0 24 24" fill="none" class="w-7 h-7" stroke="#00253b" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div style="display: inline-flex; align-items: center; gap: .375rem; background: rgba(0,37,59,0.08); border: 1px solid rgba(0,37,59,0.18); border-radius: 100px; padding: .25rem .875rem; margin-bottom: 1rem;">
            <span style="width: 6px; height: 6px; border-radius: 50%; background: #00253b;"></span>
            <span style="font-size: .75rem; font-weight: 700; color: #00253b; font-family: 'Inter', sans-serif; letter-spacing: .04em; text-transform: uppercase;">Coming Soon</span>
          </div>
          <h2 style="margin-bottom: 1rem;">Team AI Trainer</h2>
          <p style="color: #42474e; line-height: 1.75; margin-bottom: 1.75rem;">An AI-powered training platform with bilingual content — measurable upskilling for every department. Track progress, certify employees, and prove ROI on training spend.</p>
          <div style="margin-bottom: 2rem;">
            <span class="feature-tag">Bilingual content</span>
            <span class="feature-tag">Progress tracking</span>
            <span class="feature-tag">Certifications</span>
            <span class="feature-tag">Department-specific</span>
            <span class="feature-tag">ROI reporting</span>
          </div>
          <button onclick="openModal()" class="btn-primary">Join Waitlist →</button>
        </div>
        <div class="feature-list-panel">
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Courses built around your specific tools, processes, and team roles</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Arabic and English UI with auto-translated content</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">AI tutor available 24/7 to answer questions in natural language</span>
          </div>
          <div class="feature-list-item">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Certification program with verifiable credentials per department</span>
          </div>
          <div class="feature-list-item" style="margin-bottom: 0;">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            <span style="color: #42474e; font-size: .9rem; line-height: 1.6;">Manager dashboard showing team adoption, quiz scores, and time-to-proficiency</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ── CTA ── -->
<section class="section-sm" aria-label="CTA">
  <div class="container">
    <div class="cta-band">
      <div style="position: relative; z-index: 1;">
        <h2 style="color: #ffffff; font-size: clamp(1.75rem, 3vw, 2.5rem); margin-bottom: 1rem;">Ready to See These in Action?</h2>
        <p style="color: rgba(255,255,255,0.55); font-size: 1.125rem; max-width: 36rem; margin: 0 auto 2.5rem; line-height: 1.7;">Book a free demo and we'll show you exactly how each product fits your business — customised to your industry and workflows.</p>
        <button onclick="openModal()" class="btn-primary" style="font-size: 1.125rem; padding: 1.125rem 2.75rem;">Book a Free Demo →</button>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.product-panel {
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255,255,255,0.5);
      border-radius: 32px;
      padding: 4rem;
      box-shadow: 0 20px 40px rgba(0, 59, 92, 0.06);
      position: relative; overflow: hidden;
      margin-bottom: 24px;
    }
    .product-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .product-glow {
      position: absolute; top: -80px; right: -80px;
      width: 320px; height: 320px; border-radius: 50%;
      background: rgba(0,227,253,0.12); filter: blur(60px);
      pointer-events: none;
    }
    .product-icon {
      width: 56px; height: 56px; border-radius: 16px;
      background: #e7eeff;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem;
    }
    .feature-tag {
      display: inline-flex; align-items: center;
      background: #f0f3ff; color: #42474e;
      font-size: .8rem; font-weight: 500;
      padding: .375rem .875rem; border-radius: 8px;
      margin: .25rem; font-family: 'Inter', sans-serif;
    }
    .feature-list-item { display: flex; align-items: flex-start; gap: .75rem; margin-bottom: 1rem; }
    .feature-list-panel {
      background: #f0f3ff;
      border-radius: 20px; padding: 2rem;
    }
    @media (max-width: 900px) {
      .product-inner { grid-template-columns: 1fr; gap: 2rem; }
      .product-panel { padding: 2.5rem 1.75rem; }
    }
</style>