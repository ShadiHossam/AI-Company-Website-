---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPageContent, getVal } from "../lib/page-content";

export const prerender = false;

const pc = await loadPageContent('services');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);
---

<BaseLayout
  title="AI Services Dubai — Custom Build, Train & Consult | Aegis AI"
  description="Three AI services for Dubai SMEs: custom AI development, team training & workshops, and AI strategy consulting. 100% satisfaction guarantee. Arabic & English."
  canonicalPath="/services"
  ogImage="/assets/og-services.jpg"
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <nav class="page-breadcrumb" style="justify-content:center; margin-bottom:1.5rem;" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span>
      <strong>Services</strong>
    </nav>
    <div style="display:inline-flex; align-items:center; gap:8px; background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); border-radius:100px; padding:6px 16px; color:#004f58; font-size:0.875rem; font-weight:600; margin-bottom:1.5rem;">
      <span class="material-symbols-outlined" style="font-size:18px;">settings</span>
      {g('hero_eyebrow', 'What We Offer')}
    </div>
    <h1>{g('hero_h1', 'Three Services. One Mission.')}</h1>
    <p style="color:#42474e; font-size:1.125rem; max-width:600px; margin:1.5rem auto 2.5rem;">
      {g('hero_subtext', "We don't just build AI tools — we make your business genuinely AI-ready. From strategy to build to team training, we cover the full process.")}
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="services_hero" class="btn-primary">{g('hero_cta', 'Book a Free Consultation')}</button>
      <a href="#services-list" class="btn-outline">Explore Services ↓</a>
    </div>
  </div>
</header>

<!-- SERVICES LIST -->
<section id="services-list" class="section">
  <div class="container">

    <!-- Service 1 — Custom AI Development -->
    <div class="service-split">
      <div class="service-img-wrap">
        <img src="https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=800&q=80&auto=format&fit=crop" alt="Custom AI development for Dubai SME — chatbot and automation interface" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">★ 100% Guarantee · Delivered in 8–12 weeks</div>
      </div>
      <div>
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">code</span>
          Custom AI Development
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">AI Built Around Your Workflows — Not the Other Way Around</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">Off-the-shelf AI tools don't fit your business. We build AI systems that do exactly what your team needs — chatbots, automation pipelines, dashboards, and predictive tools — integrated with your existing software.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>WhatsApp &amp; chatbot AI for lead handling and support</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Automation pipelines that eliminate manual tasks</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>AI dashboards &amp; predictive analytics tools</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>UAE-compliant, Arabic + English ready</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/custom-ai-development" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_custom_ai" class="btn-outline-sky" style="font-size:0.9375rem;">Get a Quote</button>
        </div>
      </div>
    </div>

    <!-- Service 2 — AI Training & Workshops -->
    <div class="service-split">
      <div class="service-img-wrap reverse" style="order:2;">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&q=80&auto=format&fit=crop" alt="AI training workshop for Dubai business team" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">AR + EN Bilingual · Hands-on workshops</div>
      </div>
      <div style="order:1;">
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">group</span>
          AI Training &amp; Workshops
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">Your Team Needs to Use AI. We Make Sure They Do.</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">Building AI is only half the battle. We train your employees to use it confidently — with hands-on workshops in Arabic and English, tailored to your industry and the specific tools your team uses.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Role-specific workshops for every team member</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>In-person Dubai sessions or remote delivery</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Bilingual training materials (Arabic &amp; English)</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Post-workshop support for 30 days</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/ai-training" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_training" class="btn-outline-sky" style="font-size:0.9375rem;">Book a Workshop</button>
        </div>
      </div>
    </div>

    <!-- Service 3 — AI Strategy -->
    <div class="service-split" style="margin-bottom:0;">
      <div class="service-img-wrap">
        <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80&auto=format&fit=crop" alt="AI strategy consulting session for Dubai business" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">ROI-First Approach · 12-month roadmap included</div>
      </div>
      <div>
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">bar_chart</span>
          AI Strategy Consulting
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">Know Exactly Which AI to Build — Before You Spend a Dirham</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">We map your workflows, identify the highest-ROI AI opportunities, and hand you a clear 12-month implementation plan. No guesswork. No wasted budget. Just a clear path forward.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Full workflow audit to find AI opportunities</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>ROI projections for each AI use case</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>12-month AI implementation roadmap</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Vendor &amp; tool recommendations for your stack</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/ai-strategy" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_strategy" class="btn-outline-sky" style="font-size:0.9375rem;">Get a Strategy Session</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- GUARANTEE STRIP -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div style="background:rgba(245,158,11,0.06); border:1px solid rgba(245,158,11,0.20); border-radius:24px; padding:4rem 3rem; text-align:center; max-width:680px; margin:0 auto;">
      <span class="material-symbols-outlined" style="font-size:48px; color:#d97706; display:block; margin-bottom:1.25rem;">shield</span>
      <h2 style="font-size:1.75rem; font-weight:800; color:#00253b; margin-bottom:1rem;">All Three Services Are Covered by Our 100% Guarantee</h2>
      <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; max-width:480px; margin:0 auto 2rem;">If you're not completely satisfied with what we deliver — you pay absolutely nothing. No conditions. No disputes. Just a full refund.</p>
      <button onclick="openModal(this)" data-source="services_guarantee" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Start Risk-Free Today</button>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.service-split { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; margin-bottom:6rem; }
    .service-img-wrap { border-radius:20px; overflow:hidden; position:relative; min-height:320px; }
    .service-img-wrap img { width:100%; height:100%; object-fit:cover; min-height:320px; }
    .service-img-caption { position:absolute; bottom:1.25rem; left:1.25rem; background:rgba(0,37,59,0.82); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.625rem 1rem; font-size:0.75rem; color:rgba(255,255,255,0.85); }
    .service-eyebrow { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:100px; font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:1.25rem; }
    .check-item { display:flex; align-items:flex-start; gap:10px; margin-bottom:0.75rem; }
    .check-item span { color:#42474e; font-size:0.9375rem; line-height:1.5; }
    @media(max-width:768px) { .service-split { grid-template-columns:1fr; gap:2rem; } .service-split .reverse { order:-1; } }
</style>