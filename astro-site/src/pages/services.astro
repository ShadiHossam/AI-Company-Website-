---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadPageContent, getVal } from "../lib/page-content";

export const prerender = false;

const pc = await loadPageContent('services');
const g = (key: string, fallback: string) => getVal(pc, key, fallback);

const servicesLdJson = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'AI Services by Aegis AI',
    url: 'https://aegisai.ae/services',
    description: 'Custom AI development, automation, AI agents, internal tools, team training, and strategy consulting for businesses in the UAE and beyond.',
    publisher: { '@type': 'Organization', name: 'Aegis AI', url: 'https://aegisai.ae' },
    hasPart: [
      { '@type': 'Service', name: 'Custom AI Development', url: 'https://aegisai.ae/services/custom-ai-development' },
      { '@type': 'Service', name: 'AI Agents', url: 'https://aegisai.ae/services/ai-agents' },
      { '@type': 'Service', name: 'AI Automation', url: 'https://aegisai.ae/services/ai-automation' },
      { '@type': 'Service', name: 'AI Training & Workshops', url: 'https://aegisai.ae/services/ai-training' },
      { '@type': 'Service', name: 'AI Strategy Consulting', url: 'https://aegisai.ae/services/ai-strategy' },
      { '@type': 'Service', name: 'AI Integration', url: 'https://aegisai.ae/services/ai-integration' },
      { '@type': 'Service', name: 'Internal AI Tools', url: 'https://aegisai.ae/services/internal-ai-tools' },
      { '@type': 'Service', name: 'Custom GPT Development', url: 'https://aegisai.ae/services/custom-gpt-development' },
      { '@type': 'Service', name: 'Vibe Coding', url: 'https://aegisai.ae/services/vibe-coding' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://aegisai.ae/' },
      { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://aegisai.ae/services' },
    ],
  },
];
---

<BaseLayout
  title="AI Services in the UAE: Build, Automate, Train &amp; Consult | Aegis AI"
  description="Aegis AI is an AI agency in Dubai offering eight services for UAE businesses: custom AI development, automation, AI agents, internal tools, vibe coding, integration, team training, and strategy consulting."
  canonicalPath="/services"
  arPath="/ar/services"
  ogImage="/assets/og-services.jpg"
  ldJson={servicesLdJson}
>

<header class="hero-section">
  <div class="container" style="text-align:center;">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Services</div>
    <h1>{g('hero_h1', 'Eight Services. One Mission.')}</h1>
    <p style="color:rgba(255,255,255,0.72); font-size:1.125rem; max-width:600px; margin:1.5rem auto 2.5rem;">
      {g('hero_subtext', "We don't just build AI tools. We make your business genuinely AI-ready. From strategy to build to team enablement, we cover the full journey.")}
    </p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <button onclick="openModal(this)" data-source="services_hero" class="btn-primary">{g('hero_cta', 'Book a Free Consultation')}</button>
      <a href="#services-list" class="btn-outline">Explore Services ↓</a>
    </div>
  </div>
</header>

<!-- CORE SERVICES -->
<section id="services-list" class="section">
  <div class="container">

    <!-- Service 1 — Custom AI Development -->
    <div class="service-split">
      <div class="service-img-wrap">
        <img src="https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&q=80&auto=format&fit=crop" alt="Custom AI development: chatbot and automation interface" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">★ 100% Satisfaction Guarantee</div>
      </div>
      <div>
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">code</span>
          Custom AI Development
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">AI Built Around Your Workflows, Not the Other Way Around</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">Off-the-shelf AI doesn't fit your business. As an AI agency based in Dubai, we build AI systems that do exactly what your team needs: chatbots, automation pipelines, dashboards, and predictive tools, integrated with your existing software.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Chatbots &amp; AI assistants for lead handling and support</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Automation pipelines that eliminate manual tasks</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>AI dashboards &amp; predictive analytics tools</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Integrated with your existing software stack</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/custom-ai-development" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_custom_ai" class="btn-outline-sky" style="font-size:0.9375rem;">Get a Quote</button>
        </div>
      </div>
    </div>

    <!-- Service 2 — AI Training & Workshops -->
    <div class="service-split">
      <div class="service-img-wrap reverse" style="order:2;">
        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&q=80&auto=format&fit=crop" alt="AI training workshop for business team" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">Role-specific · On-site or remote · Globally delivered</div>
      </div>
      <div style="order:1;">
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">group</span>
          AI Training &amp; Workshops
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">Your Team Needs to Use AI. We Make Sure They Do.</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">Building AI is only half the battle. We train your employees to use it confidently, with hands-on workshops tailored to your industry and the specific workflows your team follows.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Role-specific workshops for every team member</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>On-site or remote delivery, anywhere in the world</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Custom training materials for your industry</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Post-workshop follow-up support included</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/ai-training" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_training" class="btn-outline-sky" style="font-size:0.9375rem;">Book a Workshop</button>
        </div>
      </div>
    </div>

    <!-- Service 3 — AI Strategy -->
    <div class="service-split">
      <div class="service-img-wrap">
        <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&q=80&auto=format&fit=crop" alt="AI strategy consulting session" loading="lazy" />
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,19,32,0.45) 0%,transparent 55%),linear-gradient(135deg,rgba(0,104,117,0.20),rgba(0,37,59,0.35));"></div>
        <div class="service-img-caption">ROI-First Approach · 12-month roadmap included</div>
      </div>
      <div>
        <div class="service-eyebrow" style="background:rgba(0,227,253,0.12); border:1px solid rgba(0,227,253,0.28); color:#004f58;">
          <span class="material-symbols-outlined" style="font-size:14px;">bar_chart</span>
          AI Strategy Consulting
        </div>
        <h2 style="font-size:clamp(1.5rem,3vw,2.25rem); font-weight:800; color:#00253b; letter-spacing:-0.03em; margin-bottom:1rem;">Know Exactly Which AI to Build Before You Spend a Dollar</h2>
        <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; margin-bottom:1.5rem;">We map your workflows, identify the highest-ROI AI opportunities, and hand you a clear 12-month implementation plan. No guesswork. No wasted budget. Just a clear path forward.</p>
        <div style="margin-bottom:1.75rem;">
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Full workflow audit to find AI opportunities</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>ROI projections for each AI use case</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>12-month AI implementation roadmap</span></div>
          <div class="check-item"><span class="material-symbols-outlined" style="color:#006875; font-size:20px; flex-shrink:0; margin-top:2px;">check</span><span>Vendor &amp; tool recommendations for your stack</span></div>
        </div>
        <div style="display:flex; gap:12px; flex-wrap:wrap;">
          <a href="/services/ai-strategy" class="btn-primary" style="font-size:0.9375rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_strategy" class="btn-outline-sky" style="font-size:0.9375rem;">Get a Strategy Session</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- MORE SERVICES GRID -->
<section class="section" style="background:#f0f3ff;">
  <div class="container">
    <div class="section-header">
      <h2>More Ways We Help You Win With AI</h2>
      <p style="color:#42474e; font-size:1.0625rem; max-width:560px; margin:0 auto;">From autonomous agents to vibe coding to deep integrations, we cover every layer of your AI journey.</p>
    </div>
    <div class="more-services-grid">

      <!-- AI Automation -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">settings_suggest</span>
        </div>
        <div class="service-card-body">
          <h3>AI Automation</h3>
          <p>Stop doing it manually. We build intelligent automation pipelines that eliminate repetitive work across sales, ops, and admin, without changing your existing tools.</p>
          <ul class="service-card-list">
            <li>Email &amp; document processing</li>
            <li>Multi-step approval workflows</li>
            <li>Data sync across your stack</li>
            <li>Lead routing &amp; follow-up automation</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/ai-automation" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_automation" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- AI Agents -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">smart_toy</span>
        </div>
        <div class="service-card-body">
          <h3>AI Agents &amp; Agentic Systems</h3>
          <p>AI that works alongside your team. We build autonomous agents that handle high-volume, repetitive tasks so your people can focus on the decisions that need human judgment.</p>
          <ul class="service-card-list">
            <li>Sales &amp; outreach agents</li>
            <li>Research &amp; analysis agents</li>
            <li>Operations &amp; scheduling agents</li>
            <li>Customer service agents</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/ai-agents" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_agents" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- Internal AI Tools -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">dashboard</span>
        </div>
        <div class="service-card-body">
          <h3>Internal AI Tools</h3>
          <p>Generic AI tools don't know your business. We build internal AI assistants, knowledge bases, and dashboards trained on your own data, SOPs, and workflows.</p>
          <ul class="service-card-list">
            <li>Company knowledge base AI</li>
            <li>Internal operations chatbot</li>
            <li>Custom analytics dashboards</li>
            <li>AI-powered document search</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/internal-ai-tools" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_internal" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- Vibe Coding -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">terminal</span>
        </div>
        <div class="service-card-body">
          <h3>Vibe Coding</h3>
          <p>Ship software faster with AI-accelerated development. We build your product using AI-first coding practices without compromising quality.</p>
          <ul class="service-card-list">
            <li>AI-assisted product development</li>
            <li>Rapid prototyping &amp; MVPs</li>
            <li>Legacy code modernization</li>
            <li>AI-generated test suites</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/vibe-coding" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_vibe" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- AI Integration -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">hub</span>
        </div>
        <div class="service-card-body">
          <h3>AI Integration Services</h3>
          <p>You don't need to replace your existing software. You need to make it smarter. We add an AI layer to your CRM, ERP, and tools so they work harder with the same team.</p>
          <ul class="service-card-list">
            <li>CRM &amp; ERP AI enrichment</li>
            <li>API-based AI connections</li>
            <li>Communication platform AI</li>
            <li>Data pipeline intelligence</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/ai-integration" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_integration" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- Custom GPT Development -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">chat</span>
        </div>
        <div class="service-card-body">
          <h3>Custom AI Model Development</h3>
          <p>Your business, your AI. We build custom language models trained on your products, documentation, and workflows so your team has an assistant that actually knows your business.</p>
          <ul class="service-card-list">
            <li>Customer support &amp; sales AI assistants</li>
            <li>Internal knowledge assistants</li>
            <li>Brand content AI tools</li>
            <li>API-connected models with live data</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/custom-gpt-development" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_custom_gpt" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- Claude Agent Builds -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">psychology</span>
        </div>
        <div class="service-card-body">
          <h3>Autonomous AI Agent Builds</h3>
          <p>The most capable autonomous agents, built for reliability. Instruction-following, long-context reasoning, and precise tool use, purpose-built for complex business workflows.</p>
          <ul class="service-card-list">
            <li>Research &amp; analysis agents</li>
            <li>Email &amp; document processing agents</li>
            <li>Sales &amp; prospecting agents</li>
            <li>Multi-agent systems</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/claude-agent-builds" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_claude_agents" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- Prompt Engineering -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">tune</span>
        </div>
        <div class="service-card-body">
          <h3>Prompt Engineering &amp; Optimization</h3>
          <p>Your AI is only as good as the prompts behind it. We audit, engineer, and optimize prompts for any AI model, cutting editing time and API costs significantly.</p>
          <ul class="service-card-list">
            <li>Prompt audit &amp; rewrite</li>
            <li>System prompt design for AI products</li>
            <li>Prompt library creation</li>
            <li>A/B testing &amp; ongoing optimization</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/prompt-engineering" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_prompt_eng" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

      <!-- AI Model Fine-Tuning -->
      <div class="service-card">
        <div class="service-card-icon">
          <span class="material-symbols-outlined" style="color:#006875; font-size:26px;">model_training</span>
        </div>
        <div class="service-card-body">
          <h3>AI Model Fine-Tuning</h3>
          <p>Stop using generic AI. We fine-tune foundation models on your proprietary data so your AI knows your business and delivers consistent results at scale.</p>
          <ul class="service-card-list">
            <li>Brand voice &amp; tone training</li>
            <li>Document classification models</li>
            <li>Industry-specific domain training</li>
            <li>Structured data extraction models</li>
          </ul>
        </div>
        <div class="service-card-footer">
          <a href="/services/ai-model-finetuning" class="btn-primary" style="font-size:0.875rem;">Learn More</a>
          <button onclick="openModal(this)" data-source="services_finetuning" class="btn-outline-sky" style="font-size:0.875rem;">Get a Quote</button>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- GUARANTEE STRIP -->
<section class="section" style="background:#e7eeff;">
  <div class="container">
    <div style="background:rgba(245,158,11,0.06); border:1px solid rgba(245,158,11,0.20); border-radius:24px; padding:4rem 3rem; text-align:center; max-width:680px; margin:0 auto;">
      <span class="material-symbols-outlined" style="font-size:48px; color:#d97706; display:block; margin-bottom:1.25rem;">shield</span>
      <h2 style="font-size:1.75rem; font-weight:800; color:#00253b; margin-bottom:1rem;">Every Service Is Covered by Our 100% Guarantee</h2>
      <p style="color:#42474e; font-size:1.0625rem; line-height:1.8; max-width:480px; margin:0 auto 2rem;">If you're not completely satisfied with what we deliver, you pay absolutely nothing. No conditions. No disputes. Just a full refund.</p>
      <button onclick="openModal(this)" data-source="services_guarantee" class="btn-primary" style="font-size:1.0625rem; padding:0.9375rem 2.5rem;">Start Risk-Free Today</button>
    </div>
  </div>
</section>

</BaseLayout>

<style>
.service-split { display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center; margin-bottom:6rem; }
    .service-img-wrap { border-radius:20px; overflow:hidden; position:relative; min-height:320px; }
    .service-img-wrap img { width:100%; height:100%; object-fit:cover; min-height:320px; }
    .service-img-caption { position:absolute; bottom:1.25rem; left:1.25rem; background:rgba(0,37,59,0.82); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.12); border-radius:10px; padding:0.625rem 1rem; font-size:0.75rem; color:rgba(255,255,255,0.85); }
    .service-eyebrow { display:none; }
    .check-item { display:flex; align-items:flex-start; gap:10px; margin-bottom:0.75rem; }
    .check-item span { color:#42474e; font-size:0.9375rem; line-height:1.5; }

    /* More services grid */
    .more-services-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
    .service-card {
      background: rgba(255,255,255,0.55);
      backdrop-filter: blur(20px) saturate(160%); -webkit-backdrop-filter: blur(20px) saturate(160%);
      border:1px solid rgba(255,255,255,0.6); border-radius:20px; padding:2rem;
      display:flex; flex-direction:column; gap:1.25rem;
      box-shadow: 0 8px 32px rgba(0,37,59,0.05);
      transition:box-shadow .3s var(--ease), transform .3s var(--ease), border-color .3s;
