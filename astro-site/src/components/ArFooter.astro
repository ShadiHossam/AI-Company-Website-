---
import { COMPANY } from '../config/company';
---

<footer id="site-footer" style="background: #00253b;" aria-label="التذييل">
  <div class="container py-16">
    <div class="rounded-2xl p-7 mb-12 flex flex-col sm:flex-row items-center justify-between gap-6" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
      <div>
        <h3 class="text-white font-bold text-lg mb-1">احصل على رؤى الذكاء الاصطناعي في بريدك</h3>
        <p class="text-sm" style="color:rgba(255,255,255,0.45);">رؤى شهرية للشركات. بدون إزعاج.</p>
      </div>
      <div class="w-full sm:w-auto">
        <form id="footer-newsletter-form" class="flex gap-2" onsubmit="handleFooterNewsletterSubmit(event)">
          <input id="footer-newsletter-email" type="email" name="EMAIL" required placeholder="بريدك@شركتك.ae" style="flex:1;min-width:0;padding:.625rem 1rem;border:1px solid rgba(255,255,255,0.10);border-radius:8px;background:rgba(255,255,255,0.05);color:#fff;font-size:.875rem;outline:none;font-family:inherit;direction:rtl;" />
          <button type="submit" class="btn-primary text-sm whitespace-nowrap" style="padding:.625rem 1.25rem;">اشترك</button>
        </form>
        <p id="footer-newsletter-success" class="hidden text-sm font-semibold mt-2" style="color:#4ADE80;">&#10003; تم الاشتراك!</p>
      </div>
    </div>

    <div class="footer-links-grid">

      <!-- Brand -->
      <div style="min-width:0;">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:#00e3fd;">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="#00253b" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12"/></svg>
          </div>
          <span class="text-white font-bold text-lg">{COMPANY.name}</span>
        </div>
        <p class="text-white/40 text-sm leading-relaxed mb-5">لا نبني الذكاء الاصطناعي لك فحسب — بل نجعل شركتك جاهزة للذكاء الاصطناعي حقاً.</p>
        <div style="display:flex;flex-wrap:wrap;gap:10px;">
          <a href={`https://www.linkedin.com/company/${COMPANY.linkedinSlug}`} class="footer-social" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="rgba(255,255,255,0.65)" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href={`https://wa.me/${COMPANY.whatsapp}`} class="footer-social" aria-label="واتساب">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="rgba(255,255,255,0.65)" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          </a>
          {COMPANY.instagram && (
            <a href={`https://www.instagram.com/${COMPANY.instagram}`} class="footer-social" aria-label="إنستغرام">
              <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="rgba(255,255,255,0.65)" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="rgba(255,255,255,0.65)" stroke="none"/></svg>
            </a>
          )}
          {COMPANY.twitter && (
            <a href={`https://x.com/${COMPANY.twitter}`} class="footer-social" aria-label="X (تويتر)">
              <svg viewBox="0 0 24 24" fill="rgba(255,255,255,0.65)" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          )}
          {COMPANY.facebook && (
            <a href={`https://www.facebook.com/${COMPANY.facebook}`} class="footer-social" aria-label="فيسبوك">
              <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="rgba(255,255,255,0.65)" stroke-width="2"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          )}
          {COMPANY.youtube && (
            <a href={`https://www.youtube.com/@${COMPANY.youtube}`} class="footer-social" aria-label="يوتيوب">
              <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="rgba(255,255,255,0.65)" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="rgba(255,255,255,0.65)" stroke="none"/></svg>
            </a>
          )}
          {COMPANY.tiktok && (
            <a href={`https://www.tiktok.com/@${COMPANY.tiktok}`} class="footer-social" aria-label="تيك توك">
              <svg viewBox="0 0 24 24" fill="rgba(255,255,255,0.65)" width="16" height="16"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>
            </a>
          )}
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">الخدمات</h4>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.625rem;">
          <li><a href="/ar/services/custom-ai-development" class="footer-link">تطوير ذكاء اصطناعي مخصص</a></li>
          <li><a href="/ar/services/ai-automation"         class="footer-link">أتمتة بالذكاء الاصطناعي</a></li>
          <li><a href="/ar/services/ai-agents"             class="footer-link">وكلاء الذكاء الاصطناعي</a></li>
          <li><a href="/ar/services/vibe-coding"           class="footer-link">Vibe Coding</a></li>
          <li><a href="/ar/services/internal-ai-tools"     class="footer-link">أدوات ذكاء اصطناعي داخلية</a></li>
          <li><a href="/ar/services/ai-integration"        class="footer-link">دمج الذكاء الاصطناعي</a></li>
          <li><a href="/ar/services/ai-training"           class="footer-link">تدريب على الذكاء الاصطناعي</a></li>
          <li><a href="/ar/services/ai-strategy"           class="footer-link">استشارات استراتيجية</a></li>
        </ul>
      </div>

      <!-- Industries -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">القطاعات</h4>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.625rem;">
          <li><a href="/ar/industries/real-estate" class="footer-link">الذكاء الاصطناعي للعقارات</a></li>
          <li><a href="/ar/industries/retail"      class="footer-link">الذكاء الاصطناعي للتجزئة</a></li>
          <li><a href="/ar/industries/hospitality" class="footer-link">الذكاء الاصطناعي للضيافة</a></li>
          <li><a href="/ar/industries/logistics"   class="footer-link">الذكاء الاصطناعي للوجستيات</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">الشركة</h4>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.625rem;">
          <li><a href="/ar/about"   class="footer-link">من نحن</a></li>
          <li><a href="/ar/results" class="footer-link">النتائج</a></li>
          <li><a href="/ar/blog"    class="footer-link">المدونة</a></li>
          <li><a href="/ar/faq"     class="footer-link">الأسئلة الشائعة</a></li>
          <li><a href="/ar/contact" class="footer-link">تواصل معنا</a></li>
          <li><a href="/"           class="footer-link" lang="en">English Version</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">تواصل معنا</h4>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.75rem;">
          <li style="display:flex;align-items:flex-start;gap:.625rem;">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" style="flex-shrink:0;margin-top:2px;" stroke="#00e3fd" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 10a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            <span style="color:rgba(255,255,255,0.45);font-size:.875rem;">{COMPANY.phone}</span>
          </li>
          <li style="display:flex;align-items:flex-start;gap:.625rem;">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" style="flex-shrink:0;margin-top:2px;" stroke="#00e3fd" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span style="color:rgba(255,255,255,0.45);font-size:.875rem;">{COMPANY.email}</span>
          </li>
          <li style="display:flex;align-items:flex-start;gap:.625rem;">
            <svg viewBox="0 0 24 24" fill="none" width="16" height="16" style="flex-shrink:0;margin-top:2px;" stroke="#00e3fd" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span style="color:rgba(255,255,255,0.45);font-size:.875rem;">دبي · الإمارات العربية المتحدة</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top:1px solid rgba(255,255,255,0.10);">
      <p class="text-white/40 text-sm">© <span id="copyright-year"></span> {COMPANY.name}. جميع الحقوق محفوظة.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="text-white/30 hover:text-white/60 text-sm transition-colors">سياسة الخصوصية</a>
        <a href="/terms"   class="text-white/30 hover:text-white/60 text-sm transition-colors">شروط الخدمة</a>
        <button onclick="window.openCookieSettings && window.openCookieSettings()" class="text-white/30 hover:text-white/60 text-sm transition-colors" style="background:transparent;border:none;padding:0;font-weight:400;font-family:inherit;line-height:inherit;cursor:pointer;">إعدادات ملفات تعريف الارتباط</button>
      </div>
    </div>
  </div>
  <script>document.getElementById('copyright-year').textContent = new Date().getFullYear();</script>
</footer>

<style>
  .footer-links-grid {
    display: grid;
    align-items: start;
    gap: 2rem;
    margin-bottom: 3rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 480px) {
    .footer-links-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .footer-links-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .footer-links-grid { grid-template-columns: 1.4fr repeat(4, 1fr); }
  }

  .footer-link {
    color: rgba(255,255,255,0.45);
    font-size: .875rem;
    text-decoration: none;
    transition: color .15s;
  }
  .footer-link:hover { color: #ffffff; }

  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    transition: background .2s;
    flex-shrink: 0;
  }
  .footer-social:hover { background: rgba(0,227,253,0.15); }
</style>
