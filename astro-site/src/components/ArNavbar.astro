---
import { COMPANY } from '../config/company';

interface Props {
  enPath?: string;
}
const { enPath } = Astro.props;
---

<nav id="navbar" role="navigation" aria-label="التنقل الرئيسي">
  <div class="container flex items-center justify-between h-18 py-3">
    <a href="/ar" class="flex items-center gap-2 cursor-pointer" aria-label="Lenoo AI - الصفحة الرئيسية">
      <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background:#00253b;">
        <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="#00e3fd" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
      </div>
      <span class="font-bold text-xl" style="color:#00253b;">{COMPANY.name}</span>
    </a>
    <div class="hidden md:flex items-center gap-7">
      <div class="nav-dropdown">
        <button class="nav-dropdown-btn" id="services-btn" onclick="toggleServicesDropdown()" aria-expanded="false" aria-haspopup="true">
          الخدمات
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav-dropdown-menu services-mega" id="services-menu" role="menu">
          <div class="services-col">
            <p class="services-col-label">بناء وأتمتة</p>
            <a href="/ar/services/custom-ai-development" class="nav-dropdown-item" role="menuitem">تطوير ذكاء اصطناعي مخصص</a>
            <a href="/ar/services/ai-automation"         class="nav-dropdown-item" role="menuitem">أتمتة بالذكاء الاصطناعي</a>
            <a href="/ar/services/ai-agents"             class="nav-dropdown-item" role="menuitem">وكلاء الذكاء الاصطناعي</a>
            <a href="/ar/services/vibe-coding"           class="nav-dropdown-item" role="menuitem">Vibe Coding</a>
          </div>
          <div class="services-divider"></div>
          <div class="services-col">
            <p class="services-col-label">أنظمة واستشارات</p>
            <a href="/ar/services/internal-ai-tools"     class="nav-dropdown-item" role="menuitem">أدوات ذكاء اصطناعي داخلية</a>
            <a href="/ar/services/ai-integration"        class="nav-dropdown-item" role="menuitem">دمج الذكاء الاصطناعي</a>
            <a href="/ar/services/ai-strategy"           class="nav-dropdown-item" role="menuitem">استشارات استراتيجية</a>
            <a href="/ar/services/ai-training"           class="nav-dropdown-item" role="menuitem">تدريب على الذكاء الاصطناعي</a>
          </div>
          <div style="height:1px;background:#E2E8F0;margin:.4rem .9rem;grid-column:1/-1;"></div>
          <a href="/ar/services" class="nav-dropdown-item" role="menuitem" style="color:#006875;grid-column:1/-1;">عرض جميع الخدمات ←</a>
        </div>
      </div>
      <div class="nav-dropdown">
        <button class="nav-dropdown-btn" id="industries-btn" onclick="toggleIndustriesDropdown()" aria-expanded="false" aria-haspopup="true">
          القطاعات
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav-dropdown-menu" id="industries-menu" role="menu">
          <a href="/ar/industries/real-estate" class="nav-dropdown-item" role="menuitem">العقارات</a>
          <a href="/ar/industries/retail"       class="nav-dropdown-item" role="menuitem">التجزئة والتجارة الإلكترونية</a>
          <a href="/ar/industries/hospitality"  class="nav-dropdown-item" role="menuitem">الضيافة والسياحة</a>
          <a href="/ar/industries/logistics"    class="nav-dropdown-item" role="menuitem">اللوجستيات وسلاسل التوريد</a>
        </div>
      </div>
      <a href="/ar/products" class="nav-link text-sm">المنتجات</a>
      <a href="/ar/about"   class="nav-link text-sm">عنّا</a>
      <a href="/ar/results" class="nav-link text-sm">النتائج</a>
      <a href="/ar/blog"    class="nav-link text-sm">المدونة</a>
      <a href="/ar/careers" class="nav-link text-sm">الوظائف</a>
    </div>
    <div class="hidden md:flex items-center gap-3">
      {enPath && (
        <a href={enPath} class="lang-switch" lang="en" hreflang="en-ae" aria-label="Switch to English">EN</a>
      )}
      <button onclick="openModal(this)" data-source="ar_navbar" class="btn-primary text-sm py-2.5 px-5">احجز استشارة مجانية</button>
    </div>
    <button id="hamburger" onclick="toggleMenu()" class="md:hidden p-2 rounded-lg cursor-pointer" style="background:rgba(0,37,59,0.06);" aria-label="فتح القائمة" aria-expanded="false">
      <svg id="ham-icon" viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="#00253b" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="close-icon" viewBox="0 0 24 24" fill="none" class="w-6 h-6 hidden" stroke="#00253b" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div id="mobile-menu" class="md:hidden" style="border-top:1px solid rgba(0,37,59,0.10);background:#f9f9ff;">
    <div class="container py-4 flex flex-col gap-4">
      <div>
        <span class="mobile-nav-link" style="color:#42474e;font-weight:600;">الخدمات</span>
        <div class="mobile-nav-sub">
          <a href="/ar/services/custom-ai-development" onclick="toggleMenu()">تطوير ذكاء اصطناعي مخصص</a>
          <a href="/ar/services/ai-automation"         onclick="toggleMenu()">أتمتة بالذكاء الاصطناعي</a>
          <a href="/ar/services/ai-agents"             onclick="toggleMenu()">وكلاء الذكاء الاصطناعي</a>
          <a href="/ar/services/vibe-coding"           onclick="toggleMenu()">Vibe Coding</a>
          <a href="/ar/services/internal-ai-tools"     onclick="toggleMenu()">أدوات ذكاء اصطناعي داخلية</a>
          <a href="/ar/services/ai-integration"        onclick="toggleMenu()">دمج الذكاء الاصطناعي</a>
          <a href="/ar/services/ai-strategy"           onclick="toggleMenu()">استشارات استراتيجية</a>
          <a href="/ar/services/ai-training"           onclick="toggleMenu()">تدريب على الذكاء الاصطناعي</a>
        </div>
      </div>
      <div>
        <span class="mobile-nav-link" style="color:#42474e;font-weight:600;">القطاعات</span>
        <div class="mobile-nav-sub">
          <a href="/ar/industries/real-estate" onclick="toggleMenu()">العقارات</a>
          <a href="/ar/industries/retail"       onclick="toggleMenu()">التجزئة</a>
          <a href="/ar/industries/hospitality"  onclick="toggleMenu()">الضيافة</a>
          <a href="/ar/industries/logistics"    onclick="toggleMenu()">اللوجستيات</a>
        </div>
      </div>
      <a href="/ar/products" onclick="toggleMenu()" class="mobile-nav-link">المنتجات</a>
      <a href="/ar/about"   onclick="toggleMenu()" class="mobile-nav-link">عنّا</a>
      <a href="/ar/results" onclick="toggleMenu()" class="mobile-nav-link">النتائج</a>
      <a href="/ar/blog"    onclick="toggleMenu()" class="mobile-nav-link">المدونة</a>
      <a href="/ar/careers" onclick="toggleMenu()" class="mobile-nav-link">الوظائف</a>
      {enPath && (
        <a href={enPath} onclick="toggleMenu()" class="mobile-nav-link" lang="en" style="color:#5a616b;">English Version</a>
      )}
      <div class="flex gap-3 pt-2">
        <button onclick="openModal(this)" data-source="ar_navbar_mobile" class="flex-1 btn-primary justify-center text-sm py-2.5">احجز استشارة مجانية</button>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link { position: relative; color: #42474e; font-weight: 500; transition: color .2s; text-decoration: none; font-size: .875rem; }
  .nav-link::after {
    content: ''; position: absolute; right: 0; left: 100%; bottom: -6px; height: 2px;
    background: linear-gradient(90deg, #006875, #00e3fd);
    border-radius: 2px; transition: left .25s var(--ease);
  }
  .nav-link:hover { color: #00253b; }
  .nav-link:hover::after, .nav-link:focus-visible::after { left: 0; }
  .nav-link:focus-visible, .nav-dropdown-btn:focus-visible {
    outline: 2px solid #006875; outline-offset: 4px; border-radius: 4px;
  }
  .mobile-nav-link { color: #00253b; font-weight: 600; text-decoration: none; font-size: 1rem; display: block; }
  .mobile-nav-link:hover { color: #006875; }
  .nav-dropdown { position: relative; }
  .nav-dropdown-btn { display:flex; align-items:center; gap:.3rem; color:#42474e; font-weight:500; font-size:.875rem; background:none; border:none; cursor:pointer; padding:0; transition:color .2s; }
  .nav-dropdown-btn:hover { color:#00253b; }
  .nav-dropdown-btn svg { transition: transform .2s var(--ease); }
  .nav-dropdown-btn.open svg { transform: rotate(180deg); }
  .nav-dropdown-menu {
    display:none; position:absolute; top:calc(100% + 14px); right:50%; transform:translateX(50%) translateY(-6px); min-width:220px;
    background:rgba(255,255,255,0.92); backdrop-filter: blur(20px) saturate(160%); -webkit-backdrop-filter: blur(20px) saturate(160%);
    border:1px solid rgba(0,37,59,0.10); border-radius:18px; padding:.5rem;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.85), 0 1px 2px rgba(0,37,59,0.05), 0 12px 28px rgba(0,59,92,0.10), 0 36px 72px rgba(0,59,92,0.10);
    z-index:100;
    opacity: 0; transition: opacity .2s var(--ease), transform .2s var(--ease);
  }
  .nav-dropdown-menu.open { display:block; opacity: 1; transform: translateX(50%) translateY(0); }
  .nav-dropdown-item { display:block; padding:.6rem .9rem; color:#42474e; font-size:.875rem; font-weight:500; text-decoration:none; border-radius:10px; transition:background .15s, color .15s; }
  .nav-dropdown-item:hover { background:rgba(0,227,253,0.10); color:#00253b; }
  .mobile-nav-sub { padding-inline-start:1rem; display:flex; flex-direction:column; gap:.6rem; margin-top:.4rem; }
  .mobile-nav-sub a { color:#72787e; font-size:.9rem; font-weight:500; text-decoration:none; }
  .mobile-nav-sub a:hover { color:#006875; }
  .services-mega { min-width:480px; display:grid; grid-template-columns:1fr 1px 1fr; gap:0; padding:.75rem .75rem .5rem; }
  .services-col { display:flex; flex-direction:column; gap:.1rem; padding:0 .25rem; }
  .services-col-label { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#72787e; padding:.4rem .9rem .5rem; }
  .services-divider { background:#E2E8F0; width:1px; margin:.25rem 0; }
  @media(max-width:860px) { .services-mega { min-width:260px; grid-template-columns:1fr; } .services-divider { display:none; } }

  #navbar a[aria-label="Lenoo AI - الصفحة الرئيسية"] > div { transition: transform .3s var(--ease), box-shadow .3s var(--ease); box-shadow: 0 4px 16px rgba(0,37,59,0.18); }
  #navbar a[aria-label="Lenoo AI - الصفحة الرئيسية"]:hover > div { transform: rotate(6deg) scale(1.06); box-shadow: 0 6px 22px rgba(0,227,253,0.30); }
</style>
