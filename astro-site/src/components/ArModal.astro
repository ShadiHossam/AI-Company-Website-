---
// Arabic contact/booking modal — rendered in every Arabic page via ArBaseLayout
// All DOM IDs are identical to Modal.astro so site.ts functions work without changes
---

<div id="modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title" onclick="handleOverlayClick(event)">
  <div class="modal-box">
    <div class="flex items-center justify-between p-6" style="border-bottom:1px solid #c2c7ce;">
      <div>
        <h2 id="modal-title" class="text-xl font-bold" style="color:#111c2d;">احجز استشارتك المجانية</h2>
        <p class="text-sm mt-0.5" style="color:#72787e;">مكالمة استراتيجية 30 دقيقة · بدون ضغط مبيعات</p>
      </div>
      <button onclick="closeModal()" class="w-9 h-9 rounded-full flex items-center justify-center transition-colors cursor-pointer" style="background:#e7eeff;" onmouseover="this.style.background='#c2c7ce'" onmouseout="this.style.background='#e7eeff'" aria-label="إغلاق">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="#42474e" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="px-6 pt-5 pb-0" id="step-indicator">
      <div class="flex items-center">
        <div class="step-dot active" id="dot-1">1</div>
        <div class="step-line" id="line-1"></div>
        <div class="step-dot inactive" id="dot-2">2</div>
        <div class="step-line" id="line-2"></div>
        <div class="step-dot inactive" id="dot-3">3</div>
      </div>
      <div class="flex justify-between mt-1.5 text-xs font-medium" style="color:#94A3B8;">
        <span>عنك</span><span>عن شركتك</span><span>حدد موعدك</span>
      </div>
    </div>
    <!-- Hidden tracking fields -->
    <input type="hidden" id="modal-source-field" value="unknown" />
    <!-- Honeypot -->
    <input type="text" id="modal-honeypot" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
    <!-- Submit error message -->
    <div id="modal-submit-error" class="hidden mx-6 mb-2 p-3 rounded-lg text-sm" style="background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.3);">
      حدث خطأ ما. يرجى <a href={`https://wa.me/971501234567`} style="color:#ef4444;font-weight:bold;">التواصل عبر واتساب</a> أو البريد الإلكتروني <a href="mailto:hello@aegisai.ae" style="color:#ef4444;font-weight:bold;">hello@aegisai.ae</a>.
    </div>
    <!-- Step 1 -->
    <div id="step-1" class="p-6">
      <h3 class="font-bold mb-5" style="color:#111c2d;">أخبرنا عنك</h3>
      <div class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div><label class="form-label" for="full-name">الاسم الكامل <span class="text-red-400">*</span></label><input id="full-name" type="text" class="form-input" placeholder="أحمد المنصوري" required /></div>
          <div><label class="form-label" for="company">اسم الشركة <span class="text-red-400">*</span></label><input id="company" type="text" class="form-input" placeholder="شركتك المحدودة" required /></div>
        </div>
        <div><label class="form-label" for="email">البريد الإلكتروني <span class="text-red-400">*</span></label><input id="email" type="email" class="form-input" placeholder="ahmed@company.ae" required /></div>
        <div><label class="form-label" for="whatsapp">رقم الواتساب <span class="text-red-400">*</span></label>
          <div class="flex">
            <select id="country-code" aria-label="كود البلد" style="border:1px solid #CBD5E1;border-left:none;border-radius:0 8px 8px 0;background:#F8FAFC;color:#42474e;font-size:.875rem;font-weight:500;padding:.75rem .5rem .75rem .75rem;outline:none;cursor:pointer;flex-shrink:0;appearance:none;-webkit-appearance:none;background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M1 1l4 4 4-4%22 stroke=%22%2372787e%22 stroke-width=%221.5%22 fill=%22none%22 stroke-linecap=%22round%22/></svg>');background-repeat:no-repeat;background-position:left .5rem center;padding-left:1.5rem;direction:ltr;">
              <option value="+971">🇦🇪 +971</option>
              <option value="+966">🇸🇦 +966</option>
              <option value="+965">🇰🇼 +965</option>
              <option value="+974">🇶🇦 +974</option>
              <option value="+973">🇧🇭 +973</option>
              <option value="+968">🇴🇲 +968</option>
              <option value="+20">🇪🇬 +20</option>
              <option value="+962">🇯🇴 +962</option>
              <option value="+961">🇱🇧 +961</option>
              <option value="+91">🇮🇳 +91</option>
              <option value="+92">🇵🇰 +92</option>
              <option value="+63">🇵🇭 +63</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+1">🇺🇸 +1</option>
            </select>
            <input id="whatsapp" type="tel" class="form-input" style="border-radius:8px 0 0 8px;direction:ltr;" placeholder="50 123 4567" required />
          </div>
        </div>
        <div><label class="form-label" for="job-title">المسمى الوظيفي</label><input id="job-title" type="text" class="form-input" placeholder="المدير التنفيذي، مدير العمليات..." /></div>
      </div>
      <div class="mt-6 flex justify-start"><button onclick="goToStep(2)" class="btn-primary">متابعة <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2" style="transform:scaleX(-1);"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button></div>
    </div>
    <!-- Step 2 -->
    <div id="step-2" class="p-6 hidden">
      <h3 class="font-bold mb-5" style="color:#111c2d;">أخبرنا عن شركتك</h3>
      <div class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div><label class="form-label" for="industry">القطاع <span class="text-red-400">*</span></label>
            <select id="industry" class="form-select" required><option value="">اختر...</option><option value="Real Estate &amp; Property">العقارات</option><option value="Retail &amp; E-commerce">التجزئة والتجارة الإلكترونية</option><option value="Hospitality &amp; Tourism">الضيافة والسياحة</option><option value="Logistics &amp; Supply Chain">اللوجستيات وسلاسل التوريد</option><option value="Healthcare">الرعاية الصحية</option><option value="Finance &amp; Banking">المال والأعمال المصرفية</option><option value="Other">أخرى</option></select>
          </div>
          <div><label class="form-label" for="company-size">حجم الشركة</label>
            <select id="company-size" class="form-select"><option value="">اختر...</option><option value="1–20 employees">١–٢٠ موظف</option><option value="21–100 employees">٢١–١٠٠ موظف</option><option value="101–500 employees">١٠١–٥٠٠ موظف</option><option value="500+ employees">٥٠٠+ موظف</option></select>
          </div>
        </div>
        <div><label class="form-label" for="challenge">التحدي الرئيسي <span class="text-red-400">*</span></label><textarea id="challenge" class="form-textarea" rows="3" placeholder="مثال: نقضي وقتاً طويلاً في المهام اليدوية..." required></textarea></div>
        <div><label class="form-label" for="budget">نطاق الميزانية</label>
          <select id="budget" class="form-select"><option value="">اختر...</option><option value="Exploring, no budget set">استكشاف، لا ميزانية محددة</option><option value="AED 10,000 – 50,000">١٠,٠٠٠ – ٥٠,٠٠٠ درهم</option><option value="AED 50,000 – 200,000">٥٠,٠٠٠ – ٢٠٠,٠٠٠ درهم</option><option value="AED 200,000+">٢٠٠,٠٠٠+ درهم</option></select>
        </div>
        <div><label class="form-label">هل جربت أدوات الذكاء الاصطناعي من قبل؟</label>
          <div class="flex gap-3 mt-1">
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="ai-exp" value="yes" style="accent-color:#006875"/> <span class="text-sm" style="color:#42474e;">نعم</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="ai-exp" value="no"  style="accent-color:#006875"/> <span class="text-sm" style="color:#42474e;">لا</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="radio" name="ai-exp" value="some" style="accent-color:#006875"/> <span class="text-sm" style="color:#42474e;">نستخدم بعضها</span></label>
          </div>
        </div>
      </div>
      <div class="mt-6 flex justify-between">
        <button onclick="goToStep(1)" class="btn-outline-sky text-sm py-2.5 px-5">→ رجوع</button>
        <button onclick="goToStep(3)" class="btn-primary">متابعة <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="currentColor" stroke-width="2" style="transform:scaleX(-1);"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
      </div>
    </div>
    <!-- Step 3 -->
    <div id="step-3" class="p-6 hidden">
      <h3 class="font-bold mb-5" style="color:#111c2d;">حدد موعدك</h3>
      <div class="space-y-4">
        <div><label class="form-label">نوع الاجتماع</label>
          <div class="grid grid-cols-3 gap-2 mt-1">
            <label class="meeting-option flex flex-col items-center gap-1.5"><input type="radio" name="meeting-type" value="video" style="accent-color:#006875" checked/><svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="#00e3fd" stroke-width="1.8"><path d="M23 7l-7 5 7 5V7z"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg><span class="text-xs font-medium" style="color:#42474e;">مكالمة فيديو</span></label>
            <label class="meeting-option flex flex-col items-center gap-1.5"><input type="radio" name="meeting-type" value="inperson" style="accent-color:#006875"/><svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="#00e3fd" stroke-width="1.8"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg><span class="text-xs font-medium" style="color:#42474e;">لقاء في دبي</span></label>
            <label class="meeting-option flex flex-col items-center gap-1.5"><input type="radio" name="meeting-type" value="phone" style="accent-color:#006875"/><svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="#00e3fd" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 10a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg><span class="text-xs font-medium" style="color:#42474e;">مكالمة هاتفية</span></label>
          </div>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div><label class="form-label" for="pref-date">التاريخ المفضل</label><input id="pref-date" type="date" class="form-input" style="direction:ltr;" /></div>
          <div><label class="form-label" for="pref-time">الوقت المفضل</label>
            <select id="pref-time" class="form-select"><option value="">اختر...</option><option value="Morning (9am–12pm)">صباحاً (٩ص–١٢ظ)</option><option value="Afternoon (12pm–5pm)">ظهراً (١٢ظ–٥م)</option><option value="Evening (5pm–7pm)">مساءً (٥م–٧م)</option></select>
          </div>
        </div>
        <div><label class="form-label" for="notes">ملاحظات إضافية (اختياري)</label><textarea id="notes" class="form-textarea" rows="2" placeholder="أي أسئلة أو موضوعات تود مناقشتها..."></textarea></div>
        <div class="flex items-start gap-3 rounded-xl p-3.5" style="background:rgba(245,158,11,0.08);border:1px solid rgba(245,158,11,0.20);">
          <svg viewBox="0 0 24 24" fill="#F59E0B" class="w-5 h-5 flex-shrink-0 mt-0.5"><path d="M12 1L3 5v6c0 5.25 3.75 10.15 9 11.25C17.25 21.15 21 16.25 21 11V5l-9-4z"/></svg>
          <p class="text-xs leading-relaxed" style="color:#92400E;"><strong>١٠٠٪ بدون مخاطرة:</strong> إذا بنينا شيئاً لم تكن راضياً عنه، تحصل على استرداد كامل. بدون أسئلة.</p>
        </div>
      </div>
      <div class="mt-6 flex justify-between">
        <button onclick="goToStep(2)" class="btn-outline-sky text-sm py-2.5 px-5">→ رجوع</button>
        <button onclick="submitForm()" class="btn-primary">تأكيد الحجز <svg viewBox="0 0 24 24" fill="#F59E0B" class="w-4 h-4"><path d="M12 1L3 5v6c0 5.25 3.75 10.15 9 11.25C17.25 21.15 21 16.25 21 11V5l-9-4z"/></svg></button>
      </div>
    </div>
    <!-- Success -->
    <div id="step-success" class="p-8 text-center hidden">
      <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background:rgba(34,197,94,0.12);"><svg viewBox="0 0 24 24" fill="none" class="w-8 h-8" stroke="#4ADE80" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg></div>
      <h3 class="text-2xl font-bold mb-3" style="color:#111c2d;">تم الحجز!</h3>
      <p class="mb-2" style="color:#42474e;">سنتواصل معك خلال <strong style="color:#111c2d;">٤ ساعات</strong> لتأكيد موعدك.</p>
      <p class="text-sm mb-6" style="color:#72787e;">تحقق من واتساب والبريد الإلكتروني للتأكيد.</p>
      <div class="flex items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-medium mb-6" style="background:rgba(245,158,11,0.10);color:#92400E;">
        <svg viewBox="0 0 24 24" fill="#F59E0B" class="w-4 h-4"><path d="M12 1L3 5v6c0 5.25 3.75 10.15 9 11.25C17.25 21.15 21 16.25 21 11V5l-9-4z"/></svg>
        استشارتك مجانية ١٠٠٪، بدون أي التزام.
      </div>
      <button onclick="closeModal()" class="btn-outline-sky w-full justify-center">إغلاق</button>
    </div>
  </div>
</div>

<style>
  .meeting-option { border:1px solid #c2c7ce; border-radius:.75rem; cursor:pointer; text-align:center; padding:.75rem .5rem; transition:border-color .2s,background .2s; }
  .meeting-option:hover { border-color:rgba(0,104,117,0.40); background:rgba(0,104,117,0.06); }
</style>
