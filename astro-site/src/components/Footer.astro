---
import { COMPANY } from '../config/company';
---

<footer id="site-footer" aria-label="Footer">
  <!-- Accent top border -->
  <div class="footer-top-bar"></div>

  <div class="footer-inner">
    <div class="container">
      <!-- Main grid -->
      <div class="footer-grid">

        <!-- Brand column -->
        <div class="footer-brand">
          <a href="/" class="brand-logo" aria-label="Home">
            <div class="logo-icon">
              <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="#00253b" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12"/></svg>
            </div>
            <span class="logo-text">{COMPANY.name}</span>
          </a>

          <p class="brand-tagline">We're the AI agency Dubai businesses trust to build tools that actually fit how they work.</p>

          <div class="social-row">
            <a href={`https://www.linkedin.com/company/${COMPANY.linkedinSlug}`} class="social-btn" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            {COMPANY.instagram && (
              <a href={`https://www.instagram.com/${COMPANY.instagram}`} class="social-btn" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
            )}
            {COMPANY.twitter && (
              <a href={`https://x.com/${COMPANY.twitter}`} class="social-btn" aria-label="X (Twitter)">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            )}
            {COMPANY.facebook && (
              <a href={`https://www.facebook.com/${COMPANY.facebook}`} class="social-btn" aria-label="Facebook">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            )}
            {COMPANY.youtube && (
              <a href={`https://www.youtube.com/@${COMPANY.youtube}`} class="social-btn" aria-label="YouTube">
                <svg viewBox="0 0 24 24" fill="none" width="16" height="16" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/></svg>
              </a>
            )}
            {COMPANY.tiktok && (
              <a href={`https://www.tiktok.com/@${COMPANY.tiktok}`} class="social-btn" aria-label="TikTok">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.76a4.85 4.85 0 01-1.01-.07z"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Services -->
        <div class="footer-col">
          <h4 class="col-heading">Services</h4>
          <ul class="col-list">
            <li><a href="/services/custom-ai-development" class="col-link">Custom AI Development</a></li>
            <li><a href="/services/ai-automation"         class="col-link">AI Automation</a></li>
            <li><a href="/services/ai-agents"             class="col-link">AI Agents</a></li>
            <li><a href="/services/claude-agent-builds"   class="col-link">Claude Agent Builds</a></li>
            <li><a href="/services/vibe-coding"           class="col-link">Vibe Coding</a></li>
            <li><a href="/services/custom-gpt-development" class="col-link">Custom GPT Development</a></li>
            <li><a href="/services/internal-ai-tools"     class="col-link">Internal AI Tools</a></li>
            <li><a href="/services/ai-integration"        class="col-link">AI Integration</a></li>
            <li><a href="/services/ai-model-finetuning"   class="col-link">AI Model Fine-Tuning</a></li>
            <li><a href="/services/prompt-engineering"    class="col-link">Prompt Engineering</a></li>
            <li><a href="/services/ai-training"           class="col-link">AI Training &amp; Workshops</a></li>
            <li><a href="/services/ai-strategy"           class="col-link">AI Strategy Consulting</a></li>
          </ul>
        </div>

        <!-- Industries -->
        <div class="footer-col">
          <h4 class="col-heading">Industries</h4>
          <ul class="col-list">
            <li><a href="/industries/real-estate" class="col-link">Real Estate</a></li>
            <li><a href="/industries/retail"      class="col-link">Retail</a></li>
            <li><a href="/industries/hospitality" class="col-link">Hospitality</a></li>
            <li><a href="/industries/logistics"   class="col-link">Logistics</a></li>
          </ul>
        </div>

        <!-- Company -->
        <div class="footer-col">
          <h4 class="col-heading">Company</h4>
          <ul class="col-list">
            <li><a href="/about"   class="col-link">About Us</a></li>
            <li><a href="/blog"    class="col-link">Blog</a></li>
            <li><a href="/results" class="col-link">Results</a></li>
            <li><a href="/careers" class="col-link">Careers</a></li>
            <li><a href="/contact" class="col-link">Contact</a></li>
          </ul>
        </div>

        <!-- Contact -->
        <div class="footer-col">
          <h4 class="col-heading">Get in Touch</h4>
          <ul class="contact-list">
            <li class="contact-item">
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" width="14" height="14" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 10a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
              </span>
              <a href={`tel:${COMPANY.phone}`} class="contact-value">{COMPANY.phone}</a>
            </li>
            <li class="contact-item">
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" width="14" height="14" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <a href={`mailto:${COMPANY.email}`} class="contact-value">{COMPANY.email}</a>
            </li>
            <li class="contact-item">
              <span class="contact-icon">
                <svg viewBox="0 0 24 24" fill="none" width="14" height="14" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span class="contact-value">{COMPANY.address}</span>
            </li>
          </ul>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="footer-bottom">
        <p class="copyright">© <span id="copyright-year"></span> {COMPANY.name}. All rights reserved.</p>
        <div class="legal-links">
          <a href="/privacy" class="legal-link">Privacy Policy</a>
          <span class="legal-sep"></span>
          <a href="/terms" class="legal-link">Terms of Service</a>
          <span class="legal-sep"></span>
          <button onclick="window.openCookieSettings && window.openCookieSettings()" class="legal-link legal-btn">Cookie Preferences</button>
        </div>
      </div>
    </div>
  </div>

  <script>document.getElementById('copyright-year').textContent = new Date().getFullYear();</script>
</footer>

<style>
  footer {
    position: relative;
    background: var(--navy);
  }

  .footer-top-bar { display: none; }

  .footer-inner {
    position: relative;
    padding: 4rem 0 0;
  }
  .footer-inner > .container { position: relative; }

  /* Grid layout */
  .footer-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr;
    margin-bottom: 3.5rem;
  }
  @media (min-width: 480px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: 1.6fr repeat(4, 1fr); gap: 2rem; }
    .footer-brand { padding-right: 2rem; }
  }

  /* Brand */
  .footer-brand {}

  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .logo-icon {
    width: 2rem;
    height: 2rem;
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: inset 0 -6px 12px rgba(0,227,253,0.25);
    transition: transform .3s var(--ease);
  }
  .brand-logo:hover .logo-icon { transform: rotate(-6deg) scale(1.06); }
  .logo-text {
    color: #fff;
    font-family: var(--display);
    font-weight: 800;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }

  .brand-tagline {
    color: #9db4c3;
    font-size: 0.875rem;
    line-height: 1.7;
    margin: 0 0 1.5rem;
    max-width: 22ch;
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: none;
    color: #c3d5e0;
    background: rgba(255,255,255,0.08);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .social-btn:hover {
    color: #00e3fd;
    background: rgba(0,227,253,0.2);
  }

  /* Columns */
  .footer-col {}

  .col-heading {
    color: #fff;
    font-family: var(--display);
    font-size: 0.8125rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 1.125rem;
  }

  .col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .col-link {
    color: rgba(255,255,255,0.5);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s, padding-left 0.15s;
    display: inline-block;
  }
  .col-link:hover {
    color: #fff;
    padding-left: 4px;
  }

  /* Contact */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }
  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(0,227,253,0.1);
    color: #00e3fd;
    flex-shrink: 0;
  }
  .contact-value {
    color: rgba(255,255,255,0.5);
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  a.contact-value:hover { color: #fff; }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 1.5rem 0 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .copyright {
    color: rgba(255,255,255,0.55);
    font-size: 0.8125rem;
    margin: 0;
  }

  .legal-links {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .legal-link {
    color: rgba(255,255,255,0.55);
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.15s;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-weight: 400;
    line-height: inherit;
  }
  .legal-link:hover { color: rgba(255,255,255,0.65); }

  /* Keyboard focus on dark footer surfaces */
  .social-btn:focus-visible, .col-link:focus-visible, .legal-link:focus-visible,
  a.contact-value:focus-visible, .brand-logo:focus-visible {
    outline: 2px solid #00e3fd; outline-offset: 3px; border-radius: 6px;
  }

  .legal-sep {
    display: block;
    width: 1px;
    height: 12px;
    background: rgba(255,255,255,0.15);
  }
</style>
