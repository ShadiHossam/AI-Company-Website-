---
import { COMPANY } from '../config/company';
---

<footer id="site-footer" style="background: #00253b;" aria-label="Footer">
  <div class="container py-16">
    <div class="rounded-2xl p-7 mb-12 flex flex-col sm:flex-row items-center justify-between gap-6" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);">
      <div>
        <h3 class="text-white font-bold text-lg mb-1">Get AI insights in your inbox</h3>
        <p class="text-sm" style="color:rgba(255,255,255,0.45);">Monthly tips for Gulf businesses. No spam.</p>
      </div>
      <div class="w-full sm:w-auto">
        <form id="footer-newsletter-form" class="flex gap-2" onsubmit="handleFooterNewsletterSubmit(event)">
          <input id="footer-newsletter-email" type="email" name="EMAIL" required placeholder="your@email.com" style="flex:1;min-width:180px;padding:.625rem 1rem;border:1px solid rgba(255,255,255,0.10);border-radius:8px;background:rgba(255,255,255,0.05);color:#fff;font-size:.875rem;outline:none;font-family:inherit;" />
          <button type="submit" class="btn-primary text-sm whitespace-nowrap" style="padding:.625rem 1.25rem;">Subscribe</button>
        </form>
        <p id="footer-newsletter-success" class="hidden text-sm font-semibold mt-2" style="color:#4ADE80;">&#10003; You're subscribed!</p>
      </div>
    </div>
    <div class="grid md:grid-cols-4 gap-10 mb-12">
      <div class="md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background:#00e3fd;">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="#00253b" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12"/></svg>
          </div>
          <span class="text-white font-bold text-lg">{COMPANY.name}</span>
        </div>
        <p class="text-white/40 text-sm leading-relaxed mb-5">We don't just build AI for you — we make your business AI-ready.</p>
        <div class="flex gap-3">
          <a href={`https://www.linkedin.com/company/${COMPANY.linkedinSlug}`} class="w-9 h-9 rounded-lg bg-white/5 hover:bg-indigo-500/20 flex items-center justify-center transition-colors cursor-pointer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="rgba(255,255,255,0.60)" stroke-width="2"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href={`https://wa.me/${COMPANY.whatsapp}`} class="w-9 h-9 rounded-lg bg-white/5 hover:bg-green-500/20 flex items-center justify-center transition-colors cursor-pointer" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" stroke="rgba(255,255,255,0.60)" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Services</h4>
        <ul class="space-y-2.5">
          <li><a href="/services/custom-ai-development" class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">Custom AI Development</a></li>
          <li><a href="/services/ai-training"           class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI Training &amp; Workshops</a></li>
          <li><a href="/services/ai-strategy"           class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI Strategy Consulting</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Industries</h4>
        <ul class="space-y-2.5">
          <li><a href="/industries/real-estate"   class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI for Real Estate</a></li>
          <li><a href="/industries/retail"        class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI for Retail</a></li>
          <li><a href="/industries/hospitality"   class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI for Hospitality</a></li>
          <li><a href="/industries/logistics"     class="text-white/45 hover:text-white text-sm transition-colors cursor-pointer">AI for Logistics</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-widest">Contact</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2.5">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#00e3fd" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 10a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            <span class="text-white/45 text-sm">{COMPANY.phone}</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#00e3fd" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span class="text-white/45 text-sm">{COMPANY.email}</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 flex-shrink-0 mt-0.5" stroke="#00e3fd" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-white/45 text-sm">Dubai, UAE</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top:1px solid rgba(255,255,255,0.10);">
      <p class="text-white/40 text-sm">© {new Date().getFullYear()} {COMPANY.name}. All rights reserved. Dubai, UAE.</p>
      <div class="flex gap-5">
        <a href="/privacy" class="text-white/30 hover:text-white/60 text-sm transition-colors cursor-pointer">Privacy Policy</a>
        <a href="/terms"   class="text-white/30 hover:text-white/60 text-sm transition-colors cursor-pointer">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
