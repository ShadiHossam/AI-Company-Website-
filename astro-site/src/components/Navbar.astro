---
import { COMPANY } from '../config/company';

interface Props {
  arPath?: string;
}
const { arPath } = Astro.props;
---

<nav id="navbar" role="navigation" aria-label="Main navigation">
  <div class="container flex items-center justify-between h-18 py-3">
    <a href="/" class="flex items-center gap-2 cursor-pointer" aria-label="Home">
      <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background:#00253b;">
        <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5" stroke="#00e3fd" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
      </div>
      <span class="font-bold text-xl" style="color:#00253b;">{COMPANY.name}</span>
    </a>
    <div class="hidden md:flex items-center gap-7">
      <div class="nav-dropdown">
        <button class="nav-dropdown-btn" id="services-btn" onclick="toggleServicesDropdown()" aria-expanded="false" aria-haspopup="true">
          Services
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav-dropdown-menu services-mega" id="services-menu" role="menu">
          <div class="services-col">
            <p class="services-col-label">Build &amp; Automate</p>
            <a href="/services/custom-ai-development" class="nav-dropdown-item" role="menuitem">Custom AI Development</a>
            <a href="/services/ai-automation"         class="nav-dropdown-item" role="menuitem">AI Automation</a>
            <a href="/services/ai-agents"             class="nav-dropdown-item" role="menuitem">AI Agents</a>
            <a href="/services/vibe-coding"           class="nav-dropdown-item" role="menuitem">Vibe Coding</a>
          </div>
          <div class="services-divider"></div>
          <div class="services-col">
            <p class="services-col-label">Systems &amp; Advise</p>
            <a href="/services/internal-ai-tools"     class="nav-dropdown-item" role="menuitem">Internal AI Tools</a>
            <a href="/services/ai-integration"        class="nav-dropdown-item" role="menuitem">AI Integration</a>
            <a href="/services/ai-strategy"           class="nav-dropdown-item" role="menuitem">AI Strategy Consulting</a>
            <a href="/services/ai-training"           class="nav-dropdown-item" role="menuitem">AI Training &amp; Workshops</a>
          </div>
          <div style="height:1px;background:#E2E8F0;margin:.4rem .9rem;grid-column:1/-1;"></div>
          <a href="/services" class="nav-dropdown-item" role="menuitem" style="color:#006875;grid-column:1/-1;">View All Services →</a>
        </div>
      </div>
      <div class="nav-dropdown">
        <button class="nav-dropdown-btn" id="industries-btn" onclick="toggleIndustriesDropdown()" aria-expanded="false" aria-haspopup="true">
          Industries
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav-dropdown-menu" id="industries-menu" role="menu">
          <a href="/industries/real-estate" class="nav-dropdown-item" role="menuitem">Real Estate</a>
          <a href="/industries/retail"       class="nav-dropdown-item" role="menuitem">Retail &amp; E-commerce</a>
          <a href="/industries/hospitality"  class="nav-dropdown-item" role="menuitem">Hospitality</a>
          <a href="/industries/logistics"    class="nav-dropdown-item" role="menuitem">Logistics</a>
        </div>
      </div>
      <a href="/products"   class="nav-link text-sm">Products</a>
      <a href="/about"      class="nav-link text-sm">About</a>
      <a href="/blog"       class="nav-link text-sm">Blog</a>
      <a href="/faq"        class="nav-link text-sm">FAQ</a>
      <a href="/careers"    class="nav-link text-sm">Careers</a>
    </div>
    <div class="hidden md:flex items-center gap-3">
      {arPath && (
        <a href={arPath} class="lang-switch" lang="ar" hreflang="ar" aria-label="عرض الموقع بالعربية">ع</a>
      )}
      <button onclick="openModal(this)" data-source="navbar" class="btn-primary text-sm py-2.5 px-5">Contact Sales</button>
    </div>
    <button id="hamburger" onclick="toggleMenu()" class="md:hidden p-2 rounded-lg cursor-pointer" style="background:rgba(0,37,59,0.06);" aria-label="Open menu" aria-expanded="false">
      <svg id="ham-icon" viewBox="0 0 24 24" fill="none" class="w-6 h-6" stroke="#00253b" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      <svg id="close-icon" viewBox="0 0 24 24" fill="none" class="w-6 h-6 hidden" stroke="#00253b" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>
  <div id="mobile-menu" class="md:hidden" style="border-top:1px solid rgba(0,37,59,0.10);background:#f9f9ff;">
    <div class="container py-4 flex flex-col gap-4">
      <div>
        <span class="mobile-nav-link" style="color:#42474e;font-weight:600;">Services</span>
        <div class="mobile-nav-sub">
          <a href="/services/custom-ai-development" onclick="toggleMenu()">Custom AI Development</a>
          <a href="/services/ai-automation"         onclick="toggleMenu()">AI Automation</a>
          <a href="/services/ai-agents"             onclick="toggleMenu()">AI Agents</a>
          <a href="/services/vibe-coding"           onclick="toggleMenu()">Vibe Coding</a>
          <a href="/services/internal-ai-tools"     onclick="toggleMenu()">Internal AI Tools</a>
          <a href="/services/ai-integration"        onclick="toggleMenu()">AI Integration</a>
          <a href="/services/ai-strategy"           onclick="toggleMenu()">AI Strategy Consulting</a>
          <a href="/services/ai-training"           onclick="toggleMenu()">AI Training &amp; Workshops</a>
        </div>
      </div>
      <div>
        <span class="mobile-nav-link" style="color:#42474e;font-weight:600;">Industries</span>
        <div class="mobile-nav-sub">
          <a href="/industries/real-estate" onclick="toggleMenu()">Real Estate</a>
          <a href="/industries/retail"       onclick="toggleMenu()">Retail &amp; E-commerce</a>
          <a href="/industries/hospitality"  onclick="toggleMenu()">Hospitality</a>
          <a href="/industries/logistics"    onclick="toggleMenu()">Logistics</a>
        </div>
      </div>
      <a href="/products" onclick="toggleMenu()" class="mobile-nav-link">Products</a>
      <a href="/about"    onclick="toggleMenu()" class="mobile-nav-link">About</a>
      <a href="/blog"     onclick="toggleMenu()" class="mobile-nav-link">Blog</a>
      <a href="/faq"      onclick="toggleMenu()" class="mobile-nav-link">FAQ</a>
      <a href="/careers"  onclick="toggleMenu()" class="mobile-nav-link">Careers</a>
      {arPath && (
        <a href={arPath} onclick="toggleMenu()" class="mobile-nav-link" lang="ar" style="color:#72787e;">النسخة العربية</a>
      )}
      <div class="flex gap-3 pt-2">
        <button onclick="openModal(this)" data-source="navbar_mobile" class="flex-1 btn-primary justify-center text-sm py-2.5">Contact Sales</button>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link { color: #42474e; font-weight: 500; transition: color .2s; text-decoration: none; font-size: .875rem; }
  .nav-link:hover { color: #00253b; }
  .mobile-nav-link { color: #00253b; font-weight: 600; text-decoration: none; font-size: 1rem; display: block; }
  .mobile-nav-link:hover { color: #006875; }
  .nav-dropdown { position: relative; }
  .nav-dropdown-btn { display:flex; align-items:center; gap:.3rem; color:#42474e; font-weight:500; font-size:.875rem; background:none; border:none; cursor:pointer; padding:0; transition:color .2s; }
  .nav-dropdown-btn:hover { color:#00253b; }
  .nav-dropdown-btn svg { transition: transform .2s; }
  .nav-dropdown-btn.open svg { transform: rotate(180deg); }
  .nav-dropdown-menu { display:none; position:absolute; top:calc(100% + 12px); left:50%; transform:translateX(-50%); min-width:220px; background:#ffffff; border:1px solid #c2c7ce; border-radius:16px; padding:.5rem; box-shadow:0 20px 40px rgba(0,59,92,0.10); z-index:100; }
  .nav-dropdown-menu.open { display:block; }
  .nav-dropdown-item { display:block; padding:.6rem .9rem; color:#42474e; font-size:.875rem; font-weight:500; text-decoration:none; border-radius:8px; transition:background .15s, color .15s; }
  .nav-dropdown-item:hover { background:#f0f3ff; color:#00253b; }
  .mobile-nav-sub { padding-inline-start:1rem; display:flex; flex-direction:column; gap:.6rem; margin-top:.4rem; }
  .mobile-nav-sub a { color:#72787e; font-size:.9rem; font-weight:500; text-decoration:none; }
  .mobile-nav-sub a:hover { color:#006875; }
  .services-mega { min-width:480px; grid-template-columns:1fr 1px 1fr; gap:0; padding:.75rem .75rem .5rem; }
  .services-mega.open { display:grid; }
  .services-col { display:flex; flex-direction:column; gap:.1rem; padding:0 .25rem; }
  .services-col-label { font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#72787e; padding:.4rem .9rem .5rem; }
  .services-divider { background:#E2E8F0; width:1px; margin:.25rem 0; }
  @media(max-width:860px) { .services-mega { min-width:260px; grid-template-columns:1fr; } .services-divider { display:none; } }
</style>
