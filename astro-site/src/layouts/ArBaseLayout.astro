---
import ArNavbar from '../components/ArNavbar.astro';
import ArFooter from '../components/ArFooter.astro';
import ArModal from '../components/ArModal.astro';
import { COMPANY } from '../config/company';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  enPath: string;
  ogImage?: string;
  ogType?: string;
  ldJson?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath,
  enPath,
  ogImage = `/assets/og-home.jpg`,
  ogType = 'website',
  ldJson,
  noindex = false,
} = Astro.props;

const canonicalURL = `https://${COMPANY.domain}${canonicalPath}`;
const enURL = `https://${COMPANY.domain}${enPath}`;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `https://${COMPANY.domain}${ogImage}`;
---

<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#00253b" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}
  <meta name="author" content="Aegis AI" />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:site_name" content="Aegis AI" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="ar_AE" />
  <meta property="og:locale:alternate" content="en_AE" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <link rel="alternate" hreflang="ar" href={canonicalURL} />
  <link rel="alternate" hreflang="en-ae" href={enURL} />
  <link rel="alternate" hreflang="x-default" href={enURL} />
  <link rel="sitemap" type="application/xml" href="/sitemap_index.xml" />

  {ldJson && (
    <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" /></noscript>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://www.clarity.ms" />
</head>
<body class="rtl">

<ArNavbar enPath={enPath} />
<slot />
<ArFooter />
<ArModal />

<script>
  import '../scripts/site';
</script>

<!-- Announcement Banner -->
<script>
(function() {
  var CACHE_KEY = 'banner_cache';
  var CACHE_TTL = 60000;
  function renderBanner(data) {
    if (!data || !data.active) return;
    var bar = document.createElement('div');
    bar.id = 'announcement-bar';
    bar.style.cssText = 'background:' + data.bg_color + ';color:' + data.text_color + ';text-align:center;padding:10px 1rem;font-size:0.875rem;font-weight:600;position:relative;z-index:200;';
    var msgNode = document.createElement('span');
    msgNode.textContent = data.message;
    bar.appendChild(msgNode);
    if (data.cta_text && data.cta_url) {
      var safeHref = /^(https?:\/\/|\/)/.test(data.cta_url) ? data.cta_url : '#';
      var link = document.createElement('a');
      link.href = safeHref;
      link.style.cssText = 'color:inherit;text-decoration:underline;margin-right:8px;';
      link.textContent = data.cta_text + ' ←';
      bar.appendChild(link);
    }
    document.body.insertBefore(bar, document.body.firstChild);
  }
  try {
    var cached = sessionStorage.getItem(CACHE_KEY);
    if (cached) {
      var entry = JSON.parse(cached);
      if (Date.now() < entry.exp) { renderBanner(entry.data); return; }
    }
  } catch(e) {}
  fetch('/api/banner')
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(data) {
      try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ data: data, exp: Date.now() + CACHE_TTL })); } catch(e) {}
      renderBanner(data);
    })
    .catch(function() {});
})();
</script>

<!-- Analytics & Tracking -->
<script>
(function() {
  function injectAnalytics(cfg) {
    var gtm = cfg['integration.gtm_container_id'];
    if (gtm) {
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',gtm);
    }
    var ga = cfg['integration.ga_measurement_id'];
    if (ga) {
      var gs = document.createElement('script'); gs.async = true;
      gs.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga;
      document.head.appendChild(gs);
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ window.dataLayer.push(arguments); };
      window.gtag('js', new Date()); window.gtag('config', ga);
    }
    var cl = cfg['integration.clarity_project_id'];
    if (cl) {
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,'clarity','script',cl);
    }
    var hj = cfg['integration.hotjar_site_id'];
    if (hj) {
      (function(h,o,t,j,a,r){h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};h._hjSettings={hjid:parseInt(hj,10),hjsv:6};a=o.getElementsByTagName('head')[0];r=o.createElement('script');r.async=1;r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;a.appendChild(r);})(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
    }
    var ic = cfg['integration.intercom_app_id'];
    if (ic) {
      window.intercomSettings = { app_id: ic };
      (function(){var w=window;var ic2=w.Intercom;if(typeof ic2==='function'){ic2('reattach_activator');ic2('update',w.intercomSettings);}else{var d=document;var i=function(){i.c(arguments)};i.q=[];i.c=function(args){i.q.push(args)};w.Intercom=i;var l=function(){var s=d.createElement('script');s.type='text/javascript';s.async=true;s.src='https://widget.intercom.io/widget/'+ic;var x=d.getElementsByTagName('script')[0];x.parentNode.insertBefore(s,x)};if(document.readyState==='complete'){l();}else if(w.attachEvent){w.attachEvent('onload',l);}else{w.addEventListener('load',l,false);}}})();
    }
    var cr = cfg['integration.crisp_website_id'];
    if (cr) {
      window.$crisp = []; window.CRISP_WEBSITE_ID = cr;
      var cs = document.createElement('script'); cs.src = 'https://client.crisp.chat/l.js'; cs.async = true;
      document.head.appendChild(cs);
    }
    var tw = cfg['integration.tawkto_property_id'];
    if (tw) {
      var Tawk_API = window.Tawk_API || {}; var Tawk_LoadStart = new Date();
      (function(){var s1=document.createElement('script'),s0=document.getElementsByTagName('script')[0];s1.async=true;s1.src='https://embed.tawk.to/'+tw;s1.charset='UTF-8';s1.setAttribute('crossorigin','*');s0.parentNode.insertBefore(s1,s0);})();
    }
  }

  function injectMarketing(cfg) {
    var mp = cfg['integration.meta_pixel_id'];
    if (mp) {
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      window.fbq('init', mp); window.fbq('track', 'PageView');
    }
    var li = cfg['integration.linkedin_insight_id'];
    if (li) {
      window._linkedin_partner_id = li;
      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      window._linkedin_data_partner_ids.push(li);
      (function(l){if(!l){window.lintrk=function(a,b){window.lintrk.q.push([a,b])};window.lintrk.q=[]}var s=document.getElementsByTagName('script')[0];var b=document.createElement('script');b.type='text/javascript';b.async=true;b.src='https://snap.licdn.com/li.lms-analytics/insight.min.js';s.parentNode.insertBefore(b,s)})(window.lintrk);
    }
    var ads = cfg['integration.google_ads_id'];
    if (ads) {
      if (window.gtag) {
        window.gtag('config', ads);
      } else {
        var as = document.createElement('script'); as.async = true;
        as.src = 'https://www.googletagmanager.com/gtag/js?id=' + ads;
        document.head.appendChild(as);
        window.dataLayer = window.dataLayer || [];
        window.gtag = function(){ window.dataLayer.push(arguments); };
        window.gtag('js', new Date()); window.gtag('config', ads);
      }
    }
    var tt = cfg['integration.tiktok_pixel_id'];
    if (tt) {
      !function(w,d,t){w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];ttq.methods=['page','track','identify','instances','debug','on','off','once','ready','alias','group','enableCookie','disableCookie'];ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)ttq.setAndDefer(e,ttq.methods[n]);return e};ttq.load=function(e,n){var i='https://analytics.tiktok.com/i18n/pixel/events.js',o=n&&n.partner;ttq._i=ttq._i||{};ttq._i[e]=[];ttq._i[e]._u=i;ttq._t=ttq._t||{};ttq._t[e]=+new Date;ttq._o=ttq._o||{};ttq._o[e]=n||{};n=document.createElement('script');n.type='text/javascript';n.async=!0;n.src=i+'?sdkid='+e+'&lib='+t;e=document.getElementsByTagName('script')[0];e.parentNode.insertBefore(n,e)};ttq.load(tt);ttq.page()}(window,document,'ttq');
    }
    var hs = cfg['integration.hubspot_portal_id'];
    if (hs) {
      var hss = document.createElement('script'); hss.type = 'text/javascript'; hss.id = 'hs-script-loader';
      hss.async = true; hss.defer = true; hss.src = '//js.hs-scripts.com/' + hs + '.js';
      document.head.appendChild(hss);
    }
  }

  function loadFromConfig(cfg) {
    var consent = localStorage.getItem('cookie_consent');
    var prefs = {};
    try { prefs = JSON.parse(localStorage.getItem('cookie_prefs') || '{}'); } catch(e) {}
    var analyticsOk = consent === 'accepted' || (consent === 'customized' && prefs.analytics !== false);
    var marketingOk = consent === 'accepted' || (consent === 'customized' && prefs.marketing !== false);
    if (analyticsOk) injectAnalytics(cfg);
    if (marketingOk) injectMarketing(cfg);
  }

  var consent = localStorage.getItem('cookie_consent');
  if (consent === 'accepted' || consent === 'customized') {
    fetch('/api/config/public').then(function(r){ return r.ok ? r.json() : {}; }).then(loadFromConfig).catch(function(){});
  }

  window.addEventListener('cookieConsent', function(e) {
    if (e.detail && e.detail.accepted) {
      fetch('/api/config/public').then(function(r){ return r.ok ? r.json() : {}; }).then(loadFromConfig).catch(function(){});
    }
  });
})();
</script>

<!-- Cookie Consent (deferred — English UI is a known limitation for Arabic pages) -->
<script defer src="/cookie-consent.js"></script>
<script>
(function() {
  window.hasCookieConsent = function() { return localStorage.getItem('cookie_consent') === 'accepted' || localStorage.getItem('cookie_consent') === 'customized'; };
  window.getCookiePrefs = function() { try { return JSON.parse(localStorage.getItem('cookie_prefs') || '{}'); } catch(e) { return {}; } };
  window.openCookieSettings = function() { /* overridden by cookie-consent.js after load */ };
})();
</script>
</body>
</html>
