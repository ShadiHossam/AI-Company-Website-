.newsletter-card { background: #00253b; border-radius: 18px; padding: 1.5rem; box-shadow: 0 6px 24px rgba(0,37,59,0.16); position: relative; overflow: hidden; }
.newsletter-card::before { content: ''; position: absolute; top: -40px; right: -40px; width: 140px; height: 140px; border-radius: 50%; background: radial-gradient(circle, rgba(0,227,253,0.14) 0%, transparent 65%); pointer-events: none; }
.nl-icon { width: 42px; height: 42px; border-radius: 12px; background: rgba(0,227,253,0.14); border: 1px solid rgba(0,227,253,0.25); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; font-size: 1.125rem; position: relative; z-index: 1; }
