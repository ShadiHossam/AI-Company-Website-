/* ─── Mobile share ─── */
.mobile-share { display: none; align-items: center; gap: 10px; margin: 2rem 0 0; padding: 1.25rem; background: #fff; border: 1px solid rgba(0,37,59,0.08); border-radius: 14px; }
.ms-label { font-size: 0.875rem; font-weight: 700; color: #00253b; margin-right: auto; }
.ms-btn { display: flex; align-items: center; gap: 7px; padding: 9px 16px; border-radius: 8px; border: 1px solid rgba(0,37,59,0.12); background: #fff; font-size: 0.8125rem; font-weight: 600; color: #006875; text-decoration: none; transition: background 0.15s; }
.ms-btn:hover { background: rgba(0,104,117,0.06); }

/* ─── Mobile ─── */
@media (max-width: 768px) {
  .ah-wrap { padding: 0 1.25rem; }
  .article-hero { padding: 48px 0 40px; }
  .hero-grid { grid-template-columns: 1fr; gap: 1.75rem; }
  .hero-grid--solo { grid-template-columns: 1fr; }
  .hero-cover { aspect-ratio: 16/9; border-radius: 14px; }
  .hero-title { font-size: 1.75rem; }
  .share-btns { display: none; }

  .page-body { padding: 2rem 0 3rem; }
  .body-grid { grid-template-columns: 1fr; gap: 0; }
  .sidebar { display: none; }
  .toc-accordion { display: block; }

  .kp-grid { grid-template-columns: 1fr; }
  .kp-item:nth-child(even) { padding-left: 0; border-left: none; }
  .kp-item:nth-child(2) { border-bottom: 1px dashed rgba(0,37,59,0.08); }
  .key-points { padding: 1.25rem 1.25rem 1.25rem 1.5rem; margin-bottom: 2rem; }

  .related-grid { grid-template-columns: 1fr; }
  .cta-band { border-radius: 14px; padding: 2rem 1.5rem; }
  .mobile-share { display: flex; }

  :global(.inline-cta) { flex-direction: column; align-items: flex-start; gap: 1rem; }
  :global(.ic-btn) { width: 100%; justify-content: center; }
}
</style>

<script>
  // Progress bar
  const bar = document.getElementById('progress-bar');
  function updateProgress() {
    const el = document.documentElement;
    const scrolled = el.scrollTop || document.body.scrollTop;
    const total = el.scrollHeight - el.clientHeight;
    if (bar) bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // Read time from article body word count
  const articleBody = document.getElementById('article-body');
  const rtEl = document.getElementById('read-time-text');
  if (articleBody && rtEl) {
    const words = (articleBody.textContent ?? '').trim().split(/\s+/).filter(Boolean).length;
    const mins = Math.max(1, Math.round(words / 200));
    rtEl.textContent = `${mins} min read`;
  }

  // Share URLs built at runtime from current page URL
  const pageUrl = window.location.href;
  const liHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`;
  const waHref = `https://wa.me/?text=${encodeURIComponent(document.title + ' ' + pageUrl)}`;
  (['share-li', 'ms-li'] as string[]).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.setAttribute('href', liHref);
  });
  (['share-wa', 'ms-wa'] as string[]).forEach(id => {
    const el = document.getElementById(id);
    if (el) el.setAttribute('href', waHref);
  });

  // Auto-generate ToC from h2s in article body
  function slugify(text: string): string {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }
  const tocSidebar = document.getElementById('toc-sidebar');
  const tocMobile = document.getElementById('toc-mobile');
  const h2s = articleBody ? Array.from(articleBody.querySelectorAll('h2')) : [];

  if (h2s.length > 0) {
    h2s.forEach((h2, idx) => {
      if (!h2.id) h2.id = slugify(h2.textContent ?? '') || `section-${idx}`;
      h2.setAttribute('data-toc', h2.id);
      const text = h2.textContent ?? '';
      const linkHtml = `<a class="toc-link" href="#${h2.id}" data-section="${h2.id}"><span class="toc-pip"></span><span class="toc-text">${text}</span></a>`;
      if (tocSidebar) tocSidebar.insertAdjacentHTML('beforeend', linkHtml);
      if (tocMobile) tocMobile.insertAdjacentHTML('beforeend', linkHtml);
    });

    // Highlight active section on scroll
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-section]');
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('data-toc');
          tocLinks.forEach(l => l.classList.toggle('active', l.getAttribute('data-section') === id));
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });
    h2s.forEach(h2 => observer.observe(h2));
  }

  // Mobile ToC accordion toggle
  const tocBtn = document.getElementById('toc-acc-btn');
  const tocBody = document.getElementById('toc-mobile');
  if (tocBtn && tocBody) {
    tocBtn.addEventListener('click', () => {
      const expanded = tocBtn.getAttribute('aria-expanded') === 'true';
      tocBtn.setAttribute('aria-expanded', String(!expanded));
      tocBody.classList.toggle('open', !expanded);
      tocBody.setAttribute('aria-hidden', String(expanded));
    });
  }

  // Key Takeaways expand / collapse
  document.querySelectorAll<HTMLButtonElement>('.kp-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest<HTMLElement>('.kp-item');
      if (!item) return;
      const open = item.classList.toggle('open');
      btn.textContent = open ? '−' : '+';
      btn.setAttribute('aria-expanded', String(open));
    });
  });

  // Inject inline CTA before the 2nd h2 in the article
  if (articleBody && h2s.length >= 2) {
    const ctaHtml = `<div class="inline-cta"><div class="ic-icon">🎯</div><div class="ic-text"><h4>Not sure which process to automate first?</h4><p>Our free AI audit maps your workflows and ranks opportunities by ROI — done in 45 minutes.</p></div><a href="/contact" class="ic-btn">Get Free Audit →</a></div>`;
    h2s[1].insertAdjacentHTML('beforebegin', ctaHtml);
  }

  // Newsletter form — optimistic success state
  const nlForm = document.getElementById('nl-form');
  if (nlForm) {
    nlForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = nlForm.querySelector<HTMLButtonElement>('button');
      const input = nlForm.querySelector<HTMLInputElement>('input');
      if (btn && input && input.value) {
        btn.textContent = 'Subscribed ✓';
        btn.disabled = true;
        input.disabled = true;
      }
    });
  }
</script>
