.rcard-tag { display: inline-flex; align-items: center; padding: 2px 10px; border-radius: 100px; font-size: 0.625rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; background: rgba(0,104,117,0.10); color: #004f58; border: 1px solid rgba(0,104,117,0.18); width: fit-content; }
