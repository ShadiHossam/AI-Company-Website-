---
import BaseLayout from './BaseLayout.astro';

interface KeyPoint {
  heading: string;
  body: string;
}

interface RelatedPost {
  title: string;
  slug: string;
  category: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  slug: string;
  ogImage?: string;
  coverImage?: string;
  authorName?: string;
  keyPoints?: KeyPoint[];
  relatedPosts?: RelatedPost[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  slug,
  ogImage,
  coverImage,
  authorName = 'Aegis AI',
  keyPoints = [],
  relatedPosts = [],
} = Astro.props;

const displayDate = updatedDate ?? pubDate;
const dateLabel = updatedDate ? 'Updated' : 'Published';
const dateStr = displayDate.toLocaleDateString('en-AE', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

const initials = authorName
  .split(' ')
  .map((w: string) => w[0] ?? '')
  .join('')
  .slice(0, 2)
  .toUpperCase();

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: authorName },
  publisher: { '@type': 'Organization', name: 'Aegis AI', url: 'https://aegisai.ae' },
  ...(coverImage ? { image: `https://aegisai.ae${coverImage}` } : {}),
};

const cardGradients = [
  'linear-gradient(135deg,#e7eeff,#f0f8ff)',
  'linear-gradient(135deg,#eefff6,#f0f8ff)',
  'linear-gradient(135deg,#fff0ee,#f0f8ff)',
];
---

<BaseLayout
  title={`${title} | Aegis AI Blog`}
  description={description}
  canonicalPath={`/blog/${slug}`}
  ogType="article"
  ogImage={ogImage ?? '/assets/og-blog.jpg'}
  ldJson={ldJson}
>

<div id="progress-bar" aria-hidden="true"></div>

<header class="article-hero">
  <div class="ah-wrap">
    <div class={coverImage ? 'hero-grid' : 'hero-grid hero-grid--solo'}>

      <div class="hero-text">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span class="sep" aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span class="sep" aria-hidden="true">/</span>
          <span class="cur">{title}</span>
        </nav>
        <div class="hero-meta">
          <span class="article-tag">{category}</span>
          <span class="meta-dot" aria-hidden="true"></span>
          <span class="read-time">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span id="read-time-text">5 min read</span>
          </span>
        </div>
        <h1 class="hero-title">{title}</h1>
        <p class="hero-desc">{description}</p>
        <div class="author-row">
          <div class="author-avatar" aria-hidden="true">{initials}</div>
          <div class="author-info">
            <span class="author-name">{authorName}</span>
            <span class="author-date">{dateLabel} {dateStr}</span>
          </div>
          <div class="share-btns">
            <a id="share-li" href="#" target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on LinkedIn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a id="share-wa" href="#" target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on WhatsApp">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.554 4.122 1.523 5.856L.072 23.928l6.286-1.428A11.956 11.956 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.65-.514-5.163-1.41l-.371-.22-3.73.847.862-3.643-.241-.382A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            </a>
          </div>
        </div>
      </div>

      {coverImage && (
        <div class="hero-cover">
          <img src={coverImage} alt="" role="presentation" width="840" height="630" loading="eager" />
        </div>
      )}

    </div>
  </div>
</header>

<div class="page-body">
  <div class="ah-wrap">
    <div class="body-grid">

      <main id="article-main">

        <!-- Mobile ToC accordion (hidden on desktop) -->
        <div class="toc-accordion">
          <button class="toc-acc-btn" id="toc-acc-btn" aria-expanded="false" aria-controls="toc-mobile">
            <span class="toc-acc-label">In this article</span>
            <svg class="toc-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
          <nav class="toc-acc-body" id="toc-mobile" aria-hidden="true"></nav>
        </div>

        <!-- Key Takeaways -->
        {keyPoints.length > 0 && (
          <div class="key-points" aria-labelledby="kp-heading">
            <div class="kp-label" id="kp-heading">Key Takeaways</div>
            <div class="kp-grid">
              {keyPoints.map((kp, i) => (
                <div class="kp-item" data-i={i}>
                  <div class="kp-row">
                    <div class="kp-check" aria-hidden="true">
                      <svg viewBox="0 0 12 12" fill="none" stroke="#00e3fd" stroke-width="2.5" width="10" height="10">
                        <polyline points="2,6 5,9 10,3"/>
                      </svg>
                    </div>
                    <p class="kp-title">{kp.heading}</p>
                    <button class="kp-toggle" aria-expanded="false" aria-label={`Expand: ${kp.heading}`}>+</button>
                  </div>
                  <p class="kp-body">{kp.body}</p>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Article body -->
        <div class="prose" id="article-body">
          <slot />
        </div>

        <!-- Mobile share row (shown only on mobile) -->
        <div class="mobile-share">
          <span class="ms-label">Share this article</span>
          <a id="ms-li" href="#" target="_blank" rel="noopener noreferrer" class="ms-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a id="ms-wa" href="#" target="_blank" rel="noopener noreferrer" class="ms-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.554 4.122 1.523 5.856L.072 23.928l6.286-1.428A11.956 11.956 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.65-.514-5.163-1.41l-.371-.22-3.73.847.862-3.643-.241-.382A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            WhatsApp
          </a>
        </div>

        <!-- Bottom CTA band -->
        <div class="cta-band">
          <h3>Ready to find your highest-ROI AI opportunity?</h3>
          <p>We map your workflows, identify quick wins, and build a custom AI roadmap — in one free strategy call.</p>
          <a href="/contact" class="cta-primary">Book a Free Strategy Call →</a>
        </div>

        <!-- Related posts -->
        {relatedPosts.length > 0 && (
          <div class="related-posts">
            <div class="related-label">Related Articles</div>
            <div class="related-grid">
              {relatedPosts.map((post, idx) => (
                <a href={`/blog/${post.slug}`} class="related-card">
                  <div class="rcard-img" style={`background:${cardGradients[idx % 3]}`}></div>
                  <div class="rcard-body">
                    <span class="rcard-tag">{post.category}</span>
                    <div class="rcard-title">{post.title}</div>
                    <div class="rcard-read">Read article →</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

      </main>

      <!-- Desktop sidebar -->
      <aside class="sidebar" aria-label="Article sidebar">
        <div class="sidebar-card">
          <p class="toc-label">In this article</p>
          <nav id="toc-sidebar" aria-label="Table of contents"></nav>
        </div>
        <div class="newsletter-card">
          <div class="nl-icon" aria-hidden="true">✉️</div>
          <p class="nl-title">AI Insights — Monthly</p>
          <p class="nl-sub">Practical AI guides and UAE market data. One email per month, zero fluff.</p>
          <form id="nl-form" novalidate>
            <input class="nl-input" type="email" name="email" placeholder="your@email.com" autocomplete="email" required aria-label="Email address" />
            <button class="nl-btn" type="submit">Subscribe Free</button>
          </form>
          <p class="nl-note">No spam · Unsubscribe any time</p>
        </div>
      </aside>

    </div>
  </div>
</div>

</BaseLayout>

<style>
/* ─── Progress bar ─── */
#progress-bar {
  position: fixed; top: 0; left: 0; height: 3px; width: 0;
  background: linear-gradient(to right, #00e3fd, #006875);
  z-index: 9999; transition: width 0.1s linear;
  box-shadow: 0 0 8px rgba(0,227,253,0.5);
}

/* ─── Shared container ─── */
.ah-wrap { max-width: 1120px; margin: 0 auto; padding: 0 2.5rem; }

/* ─── Hero ─── */
.article-hero {
  background: linear-gradient(160deg, #eef1ff 0%, #f5f7ff 60%, #f9fbff 100%);
  border-bottom: 1px solid rgba(0,37,59,0.07);
  padding: 80px 0 60px;
  position: relative; overflow: hidden;
}
.article-hero::before {
  content: ''; position: absolute; top: -60%; right: -5%; width: 500px; height: 500px;
  border-radius: 50%; background: radial-gradient(circle, rgba(0,227,253,0.09) 0%, transparent 65%);
  pointer-events: none;
}
.hero-grid { display: grid; grid-template-columns: 1fr 420px; gap: 3.5rem; align-items: center; }
.hero-grid--solo { grid-template-columns: minmax(0, 700px); }

/* Breadcrumb */
.breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 0.8rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.breadcrumb a { color: #72787e; text-decoration: none; }
.breadcrumb a:hover { color: #006875; }
.breadcrumb .sep { color: #d0d5dd; }
.breadcrumb .cur { color: #111c2d; font-weight: 600; }

/* Hero meta */
.hero-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 1.125rem; }
.article-tag { display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 100px; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; background: rgba(0,104,117,0.10); color: #004f58; border: 1px solid rgba(0,104,117,0.18); }
.meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #d0d5dd; flex-shrink: 0; }
.read-time { font-size: 0.8rem; color: #72787e; display: flex; align-items: center; gap: 5px; }

.hero-title { font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 800; color: #00253b; letter-spacing: -0.035em; line-height: 1.13; margin-bottom: 1rem; }
.hero-desc { color: #42474e; font-size: 1.0625rem; line-height: 1.75; max-width: 600px; margin-bottom: 1.75rem; }

/* Author row */
.author-row { display: flex; align-items: center; gap: 11px; }
.author-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, #00e3fd, #006875); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.9rem; color: #fff; box-shadow: 0 2px 8px rgba(0,104,117,0.3); }
.author-info { flex: 1; }
.author-name { font-size: 0.9rem; font-weight: 700; color: #00253b; display: block; }
.author-date { font-size: 0.75rem; color: #72787e; }
.share-btns { display: flex; gap: 7px; margin-left: auto; }
.share-btn { width: 34px; height: 34px; border-radius: 9px; border: 1px solid rgba(0,37,59,0.12); background: #fff; display: flex; align-items: center; justify-content: center; color: #006875; text-decoration: none; transition: border-color 0.15s, background 0.15s; }
.share-btn:hover { background: rgba(0,104,117,0.06); border-color: rgba(0,104,117,0.25); }

/* Feature image */
.hero-cover { width: 100%; aspect-ratio: 4/3; border-radius: 20px; overflow: hidden; box-shadow: 0 16px 48px rgba(0,37,59,0.18); }
.hero-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ─── Page body ─── */
.page-body { padding: 3rem 0 5rem; }
.body-grid { display: grid; grid-template-columns: 1fr 288px; gap: 3.5rem; align-items: flex-start; }

/* ─── Mobile ToC accordion ─── */
.toc-accordion { display: none; margin-bottom: 1.5rem; }
.toc-acc-btn {
  width: 100%; display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.25rem; background: #fff; border: 1px solid rgba(0,37,59,0.08);
  border-radius: 12px; cursor: pointer; font-family: inherit;
}
.toc-acc-label { font-size: 0.875rem; font-weight: 700; color: #00253b; }
.toc-chevron { color: #72787e; transition: transform 0.2s; flex-shrink: 0; }
.toc-acc-btn[aria-expanded="true"] .toc-chevron { transform: rotate(180deg); }
.toc-acc-body { display: none; background: #fff; border: 1px solid rgba(0,37,59,0.08); border-top: none; border-radius: 0 0 12px 12px; padding: 0.5rem 0.75rem 0.75rem; }
.toc-acc-body.open { display: block; }

/* ─── ToC links (shared between sidebar + mobile) ─── */
.toc-link { display: flex; align-items: flex-start; gap: 9px; padding: 6px 8px; border-radius: 8px; text-decoration: none; transition: background 0.15s; margin-bottom: 2px; }
.toc-link:hover { background: rgba(0,104,117,0.06); }
.toc-link.active { background: rgba(0,227,253,0.10); }
.toc-pip { width: 6px; height: 6px; border-radius: 50%; background: #d0d5dd; flex-shrink: 0; margin-top: 5px; transition: background 0.2s, transform 0.2s; }
.toc-link.active .toc-pip { background: #00e3fd; transform: scale(1.3); }
.toc-text { font-size: 0.8125rem; color: #72787e; line-height: 1.45; }
.toc-link.active .toc-text { color: #00253b; font-weight: 600; }

/* ─── Key Takeaways ─── */
.key-points {
  background: #fff; border: 1px solid rgba(0,37,59,0.08); border-radius: 20px;
  padding: 1.75rem 2rem; margin-bottom: 2.75rem;
  box-shadow: 0 4px 24px rgba(0,59,92,0.06); position: relative; overflow: hidden;
}
.key-points::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
  background: linear-gradient(to bottom, #00e3fd, #006875); border-radius: 20px 0 0 20px;
}
.kp-label {
  font-size: 0.6875rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase;
  color: #006875; margin-bottom: 1.375rem; display: flex; align-items: center; gap: 10px;
}
.kp-label::before { content: ''; width: 20px; height: 2px; background: #00e3fd; border-radius: 2px; }
.kp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
.kp-item { padding: 1rem 1rem 1rem 0; }
.kp-item:nth-child(even) { padding-left: 1.5rem; border-left: 1px dashed rgba(0,37,59,0.08); }
.kp-item:nth-child(1), .kp-item:nth-child(2) { border-bottom: 1px dashed rgba(0,37,59,0.08); }
.kp-row { display: flex; align-items: flex-start; gap: 10px; }
.kp-check { width: 22px; height: 22px; border-radius: 50%; background: #00253b; flex-shrink: 0; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
.kp-title { font-size: 0.9rem; font-weight: 700; color: #00253b; line-height: 1.45; flex: 1; margin: 0; }
.kp-toggle {
  width: 24px; height: 24px; border-radius: 50%; border: 1.5px solid rgba(0,104,117,0.22);
  background: rgba(0,227,253,0.06); display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 1rem; line-height: 1; color: #006875; cursor: pointer;
  margin-top: 1px; transition: all 0.2s; font-family: inherit;
}
.kp-item.open .kp-toggle { background: rgba(0,104,117,0.12); border-color: rgba(0,104,117,0.35); }
.kp-body { font-size: 0.8375rem; color: #42474e; line-height: 1.65; margin-top: 0.625rem; padding-left: 32px; margin-bottom: 0; }
.kp-item:not(.open) .kp-body { display: none; }

/* ─── Prose ─── */
.prose :global(h2) { font-size: 1.5625rem; font-weight: 800; color: #00253b; margin: 2.5rem 0 0.875rem; letter-spacing: -0.025em; line-height: 1.2; scroll-margin-top: 90px; }
.prose :global(h3) { font-size: 1.125rem; font-weight: 700; color: #111c2d; margin: 1.875rem 0 0.625rem; scroll-margin-top: 90px; }
.prose :global(p) { color: #42474e; line-height: 1.85; margin-bottom: 1.375rem; font-size: 1.0625rem; }
.prose :global(ul) { list-style: none; padding: 0; margin-bottom: 1.375rem; }
.prose :global(ul li) { position: relative; padding-left: 1.625rem; margin-bottom: 0.75rem; font-size: 1.0625rem; color: #42474e; line-height: 1.75; }
.prose :global(ul li::before) { content: ''; position: absolute; left: 0; top: 0.625em; width: 7px; height: 7px; border-radius: 50%; background: #00e3fd; }
.prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.375rem; }
.prose :global(ol li) { margin-bottom: 0.75rem; font-size: 1.0625rem; color: #42474e; line-height: 1.75; }
.prose :global(strong) { color: #00253b; font-weight: 700; }
.prose :global(a) { color: #006875; text-decoration: underline; text-underline-offset: 2px; }
.prose :global(a:hover) { color: #004f58; }
.prose :global(figure) { margin: 2rem 0 2.5rem; }
.prose :global(figure img) { width: 100%; border-radius: 14px; display: block; box-shadow: 0 6px 28px rgba(0,37,59,0.10); border: 1px solid rgba(0,37,59,0.06); }
.prose :global(figcaption) { margin-top: 0.625rem; font-size: 0.8125rem; color: #72787e; text-align: center; line-height: 1.5; }
.prose :global(img:not(figure img)) { max-width: 100%; border-radius: 14px; box-shadow: 0 6px 28px rgba(0,37,59,0.10); border: 1px solid rgba(0,37,59,0.06); margin: 1.5rem 0; display: block; }
.prose :global(blockquote) { border-left: 4px solid #00e3fd; padding-left: 1.25rem; margin: 1.5rem 0; color: #42474e; font-style: italic; }
.prose :global(code:not(pre code)) { background: rgba(0,104,117,0.08); padding: 2px 6px; border-radius: 4px; font-size: 0.9em; color: #004f58; }
.prose :global(pre) { background: #00253b; padding: 1.25rem 1.5rem; border-radius: 12px; overflow-x: auto; margin: 1.5rem 0; }
.prose :global(pre code) { background: none; padding: 0; color: #e2e8f0; font-size: 0.875rem; }

/* ─── Inline CTA (injected by JS) ─── */
:global(.inline-cta) {
  background: linear-gradient(135deg, #eef1ff 0%, #f0f8ff 100%);
  border: 1px solid rgba(0,104,117,0.14); border-radius: 18px;
