.nl-input { width: 100%; padding: 10px 13px; border-radius: 9px; border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.07); color: #fff; font-size: 0.8125rem; font-family: inherit; outline: none; margin-bottom: 9px; transition: border-color 0.2s; display: block; }
