---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSupabaseAdmin } from "../lib/supabase";
import FaqAccordion from "../components/FaqAccordion.astro";

// Hardcoded fallback products
const fallbackProducts = [
  {
    slug: "whatsapp-ai-agent",
    name: "WhatsApp AI Agent",
    tagline: "A 24/7 bilingual AI assistant that qualifies leads, books appointments, and handles FAQs directly in WhatsApp. Works in Arabic and English with zero manual effort.",
    status_badge: "Available Now",
    feature_tags: ["Lead qualification", "Appointment booking", "FAQ automation", "Arabic + English", "CRM integration"],
    features: [
      "Deployed in your WhatsApp Business account and ready for your team",
      "Trained on your products, services, and pricing",
      "Hands off to a human agent when a question needs one",
      "Full analytics dashboard: conversations, conversion rates, drop-off points",
      "Integrates with your CRM and existing tools",
    ],
  },
  {
    slug: "operations-dashboard",
    name: "Operations Dashboard",
    tagline: "Real-time AI analytics and workflow automation dashboards, connected to your existing tools. Turn raw data into clear decisions without needing a data team.",
    status_badge: "Available Now",
    feature_tags: ["Real-time analytics", "Workflow automation", "Custom KPIs", "Multi-source data", "AI insights"],
    features: [
      "Connects to your ERP, POS, spreadsheets, and data sources",
      "AI-generated daily summaries and anomaly alerts sent via WhatsApp or email",
      "Role-based views for management, operations, and frontline teams",
      "Automated approval workflows, task routing, and escalation rules",
      "Mobile-first, works on any device, optimised for managers on the go",
    ],
  },
  {
    slug: "team-ai-trainer",
    name: "Team AI Trainer",
    tagline: "An AI-powered training platform with bilingual content. Measurable upskilling for every department. Track progress, certify employees, and prove ROI on training spend.",
    status_badge: "Coming Soon",
    feature_tags: ["Bilingual content", "Progress tracking", "Certifications", "Department-specific", "ROI reporting"],
    features: [
      "Courses built around your specific tools, processes, and team roles",
      "Arabic and English UI with auto-translated content",
      "AI tutor available 24/7 to answer questions in natural language",
      "Certification program with verifiable credentials per department",
      "Manager dashboard showing team adoption, quiz scores, and time-to-proficiency",
    ],
  },
];

let products = fallbackProducts;

try {
  const supabase = getSupabaseAdmin();
  const { data, error } = await supabase
    .from('products')
    .select('slug, name, tagline, description, status_badge, feature_tags, features, sort_order')
    .eq('published', true)
    .is('deleted_at', null)
    .order('sort_order');

  if (!error && data && data.length > 0) {
    products = data.map((p) => ({
      slug: p.slug,
      name: p.name,
      tagline: p.tagline || p.description || '',
      status_badge: p.status_badge || 'Available Now',
      feature_tags: Array.isArray(p.feature_tags) ? p.feature_tags : [],
      features: Array.isArray(p.features) ? p.features : [],
    }));
  }
} catch (err) {
  // Fallback to hardcoded content on error
}

Astro.response.headers.set('Cache-Control', 's-maxage=60, stale-while-revalidate=300');

const productsFaqs = [
  { question: "Are these off-the-shelf tools or custom builds?", answer: "Both, depending on the product. Each one starts as a working platform, we then customise it to your brand, your workflows, and your data before it goes live. You're not getting a generic template with your logo on it." },
  { question: "Can we combine more than one product?", answer: "Yes. Many clients run the WhatsApp AI Agent alongside the Operations Dashboard, so leads captured on WhatsApp flow straight into the same reporting view your managers already use. We'll map out how the products connect during discovery." },
  { question: "How long does it take to go live?", answer: "The WhatsApp AI Agent and Operations Dashboard typically launch within a few weeks of kickoff, depending on how many systems we're integrating with. We'll give you a specific timeline on the discovery call once we understand your setup." },
  { question: "What if our team isn't technical?", answer: "That's the normal case, not the exception. Every product ships with training for the people who'll use it day to day, in plain language, in the language your team works in." },
  { question: "Is Team AI Trainer available now?", answer: "It's currently in development. Join the waitlist and we'll reach out as soon as it's ready, with early access for businesses already working with us on other products." },
];

const productsFaqLdJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: productsFaqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const productsSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'AI Products by Lenoo AI',
    url: 'https://lenooai.com/products',
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SoftwareApplication',
        name: p.name,
        description: p.tagline,
        url: `https://lenooai.com/products#${p.slug}`,
        applicationCategory: 'BusinessApplication',
        operatingSystem: 'Web',
        provider: { '@type': 'Organization', name: 'Lenoo AI', url: 'https://lenooai.com' },
      },
    })),
  },
  productsFaqLdJson,
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://lenooai.com/' },
      { '@type': 'ListItem', position: 2, name: 'Products', item: 'https://lenooai.com/products' },
    ],
  },
];
---

<BaseLayout
  title="AI Products for UAE SMEs: WhatsApp AI & Dashboard | Lenoo AI"
  description="Pre-built AI products from Lenoo AI, a Dubai AI agency, for UAE SMEs: WhatsApp AI Agent, Operations Dashboard, and Team AI Trainer. Bilingual."
  canonicalPath="/products"
  ogImage="/assets/og-products.jpg"
  ldJson={productsSchema}
  arPath="/ar/products"
>

<!-- ── HERO ── -->
<header class="hero-section page-hero">
  <div class="container">
    <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(0,227,253,0.12);border:1px solid rgba(0,227,253,0.28);border-radius:100px;padding:6px 16px;color:#a8f2ff;font-size:0.875rem;font-weight:600;margin-bottom:1.5rem;" aria-label="Breadcrumb"><a href="/" style="color:inherit;text-decoration:none;opacity:0.65;">Home</a><span style="opacity:0.4;padding:0 4px;"> / </span>Products</div>
    <h1 style="max-width: 48rem; margin: 0 auto 1.5rem;">
      AI Products Built for the <span class="gradient-text">UAE</span>
    </h1>
    <p style="color: rgba(255,255,255,0.72); font-size: 1.125rem; line-height: 1.75; max-width: 36rem; margin: 0 auto;">
      Pre-built AI modules for the industries we serve, customised to your brand and workflows. Each product integrates with your existing tools and is tailored to your team.
    </p>
  </div>
</header>

<!-- ── PRODUCTS ── -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Three Products. Ready Sooner Than a Custom Build.</h2>
      <p>The systems we build most often, packaged as pre-built modules. We start from a proven base, then customise it to your brand, your industry, and the way your team works.</p>
    </div>
    <div class="bento-grid bento-grid-3">
    {products.map((product) => {
      const isAvailable = product.status_badge?.toLowerCase().includes('available');
      const badgeStyle = isAvailable
        ? "background: rgba(34,197,94,0.10); border: 1px solid rgba(34,197,94,0.30);"
        : "background: rgba(0,37,59,0.08); border: 1px solid rgba(0,37,59,0.18);";
      const dotColor = isAvailable ? "#22c55e" : "#00253b";
      const textColor = isAvailable ? "#166534" : "#00253b";
      const ctaLabel = isAvailable ? "Get Started" : "Join Waitlist";
      const dataSource = product.slug === 'whatsapp-ai-agent' ? 'products_whatsapp_agent'
        : product.slug === 'operations-dashboard' ? 'products_ops_dashboard'
        : product.slug === 'team-ai-trainer' ? 'products_team_trainer'
        : `products_${product.slug}`;
      const photo = product.slug === 'whatsapp-ai-agent' ? 'https://images.unsplash.com/photo-1611746869696-d09bce200020?w=800&q=80&auto=format&fit=crop'
        : product.slug === 'operations-dashboard' ? 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80&auto=format&fit=crop'
        : 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80&auto=format&fit=crop';
      const iconName = product.slug === 'whatsapp-ai-agent' ? 'chat' : product.slug === 'operations-dashboard' ? 'dashboard' : 'groups';

      return (
        <div class="value-card" style="display:flex; flex-direction:column;">
          <div class="split-media" style="margin-bottom:1.25rem;">
            <img src={photo} alt={product.name} loading="lazy" width="800" height="160" style="height:160px;" />
          </div>
          <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">{iconName}</span></div>
          <div style={`display: inline-flex; align-items: center; gap: .375rem; ${badgeStyle} border-radius: 100px; padding: .25rem .875rem; margin: 0.75rem 0;`}>
            <span style={`width: 6px; height: 6px; border-radius: 50%; background: ${dotColor};`}></span>
            <span style={`font-size: .75rem; font-weight: 700; color: ${textColor}; letter-spacing: .04em; text-transform: uppercase;`}>{product.status_badge}</span>
          </div>
          <h3 style="font-size:1.125rem; font-weight:700; margin-bottom:0.75rem;">{product.name}</h3>
          <p style="color:#42474e; font-size:0.9375rem; line-height:1.75; margin-bottom:1.25rem;">{product.tagline}</p>
          <div style="display:flex; flex-direction:column; gap:0.625rem; margin-bottom:1.25rem;">
            {product.features.map((feature: string) => (
              <div style="display:flex; align-items:flex-start; gap:8px;">
                <svg viewBox="0 0 24 24" fill="none" style="width:16px;height:16px;flex-shrink:0;margin-top:3px;" stroke="#006875" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span style="color:#42474e; font-size:0.8125rem; line-height:1.6;">{feature}</span>
              </div>
            ))}
          </div>
          <div style="margin-bottom: 1.5rem;">
            {product.feature_tags.map((tag: string) => (
              <span class="feature-tag">{tag}</span>
            ))}
          </div>
          <button onclick="openModal(this)" data-source={dataSource} class="learn-link" style="background:none; border:none; cursor:pointer; font-size:0.84375rem;">{ctaLabel} <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;">arrow_forward</span></button>
        </div>
      );
    })}
    </div>
  </div>
</section>

<!-- INCLUDED WITH EVERY PRODUCT -->
<section class="section hp-ind-bg">
  <div class="container">
    <div class="section-header">
      <h2>Included With Every Product</h2>
      <p>The same promises that come with every Lenoo AI project apply to our products too.</p>
    </div>
    <div class="bento-grid bento-grid-4">
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">verified</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Refund Guarantee</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">If we deliver the agreed system and your team genuinely isn't satisfied with it, we refund everything you paid.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">group</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Team Training</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Your people get hands-on training until they use the product with confidence. No tool gets handed over and abandoned.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">support_agent</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">90 Days of Support</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">If something needs fixing after launch, we fix it at no extra cost, for a full 90 days on every project.</p>
      </div>
      <div class="value-card">
        <div class="service-icon"><span class="material-symbols-outlined" aria-hidden="true">hub</span></div>
        <h3 style="font-size:1.0625rem; font-weight:700; margin-bottom:0.5rem;">Integration Included</h3>
        <p style="color:#42474e; font-size:0.875rem; line-height:1.6; margin:0;">Each product connects to the CRM, messaging, and business tools you already run on. Nothing gets ripped out or replaced.</p>
      </div>
    </div>
  </div>
</section>

<!-- PRODUCTS FAQ -->
<section class="section" style="background:#f9f9ff;" aria-labelledby="products-faq-heading">
  <div class="container" style="max-width:720px;">
    <div class="section-header">
      <h2 id="products-faq-heading">Questions About Our Products</h2>
    </div>
    <FaqAccordion items={productsFaqs} />
  </div>
</section>

<!-- FINAL CTA -->
<section class="section">
  <div class="container">
    <div class="cta-band">
      <h2>Ready to See These in Action?</h2>
      <p style="max-width:36rem; margin:1rem auto 2rem; line-height:1.7;">Book a free demo and we'll show you exactly how each product fits your business, customised to your industry and workflows. 30-min call · No sales pressure.</p>
      <button onclick="openModal(this)" data-source="products_cta" class="btn-primary">Book a Free Demo</button>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  .hp-ind-bg { background: var(--bg-soft-2, #f4f7fb); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .feature-tag {
    display: inline-flex; align-items: center;
    background: #f0f3ff; color: #42474e;
    font-size: .75rem; font-weight: 500;
    padding: .3rem .75rem; border-radius: 8px;
    margin: .2rem .25rem .2rem 0;
  }
</style>